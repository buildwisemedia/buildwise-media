---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLdGraph from '../components/seo/JsonLdGraph.astro';
// @r020-exempt: document shell; the only image is a 1x1 invisible analytics pixel, no visual or conversion role

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  // LCP image preload — path to the page's hero <img> src. Emits a
  // <link rel="preload" as="image" fetchpriority="high"> early in <head> so the
  // preload scanner fires the fetch before body parsing discovers the <img>.
  // Pair with fetchpriority="high" on the <img> tag itself.
  preloadImage?: string;
}

const {
  title,
  description,
  canonical,
  noindex = false,
  ogTitle,
  ogDescription,
  jsonLd,
  preloadImage,
} = Astro.props;

const siteUrl = 'https://buildwisemedia.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogT = ogTitle ?? title;
const ogD = ogDescription ?? description;

// Centralised tracking IDs from site-config.json
const GA4 = 'G-V5LSP69E41';
const GTM = 'GTM-P5JSD86L';
const PIXEL = '2728397250833051';
const CLARITY = 'w7ga9q22fa';

const perPageSchemas = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

// Verified owned profiles for entity reconciliation (sameAs). Only confirmed-live,
// unambiguously-BWM URLs belong here — a wrong or 404 sameAs HURTS entity trust.
// LinkedIn is 200-confirmed and tied to this company (not the unrelated "buildwise-ai").
// Confirmable adds: Yelp (buildwise-media-alpharetta) + Google Business Profile URL.
const socialProfiles = [
  'https://www.linkedin.com/company/buildwise-media',
];

// Site-wide schemas — emitted on every page so AI engines have a stable
// WebSite/Organization @id graph to traverse. Per LOCKED Triangulation voice:
// author = "the Buildwise team + our AI system" (no sole-prop framing).
const siteSchemas: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': `${siteUrl}/#org`,
    name: 'Buildwise Media',
    legalName: 'Buildwise Media LLC',
    url: siteUrl,
    email: 'hello@buildwisemedia.com',
    description:
      'Verifiable autonomous marketing systems for service businesses — Ascend installs in 30 days, operates weekly, and stays owned by the client.',
    foundingLocation: {
      '@type': 'Place',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Atlanta',
        addressRegion: 'GA',
        addressCountry: 'US',
      },
    },
    sameAs: socialProfiles,
  },
  {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: siteUrl,
    name: 'Buildwise Media',
    description:
      'Verifiable autonomous marketing systems for service businesses — Ascend installs in 30 days, operates weekly, and stays owned by the client.',
    publisher: { '@id': `${siteUrl}/#org` },
    inLanguage: 'en-US',
  },
  {
    '@type': 'LocalBusiness',
    '@id': `${siteUrl}/#localbusiness`,
    name: 'Buildwise Media',
    url: siteUrl,
    email: 'hello@buildwisemedia.com',
    priceRange: '$$$',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Atlanta',
      addressRegion: 'GA',
      addressCountry: 'US',
    },
    areaServed: {
      '@type': 'Country',
      name: 'United States',
    },
    parentOrganization: { '@id': `${siteUrl}/#org` },
    sameAs: socialProfiles,
  },
  {
    '@type': 'WebPage',
    '@id': `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: { '@id': `${siteUrl}/#website` },
    inLanguage: 'en-US',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.h-hero', '.hero-sub', '.h-section', '.lede', '.faq-q', '.faq-a p'],
    },
  },
];

const graph = [...siteSchemas, ...perPageSchemas];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        fetchpriority="high"
        type={preloadImage.endsWith('.webp') ? 'image/webp' : undefined}
      />
    )}

    <!-- Theme + favicon (Triangulation V3 mark — locked 2026-04-30 against brand/BWM-Logo-System-Locked.md) -->
    <meta name="theme-color" content="#050507" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180.png" />

    <!-- Open Graph (Triangulation V3 banner — image on R2 bucket bwm-assets/marks/triangulation-v3/) -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={ogT} />
    <meta property="og:description" content={ogD} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Buildwise Media" />
    <meta property="og:image" content="https://pub-85c635a2536e438b9927af5e6723b0f7.r2.dev/marks/triangulation-v3/exports/banner/og-1200x630-v2.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Buildwise Media — Your AI Department" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogT} />
    <meta name="twitter:description" content={ogD} />
    <meta name="twitter:image" content="https://pub-85c635a2536e438b9927af5e6723b0f7.r2.dev/marks/triangulation-v3/exports/banner/og-1200x630-v2.png" />

    <!-- Booking embed preconnect (used on /book) — cuts ~200-500ms off first paint of the calendar iframe. EXP-002 telemetry shows 50% click-to-LPV drop, primary suspect = TLS cold-start on this subdomain. -->
    <link rel="preconnect" href="https://book.buildwisemedia.com" />
    <link rel="dns-prefetch" href="https://book.buildwisemedia.com" />

    <!-- Analytics boot: queue immediately, load vendors after the first interaction or post-LCP timeout. -->
    <script is:inline define:vars={{ GTM, GA4, PIXEL }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = window.gtag || gtag;
      // Queue js+config at parse time, BEFORE any page event can enter the
      // dataLayer. gtag.js replays the queue in order on load; an 'event'
      // command queued ahead of 'config' has no destination and is dropped
      // with no network hit — this silently ate every pre-interaction event
      // (diagnostic_start / diagnostic_step_complete) while interaction-gated
      // loadAnalytics() held the config back. Queueing is free; only the
      // vendor script loading below stays lazy.
      window.gtag('js', new Date());
      // send_page_view true: with gtag.js initializing first (see ordering
      // note in loadAnalytics) the GTM container's GA4 page_view merges into
      // the already-configured destination and never sends, so the direct
      // config must own page_view or the property records none at all
      // (verified headless 2026-06-11, 3/3 gtag-first loads: zero GTM
      // page_view). Single-send is asserted by the post-deploy matrix.
      window.gtag('config', GA4, { send_page_view: true });

      (function () {
        var loaded = false;
        var events = ['pointerdown', 'keydown', 'touchstart', 'scroll'];
        function append(src) {
          var s = document.createElement('script');
          s.async = true;
          s.src = src;
          document.head.appendChild(s);
          return s;
        }
        function loadAnalytics() {
          if (loaded) return;
          loaded = true;
          // ORDER IS LOAD-BEARING. gtm.js and gtag.js fight over dataLayer
          // processing; whichever initializes first wins for the page's
          // lifetime. gtm.js-first silently drops EVERY direct gtag('event')
          // (no network hit, no error); gtag.js-first delivers them all.
          // Appending both async made this a 50/50 network race on every
          // page load (verified headless 2026-06-11 — the root cause of 30
          // days of zero conversion events in ga4_events). gtag.js loads
          // first; gtm.js (Meta pixel + Ads tag owner) follows on its
          // load/error.
          var gtagScript = append('https://www.googletagmanager.com/gtag/js?id=' + GA4);
          function loadGtm() {
            window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            append('https://www.googletagmanager.com/gtm.js?id=' + GTM);
          }
          gtagScript.addEventListener('load', loadGtm);
          gtagScript.addEventListener('error', loadGtm);
          // Meta Pixel — load inline alongside GTM so the fbevents.js loader
          // appears in page HTML source (required for cell_03/cell_14 audit checks
          // and for server-side CAPI deduplication via fbq('track') eventID).
          // GTM also fires this via its own tag, but since GTM is lazy/interaction-
          // triggered, crawlers and audit tools would never see the loader.
          // The GTM tag fires init+PageView too, but fbq() is idempotent on the
          // same pixel ID so there is no double-counting.
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
          n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
          document,'script','https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', PIXEL);
          fbq('track', 'PageView');
          events.forEach(function (eventName) {
            window.removeEventListener(eventName, loadAnalytics, { passive: true });
          });
        }
        events.forEach(function (eventName) {
          window.addEventListener(eventName, loadAnalytics, { once: true, passive: true });
        });
        setTimeout(loadAnalytics, 5000);
      })();
    </script>

    <!-- Microsoft Clarity (deferred to keep LCP tight per memory feedback_perf_text_lcp_after_webp.md) -->
    <script is:inline define:vars={{ CLARITY }}>
      setTimeout(function () {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          var y0=l.getElementsByTagName(r)[0];y0.parentNode.insertBefore(t,y0);
        })(window, document, "clarity", "script", CLARITY);
      }, 15000);
    </script>

    <!-- Attribution capture (first-touch + last-touch + UTM, persisted to localStorage) -->
    <script is:inline define:vars={{ GA4 }}>
      (function () {
        var KEY = '_bwm_attribution';
        var BOOKING_EVENT_KEY = 'bwm_booking_event_id';
        var UTM_KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','fbclid'];

        function safeJson(value, fallback) {
          try { return JSON.parse(value); } catch (_) { return fallback; }
        }

        function uuid() {
          if (window.crypto && typeof window.crypto.randomUUID === 'function') return window.crypto.randomUUID();
          return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
            var r = Math.random() * 16 | 0;
            var v = c === 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
          });
        }

        function cookie(name) {
          var match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/[.$?*|{}()[\]\\/+^]/g, '\\$&') + '=([^;]*)'));
          return match ? decodeURIComponent(match[1]) : '';
        }

        function currentUtms() {
          var params = new URL(window.location.href).searchParams;
          var out = {};
          UTM_KEYS.forEach(function (k) {
            var v = params.get(k);
            if (v) out[k] = v;
          });
          return out;
        }

        function ensureBookingEventId(preferred) {
          var clean = preferred && String(preferred).trim();
          var current = clean || sessionStorage.getItem(BOOKING_EVENT_KEY) || '';
          if (!current) current = uuid();
          sessionStorage.setItem(BOOKING_EVENT_KEY, current);
          return current;
        }

        function getPayload(extra) {
          var record = safeJson(localStorage.getItem(KEY) || 'null', null) || window.__bwmAttribution || {};
          var last = record.last_touch || {};
          var first = record.first_touch || {};
          var urlUtms = currentUtms();
          var utm = Object.assign({}, first.utm || {}, last.utm || {}, urlUtms);
          var payload = {
            attribution: record,
            referrer: sessionStorage.getItem('bwm_referrer') || document.referrer || last.referrer || first.referrer || '',
            landing_page: sessionStorage.getItem('bwm_landing_page') || last.landing_page || first.landing_page || window.location.href,
            utm_source: utm.utm_source || '',
            utm_medium: utm.utm_medium || '',
            utm_campaign: utm.utm_campaign || '',
            utm_content: utm.utm_content || '',
            utm_term: utm.utm_term || '',
            fbclid: utm.fbclid || '',
            gclid: utm.gclid || '',
            fbp: cookie('_fbp'),
            fbc: cookie('_fbc'),
            booking_event_id: ensureBookingEventId(),
          };
          return Object.assign(payload, extra || {});
        }

        // gtag('event') calls that enter the dataLayer BEFORE gtag.js loads are
        // dropped by the queue replay — verified live 2026-06-11: with js/config
        // queued first and correct ordering confirmed, pre-load events
        // (diagnostic_step_complete + qa probes) still never produced a
        // /g/collect hit, while identical events fired after the G-V5LSP69E41
        // destination bootstrapped all delivered (GA4 Realtime-confirmed).
        // So: buffer events until the destination exists, then send. Vendor
        // loading stays lazy (interaction/5s) — worst case an early event
        // flushes ~6s after page load instead of being lost forever.
        var pendingGtag = [];
        var flushTimer = null;
        function gtagReady() {
          return !!(window.google_tag_manager && window.google_tag_manager[GA4]);
        }
        function sendGtag(name, payload) {
          // beacon transport: conversion events fire at navigation boundaries
          // (disqualified redirect, booking handoff) — default XHR sends get
          // ERR_ABORTED on unload and the event is silently lost (verified
          // live 2026-06-11: zero form/lead events in 30d of GA4 pulls).
          try { window.gtag('event', name, Object.assign({ transport_type: 'beacon' }, payload)); } catch (_) {}
        }
        function flushPendingGtag() {
          var q = pendingGtag.splice(0);
          q.forEach(function (e) { sendGtag(e.name, e.payload); });
          if (flushTimer) { clearInterval(flushTimer); flushTimer = null; }
        }
        // Last-chance delivery: an event queued while the page is already
        // hidden/unloading can never be flushed by the 250ms timer, and the
        // gtag stub silently drops it when the destination never bootstrapped
        // (hard tab-close within ~3s of first interaction). Hand the hit to
        // sendBeacon directly with a minimal /g/collect payload instead of
        // queueing it into a grave.
        function lastChanceBeacon(name, payload) {
          try {
            var m = document.cookie.match(/(?:^|; )_ga=GA\d+\.\d+\.([^;]+)/);
            var cid = m ? m[1] : Math.floor(Math.random() * 1e9) + '.' + Math.floor(Date.now() / 1000);
            var qs = 'v=2&tid=' + GA4 + '&cid=' + encodeURIComponent(cid) + '&en=' + encodeURIComponent(name);
            Object.keys(payload || {}).forEach(function (k) {
              var v = payload[k];
              if (v === null || v === undefined || typeof v === 'object') return;
              qs += '&' + (typeof v === 'number' ? 'epn.' : 'ep.') + encodeURIComponent(k) + '=' + encodeURIComponent(String(v));
            });
            navigator.sendBeacon('https://www.google-analytics.com/g/collect?' + qs);
          } catch (_) {}
        }
        function queueGtag(name, payload) {
          if (gtagReady()) { sendGtag(name, payload); return; }
          if (document.visibilityState === 'hidden' && typeof navigator.sendBeacon === 'function') {
            lastChanceBeacon(name, payload);
            return;
          }
          pendingGtag.push({ name: name, payload: payload });
          if (!flushTimer) {
            flushTimer = setInterval(function () { if (gtagReady()) flushPendingGtag(); }, 250);
            // after 15s give up gating and send best-effort (ad blocker /
            // vendor never loads) — no worse than the pre-buffer behavior
            setTimeout(function () { if (flushTimer) flushPendingGtag(); }, 15000);
          }
        }
        window.addEventListener('pagehide', function () { if (pendingGtag.length) flushPendingGtag(); });

        function trackEvent(name, params, opts) {
          var payload = Object.assign({}, params || {});
          var eventId = (opts && opts.eventId) || payload.event_id || payload.capi_event_id || payload.booking_event_id || '';
          if (eventId) {
            payload.event_id = eventId;
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push(Object.assign({ event: name }, payload));
          if (typeof window.gtag === 'function') {
            queueGtag(name, payload);
          }
          if (opts && opts.fbqEvent && typeof window.fbq === 'function') {
            try {
              if (eventId) {
                window.fbq('track', opts.fbqEvent, opts.fbqParams || {}, { eventID: eventId });
              } else {
                window.fbq('track', opts.fbqEvent, opts.fbqParams || {});
              }
            } catch (_) {}
          }
        }

        try {
          var url = new URL(window.location.href);
          var utm = currentUtms();
          if (!sessionStorage.getItem('bwm_referrer')) sessionStorage.setItem('bwm_referrer', document.referrer || '');
          if (!sessionStorage.getItem('bwm_landing_page')) sessionStorage.setItem('bwm_landing_page', window.location.href);
          var prior = safeJson(localStorage.getItem(KEY) || 'null', null);
          var now = new Date().toISOString();
          var record = prior || { first_touch: { ts: now, referrer: document.referrer || null, landing_page: window.location.href, utm: utm }, last_touch: null };
          record.last_touch = { ts: now, referrer: document.referrer || null, landing_page: window.location.href, utm: utm };
          localStorage.setItem(KEY, JSON.stringify(record));
          window.__bwmAttribution = record;
        } catch (e) {}

        // Experiment context (PROJ-AUTO-MVT-001 / PROJ-DESIGN-INTEL-001 P4):
        // worker-served pages carry window.__BWM_EXP; everywhere else the
        // JS-readable _bwm_exp_host carry cookie travels with the visitor.
        // Empty strings when never assigned (treated as no-op downstream).
        function getExperimentContext() {
          var g = window.__BWM_EXP;
          if (g && g.experiment_id && g.variant_id) {
            return { experiment_id: g.experiment_id, experiment_variant_id: g.variant_id };
          }
          var m = document.cookie.match(/(?:^|; )_bwm_exp_host=([^;]*)/);
          if (m) {
            try {
              var c = JSON.parse(decodeURIComponent(m[1]));
              if (c && c.e && c.v) return { experiment_id: c.e, experiment_variant_id: c.v };
            } catch (_) {}
          }
          return { experiment_id: '', experiment_variant_id: '' };
        }

        window.__bwmGetAttributionPayload = getPayload;
        window.__bwmEnsureBookingEventId = ensureBookingEventId;
        window.__bwmTrackEvent = trackEvent;
        window.__bwmGetExperimentContext = getExperimentContext;
      })();
    </script>

    <JsonLdGraph graph={graph} />
  </head>

  <body>
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
      <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${PIXEL}&ev=PageView&noscript=1`} alt="" />
    </noscript>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- CTA click telemetry -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href^="/book"]');
        if (!a) return;
        var src = a.getAttribute('data-cta-source') || 'unspecified';
        try {
          var payload = { cta_label: a.textContent.trim(), cta_source: src };
          if (typeof window.__bwmGetAttributionPayload === 'function') {
            payload = Object.assign(window.__bwmGetAttributionPayload(), payload);
          }
          if (typeof window.__bwmTrackEvent === 'function') {
            window.__bwmTrackEvent('cta_click', payload, { fbqEvent: 'InitiateCheckout' });
            return;
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push(Object.assign({ event: 'cta_click' }, payload));
          // InitiateCheckout signals click-intent. Real Lead fires from the booking webhook → CAPI server-side, deduplicated by event_id. Meta optimizes delivery toward whatever fires Lead — keeping it server-side = optimization toward bookers, not clickers.
          if (window.fbq) window.fbq('track', 'InitiateCheckout');
        } catch (err) {}
      });
    </script>

    <!-- Scroll-depth telemetry (PROJ-DESIGN-INTEL-001 P4): layout-archetype
         falsifiable predictions name scroll_depth as a target metric
         (reference/Layout-Archetype-Vocabulary.md) — this makes those
         predictions testable. percent_scrolled fires at 25/50/75/90 once each
         per pageview, with experiment context so hero variants can be scored
         on read-through. -->
    <script is:inline>
      (function () {
        var marks = [25, 50, 75, 90];
        var fired = {};
        var ticking = false;
        function check() {
          ticking = false;
          var doc = document.documentElement;
          var scrollable = Math.max(1, doc.scrollHeight - window.innerHeight);
          var pct = ((window.scrollY || doc.scrollTop || 0) / scrollable) * 100;
          marks.forEach(function (mark) {
            if (fired[mark] || pct < mark) return;
            fired[mark] = true;
            var payload = { percent_scrolled: mark, page_path: location.pathname };
            if (typeof window.__bwmGetExperimentContext === 'function') {
              payload = Object.assign(payload, window.__bwmGetExperimentContext());
            }
            if (typeof window.__bwmTrackEvent === 'function') {
              window.__bwmTrackEvent('scroll_depth', payload);
            }
          });
        }
        function onScroll() {
          if (ticking) return;
          ticking = true;
          (window.requestAnimationFrame || window.setTimeout)(check);
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('load', onScroll);
      })();
    </script>

    <!-- Phone & email click telemetry — v2.10 parity with attribution.js (2026-05-07).
         Redacted payloads: phone = last-4 digits, email = domain only.
         transport_type='beacon' so GA4 hits survive tel:/mailto: navigation on mobile. -->
    <script is:inline>
      (function () {
        function redactPhone(href) {
          var digits = String(href || '').replace(/\D/g, '');
          return digits.length >= 4 ? digits.slice(-4) : '';
        }
        function emailDomain(href) {
          var addr = String(href || '').replace(/^mailto:/i, '').split(/[?#]/)[0];
          var at = addr.indexOf('@');
          return at >= 0 ? addr.slice(at + 1).toLowerCase() : '';
        }
        function fireClickEvent(eventName, params) {
          var payload = { page_path: location.pathname, page_referrer: document.referrer || '' };
          Object.keys(params || {}).forEach(function (k) { payload[k] = params[k]; });
          if (typeof window.__bwmGetAttributionPayload === 'function') {
            payload = Object.assign(window.__bwmGetAttributionPayload(), payload);
          }
          if (typeof window.__bwmTrackEvent === 'function') {
            window.__bwmTrackEvent(eventName, payload);
            return;
          }
          window.dataLayer = window.dataLayer || [];
          var dlEvent = { event: eventName };
          Object.keys(payload).forEach(function (k) { dlEvent[k] = payload[k]; });
          window.dataLayer.push(dlEvent);
          if (typeof window.gtag === 'function') {
            var gtagParams = { transport_type: 'beacon' };
            Object.keys(payload).forEach(function (k) { gtagParams[k] = payload[k]; });
            try { window.gtag('event', eventName, gtagParams); } catch (_) {}
          }
        }
        document.addEventListener('click', function (e) {
          if (!e.target || typeof e.target.closest !== 'function') return;
          var a = e.target.closest('a[href]');
          if (!a) return;
          var href = a.getAttribute('href') || '';
          if (/^tel:/i.test(href)) {
            fireClickEvent('phone_click', { phone_number_redacted: redactPhone(href) });
          } else if (/^mailto:/i.test(href)) {
            fireClickEvent('email_click', { email_domain: emailDomain(href) });
          }
        }, true);
      })();
    </script>
  </body>
</html>
