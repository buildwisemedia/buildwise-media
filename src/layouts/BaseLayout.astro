---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  noindex = false,
  ogTitle,
  ogDescription,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://buildwisemedia.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogT = ogTitle ?? title;
const ogD = ogDescription ?? description;

// Centralised tracking IDs from site-config.json
const GA4 = 'G-V5LSP69E41';
const GTM = 'GTM-P5JSD86L';
const PIXEL = '2728397250833051';
const CLARITY = 'w7ga9q22fa';

const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Theme + favicon (Triangulation V3 mark — locked 2026-04-30 against brand/BWM-Logo-System-Locked.md) -->
    <meta name="theme-color" content="#050507" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180.png" />

    <!-- Open Graph (Triangulation V3 banner — image on R2 bucket bwm-assets/marks/triangulation-v3/) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogT} />
    <meta property="og:description" content={ogD} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Buildwise Media" />
    <meta property="og:image" content="https://pub-85c635a2536e438b9927af5e6723b0f7.r2.dev/marks/triangulation-v3/exports/banner/og-1200x630-v2.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Buildwise Media — Your AI Department" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://pub-85c635a2536e438b9927af5e6723b0f7.r2.dev/marks/triangulation-v3/exports/banner/og-1200x630-v2.png" />

    <!-- Fonts: Inter (display + body) + JetBrains Mono (micro) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Cal.com booking embed (used on /book) — preconnect cuts ~200-500ms off first paint of the calendar iframe. EXP-002 telemetry shows 50% click-to-LPV drop, primary suspect = TLS cold-start on this subdomain. -->
    <link rel="preconnect" href="https://book.buildwisemedia.com" />
    <link rel="dns-prefetch" href="https://book.buildwisemedia.com" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;700&display=swap"
    />

    <!-- Google Tag Manager -->
    <script is:inline define:vars={{ GTM }}>
      (function (w, d, s, l, i) {
        w[l] = w[l] || []; w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true; j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', GTM);
    </script>

    <!-- GA4 (loaded directly so events fire even if GTM is blocked) -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4}`}></script>
    <script is:inline define:vars={{ GA4 }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA4, { send_page_view: true });
    </script>

    <!-- Meta Pixel -->
    <script is:inline define:vars={{ PIXEL }}>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', PIXEL);
      fbq('track', 'PageView');
    </script>

    <!-- Microsoft Clarity (deferred to keep LCP tight per memory feedback_perf_text_lcp_after_webp.md) -->
    <script is:inline define:vars={{ CLARITY }}>
      setTimeout(function () {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          var y0=l.getElementsByTagName(r)[0];y0.parentNode.insertBefore(t,y0);
        })(window, document, "clarity", "script", CLARITY);
      }, 15000);
    </script>

    <!-- Attribution capture (first-touch + last-touch + UTM, persisted to localStorage) -->
    <script is:inline>
      (function () {
        try {
          var KEY = '_bwm_attribution';
          var url = new URL(window.location.href);
          var utm = {};
          ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','fbclid'].forEach(function (k) {
            var v = url.searchParams.get(k); if (v) utm[k] = v;
          });
          var prior = JSON.parse(localStorage.getItem(KEY) || 'null');
          var now = new Date().toISOString();
          var record = prior || { first_touch: { ts: now, referrer: document.referrer || null, landing_page: location.pathname, utm: utm }, last_touch: null };
          record.last_touch = { ts: now, referrer: document.referrer || null, landing_page: location.pathname, utm: utm };
          localStorage.setItem(KEY, JSON.stringify(record));
          window.__bwmAttribution = record;
        } catch (e) {}
      })();
    </script>

    {jsonLdArray.map((data) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>

  <body>
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
      <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${PIXEL}&ev=PageView&noscript=1`} alt="" />
    </noscript>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- CTA click telemetry -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href="/book"]');
        if (!a) return;
        var src = a.getAttribute('data-cta-source') || 'unspecified';
        try {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'cta_click', cta_label: a.textContent.trim(), cta_source: src });
          // InitiateCheckout signals click-intent. Real Lead fires from Cal.com booking webhook → CAPI server-side, deduplicated by event_id. Meta optimizes delivery toward whatever fires Lead — keeping it server-side = optimization toward bookers, not clickers.
          if (window.fbq) window.fbq('track', 'InitiateCheckout');
        } catch (err) {}
      });
    </script>
  </body>
</html>
