---
// L2 — The Poor Four (evolved framing)
// Plan: ~/.claude/plans/based-on-all-nifty-karp.md
// Source of truth: ~/bwm-strategic-roadmap/data/canonical.json line 212 — framework.poor_four
const problems = [
  {
    n: '01',
    slug: 'invisible-market',
    name: 'Invisible Market',
    body: 'Buyers search, ask AI, ask a neighbor, or compare options and your name is not the default answer. The market cannot choose you if it does not see you.',
    tone: 'cyan',
  },
  {
    n: '02',
    slug: 'leaky-revenue',
    name: 'Leaky Revenue',
    body: 'Calls wait. Quotes drift. Reviews never get asked for. Past customers go cold. The leak is not one big hole. It is ten small misses that cost real jobs.',
    tone: 'red',
  },
  {
    n: '03',
    slug: 'owner-bottleneck',
    name: 'Owner Bottleneck',
    body: 'The business still needs you to notice the problem, make the decision, and push the next step. That is not scale. That is your attention holding the system together.',
    tone: 'orange',
  },
  {
    n: '04',
    slug: 'reactive-growth',
    name: 'Reactive Growth',
    body: 'The numbers arrive late. The team reacts after the slow month hurts. Big calls get made from stale data instead of a clear weekly scoreboard.',
    tone: 'green',
  },
];
---
<section id="problem" class="poor-four">
  <div class="container">

    <header class="poor-four-head reveal">
      <p class="section-tag">The Pattern</p>
      <h2 class="h-section">
        Most service businesses don't have a <em>lead</em> problem.<br/>
        They have an <em>operations</em> problem.
      </h2>
      <p class="lede">
        Four gaps show up in owner-led service businesses again and again. Name the active leak before buying another tactic.
      </p>
    </header>

    <figure class="poor-four-diagram-wrap reveal" aria-labelledby="poor-four-diagram-cap">
      <!-- @r020:F4 curiosity: the four operational leaks converging into one gap opens the "which of these is me?" loop that the free Revenue Leak Map resolves. -->
      <svg class="poor-four-diagram" viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Four problem leaks converging into one operations gap">
        <text class="pf-diag-label" x="100" y="22" text-anchor="middle">01 · INVISIBLE MARKET</text>
        <text class="pf-diag-label" x="300" y="22" text-anchor="middle">02 · LEAKY REVENUE</text>
        <text class="pf-diag-label" x="500" y="22" text-anchor="middle">03 · OWNER BOTTLENECK</text>
        <text class="pf-diag-label" x="700" y="22" text-anchor="middle">04 · REACTIVE GROWTH</text>

        <line class="pf-diag-source" x1="100" y1="34" x2="100" y2="80" />
        <line class="pf-diag-source" x1="300" y1="34" x2="300" y2="80" />
        <line class="pf-diag-source" x1="500" y1="34" x2="500" y2="80" />
        <line class="pf-diag-source" x1="700" y1="34" x2="700" y2="80" />

        <circle class="pf-diag-dot" cx="100" cy="84" r="4" />
        <circle class="pf-diag-dot" cx="300" cy="84" r="4" />
        <circle class="pf-diag-dot" cx="500" cy="84" r="4" />
        <circle class="pf-diag-dot" cx="700" cy="84" r="4" />

        <line class="pf-diag-flow" x1="100" y1="86" x2="284" y2="178" />
        <line class="pf-diag-flow" x1="300" y1="86" x2="345" y2="178" />
        <line class="pf-diag-flow" x1="500" y1="86" x2="455" y2="178" />
        <line class="pf-diag-flow" x1="700" y1="86" x2="516" y2="178" />

        <rect class="pf-diag-drain" x="280" y="180" width="240" height="64" rx="2" />
        <text class="pf-diag-drain-label" x="400" y="218" text-anchor="middle">OPERATIONS GAP</text>
        <text class="pf-diag-drain-sub" x="400" y="234" text-anchor="middle">WHERE REVENUE DISAPPEARS</text>
      </svg>
      <figcaption id="poor-four-diagram-cap" class="poor-four-diagram-cap">
        Four leaks converge into one drain. Fix the drain, every leak slows.
      </figcaption>
    </figure>

    <ol class="problems-grid" role="list">
      {problems.map((p) => (
        <li class="problem-card-li reveal">
          <a class={`problem-card problem-card--${p.tone}`} href={`/problem/${p.slug}`}>
            <span class="problem-dot" aria-hidden="true"></span>
            <p class="problem-num">{p.n}</p>
            <h3 class="problem-name h-sub">{p.name}</h3>
            <p class="problem-body">{p.body}</p>
            <span class="problem-cta mono">Read more <em>→</em></span>
          </a>
        </li>
      ))}
    </ol>

    <div class="poor-four-foot reveal">
      <div class="poor-four-foot-statement">
        <p class="poor-four-foot-lede">Three of these fit?</p>
        <p class="poor-four-foot-verdict">
          It is probably not a lead problem.<br/>
          It's an <em>operations</em> problem.
        </p>
      </div>
      <aside class="poor-four-foot-card" aria-label="Diagnose your operations gap">
        <span class="poor-four-foot-dot" aria-hidden="true"></span>
        <p class="poor-four-foot-eyebrow">Revenue Leak Map</p>
        <p class="poor-four-foot-card-body">Five minutes starts the map. We name the leaks. You decide what to do next.</p>
        <a href="/book" class="cta poor-four-foot-cta" data-cta-source="poor-four-footer">
          Get My Free Revenue Leak Map
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
      </aside>
    </div>

  </div>
</section>

<style>
.poor-four { padding-block: var(--section-y); }
.poor-four-head { display: flex; flex-direction: column; gap: 20px; margin-bottom: 44px; max-width: 880px; }
.poor-four-head h2 em,
.poor-four-foot em {
  color: var(--y2);
  font-style: normal;
  font-weight: inherit;
}

.problems-grid {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin-block: 20px 44px;
}
.problem-card-li { list-style: none; }
.problem-card {
  --problem-accent: var(--y2);
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-top: 2px solid var(--problem-accent);
  border-radius: 2px;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  text-decoration: none;
  color: inherit;
  transition: border-color 220ms ease, background 220ms ease;
  overflow: hidden;
}
.problem-card--cyan { --problem-accent: var(--signal-cyan); }
.problem-card--red { --problem-accent: var(--signal-red); }
.problem-card--orange { --problem-accent: var(--signal-orange); }
.problem-card--green { --problem-accent: var(--signal-green); }
.problem-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, color-mix(in srgb, var(--problem-accent) 14%, transparent), transparent 48%);
  opacity: 0.45;
  pointer-events: none;
}
.problem-card:hover {
  border-color: var(--problem-accent);
  background: var(--bg-elev);
}
.problem-dot {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--problem-accent);
  opacity: 0;
  transition: opacity 220ms ease;
}
.problem-card:hover .problem-dot,
.problem-card:focus-visible .problem-dot {
  opacity: 1;
}
.problem-cta {
  margin-top: 4px;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-faint);
  transition: color 220ms ease;
}
.problem-cta em { font-style: normal; color: inherit; }
.problem-card:hover .problem-cta { color: var(--problem-accent); }
.problem-num {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(28px, 3vw, 40px);
  letter-spacing: -0.03em;
  line-height: 0.9;
  color: color-mix(in srgb, var(--problem-accent) 54%, var(--ink-faint));
  margin-bottom: 4px;
}
.problem-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* ── Scene illustration: 4 leaks → 1 drain (R020 F1-Emotion) ── */
.poor-four-diagram-wrap {
  margin: 0 0 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.poor-four-diagram {
  width: 100%;
  max-width: 1100px;
  height: auto;
  display: block;
}
.poor-four-diagram .pf-diag-label {
  fill: var(--ink-faint);
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.16em;
}
.poor-four-diagram .pf-diag-source {
  stroke: var(--rule-bright);
  stroke-width: 1;
}
.poor-four-diagram .pf-diag-dot {
  fill: var(--y2);
}
.poor-four-diagram .pf-diag-flow {
  stroke: var(--y2);
  stroke-width: 1;
  opacity: 0.5;
}
.poor-four-diagram .pf-diag-drain {
  stroke: var(--y2);
  stroke-width: 1.5;
  fill: rgba(240, 255, 0, 0.04);
}
.poor-four-diagram .pf-diag-drain-label {
  fill: var(--ink);
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: 18px;
  letter-spacing: -0.01em;
}
.poor-four-diagram .pf-diag-drain-sub {
  fill: var(--ink-faint);
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.20em;
}
.poor-four-diagram-cap {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-faint);
  text-align: center;
}

/* ── Footer diagnostic block (2-col on desktop, stacked on mobile) ── */
.poor-four-foot {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: clamp(24px, 4vw, 56px);
  align-items: stretch;
  border-top: 1px solid var(--rule);
  padding-top: 30px;
}
.poor-four-foot-statement {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 520px;
  align-self: center;
}
.poor-four-foot-lede {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin: 0;
}
.poor-four-foot-verdict {
  font-family: var(--sans);
  font-weight: 500;
  font-size: clamp(22px, 2.4vw, 30px);
  line-height: 1.25;
  color: var(--ink);
  margin: 0;
  letter-spacing: -0.01em;
}
.poor-four-foot-verdict em {
  color: var(--y2);
  font-style: normal;
  font-weight: 600;
}

.poor-four-foot-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--rule-bright);
  border-left: 2px solid var(--y2);
  border-radius: 2px;
  padding: 24px 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-width: 280px;
  max-width: 340px;
}
.poor-four-foot-dot {
  position: absolute;
  top: 18px;
  right: 18px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--y2);
}
.poor-four-foot-eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--y2);
  margin: 0;
}
.poor-four-foot-card-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.5;
  color: var(--ink-dim);
  margin: 0 0 4px;
}
.poor-four-foot-cta {
  align-self: flex-start;
  font-size: 13px;
  padding: 12px 20px;
}

@media (max-width: 860px) {
  .poor-four-foot {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .poor-four-foot-card {
    max-width: 100%;
    min-width: 0;
  }
}

@media (max-width: 720px) {
  .poor-four-head { margin-bottom: 32px; }
  .problems-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; }
  .problem-card {
    min-height: 148px;
    padding: 18px 16px;
    gap: 10px;
  }
  .problem-name { font-size: 17px; line-height: 1.08; }
  .problem-body,
  .problem-cta { display: none; }
  .poor-four-diagram-wrap { margin-bottom: 28px; }
  .poor-four-diagram .pf-diag-label { font-size: 11px; }
  .poor-four-diagram .pf-diag-drain-label { font-size: 22px; }
}
</style>
