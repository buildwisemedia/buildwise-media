---
// L2 — The Poor Four (evolved framing)
// Plan: ~/.claude/plans/based-on-all-nifty-karp.md
// Source of truth: ~/bwm-strategic-roadmap/data/canonical.json line 212 — framework.poor_four
// Slugs evolved from stale (lead-drought/owner-trap/manual-mayhem/reactive-mode) to canonical.
// Old slug SEO equity preserved via 301 redirects in astro.config.mjs.
const problems = [
  {
    n: '01',
    slug: 'invisible-market',
    name: 'Invisible Market',
    body: 'Not found in search. Not remembered when buyers ask around. Not trusted enough to call first. Competitors show up before you in Google, in AI answers, and in the recommendation a buyer gets from a friend.',
  },
  {
    n: '02',
    slug: 'leaky-revenue',
    name: 'Leaky Revenue',
    body: 'Leads come in. Calls go unanswered. Reviews go un-requested. Quotes go un-followed-up. Every leak is a revenue line draining quietly — and most owners spot the leaks too late to save the month.',
  },
  {
    n: '03',
    slug: 'owner-bottleneck',
    name: 'Owner Bottleneck',
    body: 'You are the brand, the closer, the operator, and the marketing department. The business can\'t grow past you because you ARE the business. Take a week off and the pipeline stalls.',
  },
  {
    n: '04',
    slug: 'reactive-growth',
    name: 'Reactive Growth',
    body: 'No weekly rhythm. No clear scoreboard. By the time you spot a trend in the numbers, the quarter is over. Big decisions get made on tiny data, and the whole operation is always one step behind.',
  },
];
---
<section id="problem" class="poor-four">
  <div class="container">

    <header class="poor-four-head reveal">
      <p class="section-tag">The Pattern</p>
      <h2 class="h-section">
        Most service businesses don't<br/>
        have a <em>lead</em> problem.<br/>
        They have an <em>operations</em> problem.
      </h2>
      <p class="lede">
        Four gaps show up in nearly every service business we audit. Name yours. We've named ours.
      </p>
    </header>

    <ol class="problems-grid" role="list">
      {problems.map((p) => (
        <li class="problem-card-li reveal">
          <a class="problem-card" href={`/problem/${p.slug}`}>
            <span class="problem-dot" aria-hidden="true"></span>
            <p class="problem-num">{p.n}</p>
            <h3 class="problem-name h-sub">{p.name}</h3>
            <p class="problem-body">{p.body}</p>
            <span class="problem-cta mono">Read more <em>→</em></span>
          </a>
        </li>
      ))}
    </ol>

    <p class="poor-four-foot h-sub reveal">
      If three of these sound familiar, you don't have a marketing problem.<br/>
      You have an <em>operations</em> problem dressed as a marketing problem.
    </p>

  </div>
</section>

<style>
.poor-four { padding-block: var(--section-y); }
.poor-four-head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; max-width: 880px; }
.poor-four-head h2 em,
.poor-four-foot em {
  color: var(--y2);
  font-style: normal;
  font-weight: inherit;
}

.problems-grid {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
  margin-block: 24px 64px;
}
.problem-card-li { list-style: none; }
.problem-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  text-decoration: none;
  color: inherit;
  transition: border-color 220ms ease;
}
.problem-card:hover {
  border-color: var(--y2);
}
.problem-dot {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--y2);
  opacity: 0;
  transition: opacity 220ms ease;
}
.problem-card:hover .problem-dot,
.problem-card:focus-visible .problem-dot {
  opacity: 1;
}
.problem-cta {
  margin-top: 4px;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-faint);
  transition: color 220ms ease;
}
.problem-cta em { font-style: normal; color: inherit; }
.problem-card:hover .problem-cta { color: var(--y2); }
.problem-num {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(28px, 3vw, 40px);
  letter-spacing: -0.03em;
  line-height: 0.9;
  color: var(--ink-faint);
  margin-bottom: 4px;
}
.problem-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.55;
  color: var(--ink-dim);
}

.poor-four-foot {
  color: var(--ink);
  border-top: 1px solid var(--rule);
  padding-top: 32px;
  max-width: 760px;
}

@media (max-width: 720px) {
  .problems-grid { grid-template-columns: 1fr; gap: 16px; }
  .problem-card { padding: 28px 24px; }
}
</style>
