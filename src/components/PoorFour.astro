---
// Problem Agitation — "The Poor Four" pillar framework
// Source: BO Phase 4 + CB Pillar 2 + Marketing Strategy ICP pain states
const problems = [
  {
    n: '01',
    slug: 'lead-drought',
    name: 'Lead Drought',
    body: 'Some weeks the phone rings. Other weeks it doesn\'t. You can\'t plan, can\'t hire, can\'t breathe. Every quiet stretch is its own emergency.',
  },
  {
    n: '02',
    slug: 'owner-trap',
    name: 'Owner Trap',
    body: 'You are the brand, the closer, the operator, the marketing department. You can\'t take a vacation without watching the pipeline collapse.',
  },
  {
    n: '03',
    slug: 'manual-mayhem',
    name: 'Manual Mayhem',
    body: 'A vendor for ads. A different one for SEO. A third for the website. None of them talk. You\'re the integration layer — by accident.',
  },
  {
    n: '04',
    slug: 'reactive-mode',
    name: 'Reactive Mode',
    body: 'You spend the day putting out fires you didn\'t start. Strategy keeps slipping to "after this quarter." The quarter never ends.',
  },
];
---
<section id="problem" class="poor-four">
  <div class="container">

    <header class="poor-four-head reveal">
      <p class="section-tag">The Pattern</p>
      <h2 class="h-section">
        Most service businesses don't<br/>
        have a <em>lead</em> problem.<br/>
        They have an <em>operations</em> problem.
      </h2>
      <p class="lede">
        Four gaps show up in nearly every $1M–$5M shop we audit. Name yours. We've named ours.
      </p>
    </header>

    <ol class="problems-grid" role="list">
      {problems.map((p) => (
        <li class="problem-card-li reveal">
          <a class="problem-card" href={`/problem/${p.slug}`}>
            <span class="problem-dot" aria-hidden="true"></span>
            <p class="problem-num">{p.n}</p>
            <h3 class="problem-name h-sub">{p.name}</h3>
            <p class="problem-body">{p.body}</p>
            <span class="problem-cta mono">Read more <em>→</em></span>
          </a>
        </li>
      ))}
    </ol>

    <p class="poor-four-foot h-sub reveal">
      If three of these sound familiar, you don't have a marketing problem.<br/>
      You have an <em>operations</em> problem dressed as a marketing problem.
    </p>

  </div>
</section>

<style>
.poor-four { padding-block: var(--section-y); }
.poor-four-head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; max-width: 880px; }
.poor-four-head h2 em,
.poor-four-foot em {
  color: var(--y2);
  font-style: normal;
  font-weight: inherit;
}

.problems-grid {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
  margin-block: 24px 64px;
}
.problem-card-li { list-style: none; }
.problem-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  text-decoration: none;
  color: inherit;
  transition: border-color 220ms ease;
}
.problem-card:hover {
  border-color: var(--y2);
}
.problem-dot {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--y2);
  opacity: 0;
  transition: opacity 220ms ease;
}
.problem-card:hover .problem-dot,
.problem-card:focus-visible .problem-dot {
  opacity: 1;
}
.problem-cta {
  margin-top: 4px;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-faint);
  transition: color 220ms ease;
}
.problem-cta em { font-style: normal; color: inherit; }
.problem-card:hover .problem-cta { color: var(--y2); }
.problem-num {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(28px, 3vw, 40px);
  letter-spacing: -0.03em;
  line-height: 0.9;
  color: var(--ink-faint);
  margin-bottom: 4px;
}
.problem-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.55;
  color: var(--ink-dim);
}

.poor-four-foot {
  color: var(--ink);
  border-top: 1px solid var(--rule);
  padding-top: 32px;
  max-width: 760px;
}

@media (max-width: 720px) {
  .problems-grid { grid-template-columns: 1fr; gap: 16px; }
  .problem-card { padding: 28px 24px; }
}
</style>
