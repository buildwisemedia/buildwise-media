---
// Mo' Money campaign hero — three-line strikethrough headline matched to ad creative
// Locked 2026-05-20: Y2 rotated strikethrough at -1.6deg + text-shadow glow per concept.html ref
// Source visual register: bwm-campaigns/mo-money-mo-peace/concept.html lines 254-273
//
// Props:
//   keyword: 'time' | 'peace' | 'freedom' | 'life' | 'calm'
//   subhead: string  (2-3 sentence chain-stage anchor — see ~/.claude/plans/mo-money-build-brief.md §B)

interface Props {
  keyword: 'time' | 'peace' | 'freedom' | 'life' | 'calm';
  subhead: string;
}

const { keyword, subhead } = Astro.props;
---

<section class="mo-hero" aria-labelledby="mo-hero-headline">
  <div class="container mo-hero-grid">
    <div class="mo-hero-text">
      <p class="eyebrow">Buildwise Media · Custom AI systems, run for you</p>

      <h1 id="mo-hero-headline" class="mo-headline">
        <span class="mo-line">Mo' money.</span>
        <span class="mo-line"><span class="mo-strike">Mo' problems.</span></span>
        <span class="mo-line"><span class="mo-accent">Mo' {keyword}.</span></span>
      </h1>

      <p class="mo-subhead">{subhead}</p>

      <div class="mo-ctas">
        <a href="#diagnostic" class="cta" data-cta-source={`mo-${keyword}-hero-primary`}>
          See If We're a Fit
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#mechanism" class="cta-ghost" data-cta-source={`mo-${keyword}-hero-secondary`}>See the System</a>
      </div>
      <p class="mo-icp mono">For service businesses only.</p>
    </div>

    <div class="mo-hero-proof">
      <!-- @r020:F1 emotion: a calm owner's workspace at dusk shows the "mo' {keyword}" payoff made real — the settled life on the other side of the system; the visible calm is the outcome the CTA delivers -->
      <figure class="mo-hero-photo">
        <img
          src="/images/bwm-hero-atmospheric-v1.webp"
          alt="A quiet executive office at dusk with a city view — the calm, unhurried space an owner gets back when the system runs the growth."
          width="640"
          height="426"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <figcaption class="mo-hero-photo-cap mono">More money — and the room to actually enjoy it</figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
.mo-hero {
  padding-top: clamp(96px, 11vw, 168px);
  padding-bottom: clamp(64px, 7vw, 112px);
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

/* Subtle 32px dot grid at 2.5% opacity — matches flagship hero pattern */
.mo-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  /* @r020:identity: Triangulation surface dot-grid (R014b geometric vocabulary) — sub-identity ambient texture that signals the engineered-system register; not standalone imagery */
  background-image: radial-gradient(circle at center, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
  z-index: 0;
}
.mo-hero > * { position: relative; z-index: 1; }

.mo-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(36px, 5vw, 56px);
  align-items: start;
}

@media (min-width: 980px) {
  .mo-hero-grid {
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(40px, 4vw, 72px);
    align-items: start;
  }
}

.mo-hero-text { display: flex; flex-direction: column; gap: 28px; max-width: 640px; }

.mo-hero-proof { display: flex; flex-direction: column; gap: 24px; min-width: 0; }
.mo-hero-photo { margin: 0; }
.mo-hero-photo img { width: 100%; height: auto; display: block; border: 1px solid var(--rule); }
.mo-hero-photo-cap { font-size: 10px; letter-spacing: 0.15em; color: var(--ink-faint); margin-top: 10px; display: block; }

/* THE HEADLINE — port of concept.html .headline (lines 240-279) */
.mo-headline {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(40px, 5.2vw, 92px);
  line-height: 0.92;
  letter-spacing: -0.045em;
  color: var(--ink);
  max-width: 600px;
  margin: 0;
}

.mo-line {
  display: block;
}

/* THE STRIKETHROUGH — the rhetorical move (concept.html lines 254-273) */
.mo-strike {
  position: relative;
  color: rgba(244, 244, 246, 0.28);
  display: inline-block;
  padding: 0 0.05em;
}

.mo-strike::before {
  content: "";
  position: absolute;
  top: 52%;
  left: -2%;
  right: -2%;
  height: clamp(6px, 0.9vw, 11px);
  background: var(--y2);
  transform: translateY(-50%) rotate(-1.6deg);
  transform-origin: center;
  box-shadow: 0 0 28px rgba(240, 255, 0, 0.6), 0 0 60px rgba(240, 255, 0, 0.15);
}

.mo-accent {
  color: var(--y2);
  text-shadow: 0 0 40px rgba(240, 255, 0, 0.25);
}

.mo-subhead {
  font-family: var(--sans);
  font-weight: 400;
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.5;
  color: var(--ink-dim);
  max-width: 520px;
  letter-spacing: -0.012em;
  margin: 0;
}

.mo-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
  margin-top: 8px;
}

.mo-icp {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  margin: 0;
}

@media (max-width: 768px) {
  .mo-headline { font-size: clamp(40px, 11vw, 74px); }
  .mo-subhead { font-size: 17px; }
}
</style>
