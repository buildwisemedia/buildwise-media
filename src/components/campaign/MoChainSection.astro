---
// Mo' Money campaign — shared 80% sections (time-enemy + system-mechanism)
// Identical on all 5 landings; isolates tagline signal to hero + payoff.
// Show-Don't-Tell Standard (LOCKED 2026-05-20): each section carries ≥1 functional visual.
//   Section 1 = data viz (F2 proof — hours-allocation comparison)
//   Section 2 = scene illustration (F3 CTA-pull — 3-step install/operate/own staircase)
import A2 from '../atoms/A2.astro';
import A3 from '../atoms/A3.astro';
import A5 from '../atoms/A5.astro';
import MechInstall from '../illustrations/MechInstall.astro';
import MechOperate from '../illustrations/MechOperate.astro';
import MechOwn from '../illustrations/MechOwn.astro';
---

<section class="mo-chain-enemy" aria-labelledby="mo-enemy-heading">
  <div class="container">
    <p class="section-tag">01 · THE COST</p>
    <h2 id="mo-enemy-heading" class="h-section">Your business has been quietly eating your time.</h2>
    <p class="lede">
      Mornings buried in operations. Evenings answering emails the team should have closed. Weekends filling in for staff who didn't show. Calls dropped because nobody got to them in time. Reviews unposted. Ads unfired. The growth tasks pile up because every one of them routes through you.
    </p>

    <div class="mo-week-grid">
      <figure class="mo-week-card">
        <figcaption class="mono mo-week-label">
          <A3 size={6} class="mo-week-flank" />
          Your week today
          <A3 size={6} class="mo-week-flank" />
        </figcaption>
        <svg class="mo-week-svg" viewBox="0 0 400 220" role="img" aria-label="Today: 60% ops, 25% growth tasks routing through you, 15% personal time">
          <!-- Bars: M T W T F S S, each 220h tall with 3-segment stack -->
          {[
            { day: 'M', ops: 70, growth: 22, personal: 8 },
            { day: 'T', ops: 75, growth: 18, personal: 7 },
            { day: 'W', ops: 65, growth: 28, personal: 7 },
            { day: 'T', ops: 78, growth: 15, personal: 7 },
            { day: 'F', ops: 60, growth: 30, personal: 10 },
            { day: 'S', ops: 50, growth: 30, personal: 20 },
            { day: 'S', ops: 45, growth: 25, personal: 30 },
          ].map((d, i) => {
            const x = 30 + i * 50;
            const totalH = 160;
            const opsH = (d.ops / 100) * totalH;
            const growthH = (d.growth / 100) * totalH;
            const personalH = (d.personal / 100) * totalH;
            const yOps = 200 - opsH;
            const yGrowth = yOps - growthH;
            const yPersonal = yGrowth - personalH;
            return (
              <g>
                <rect x={x} y={yOps} width="32" height={opsH} fill="#5a5650" />
                <rect x={x} y={yGrowth} width="32" height={growthH} fill="rgba(168, 162, 152, 0.6)" />
                <rect x={x} y={yPersonal} width="32" height={personalH} fill="rgba(240, 255, 0, 0.2)" />
                <text x={x + 16} y="215" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#a8a298">{d.day}</text>
              </g>
            );
          })}
        </svg>
      </figure>

      <figure class="mo-week-card mo-week-card--after">
        <figcaption class="mono mo-week-label">
          <A3 size={6} class="mo-week-flank" />
          Your week after install
          <A3 size={6} class="mo-week-flank" />
        </figcaption>
        <svg class="mo-week-svg" viewBox="0 0 400 220" role="img" aria-label="After install: 35% ops, 20% strategic review, 45% personal time and life">
          {[
            { day: 'M', ops: 40, growth: 25, personal: 35 },
            { day: 'T', ops: 38, growth: 22, personal: 40 },
            { day: 'W', ops: 35, growth: 25, personal: 40 },
            { day: 'T', ops: 42, growth: 18, personal: 40 },
            { day: 'F', ops: 30, growth: 25, personal: 45 },
            { day: 'S', ops: 15, growth: 10, personal: 75 },
            { day: 'S', ops: 10, growth: 5, personal: 85 },
          ].map((d, i) => {
            const x = 30 + i * 50;
            const totalH = 160;
            const opsH = (d.ops / 100) * totalH;
            const growthH = (d.growth / 100) * totalH;
            const personalH = (d.personal / 100) * totalH;
            const yOps = 200 - opsH;
            const yGrowth = yOps - growthH;
            const yPersonal = yGrowth - personalH;
            return (
              <g>
                <rect x={x} y={yOps} width="32" height={opsH} fill="#5a5650" />
                <rect x={x} y={yGrowth} width="32" height={growthH} fill="rgba(168, 162, 152, 0.6)" />
                <rect x={x} y={yPersonal} width="32" height={personalH} fill="#F0FF00" />
                <text x={x + 16} y="215" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#a8a298">{d.day}</text>
              </g>
            );
          })}
        </svg>
      </figure>
    </div>

    <div class="mo-week-legend">
      <span class="mo-week-legend-item"><span class="mo-week-swatch" style="background:#5a5650"></span><span class="mono">Operations</span></span>
      <span class="mo-week-legend-item"><span class="mo-week-swatch" style="background:rgba(168, 162, 152, 0.6)"></span><span class="mono">Growth tasks routing through you</span></span>
      <span class="mo-week-legend-item"><span class="mo-week-swatch" style="background:#F0FF00"></span><span class="mono">Yours</span></span>
    </div>

    <p class="mo-week-caption mono">
      Modeled · owner-week allocation before and after install · representative shape, not a single client
    </p>

    <p class="mo-chain-close">
      The cost isn't financial. The cost is hours — the resource your business has none of and can't make more of.
    </p>
  </div>
</section>

<section class="mo-chain-mechanism" id="mechanism" aria-labelledby="mo-mech-heading">
  <div class="container">
    <p class="section-tag">02 · THE MECHANISM</p>
    <div class="mo-mech-rule" aria-hidden="true"><A5 length={120} stroke={1.6} /></div>
    <h2 id="mo-mech-heading" class="h-section">We install an AI growth system.<br/>Then it runs without you.</h2>

    <div class="mo-staircase">
      <article class="mo-step">
        <div class="mo-step-illust" aria-hidden="true"><MechInstall /></div>
        <p class="mono mo-step-num">01</p>
        <h3 class="mo-step-title">Install (30 days)</h3>
        <p class="mo-step-body">
          We build your AI growth system — lead capture, qualification, follow-up, attribution, review velocity, content engine. You sign off. It goes live.
        </p>
        <span class="mo-step-arrow" aria-hidden="true"><A2 length={60} stroke={1.6} direction="horizontal" /></span>
      </article>

      <article class="mo-step">
        <div class="mo-step-illust" aria-hidden="true"><MechOperate /></div>
        <p class="mono mo-step-num">02</p>
        <h3 class="mo-step-title">Operate (weekly)</h3>
        <p class="mo-step-body">
          The system runs the marketing department. Leads land. Calls book. Follow-ups fire. Attribution tracks. You get a weekly summary of what mattered.
        </p>
        <span class="mo-step-arrow" aria-hidden="true"><A2 length={60} stroke={1.6} direction="horizontal" /></span>
      </article>

      <article class="mo-step">
        <div class="mo-step-illust" aria-hidden="true"><MechOwn /></div>
        <p class="mono mo-step-num">03</p>
        <h3 class="mo-step-title">Own (forever)</h3>
        <p class="mo-step-body">
          You own the system. The code, the data, the workflows. We don't hold it hostage. If we part ways, the system keeps running. That's the contract.
        </p>
      </article>
    </div>
  </div>
</section>

<style>
.mo-chain-enemy {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
}

.mo-chain-enemy .lede {
  margin-top: 24px;
  margin-bottom: 56px;
}

.mo-week-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 40px;
}

.mo-week-card {
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  padding: 28px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.mo-week-card--after {
  border-color: rgba(240, 255, 0, 0.4);
}

.mo-week-label {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  display: inline-flex;
  align-items: center;
  gap: 10px;
}

.mo-week-label :global(.mo-week-flank) {
  display: inline-block;
  vertical-align: middle;
}

.mo-week-svg {
  width: 100%;
  height: auto;
}

.mo-week-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 28px;
  margin-top: 24px;
}

.mo-week-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  color: var(--ink-dim);
}

.mo-week-swatch {
  display: inline-block;
  width: 14px;
  height: 14px;
}

.mo-week-caption {
  margin-top: 28px;
  font-size: 11px;
  letter-spacing: 0.14em;
  color: var(--ink-faint);
  text-transform: uppercase;
  max-width: 760px;
}

.mo-chain-close {
  margin-top: 48px;
  font-family: var(--sans);
  font-size: clamp(20px, 2vw, 26px);
  font-weight: 500;
  line-height: 1.4;
  color: var(--ink);
  max-width: 820px;
  letter-spacing: -0.012em;
}

.mo-chain-mechanism {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
  background: var(--bg-elev);
}

.mo-mech-rule {
  margin-top: 16px;
  margin-bottom: 8px;
  line-height: 0;
}

.mo-chain-mechanism .h-section {
  margin-top: 16px;
  margin-bottom: 64px;
}

.mo-staircase {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 32px;
  align-items: start;
}

.mo-step {
  position: relative;
  padding: 32px;
  padding-left: 36px;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-left: 2px solid var(--y2);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Voicura-register vertical left-spine glow on each step card */
.mo-step::before {
  content: '';
  position: absolute;
  left: -2px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, rgba(240, 255, 0, 0) 0%, var(--y2) 12%, var(--y2) 88%, rgba(240, 255, 0, 0) 100%);
  pointer-events: none;
}

.mo-step-illust {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -8px -8px 12px -8px;
  padding: 12px;
  background: rgba(5, 5, 7, 0.5);
  border: 1px solid rgba(122, 132, 0, 0.18);
  border-radius: 1px;
}

.mo-step-illust svg {
  width: 100%;
  height: auto;
  max-width: 240px;
  display: block;
}

.mo-step-num {
  font-size: 11px;
  letter-spacing: 0.20em;
  color: var(--y2);
}

.mo-step-title {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(24px, 2.4vw, 30px);
  line-height: 1.15;
  color: var(--ink);
  letter-spacing: -0.02em;
}

.mo-step-body {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.55;
  color: var(--ink-dim);
}

.mo-step-arrow {
  position: absolute;
  right: -38px;
  top: 50%;
  width: 60px;
  height: 60px;
  transform: translateY(-50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  line-height: 0;
}

@media (max-width: 880px) {
  .mo-week-grid { grid-template-columns: 1fr; }
  .mo-staircase { grid-template-columns: 1fr; }
  .mo-step-arrow { display: none; }
}
</style>
