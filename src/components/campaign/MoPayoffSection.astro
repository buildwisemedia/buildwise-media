---
// Mo' Money campaign — bespoke payoff section per chain stage
// Copy locked 2026-05-20 — see ~/.claude/plans/mo-money-build-brief.md §B
//
// Props:
//   keyword: 'time' | 'peace' | 'freedom' | 'life' | 'calm'
import A4 from '../atoms/A4.astro';
import A5 from '../atoms/A5.astro';
import A2 from '../atoms/A2.astro';

interface Props {
  keyword: 'time' | 'peace' | 'freedom' | 'life' | 'calm';
}

const { keyword } = Astro.props;

// Per-variant Payoff photography (R018 register per variant — atmospheric/
// composed/editorial-journalism/cinematic-film). R015 color contract holds:
// ≥90% dark cool, ≤10% Y2/Y1/O1, 0% warm pixels above 40% saturation.
// Files in /public/payoff/ — graceful fallback if not yet generated.
const PHOTO_ALT: Record<Props['keyword'], string> = {
  peace: 'An owner desk at first light — phone face-down, the morning held still.',
  time: 'Closed laptop, watch, half-finished coffee in afternoon window-light — work finished, hours returned.',
  freedom: 'An owner mid-step out the door, hand on the frame — leaving the system to run.',
  life: 'A family at the dinner table with the owner fully present — no devices, no second screens.',
  calm: 'A single chair by a window, a plant catching cool light — the room is still while the system runs.',
};

const COPY: Record<Props['keyword'], { h2: string; body: string; chainStage: string }> = {
  time: {
    chainStage: 'PAYOFF',
    h2: 'The hours stack up.',
    body: `This isn't "we'll save you 5 hours a week." This is the marketing department running while you sleep. Lead capture, qualification, follow-up, attribution — all of it happens without you in the loop. You stop being the person who answers leads. You stop being the person who chases reviews. You stop being the person who writes the next ad. Mornings unburied. Evenings closed. Weekends actually off. You hire it once. It runs forever.`,
  },
  freedom: {
    chainStage: 'MECHANISM',
    h2: "Freedom is what you're actually buying.",
    body: `Freedom is what most owners are actually after when they say they want growth. Freedom from being the only person who knows how leads get qualified. Freedom from being the bottleneck on every campaign decision. Freedom from being the unpaid CMO who already has two other jobs. The AI growth system takes the routing weight off you. You don't manage it. You don't operate it. You don't even check it most days — it tells you what mattered. The system runs the business of getting customers. You run your life.`,
  },
  peace: {
    chainStage: 'DOWNSTREAM EMOTION',
    h2: "Peace isn't a mindset. It's a byproduct.",
    body: `Peace isn't an attitude adjustment. It's what happens when the thing that was stealing your attention stops stealing your attention. The AI growth system handles lead capture, qualification, follow-up, and attribution on its own. You don't wake up to a marketing inbox. You don't refresh the dashboard four times a day. You don't carry the campaign in your head while you're at dinner. The work that was consuming your mental space moves out of your mental space. We install the system. The peace shows up after.`,
  },
  calm: {
    chainStage: 'DOWNSTREAM EMOTION',
    h2: 'Calm is a nervous-system state.',
    body: `Calm shows up when the part of your brain that's been on alert about leads-this-week and ads-this-quarter and reviews-last-month finally lets go. The AI growth system holds all of it. It catches the leads, qualifies them against your real criteria, follows up the way you'd want followed up, and tells you only what you actually need to see. The thirty open browser tabs in your head close. Your breathing slows. The marketing keeps running. You stop being the redundancy. The system is the redundancy.`,
  },
  life: {
    chainStage: 'WHOLE-CHAIN COMPRESSION',
    h2: 'More life is the whole point.',
    body: `Not more revenue. Not more leads. Not more anything in the business. Life is what your business has been borrowing against — the dinners, the trips, the mornings, the marriages, the kids' games, the days that didn't have a 6am or a 10pm. The AI growth system gives those back, one returned hour at a time, because the work that was stealing them runs without you now. You'll still own the business. You'll still call the shots. But you won't be the engine of it. You'll be a person again, with a business that runs in the background.`,
  },
};

// PHOTOS_AVAILABLE: keywords whose payoff photo file ships in /public/payoff/.
// Flip a keyword into this list AFTER its image lands + clears R015 color gate.
// Empty by default — keeps the slot hidden until the photo is real.
const PHOTOS_AVAILABLE: ReadonlyArray<Props['keyword']> = [];

const { h2, body, chainStage } = COPY[keyword];
const photoAlt = PHOTO_ALT[keyword];
const photoSrc = `/payoff/${keyword}.webp`;
const showPhoto = PHOTOS_AVAILABLE.includes(keyword);
---

<section class="mo-payoff" aria-labelledby="mo-payoff-heading">
  <div class="mo-payoff-corner" aria-hidden="true">
    <A4 size={18} stroke={1.6} />
  </div>
  <div class="container">
    <p class="section-tag">03 · THE PAYOFF · {chainStage}</p>
    <div class="mo-payoff-rule"><A5 length={120} stroke={1.6} /></div>
    <h2 id="mo-payoff-heading" class="h-section">{h2}</h2>

    {showPhoto && (
      <figure class="mo-payoff-figure" aria-hidden="false">
        <span class="mo-payoff-flank mo-payoff-flank--left" aria-hidden="true"><A2 length={48} stroke={1.4} direction="tl-br" /></span>
        <img
          class="mo-payoff-photo"
          src={photoSrc}
          alt={photoAlt}
          loading="lazy"
          decoding="async"
          width="1600"
          height="1000"
        />
        <span class="mo-payoff-flank mo-payoff-flank--right" aria-hidden="true"><A2 length={48} stroke={1.4} direction="tr-bl" /></span>
      </figure>
    )}

    <p class="mo-payoff-body">{body}</p>

    <div class="mo-payoff-anchor">
      <span class="mo-payoff-mark"><A4 size={28} stroke={1.6} /></span>
      <p class="mo-payoff-hook mono">
        Ready to see if the system fits your shop? <a href="#diagnostic">Take the diagnostic ↓</a>
      </p>
    </div>
  </div>
</section>

<style>
.mo-payoff {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
  background: var(--bg);
  position: relative;
}

/* A4 hollow-vertex corner marker — section-open anchor per R014b */
.mo-payoff-corner {
  position: absolute;
  top: 24px;
  right: clamp(20px, 4vw, 48px);
  pointer-events: none;
}

/* A5 90-hairline section-open transition rule above h2 */
.mo-payoff-rule {
  margin-top: 16px;
  margin-bottom: 8px;
  line-height: 0;
}

.mo-payoff .h-section {
  margin-top: 16px;
  margin-bottom: 40px;
}

.mo-payoff-figure {
  margin: 32px 0 40px 0;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 20px;
  max-width: 1040px;
}

.mo-payoff-flank {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0.7;
  line-height: 0;
}

.mo-payoff-photo {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  display: block;
  border: 1px solid var(--rule);
  background: var(--bg-elev);
  /* If photo not yet generated, the bg + border still render a clean slot */
}

@media (max-width: 760px) {
  .mo-payoff-figure {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .mo-payoff-flank { display: none; }
}

.mo-payoff-body {
  font-family: var(--sans);
  font-size: clamp(19px, 1.8vw, 22px);
  font-weight: 400;
  line-height: 1.6;
  color: var(--ink-dim);
  max-width: 820px;
  letter-spacing: -0.005em;
}

.mo-payoff-anchor {
  margin-top: 56px;
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 28px;
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  border-left: 3px solid var(--y2);
  max-width: 820px;
}

.mo-payoff-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 0;
}

.mo-payoff-hook {
  font-size: 12px;
  letter-spacing: 0.16em;
  color: var(--ink);
  margin: 0;
}

.mo-payoff-hook a {
  color: var(--y2);
  text-decoration: none;
  border-bottom: 1px solid rgba(240, 255, 0, 0.3);
  transition: border-color 180ms ease;
}

.mo-payoff-hook a:hover {
  border-color: var(--y2);
}
</style>
