---
// Voice-search phrased FAQ — FAQPage schema emitted at the page level
// alongside the rendered section so AI agents see matching content.
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;
---
<section class="faq">
  <div class="container faq-grid">

    <div class="faq-head reveal">
      <header class="faq-head-text">
        <p class="section-tag">Questions, answered</p>
        <h2 class="h-section">
          Real systems.<br/>
          Real <em>numbers.</em><br/>
          Real answers.
        </h2>
      </header>
      <!-- @r020:F2 proof: question→running-system→verified-answer routing diagram — visually encodes the "real systems, real answers" claim beside booking-intent FAQs -->
      <figure class="faq-scene">
        <svg viewBox="0 0 360 232" role="img" aria-label="Diagram: each question routes through the running system and returns a verified answer.">
          <!-- question nodes -->
          <rect class="fx-vertex" x="16" y="36" width="8" height="8" />
          <text class="fx-label" x="34" y="44">Q-01</text>
          <rect class="fx-vertex" x="16" y="102" width="8" height="8" />
          <text class="fx-label" x="34" y="110">Q-02</text>
          <rect class="fx-vertex" x="16" y="168" width="8" height="8" />
          <text class="fx-label" x="34" y="176">Q-03</text>
          <!-- routing hairlines into the system block -->
          <line class="fx-hair" x1="24" y1="40" x2="150" y2="96" />
          <line class="fx-hair" x1="24" y1="106" x2="150" y2="116" />
          <line class="fx-hair" x1="24" y1="172" x2="150" y2="136" />
          <!-- running system block -->
          <rect class="fx-block" x="150" y="76" width="112" height="80" />
          <text class="fx-label" x="166" y="100">RUNNING</text>
          <text class="fx-label" x="166" y="114">SYSTEM</text>
          <circle class="fx-dot" cx="170" cy="138" r="2.5" />
          <circle class="fx-dot" cx="184" cy="138" r="2.5" />
          <circle class="fx-dot" cx="198" cy="138" r="2.5" />
          <!-- verified answer out -->
          <line class="fx-hair" x1="262" y1="116" x2="322" y2="116" />
          <rect class="fx-vertex-filled" x="322" y="112" width="8" height="8" />
          <text class="fx-label" x="282" y="104">ANSWER</text>
          <!-- caption -->
          <text class="fx-caption" x="16" y="220">EVERY ANSWER TRACES TO LIVE SYSTEM STATE</text>
        </svg>
      </figure>
    </div>

    <ul class="faq-list" role="list">
      {faqs.map((f, i) => (
        <li class="faq-item reveal">
          <details>
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
.faq { padding-block: var(--section-y); }
.faq-grid { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr); gap: clamp(48px, 6vw, 96px); align-items: start; }
.faq-head { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 32px; }
.faq-head-text { display: flex; flex-direction: column; gap: 24px; }
.faq-aside { margin: 0; }

.faq-scene { margin: 0; max-width: 360px; }
.faq-scene svg { width: 100%; height: auto; display: block; }
.faq-aside img {
  width: 100%;
  height: auto;
  display: block;
  border: 1px solid var(--rule);
  border-radius: 2px;
  aspect-ratio: 4 / 5;
  object-fit: cover;
}

.faq-list { list-style: none; }
.faq-item { border-top: 1px solid var(--rule); }
.faq-item:last-child { border-bottom: 1px solid var(--rule); }

.faq-item details summary {
  list-style: none;
  cursor: pointer;
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
}
.faq-item details summary::-webkit-details-marker { display: none; }

.faq-q {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(22px, 2.4vw, 28px);
  letter-spacing: -0.015em;
  line-height: 1.3;
  color: var(--ink);
}

.faq-toggle {
  font-family: var(--mono);
  font-size: 24px;
  color: var(--y2);
  flex: none;
  width: 32px;
  text-align: center;
  line-height: 1;
  transition: transform 220ms ease;
}
.faq-item details[open] .faq-toggle { transform: rotate(45deg); }

.faq-a {
  padding: 0 0 28px 0;
  max-width: 720px;
}
.faq-a p {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.65;
  color: var(--ink-dim);
}

@media (max-width: 880px) {
  .faq-grid { grid-template-columns: 1fr; }
  .faq-head { position: static; gap: 24px; }
  .faq-aside { display: none; }
}
</style>
