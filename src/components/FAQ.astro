---
// Homepage FAQ — voice-search phrased; FAQPage schema emitted at page level
const faqs = [
  {
    q: "What does Buildwise Media actually do?",
    a: "We install and operate one integrated lead-generation system — the Buildwise Revenue Engine. That includes the website built to AI-search-era standards, paid acquisition wired to baseline-first attribution, AI-assisted content production with a human quality gate, and an integrated operations layer (CRM, analytics, weekly connector audit). We treat marketing as operations: ad spend in, revenue out, verified weekly.",
  },
  {
    q: "Who is Buildwise Media for?",
    a: "Service-business owners between $1M and $5M who want to run marketing the way they run their business — measurable, accountable, instrumented. Owners looking for a savior or hoping for comfort tend to bounce off our process. Owners who want to operate the system themselves tend to thrive.",
  },
  {
    q: "How fast does the system go live?",
    a: "Inside 30 days the website is live, ad accounts are wired, the CRM is instrumented, and first leads start to flow. Full-system instrumentation completes in the same window. We don't run a 90-day waiting period before anything is observable.",
  },
  {
    q: "How do you measure success?",
    a: "Every commitment carries three required fields — a confidence percentage (75% floor), an evidence class (Measured / Attributed / Modeled / Benchmark), and a captured baseline. Outcomes ratchet up as real data arrives. The Outcomes Commitment Card is the contract; it's not aspirational copy.",
  },
  {
    q: "Is there a long-term contract?",
    a: "No. The engagement runs month-to-month, no long-term lock-in. The build-right guarantee covers install milestones; if we miss them we keep working until we don't. We earn the retainer every month or we don't.",
  },
  {
    q: "What does it cost?",
    a: "Pricing is set per engagement and exposed only to qualified prospects in the discovery call. We don't publish a generic price tile because the system that fits a $1.5M shop is genuinely different from the one that fits a $4M shop. Booking a call is the way to find out.",
  },
];
---
<section class="faq">
  <div class="container faq-grid">

    <header class="faq-head reveal">
      <p class="section-tag">Questions, answered</p>
      <h2 class="h-section">
        Real systems.<br/>
        Real <em>numbers.</em><br/>
        Real answers.
      </h2>
    </header>

    <ul class="faq-list" role="list">
      {faqs.map((f, i) => (
        <li class="faq-item reveal">
          <details>
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
.faq { padding-block: var(--section-y); }
.faq-grid { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr); gap: clamp(48px, 6vw, 96px); align-items: start; }
.faq-head { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 24px; }

.faq-list { list-style: none; }
.faq-item { border-top: 1px solid var(--rule); }
.faq-item:last-child { border-bottom: 1px solid var(--rule); }

.faq-item details summary {
  list-style: none;
  cursor: pointer;
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
}
.faq-item details summary::-webkit-details-marker { display: none; }

.faq-q {
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(22px, 2.4vw, 28px);
  letter-spacing: -0.015em;
  line-height: 1.3;
  color: var(--ink);
}

.faq-toggle {
  font-family: var(--mono);
  font-size: 24px;
  color: var(--gold);
  flex: none;
  width: 32px;
  text-align: center;
  line-height: 1;
  transition: transform 220ms ease;
}
.faq-item details[open] .faq-toggle { transform: rotate(45deg); }

.faq-a {
  padding: 0 0 28px 0;
  max-width: 720px;
}
.faq-a p {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.65;
  color: var(--ink-dim);
}

@media (max-width: 880px) {
  .faq-grid { grid-template-columns: 1fr; }
  .faq-head { position: static; }
}
</style>
