---
// Voice-search phrased FAQ — FAQPage schema emitted at the page level
// alongside the rendered section so AI agents see matching content.
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;
---
<section class="faq">
  <div class="container faq-grid">

    <div class="faq-head reveal">
      <header class="faq-head-text">
        <p class="section-tag">Questions, answered</p>
        <h2 class="h-section">
          Real systems.<br/>
          Real <em>numbers.</em><br/>
          Real answers.
        </h2>
      </header>
      <figure class="faq-aside" aria-hidden="true">
        <img
          src="/images/bwm-about-atmospheric-v1.webp"
          alt=""
          width="960"
          height="1200"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>

    <ul class="faq-list" role="list">
      {faqs.map((f, i) => (
        <li class="faq-item reveal">
          <details>
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
.faq { padding-block: var(--section-y); }
.faq-grid { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr); gap: clamp(48px, 6vw, 96px); align-items: start; }
.faq-head { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 32px; }
.faq-head-text { display: flex; flex-direction: column; gap: 24px; }
.faq-aside { margin: 0; }
.faq-aside img {
  width: 100%;
  height: auto;
  display: block;
  border: 1px solid var(--rule);
  border-radius: 2px;
  aspect-ratio: 4 / 5;
  object-fit: cover;
}

.faq-list { list-style: none; }
.faq-item { border-top: 1px solid var(--rule); }
.faq-item:last-child { border-bottom: 1px solid var(--rule); }

.faq-item details summary {
  list-style: none;
  cursor: pointer;
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
}
.faq-item details summary::-webkit-details-marker { display: none; }

.faq-q {
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(22px, 2.4vw, 28px);
  letter-spacing: -0.015em;
  line-height: 1.3;
  color: var(--ink);
}

.faq-toggle {
  font-family: var(--mono);
  font-size: 24px;
  color: var(--gold);
  flex: none;
  width: 32px;
  text-align: center;
  line-height: 1;
  transition: transform 220ms ease;
}
.faq-item details[open] .faq-toggle { transform: rotate(45deg); }

.faq-a {
  padding: 0 0 28px 0;
  max-width: 720px;
}
.faq-a p {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 17px;
  line-height: 1.65;
  color: var(--ink-dim);
}

@media (max-width: 880px) {
  .faq-grid { grid-template-columns: 1fr; }
  .faq-head { position: static; gap: 24px; }
  .faq-aside { display: none; }
}
</style>
