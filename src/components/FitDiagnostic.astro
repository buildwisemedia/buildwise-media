    .chip:focus-visible, .ms-card:focus-visible, .bn-card:focus-visible, .split-btn:focus-visible, .slider-snap:focus-visible, .q-nav-back:focus-visible, .q-nav-next:focus-visible, .cta-primary:focus-visible, .cta-secondary:focus-visible { outline: 2px solid var(--y2); outline-offset: 3px; }

    .chip-grid {
