        card.appendChild(num);
        card.appendChild(title);
        card.appendChild(body);
        card.appendChild(tag);
        systemGrid.appendChild(card);
      });

      // Projection chart (SVG via createElementNS — no innerHTML)
      drawProjection(state);

      // Verdict
      document.getElementById('verdict-card').dataset.verdict = verdict;
      document.getElementById('verdict-status').textContent = verdictLabel;
