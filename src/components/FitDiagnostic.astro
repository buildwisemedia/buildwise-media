---
// Mo' Money campaign — Fit Diagnostic
// @r020-exempt: interactive diagnostic UI (icon svgs + progress indicators); the one editorial photo below carries its own annotation
// Ported 2026-05-20 from bwm-campaigns/mo-money-mo-peace/landing.html
// Self-contained: state machine + 7 question screens + reveal + verdict routing
// Submit handler POSTs to bwm-form-handler /buildwisemedia/fit-diagnostic
// Email is OPTIONAL per locked promise "The reveal is yours regardless"
//
// Token swap from source: --canvas → --bg, --text → --ink, --text-dim → --ink-dim,
// --hairline → --rule. Component scoped via #diagnostic wrapper to avoid bleed.
---

<section id="diagnostic" class="bwm-fit-diagnostic">
<div id="screen-announce" aria-live="polite" class="sr-only" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;"></div>
<header class="doc-header">
    <div class="container">
      <div class="doc-header-inner">
        <div class="doc-mark">
          <div class="doc-mark-glyph">
            <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="markGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#F0FF00"/>
                  <stop offset="100%" stop-color="#B8FF3A" stop-opacity="0.85"/>
                </linearGradient>
              </defs>
              <circle cx="5" cy="23" r="2.4" fill="url(#markGrad)"/>
              <circle cx="23" cy="23" r="2.4" fill="url(#markGrad)"/>
              <circle cx="14" cy="5" r="2.4" fill="url(#markGrad)"/>
              <line x1="6.5" y1="21.5" x2="13" y2="6.5" stroke="#F0FF00" stroke-width="0.8" opacity="0.55"/>
              <line x1="21.5" y1="21.5" x2="15" y2="6.5" stroke="#F0FF00" stroke-width="0.8" opacity="0.55"/>
              <line x1="7.5" y1="23" x2="20.5" y2="23" stroke="#F0FF00" stroke-width="0.8" opacity="0.55"/>
              <circle cx="14" cy="16" r="1.3" fill="#F0FF00"/>
            </svg>
          </div>
          <div class="doc-mark-text">Buildwise&nbsp;Media</div>
          <div class="doc-mark-separator"></div>
          <div class="doc-mark-tag">Fit Diagnostic</div>
        </div>
        <div class="progress-mark" id="progress" style="display: none;">
          <svg viewBox="0 0 36 36" fill="none">
            <circle cx="6" cy="30" r="3" fill="none" stroke="#F0FF00" stroke-width="1" id="vtx-1"/>
            <circle cx="30" cy="30" r="3" fill="none" stroke="#F0FF00" stroke-width="1" id="vtx-2"/>
            <circle cx="18" cy="6" r="3" fill="none" stroke="#F0FF00" stroke-width="1" id="vtx-3"/>
            <line x1="8" y1="28" x2="16" y2="8" stroke="#F0FF00" stroke-width="0.6" opacity="0.35"/>
            <line x1="28" y1="28" x2="20" y2="8" stroke="#F0FF00" stroke-width="0.6" opacity="0.35"/>
            <line x1="9" y1="30" x2="27" y2="30" stroke="#F0FF00" stroke-width="0.6" opacity="0.35"/>
          </svg>
          <span class="progress-mark-label"><span class="current" id="q-current">01</span> / 07 · <span id="q-cat">Service</span></span>
        </div>
      </div>
    </div>
  </header>

  

    <section class="screen screen-welcome">
      <div class="welcome-hero">
        <div class="container">
          <div class="welcome-eyebrow">
            <span class="verdict-dot"></span>
            <span class="mono-eyebrow">For Service Businesses Only · ~3 Minutes · No Email Required</span>
          </div>
          <div class="welcome-hero-grid">
            <div class="welcome-hero-text">
              <h2 class="welcome-headline">
                Most consultations <span class="strike">qualify you</span>.<br>
                Ours shows you what your business could <span class="y">become</span>.
              </h2>
              <p class="welcome-subhead">
                Answer 7 questions. We'll show you <strong>exactly where your business sits today</strong>, <strong>where the bottleneck is</strong>, and what your AI growth system would look like over the next 12 months — <strong>even if we never work together</strong>.
              </p>
              <div class="welcome-trust">
                <div class="trust-item"><span class="verdict-dot-sm"></span> 7 Questions</div>
                <div class="trust-item"><span class="verdict-dot-sm"></span> ~3 Minutes</div>
                <div class="trust-item"><span class="verdict-dot-sm"></span> No Email To See Result</div>
                <div class="trust-item"><span class="verdict-dot-sm"></span> Tailored To You</div>
              </div>
              <div class="welcome-cta-wrap">
                <button class="cta-primary" data-action="start">
                  Get My Free Revenue Leak Map
                  <span class="arrow">→</span>
                </button>
                <a href="/book" class="cta-secondary">Or just book a 15-min call →</a>
              </div>
            </div>
            <div class="welcome-hero-visual">
              <!-- @r020:F1 emotion: pre-dawn owner-in-truck portrait mirrors the visitor's own morning — self-recognition pulls them into the diagnostic -->
              <img src="/assets/photography/v1-editorial-black-owner.jpg" alt="A service-business owner in his work truck at dawn, looking out at the road ahead" loading="eager" decoding="async" width="1600" height="1200">
              <div class="welcome-hero-visual-overlay"></div>
              <span class="welcome-hero-visual-dot"></span>
              <span class="welcome-hero-visual-hairline"></span>
              <div class="welcome-hero-visual-meta">
                <div class="welcome-hero-visual-label">This is <span class="y">your morning</span>.</div>
                <div class="welcome-hero-visual-cite">Service Owner<br>Pre-Shift · Dawn</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="welcome-divider-section">
        <div class="container">
          <div class="mono-eyebrow" style="margin-bottom: 32px;">Why This Is Different</div>
          <div class="divider-grid">
            <div class="divider-cell">
              <div class="divider-cell-num">01 · The Premise</div>
              <h3 class="divider-cell-title">No transaction. No free PDF.</h3>
              <p class="divider-cell-body">
                Most lead-gen funnels extract from you — your email, your time, your data — in exchange for a hope. We're doing the opposite. The diagnostic itself is the value. The reveal is yours regardless.
              </p>
            </div>
            <div class="divider-cell">
              <div class="divider-cell-num">02 · The Reveal</div>
              <h3 class="divider-cell-title">A personalized growth report.</h3>
              <p class="divider-cell-body">
                Your inputs synthesize into a real diagnostic: where you sit, where your bottleneck is, what your custom AI growth system would look like, and a 12-month projection. Generated for you, not from a template.
              </p>
            </div>
            <div class="divider-cell">
              <div class="divider-cell-num">03 · The Verdict</div>
              <h3 class="divider-cell-title">Three honest paths.</h3>
              <p class="divider-cell-body">
                If you're a Fit, we'll book the strategy call. If you're close, we'll show you the 3 things to lock in first. If you're not ready yet, we'll hand you the exact playbook to fix the gaps. We don't waste your time.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="screen screen-q1 q-screen">
      <div class="container">
        <div class="q-eyebrow">
          <span class="q-eyebrow-num">/01</span>
          <span class="q-eyebrow-sep">·</span>
          <span class="q-eyebrow-cat">Service</span>
        </div>
        <!-- @r020:F3 cta-pull: step-progress dots show how close the reveal is — momentum pulls completion -->
        <svg class="q-progress" viewBox="0 0 136 12" width="136" height="12" role="img" aria-label="Question 1 of 7"><circle cx="10" cy="6" r="4" fill="#F0FF00"/><circle cx="28" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="46" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="64" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="82" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="100" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="118" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/></svg>
        <h2 class="q-text">What kind of <span class="y">service business</span> do you run?</h2>
        <p class="q-help">Pick the one that fits best. If your service is mixed, pick the line that's the largest share of revenue today.</p>
        <div class="chip-grid" data-single="service">
          <button class="chip" data-value="hvac">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <rect x="3" y="8" width="26" height="16" rx="1"/>
              <path d="M6 12h20 M6 16h20 M6 20h20" class="hair"/>
              <circle cx="23" cy="16" r="3.2" class="verdict-glow"/>
              <circle cx="23" cy="16" r="1.4" class="verdict"/>
            </svg>
            <span class="chip-label">HVAC</span>
            <span class="chip-sub">Heat pumps · ducted · mini-splits</span>
          </button>
          <button class="chip" data-value="roofing">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M3 24 L16 7 L29 24"/>
              <path d="M7 21 L16 11 L25 21" class="hair"/>
              <path d="M11 24 L16 17 L21 24" class="hair"/>
              <circle cx="16" cy="7" r="2.6" class="verdict-glow"/>
              <circle cx="16" cy="7" r="1.4" class="verdict"/>
            </svg>
            <span class="chip-label">Roofing</span>
            <span class="chip-sub">Tearoffs · replacements · storm</span>
          </button>
          <button class="chip" data-value="plumbing">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M16 4 C12.5 8 8 13 8 19 a8 8 0 0 0 16 0 c0 -6 -4.5 -11 -8 -15 Z"/>
              <path d="M12 19 a4 4 0 0 0 4 4" class="hair"/>
              <circle cx="20" cy="13" r="1.7" class="verdict"/>
            </svg>
            <span class="chip-label">Plumbing</span>
            <span class="chip-sub">Service · water heaters · drains</span>
          </button>
          <button class="chip" data-value="pest">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="13" cy="13" r="7.5"/>
              <path d="M18.5 18.5 L27 27"/>
              <path d="M10 13 h6 M13 10 v6" class="hair"/>
              <circle cx="13" cy="13" r="2.4" class="verdict-glow"/>
              <circle cx="13" cy="13" r="1.3" class="verdict"/>
            </svg>
            <span class="chip-label">Pest Control</span>
            <span class="chip-sub">Recurring · wildlife removal</span>
          </button>
          <button class="chip" data-value="realtor">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M4 15 L16 5 L28 15 V27 H4 Z"/>
              <path d="M12 27 V19 H20 V27" class="hair"/>
              <path d="M9 13 L9 9 L13 9" class="hair"/>
              <circle cx="16" cy="12" r="2.6" class="verdict-glow"/>
              <circle cx="16" cy="12" r="1.4" class="verdict"/>
            </svg>
            <span class="chip-label">Real Estate</span>
            <span class="chip-sub">Listings · buyer-side</span>
          </button>
          <button class="chip" data-value="concrete">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M3 18 L16 10 L29 18 L16 26 Z"/>
              <path d="M9.5 14 L22.5 22" class="hair"/>
              <path d="M22.5 14 L9.5 22" class="hair"/>
              <path d="M16 10 L16 26" class="hair"/>
              <circle cx="29" cy="18" r="1.5" class="verdict"/>
            </svg>
            <span class="chip-label">Concrete</span>
            <span class="chip-sub">Driveways · slabs · foundations</span>
          </button>
          <button class="chip" data-value="cleaning">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M12 13 H22 V28 H12 Z"/>
              <path d="M14 13 V8 H20 V13"/>
              <path d="M20 8 L27 5 L27 10 L20 10" class="hair"/>
              <path d="M14 18 H20" class="hair"/>
              <circle cx="28.5" cy="3.5" r="1.2" class="verdict"/>
              <circle cx="30" cy="6" r="0.9" class="verdict"/>
              <circle cx="29.5" cy="9" r="0.7" class="verdict"/>
            </svg>
            <span class="chip-label">Cleaning</span>
            <span class="chip-sub">Recurring residential · commercial</span>
          </button>
          <button class="chip" data-value="other">
            <svg class="chip-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M4 12 H28 V27 H4 Z"/>
              <path d="M10 12 V7 H22 V12"/>
              <path d="M4 18 H28" class="hair"/>
              <circle cx="16" cy="22.5" r="2.4" class="verdict-glow"/>
              <circle cx="16" cy="22.5" r="1.3" class="verdict"/>
            </svg>
            <span class="chip-label">Other Service</span>
            <span class="chip-sub">Tell us what you do</span>
          </button>
        </div>
        <div class="q-nav">
          <button class="q-nav-back" data-back="welcome">← Back</button>
          <button class="q-nav-next" id="next-q1" data-next="q2" disabled>Next →</button>
        </div>
      </div>
    </section>

    <section class="screen screen-q2 q-screen">
      <div class="container">
        <div class="q-eyebrow">
          <span class="q-eyebrow-num">/02</span>
          <span class="q-eyebrow-sep">·</span>
          <span class="q-eyebrow-cat">Acquisition</span>
        </div>
        <!-- @r020:F3 cta-pull: step-progress dots show how close the reveal is — momentum pulls completion -->
        <svg class="q-progress" viewBox="0 0 136 12" width="136" height="12" role="img" aria-label="Question 2 of 7"><circle cx="10" cy="6" r="2.5" fill="#F0FF00"/><circle cx="28" cy="6" r="4" fill="#F0FF00"/><circle cx="46" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="64" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="82" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="100" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="118" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/></svg>
        <h2 class="q-text">Where do <span class="y">new clients</span> come from today?</h2>
        <p class="q-help">Select all that apply. We're looking at your acquisition mix — the channels that bring you actual new business in the last 90 days.</p>
        <div class="q2-split">
          <div class="multiselect-grid" data-multi="leadSources">
            <button class="ms-card" data-value="referrals">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <circle cx="6" cy="16" r="2.6"/>
                <circle cx="16" cy="6" r="2.6"/>
                <circle cx="26" cy="16" r="2.6"/>
                <circle cx="16" cy="26" r="2.6"/>
                <path d="M8.2 14 L13.6 8.4 M18.4 8.4 L23.8 14 M23.8 18 L18.4 23.6 M13.6 23.6 L8.2 18" class="hair"/>
                <circle cx="16" cy="16" r="1.6" class="verdict"/>
              </svg>
              <div class="ms-card-title">Referrals &amp; word-of-mouth</div>
              <div class="ms-card-sub">Past clients, neighbors, partners</div>
              <div class="ms-card-tag">Hardest to scale · slowest growth lever</div>
            </button>
            <button class="ms-card" data-value="google-organic">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <path d="M16 28 C10 22 7 17 7 13 a9 9 0 0 1 18 0 c0 4 -3 9 -9 15 Z"/>
                <circle cx="16" cy="13" r="3.6" class="hair"/>
                <circle cx="16" cy="13" r="1.6" class="verdict"/>
              </svg>
              <div class="ms-card-title">Local search (organic)</div>
              <div class="ms-card-sub">Map visibility, SEO, business profile strength</div>
              <div class="ms-card-tag">Slow to build · sticky once won</div>
            </button>
            <button class="ms-card" data-value="paid-ads">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <path d="M6 26 L26 6"/>
                <path d="M16 6 L26 6 L26 16"/>
                <path d="M11 23 L19 15" class="hair"/>
                <circle cx="26" cy="6" r="2.6" class="verdict-glow"/>
                <circle cx="26" cy="6" r="1.4" class="verdict"/>
              </svg>
              <div class="ms-card-title">Paid ads</div>
              <div class="ms-card-sub">Search, social, and video campaigns</div>
              <div class="ms-card-tag">Fastest scale · biggest spend exposure</div>
            </button>
            <button class="ms-card" data-value="social">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <path d="M4 8 H18 V18 H10 L6 22 V18 H4 Z"/>
                <path d="M14 14 H28 V22 H22 L26 26 V22" class="hair"/>
                <circle cx="11" cy="13" r="1.2" class="verdict"/>
              </svg>
              <div class="ms-card-title">Social content</div>
              <div class="ms-card-sub">Organic posts, video, community</div>
              <div class="ms-card-tag">Brand lift · attribution-blind</div>
            </button>
            <button class="ms-card" data-value="cold-outreach">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <path d="M6 6 H11 L13 11 L10 14 C12 18 14 20 18 22 L21 19 L26 21 V26 H22 C13 26 6 19 6 10 Z"/>
                <circle cx="22" cy="8" r="2.4" class="verdict-glow"/>
                <circle cx="22" cy="8" r="1.3" class="verdict"/>
              </svg>
              <div class="ms-card-title">Cold outreach</div>
              <div class="ms-card-sub">Door-knocking, calls, email lists</div>
              <div class="ms-card-tag">Predictable · operationally heavy</div>
            </button>
            <button class="ms-card" data-value="unsure">
              <div class="ms-card-checkbox"></div>
              <svg class="ms-card-icon" viewBox="0 0 32 32" aria-hidden="true">
                <circle cx="16" cy="16" r="11"/>
                <path d="M12 13 a4 4 0 0 1 8 0 c0 3 -4 3 -4 6"/>
                <circle cx="16" cy="22" r="1.3" class="verdict"/>
              </svg>
              <div class="ms-card-title">Honestly? Not sure.</div>
              <div class="ms-card-sub">No tracking, can't attribute</div>
              <div class="ms-card-tag">Attribution gap · we install the layer</div>
            </button>
          </div>

          <aside class="q2-aside" aria-label="Live acquisition-mix readout">
            <span class="q2-aside-eyebrow">Your Acquisition Mix · Live</span>
            <svg class="q2-donut" id="q2-donut" viewBox="0 0 200 200" aria-hidden="true">
              <circle class="donut-arc" data-channel="referrals"      cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(-116 100 100)"/>
              <circle class="donut-arc" data-channel="google-organic" cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(-56 100 100)"/>
              <circle class="donut-arc" data-channel="paid-ads"       cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(4 100 100)"/>
              <circle class="donut-arc" data-channel="social"         cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(64 100 100)"/>
              <circle class="donut-arc" data-channel="cold-outreach"  cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(124 100 100)"/>
              <circle class="donut-arc" data-channel="unsure"         cx="100" cy="100" r="65" stroke-dasharray="63.5 408.4" transform="rotate(184 100 100)"/>
              <text class="donut-count" id="q2-donut-count" x="100" y="108" text-anchor="middle">0</text>
              <text class="donut-count-label" x="100" y="130" text-anchor="middle">CHANNELS</text>
            </svg>
            <div class="q2-diagnostic" id="q2-diagnostic">
              <div class="diagnostic-headline idle" id="q2-diag-headline">—</div>
              <div class="diagnostic-sub" id="q2-diag-sub">Pick all that apply</div>
            </div>
          </aside>
        </div>
        <div class="q-nav">
          <button class="q-nav-back" data-back="q1">← Back</button>
          <button class="q-nav-next" id="next-q2" data-next="q3" disabled>Next →</button>
        </div>
      </div>
    </section>

    <section class="screen screen-q3 q-screen">
      <div class="container">
        <div class="q-eyebrow">
          <span class="q-eyebrow-num">/03</span>
          <span class="q-eyebrow-sep">·</span>
          <span class="q-eyebrow-cat">Scale</span>
        </div>
        <!-- @r020:F3 cta-pull: step-progress dots show how close the reveal is — momentum pulls completion -->
        <svg class="q-progress" viewBox="0 0 136 12" width="136" height="12" role="img" aria-label="Question 3 of 7"><circle cx="10" cy="6" r="2.5" fill="#F0FF00"/><circle cx="28" cy="6" r="2.5" fill="#F0FF00"/><circle cx="46" cy="6" r="4" fill="#F0FF00"/><circle cx="64" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="82" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="100" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/><circle cx="118" cy="6" r="2.5" fill="rgba(168,162,152,0.35)"/></svg>
        <h2 class="q-text">What's your <span class="y">current monthly revenue</span>?</h2>
        <p class="q-help">Pick the range you're trending in. This tells us where the system needs to plug in — you don't need to be precise.</p>
        <div class="slider-block">
          <div class="slider-readout" id="revenue-readout">Pick A Range</div>
          <div class="slider-readout-label">Monthly Recurring Revenue</div>
          <div class="slider-track" id="revenueSlider">
            <div class="slider-line">
              <div class="slider-line-fill" id="revenue-fill" style="width: 0%;"></div>
            </div>
            <button type="button" class="slider-snap" data-value="1" data-label="&lt; $10K" aria-label="Revenue range < $10K" aria-pressed="false" style="left: 0%;">
              <span class="slider-snap-label">&lt; $10K</span>
            </button>
            <button type="button" class="slider-snap" data-value="2" data-label="$10–25K" aria-label="Revenue range $10–25K" aria-pressed="false" style="left: 16.66%;">
              <span class="slider-snap-label">$10–25K</span>
            </button>
            <button type="button" class="slider-snap" data-value="3" data-label="$25–50K" aria-label="Revenue range $25–50K" aria-pressed="false" style="left: 33.33%;">
              <span class="slider-snap-label">$25–50K</span>
            </button>
            <button type="button" class="slider-snap" data-value="4" data-label="$50–100K" aria-label="Revenue range $50–100K" aria-pressed="false" style="left: 50%;">
              <span class="slider-snap-label">$50–100K</span>
            </button>
