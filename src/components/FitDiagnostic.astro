    .chip-icon {
      width: 40px; height: 40px;
      stroke: var(--y2); stroke-width: 1.3; fill: none;
      stroke-linecap: round; stroke-linejoin: round;
      transition: transform .25s cubic-bezier(.2,.7,.3,1);
