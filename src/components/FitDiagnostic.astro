    /* On mobile the centered end-labels (< $10K / $500K+) overflow the track edges and
       get clipped by body overflow-x:hidden. Anchor the first label left, the last
       right, and shrink slightly so both stay on screen. */
    @media (max-width: 640px) {
      .slider-snap-label { font-size: 9px; letter-spacing: 0.06em; }
      .slider-snap[data-value="1"] .slider-snap-label { left: 0; transform: none; }
