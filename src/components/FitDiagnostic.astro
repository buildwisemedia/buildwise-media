<script is:inline>
// ============ STATE ============
    const state = {
      service: null,
      leadSources: [],
      revenue: null,
      revenueLabel: null,
      opsRatio: null,
      bottleneck: null,
      capacityGaps: [],
      target: { revenue: '', team: '', hours: '' }
    };

    const SERVICE_LABEL = {
      hvac: 'HVAC', roofing: 'Roofing', plumbing: 'Plumbing',
      pest: 'Pest Control', realtor: 'Real Estate', concrete: 'Concrete',
      cleaning: 'Cleaning', other: 'Service Business'
    };
    const BOTTLENECK_LABEL = {
      leads: 'Lead Volume', quality: 'Lead Quality', capacity: 'Delivery Capacity',
      speed: 'Response Speed', conversion: 'Conversion'
    };
    const LEAD_SOURCE_LABEL = {
      referrals: 'Referrals', 'google-organic': 'Local Search',
      'paid-ads': 'Paid Ads', social: 'Social', 'cold-outreach': 'Cold Outreach', unsure: 'Untracked'
    };

    // ============ NAVIGATION ============
    function goTo(screen) {
      document.body.dataset.screen = screen;
      var ann = document.getElementById('screen-announce'); if (ann) ann.textContent = screen === 'reveal' ? 'Your results are ready.' : (screen === 'welcome' ? '' : 'Question ' + screen.replace('q','') + ' of 7.');
      // Keep the visitor inside the diagnostic on each step. The diagnostic is
      // embedded at the bottom of a long landing page, so scrolling the window
      // to the very top (the old behavior) teleported them up to the page hero.
      const diag = document.getElementById('diagnostic');
      if (diag) {
        const header = document.querySelector('.site-header');
        const offset = header ? header.getBoundingClientRect().height : 0;
        const top = diag.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: top, behavior: 'instant' });
      } else {
        window.scrollTo({ top: 0, behavior: 'instant' });
      }
      updateProgress(screen);
    }

    const SCREEN_CATEGORIES = {
      q1: { num: '01', cat: 'Service' }, q2: { num: '02', cat: 'Acquisition' },
      q3: { num: '03', cat: 'Scale' },   q4: { num: '04', cat: 'Time' },
      q5: { num: '05', cat: 'Bottleneck' }, q6: { num: '06', cat: 'Constraints' },
      q7: { num: '07', cat: 'Vision' }
    };

    function updateProgress(screen) {
      const progress = document.getElementById('progress');
      if (screen.startsWith('q')) {
        progress.style.display = 'flex';
        const meta = SCREEN_CATEGORIES[screen];
        if (meta) {
          document.getElementById('q-current').textContent = meta.num;
          document.getElementById('q-cat').textContent = meta.cat;
        }
        const qNum = parseInt((meta && meta.num) || '01', 10);
        document.getElementById('vtx-1').setAttribute('fill', qNum >= 2 ? '#F0FF00' : 'none');
        document.getElementById('vtx-2').setAttribute('fill', qNum >= 4 ? '#F0FF00' : 'none');
        document.getElementById('vtx-3').setAttribute('fill', qNum >= 6 ? '#F0FF00' : 'none');
      } else {
        progress.style.display = 'none';
      }
    }

    // ============ ANSWER HANDLERS ============
    document.querySelectorAll('[data-single]').forEach(grid => {
      const key = grid.dataset.single;
      grid.querySelectorAll('button[data-value]').forEach(btn => {
        btn.addEventListener('click', () => {
          state[key] = btn.dataset.value;
          grid.querySelectorAll('button[data-value]').forEach(b => { b.classList.remove('selected'); b.setAttribute('aria-pressed','false'); });
          btn.classList.add('selected');
          btn.setAttribute('aria-pressed','true');
          const screen = document.body.dataset.screen;
          const nextBtn = document.getElementById('next-' + screen);
          if (nextBtn) nextBtn.disabled = false;
        });
      });
    });

    document.querySelectorAll('[data-multi]').forEach(grid => {
      const key = grid.dataset.multi;
      grid.querySelectorAll('button[data-value]').forEach(btn => {
        btn.addEventListener('click', () => {
          const arr = state[key];
          const val = btn.dataset.value;
          const idx = arr.indexOf(val);
          if (idx >= 0) { arr.splice(idx, 1); btn.classList.remove('selected'); btn.setAttribute('aria-pressed','false'); }
          else { arr.push(val); btn.classList.add('selected'); btn.setAttribute('aria-pressed','true'); }
          const screen = document.body.dataset.screen;
          const nextBtn = document.getElementById('next-' + screen);
          // Q6 (capacityGaps) is optional tailoring input — scoring handles an empty
          // array — so a user who'd pick nothing isn't trapped with Next disabled.
          if (nextBtn) nextBtn.disabled = grid.hasAttribute('data-optional') ? false : arr.length === 0;
          if (key === 'leadSources' && typeof renderQ2Donut === 'function') renderQ2Donut();
        });
      });
    });

    // /02 — Live acquisition-mix donut + diagnostic readout (R020 F2 Proof + F3 CTA-Pull)
    const renderQ2Donut = (function() {
      const donut = document.getElementById('q2-donut');
      if (!donut) return function(){};
      const countEl = document.getElementById('q2-donut-count');
      const headlineEl = document.getElementById('q2-diag-headline');
      const subEl = document.getElementById('q2-diag-sub');
      const arcs = donut.querySelectorAll('[data-channel]');
      return function() {
        const sel = state.leadSources || [];
        arcs.forEach(a => {
          if (sel.indexOf(a.dataset.channel) >= 0) a.classList.add('active');
          else a.classList.remove('active');
        });
        if (countEl) countEl.textContent = sel.length;
        if (!headlineEl || !subEl) return;
        const onlyUnsure = sel.length === 1 && sel[0] === 'unsure';
        let h, s;
        if (sel.length === 0)               { h = '—';                       s = 'Pick all that apply'; headlineEl.classList.add('idle'); }
        else if (onlyUnsure)                { h = 'Attribution gap';         s = 'No tracking layer · we install one'; headlineEl.classList.remove('idle'); }
        else if (sel.length === 1)          { h = 'Single-channel risk';     s = '100% dependency on one source'; headlineEl.classList.remove('idle'); }
        else if (sel.length === 2)          { h = 'Light diversification';   s = 'Two channels in motion'; headlineEl.classList.remove('idle'); }
        else if (sel.length === 3)          { h = 'Healthy mix forming';     s = 'Three active acquisition lanes'; headlineEl.classList.remove('idle'); }
        else                                { h = 'Diversified mix';         s = 'Attribution gap likely · we untangle it'; headlineEl.classList.remove('idle'); }
        headlineEl.textContent = h;
        subEl.textContent = s;
      };
    })();
    renderQ2Donut();
    document.querySelectorAll('[data-single] button[data-value], [data-multi] button[data-value]').forEach(b => b.setAttribute('aria-pressed','false'));

    document.querySelectorAll('#revenueSlider .slider-snap').forEach(snap => {
      snap.addEventListener('click', () => {
        const value = parseInt(snap.dataset.value, 10);
        state.revenue = value;
        state.revenueLabel = snap.dataset.label;
        document.querySelectorAll('#revenueSlider .slider-snap').forEach(s => { s.classList.remove('active'); s.setAttribute('aria-pressed','false'); });
        snap.classList.add('active');
        snap.setAttribute('aria-pressed','true');
        const pct = ((value - 1) / 6) * 100;
        document.getElementById('revenue-fill').style.width = pct + '%';
        document.getElementById('revenue-readout').textContent = snap.dataset.label + '/mo';
        document.getElementById('next-q3').disabled = false;
      });
    });

    document.querySelectorAll('[data-split-buttons] button').forEach(btn => {
      btn.addEventListener('click', () => {
        const opsPct = parseInt(btn.dataset.ops, 10);
        state.opsRatio = opsPct;
        const growthPct = 100 - opsPct;
        document.getElementById('split-ops').style.width = opsPct + '%';
        document.getElementById('split-growth').style.width = growthPct + '%';
        document.getElementById('ops-pct').textContent = opsPct + '%';
        document.getElementById('growth-pct').textContent = growthPct + '%';
        document.querySelectorAll('[data-split-buttons] button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('next-q4').disabled = false;
      });
    });

    function updateTargetState() {
      state.target.revenue = document.getElementById('target-revenue').value;
      state.target.team = document.getElementById('target-team').value;
      state.target.hours = document.getElementById('target-hours').value;
      const hasAny = state.target.revenue || state.target.team || state.target.hours;
      document.getElementById('next-q7').disabled = !hasAny;
    }
    ['target-revenue', 'target-team', 'target-hours'].forEach(id => {
      document.getElementById(id).addEventListener('input', updateTargetState);
    });

    // ============ BUTTON BINDINGS ============
    document.querySelectorAll('[data-back]').forEach(btn => {
      btn.addEventListener('click', () => goTo(btn.dataset.back));
    });
    document.querySelectorAll('[data-next]').forEach(btn => {
      btn.addEventListener('click', () => goTo(btn.dataset.next));
    });
    document.querySelector('[data-action="start"]').addEventListener('click', () => goTo('q1'));
    document.querySelector('[data-action="reveal"]').addEventListener('click', computeAndReveal);

    // Initialize the diagnostic to its welcome screen on load. Without this the
    // <body> has no data-screen, every .screen stays display:none, and the
    // diagnostic renders as a blank section (only the sticky header) — the start
    // button is hidden and the visitor can never begin. No scroll here: the
    // visitor may still be reading the landing page above.
    if (!document.body.dataset.screen) {
      document.body.dataset.screen = 'welcome';
      updateProgress('welcome');
    }

    // ============ DOM HELPERS (no innerHTML) ============
    function el(tag, attrs, children) {
      const node = document.createElementNS(tag === 'svg' || tag === 'g' || tag === 'path' || tag === 'line' || tag === 'circle' || tag === 'rect' || tag === 'text'
        ? 'http://www.w3.org/2000/svg' : 'http://www.w3.org/1999/xhtml', tag);
      if (attrs) Object.keys(attrs).forEach(k => {
        if (k === 'className') node.setAttribute('class', attrs[k]);
        else if (k === 'text') node.textContent = attrs[k];
        else node.setAttribute(k, attrs[k]);
      });
      if (children) children.forEach(c => { if (c) node.appendChild(c); });
      return node;
    }
    function clearChildren(parent) {
      while (parent.firstChild) parent.removeChild(parent.firstChild);
    }

    // ============ COMPUTE + REVEAL ============
    function computeAndReveal() {
      // ---- Growth Index ----
      let revScore = 0;
      if (state.revenue >= 2) revScore = 1;
      if (state.revenue >= 4) revScore = 2;
      if (state.revenue >= 6) revScore = 3;

      let channelScore = 0;
      const hasOrganic = state.leadSources.indexOf('google-organic') >= 0;
      const hasPaid = state.leadSources.indexOf('paid-ads') >= 0;
      const hasReferral = state.leadSources.indexOf('referrals') >= 0;
      const isUntracked = state.leadSources.indexOf('unsure') >= 0;
      if ((hasOrganic || hasPaid) && hasReferral) channelScore = 2;
      else if (hasOrganic || hasPaid || hasReferral) channelScore = 1;
      if (isUntracked && state.leadSources.length === 1) channelScore = 0;

      const growthHours = 100 - (state.opsRatio || 90);
      let timeScore = 0;
      if (growthHours >= 20) timeScore = 1;
      if (growthHours >= 40) timeScore = 2;

      const targetRev = parseInt((state.target.revenue || '').replace(/[^0-9]/g, ''), 10) || 0;
      let ambitionScore = 0;
      const currentRevMid = [0, 5000, 17500, 37500, 75000, 175000, 375000, 750000][state.revenue || 1];
      if (targetRev > currentRevMid * 1.5) ambitionScore = 1;
      if (targetRev > currentRevMid * 2.5) ambitionScore = 2;

      const totalRaw = revScore + channelScore + timeScore + ambitionScore;
      const growthIndex = Math.round((totalRaw / 9) * 100);

      // ---- Verdict ----
      let verdict, verdictLabel, verdictExplainer, verdictDetail;
      const bottleneckLabel = BOTTLENECK_LABEL[state.bottleneck] || 'unknown';
      if (growthIndex >= 65) {
        verdict = 'fit'; verdictLabel = "You're A Fit.";
        verdictExplainer = "You're at the stage where an AI growth system installed correctly compounds. Revenue traction is real, you've already got channel diversity, and your target is ambitious enough that hand-rolled workflows will hold you back.";
        verdictDetail = "The system pays for itself in the first 90 days at your current revenue band. Your bottleneck (" + bottleneckLabel + ") is exactly the kind we engineer around. The next move is a 30-minute call to map your install plan.";
      } else if (growthIndex >= 35) {
        verdict = 'maybe'; verdictLabel = "Close. Three Things To Lock.";
        verdictExplainer = "You're not far. The diagnostic shows you've got real revenue traction, but one or two foundational pieces aren't dialed in yet. Lock those first, then come back — the system installs cleaner when these are in place.";
        verdictDetail = "Locking these takes most operators 60-90 days of focused work. We'll send you the exact playbook so you can move on it. When the gaps close, the diagnostic flips to Fit and we book the strategy call.";
      } else {
        verdict = 'not-yet'; verdictLabel = "Not Yet — But Here's The Map.";
        verdictExplainer = "Honest read: installing a growth system at your stage would amplify whatever's already breaking, not fix it. The foundation has to come first. We'd rather hand you the playbook than sell you a system you're not ready for.";
        verdictDetail = "Most operators in your position need 6-12 months of focused foundational work before an AI growth system is the right move. We'll send you the exact 5-step playbook tailored to your bottleneck — yours regardless of whether we ever work together.";
      }

      // ---- Populate Reveal ----
      const now = new Date();
      const pad = n => String(n).padStart(2, '0');
      const ts = pad(now.getMonth() + 1) + '/' + pad(now.getDate()) + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes());
      document.getElementById('reveal-timestamp').textContent = ts;
      document.getElementById('reveal-service').textContent = SERVICE_LABEL[state.service] || 'Your Business';

      document.getElementById('growth-index-value').textContent = growthIndex;

      document.getElementById('snap-service').textContent = SERVICE_LABEL[state.service] || '—';
      document.getElementById('snap-revenue').textContent = state.revenueLabel || '—';
      document.getElementById('snap-growth').textContent = (100 - (state.opsRatio || 90)) + '%';
      const channels = state.leadSources.map(s => LEAD_SOURCE_LABEL[s]).slice(0, 2).join(' + ');
      document.getElementById('snap-channels').textContent = channels || '—';

      // Diagnosis — populate three span slots + body text
      const DIAGNOSIS = {
        leads: {
          lead: 'Your bottleneck is ',
          y: 'lead volume',
          tail: ' — and your acquisition mix tells us why.',
          body: 'You have ' + state.leadSources.length + ' active channels but ' + (isUntracked ? 'no attribution layer' : 'no compounding asset that fills the calendar on autopilot') + '. Referrals are great when they show up — but they don\'t scale at will. Without a system that creates leads predictably (paid, organic, or both), every growth attempt feels like starting over. The fix isn\'t more activity — it\'s building the lead-generation engine that runs without you starting it each morning.'
        },
        quality: {
          lead: 'Your bottleneck is ',
          y: 'lead quality',
          tail: ' — the funnel is leaking before the call.',
          body: 'You\'re getting leads, but the ones reaching you aren\'t pre-qualified. This is a positioning + filtering problem, not a volume problem. Most service businesses solve this by adding more leads on top, which makes the problem worse. The right move is an upstream qualifier (positioning, pricing display, ICP-tight ad targeting) that filters out the wrong people before they consume your calendar.'
        },
        capacity: {
          lead: 'Your bottleneck is ',
          y: 'delivery capacity',
          tail: ' — growth would amplify a structural ceiling.',
          body: 'You\'re already at or near the ceiling of what your crew/schedule can absorb. Adding leads without expanding capacity just turns leads into lost-revenue rage. The system has to solve delivery alongside acquisition — productized scope, dispatch automation, and crew-augmentation patterns. Otherwise the diagnostic becomes the disease.'
        },
        speed: {
          lead: 'Your bottleneck is ',
          y: 'response speed',
          tail: ' — and that\'s the most fixable one.',
          body: 'Leads come in, they go cold before you reach them. Studies show response in under 5 minutes converts at 4-9x the rate of response after 30 minutes. This is the highest-leverage fix in your funnel — automated triage, instant-callback workflows, and AI-first-touch can lift your close-rate without changing anything upstream. Often the cheapest win in the whole system.'
        },
        conversion: {
          lead: 'Your bottleneck is ',
          y: 'conversion',
          tail: ' — the lead reaches you, then doesn\'t close.',
          body: 'You\'ve got volume + speed dialed, but close-rate is below where it should be for your service category. This is usually a sales-system problem, not a sales-skill problem. Standardized discovery, structured proposals, follow-up sequences, and objection-handling automations close the gap. The good news: every percentage point of close-rate compounds on existing traffic. No new leads needed.'
        }
      };
      const diag = DIAGNOSIS[state.bottleneck] || DIAGNOSIS.leads;
      document.getElementById('diagnosis-title-lead').textContent = diag.lead;
      document.getElementById('diagnosis-title-bottleneck').textContent = diag.y;
      document.getElementById('diagnosis-title-tail').textContent = diag.tail;
      document.getElementById('diagnosis-body').textContent = diag.body;

      // System modules
      const tailored = state.bottleneck;
      const cap = state.capacityGaps;
      const modules = [
        { title: 'Lead Generation Engine', body: 'Multi-channel intake — paid + organic + referral — funnel-tagged with UTM attribution to every channel.', tailored: tailored === 'leads' },
        { title: 'Lead Qualifier (Diagnostic)', body: 'Front-door qualifier that filters out price-shoppers and routes by ICP fit before consuming your calendar.', tailored: tailored === 'quality' },
        { title: 'Instant-Response Workflow', body: 'AI-first-touch + escalation. New leads get a meaningful reply in under 60 seconds — even on weekends.', tailored: tailored === 'speed' },
        { title: 'Sales Conversion Stack', body: 'Standardized discovery, structured proposals, automated follow-up sequences. Close-rate compounds on existing traffic.', tailored: tailored === 'conversion' },
        { title: 'Delivery Capacity Layer', body: 'Productized scope + dispatch automation + crew assignment. Volume scales without quality drift.', tailored: tailored === 'capacity' || cap.indexOf('ops-dispatch') >= 0 || cap.indexOf('quality') >= 0 },
        { title: 'Attribution + Dashboards', body: 'Every lead, every dollar, every channel — traced back to source with weekly reporting you actually read.', tailored: state.leadSources.indexOf('unsure') >= 0 }
      ];
      const systemGrid = document.getElementById('system-grid');
      clearChildren(systemGrid);
      modules.forEach((m, i) => {
        const card = document.createElement('div');
        card.className = 'system-module' + (m.tailored ? ' tailored' : '');
        const num = document.createElement('div');
        num.className = 'system-module-num';
        const dot = document.createElement('span');
        dot.className = m.tailored ? 'verdict-dot-sm' : 'verdict-dot-hollow';
        num.appendChild(dot);
        num.appendChild(document.createTextNode(' Module ' + pad(i + 1)));
