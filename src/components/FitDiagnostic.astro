    /* hover icon nudge removed 2026-06-11 (R017 System A — hover is color
       shift only); .selected keeps the nudge (click = explicit gesture). */
    .chip.selected .chip-icon { transform: translate(0, -2px); }
    .chip.selected .chip-icon .verdict { filter: drop-shadow(0 0 6px var(--y2-glow)); }
    .chip-label { font-weight: 600; font-size: 17px; letter-spacing: -0.008em; }
