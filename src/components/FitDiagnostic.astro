<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* Diagnostic-specific tokens scoped to #diagnostic so they don't leak.
       Flagship global.css provides the canonical --bg / --y2 / --ink / --rule tokens
       (--y2: #F0FF00). The original ported :root block redefined --y2 to #c0c0a8
       which broke the MoHero brand accent — root-cause fix 2026-05-20. */
    .q-progress { display:block; margin: 6px 0 14px; }
  #diagnostic {
      --bg-lift: var(--bg-elev);
      --bg-deep: #050507;
      --y2-glow: rgba(240, 255, 0, 0.45);
      --y2-dim: rgba(240, 255, 0, 0.62);
      --y2-shade: rgba(240, 255, 0, 0.08);
      --ink-dimmest: var(--ink-faint);
    }

    @media (prefers-reduced-motion: no-preference) {
      html { scroll-behavior: smooth; }
    }
    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      line-height: 1.5;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
    }
    body::before {
      content: ""; position: fixed; inset: 0; pointer-events: none;
      background-image:
        radial-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        radial-gradient(rgba(240,255,0,0.012) 1px, transparent 1px);
      background-size: 3px 3px, 7px 7px;
      background-position: 0 0, 1px 1px;
      z-index: 1; mix-blend-mode: overlay;
    }
    body::after {
      content: ""; position: fixed; top: -300px; right: -300px;
      width: 800px; height: 800px;
      background: radial-gradient(circle, rgba(240, 255, 0, 0.07) 0%, transparent 60%);
      pointer-events: none; z-index: 0; transition: opacity 1s ease;
    }
    main, header, footer { position: relative; z-index: 2; }

    .container { max-width: 1320px; margin: 0 auto; padding: 0 48px; }
    .container-narrow { max-width: 880px; margin: 0 auto; padding: 0 48px; }

    .mono-eyebrow {
      font-family: 'JetBrains Mono', monospace; font-weight: 500;
      font-size: 11px; letter-spacing: 0.20em; text-transform: uppercase;
      color: var(--y2-dim);
    }
    .label-micro {
      font-family: 'JetBrains Mono', monospace; font-weight: 400;
      font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--ink-faint);
    }

    .verdict-dot {
      display: inline-block; width: 9px; height: 9px;
      border-radius: 50%; background: var(--y2);
      box-shadow: 0 0 14px var(--y2-glow);
      vertical-align: middle; flex-shrink: 0;
    }
    .verdict-dot-sm {
      display: inline-block; width: 6px; height: 6px;
      border-radius: 50%; background: var(--y2);
      box-shadow: 0 0 8px var(--y2-glow);
      vertical-align: middle; flex-shrink: 0;
    }
    .verdict-dot-hollow {
      display: inline-block; width: 8px; height: 8px;
      border-radius: 50%; border: 1px solid var(--y2);
      vertical-align: middle; flex-shrink: 0;
    }

    .doc-header {
      /* Hidden: this component embeds inside BaseLayout, which already renders the
         fixed site header. The doc-header duplicated the BWM lockup right under it
         (a redundant second header), and its 01/07 progress is already shown by each
         question's eyebrow (/01 · Service) + step-dot SVG. */
      display: none;
      padding: 24px 0; border-bottom: 1px solid var(--rule);
      position: sticky; top: 0;
      background: rgba(5, 5, 7, 0.88);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      z-index: 50;
    }
    .doc-header-inner {
      display: flex; justify-content: space-between;
      align-items: center; gap: 32px;
    }
    .doc-mark { display: flex; align-items: center; gap: 14px; }
    .doc-mark-glyph { width: 28px; height: 28px; }
    .doc-mark-text {
      font-family: 'Inter', sans-serif; font-weight: 800;
      font-size: 13px; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--ink);
    }
    .doc-mark-separator { width: 1px; height: 16px; background: var(--rule-bright); }
    .doc-mark-tag {
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-faint);
    }

    .progress-mark { display: flex; align-items: center; gap: 14px; }
    .progress-mark svg { width: 36px; height: 36px; }
    .progress-mark-label {
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
      letter-spacing: 0.16em; color: var(--ink-dim); text-transform: uppercase;
    }
    .progress-mark-label .current { color: var(--y2); }

    .screen { display: none; }

    /* The host page's global.css applies `section { padding-block: var(--section-y) }`
       to every <section>. This component manages its own spacing (welcome-hero,
       .q-screen, .reveal-* all set their own padding), so the global rule stacks an
       extra ~112px onto each un-self-padded wrapper — the outer #diagnostic section
       and the welcome/reveal screens — producing ~310px of dead space at the top of
       the welcome. Neutralize it only on those wrappers; the self-padded screens
       (.q-screen, .reveal-section, etc.) keep their own padding via higher specificity. */
    #diagnostic { padding-block: 0; }
    .screen-welcome, .screen-reveal { padding-block: 0; }

    body[data-screen="welcome"] .screen-welcome,
    body[data-screen="q1"] .screen-q1,
    body[data-screen="q2"] .screen-q2,
