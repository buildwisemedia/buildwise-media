    function drawProjection(state) {
      const NS = 'http://www.w3.org/2000/svg';
      const svg = document.getElementById('projection-svg');
      clearChildren(svg);

      const currentRev = [0, 5000, 17500, 37500, 75000, 175000, 375000, 750000][state.revenue || 1];
      const targetRev = parseInt((state.target.revenue || '').replace(/[^0-9]/g, ''), 10) || currentRev * 2;

      const months = 12;
      const w = 1200, h = 420;
      const padX = 80, padY = 60;
      const innerW = w - padX * 2, innerH = h - padY * 2;
      const currentEnd = currentRev * 1.08;
      const systemEnd = Math.max(targetRev, currentRev * 2);
      const maxRev = systemEnd * 1.1;

      const xAt = m => padX + (m / months) * innerW;
      const yAt = r => padY + innerH - (r / maxRev) * innerH;

      const mkNS = (tag, attrs) => {
        const n = document.createElementNS(NS, tag);
        Object.keys(attrs).forEach(k => n.setAttribute(k, attrs[k]));
        return n;
      };
      const mkText = (x, y, content, attrs) => {
        const n = mkNS('text', Object.assign({ x: x, y: y }, attrs));
        n.textContent = content;
        return n;
      };

      // Gridlines + revenue labels
      for (let i = 0; i <= 4; i++) {
        const r = (maxRev / 4) * i;
        const y = yAt(r);
        svg.appendChild(mkNS('line', { x1: padX, y1: y, x2: w - padX, y2: y, stroke: 'rgba(240,255,0,0.06)', 'stroke-width': '1' }));
        svg.appendChild(mkText(padX - 12, y + 4, '$' + (r / 1000).toFixed(0) + 'K',
          { fill: '#5e5e66', 'font-family': 'JetBrains Mono', 'font-size': '10', 'text-anchor': 'end' }));
      }

      // Month labels
      for (let m = 0; m <= 12; m += 3) {
        svg.appendChild(mkText(xAt(m), h - 20, 'M' + pad(m),
          { fill: '#5e5e66', 'font-family': 'JetBrains Mono', 'font-size': '11', 'letter-spacing': '2', 'text-anchor': 'middle' }));
      }

      // Current trajectory
      let currentPath = 'M ' + xAt(0) + ' ' + yAt(currentRev);
      for (let m = 1; m <= months; m++) {
        const r = currentRev * (1 + (m / 12) * 0.08);
        currentPath += ' L ' + xAt(m) + ' ' + yAt(r);
      }

      // System trajectory (S-curve)
      let systemPath = 'M ' + xAt(0) + ' ' + yAt(currentRev);
      for (let m = 1; m <= months; m++) {
        const t = m / months;
        const sCurve = 1 / (1 + Math.exp(-8 * (t - 0.5)));
        const r = currentRev + (systemEnd - currentRev) * sCurve;
        systemPath += ' L ' + xAt(m) + ' ' + yAt(r);
      }

      // Gap shaded region
      let gapPath = 'M ' + xAt(0) + ' ' + yAt(currentRev) + ' L ' + xAt(months) + ' ' + yAt(currentEnd) + ' L ' + xAt(months) + ' ' + yAt(systemEnd);
      for (let m = months; m >= 0; m--) {
        const t = m / months;
        const sCurve = 1 / (1 + Math.exp(-8 * (t - 0.5)));
        const r = currentRev + (systemEnd - currentRev) * sCurve;
        gapPath += ' L ' + xAt(m) + ' ' + yAt(r);
      }
      gapPath += ' Z';
      svg.appendChild(mkNS('path', { d: gapPath, fill: 'rgba(240,255,0,0.06)' }));

      // Current line (dashed)
      svg.appendChild(mkNS('path', { d: currentPath, fill: 'none', stroke: '#9a9aa3', 'stroke-width': '2', 'stroke-dasharray': '4 4' }));
      // System line (glowing Y2)
      svg.appendChild(mkNS('path', { d: systemPath, fill: 'none', stroke: '#F0FF00', 'stroke-width': '3', filter: 'drop-shadow(0 0 8px rgba(240,255,0,0.4))' }));

      // End-point dots
      svg.appendChild(mkNS('circle', { cx: xAt(months), cy: yAt(currentEnd), r: '6', fill: '#9a9aa3' }));
      svg.appendChild(mkNS('circle', { cx: xAt(months), cy: yAt(systemEnd), r: '8', fill: '#F0FF00', filter: 'drop-shadow(0 0 8px rgba(240,255,0,0.6))' }));

      // Annotations
      svg.appendChild(mkText(xAt(months) - 16, yAt(systemEnd) - 16, '$' + (systemEnd / 1000).toFixed(0) + 'K/mo',
        { fill: '#F0FF00', 'font-family': 'Inter', 'font-weight': '700', 'font-size': '22', 'text-anchor': 'end' }));
      svg.appendChild(mkText(xAt(months) - 16, yAt(currentEnd) + 24, '$' + (currentEnd / 1000).toFixed(0) + 'K/mo',
        { fill: '#9a9aa3', 'font-family': 'JetBrains Mono', 'font-size': '12', 'text-anchor': 'end' }));
    }

    function renderPath(verdict, state) {
      const pathTitleLead = document.getElementById('path-title-lead');
      const pathTitleY = document.getElementById('path-title-y');
      const pathTitleTail = document.getElementById('path-title-tail');
      const pathBody = document.getElementById('path-body');
      const pathList = document.getElementById('path-list');
      const pathCta = document.getElementById('path-cta-block');

      clearChildren(pathList);
      clearChildren(pathCta);

      const mkListItem = (num, text, strongs) => {
        const item = document.createElement('div');
        item.className = 'path-list-item';
        const numEl = document.createElement('span');
        numEl.className = 'path-list-num';
        numEl.textContent = pad(num);
        const textEl = document.createElement('span');
        textEl.className = 'path-list-text';
        // strongs is array of [strongText, restText] pairs OR a single string
        if (typeof text === 'string') {
          textEl.textContent = text;
        } else {
          text.forEach(segment => {
            if (segment.strong) {
              const s = document.createElement('strong');
              s.textContent = segment.strong;
              textEl.appendChild(s);
            }
            if (segment.text) {
              textEl.appendChild(document.createTextNode(segment.text));
            }
          });
        }
        item.appendChild(numEl);
        item.appendChild(textEl);
        return item;
      };

      const mkCtaForm = (placeholder, btnText) => {
        const form = document.createElement('form');
        form.className = 'path-cta-form';
        form.addEventListener('submit', e => e.preventDefault());
        const input = document.createElement('input');
        input.type = 'email';
        input.className = 'path-cta-input';
        input.placeholder = placeholder;
        const btn = document.createElement('button');
        btn.className = 'path-cta-btn';
        btn.textContent = btnText;
        form.appendChild(input);
        form.appendChild(btn);
        return form;
      };

      const mkCtaBlock = (eyebrow, title, body, formOrLink) => {
        const e = document.createElement('div');
        e.className = 'path-cta-eyebrow';
        e.textContent = eyebrow;
        const t = document.createElement('h3');
        t.className = 'path-cta-title';
        t.textContent = title;
        const b = document.createElement('p');
        b.className = 'path-cta-body';
        b.textContent = body;
        pathCta.appendChild(e);
        pathCta.appendChild(t);
        pathCta.appendChild(b);
        pathCta.appendChild(formOrLink);
      };

      if (verdict === 'fit') {
        pathTitleLead.textContent = 'Let\'s ';
        pathTitleY.textContent = 'build your install plan';
        pathTitleTail.textContent = '.';
        pathBody.textContent = 'Book a 30-minute strategy call. We\'ll walk through your diagnostic, map the exact modules to your business, and put a 90-day install timeline on the table.';
        pathList.appendChild(mkListItem(1, [{ strong: '30 minutes' }, { text: ' — walk through your diagnostic together' }]));
        pathList.appendChild(mkListItem(2, [{ strong: 'Tailored install plan' }, { text: ' — modules, sequence, 90-day milestones' }]));
        pathList.appendChild(mkListItem(3, [{ strong: 'Honest go/no-go' }, { text: " — if it's not the right fit on the call, we'll tell you" }]));
        const link = document.createElement('a');
        link.href = '/book';
        link.className = 'cta-primary';
        link.style.display = 'inline-flex';
        link.style.padding = '18px 28px';
        link.style.fontSize = '15px';
        link.appendChild(document.createTextNode('Book The Call '));
        const arrow = document.createElement('span');
        arrow.className = 'arrow';
        arrow.textContent = '→';
        link.appendChild(arrow);
        mkCtaBlock('Book Your Strategy Call', "Pick a time. We'll see you there.",
          'Direct link to the team\'s calendar. No discovery questionnaire — we already have your diagnostic.', link);
      } else if (verdict === 'maybe') {
        pathTitleLead.textContent = 'Three ';
        pathTitleY.textContent = 'foundation moves';
        pathTitleTail.textContent = ' would lock you in.';
        pathBody.textContent = 'Below are the gaps the diagnostic surfaced. Most operators close these in 60-90 days. When they\'re locked, come back — we\'ll re-diagnose for free.';
        const fixes = [];
        if (state.leadSources.indexOf('google-organic') < 0 && state.leadSources.indexOf('paid-ads') < 0) {
          fixes.push([{ strong: 'Lock one paid + one organic channel.' }, { text: ' Even at a small budget, dual-channel traction signals system-readiness.' }]);
        }
        if ((100 - state.opsRatio) < 20) {
          fixes.push([{ strong: 'Reclaim 8 hours/week for growth work.' }, { text: " Delegate or systematize 2 things you're still doing yourself." }]);
        }
        if (state.leadSources.indexOf('unsure') >= 0) {
          fixes.push([{ strong: 'Install basic attribution.' }, { text: ' Even a spreadsheet — every lead, source, status. The data unlocks every other move.' }]);
        }
        if (state.revenue < 3) {
          fixes.push([{ strong: 'Get to $25K/mo first.' }, { text: ' Below that, foundational distribution matters more than a system.' }]);
        }
        const fallbackFixes = [
          [{ strong: 'Document your current sales process.' }, { text: ' Even a 1-pager. The system needs something to standardize.' }],
          [{ strong: 'Write down who your best client is.' }, { text: ' One paragraph. It tells the system who to chase and who to filter.' }],
          [{ strong: 'Use the same follow-up for every lead.' }, { text: ' Pick one sequence and run it every time, so we have a baseline to beat.' }]
        ];
        let fbi = 0;
        while (fixes.length < 3) {
          fixes.push(fallbackFixes[fbi++ % fallbackFixes.length]);
        }
        fixes.slice(0, 3).forEach((f, i) => pathList.appendChild(mkListItem(i + 1, f)));
        mkCtaBlock('Get The Playbook', 'Send me the foundation playbook.',
          '90-day playbook tailored to your gaps. We\'ll check in at day 90 to re-diagnose.',
          mkCtaForm('your@email.com', 'Send It →'));
      } else {
        pathTitleLead.textContent = 'Here\'s the ';
        pathTitleY.textContent = 'exact playbook';
        pathTitleTail.textContent = ' to get ready.';
        pathBody.textContent = "You're not ready for a system installation — yet. Below is the 5-step sequence that gets you there. Most operators take 6-12 months. We'll send the playbook, you do the work, we re-diagnose when you're ready.";
        const steps = [
          [{ strong: 'Distribution before automation.' }, { text: ' Get to consistent $15-25K/mo via referrals + 1 channel.' }],
          [{ strong: 'One pricing model, one offer.' }, { text: ' Stop bidding ad-hoc. Productize one core service.' }],
          [{ strong: 'Track every lead.' }, { text: ' Even on paper. The data unlocks the next move.' }],
          [{ strong: 'Free 10 hours/week.' }, { text: ' Delegate or systematize. System-readiness requires capacity.' }],
          [{ strong: 'Come back when 1–4 are done.' }, { text: " The diagnostic flips. We'll install then." }]
        ];
        steps.forEach((s, i) => pathList.appendChild(mkListItem(i + 1, s)));
        mkCtaBlock('Yours Regardless', 'Send me the playbook.',
          'Tailored 5-step playbook for your service category + bottleneck. No follow-up sales. We\'ll check in at month 6.',
          mkCtaForm('your@email.com', 'Send It →'));
      }
    }

    function pad(n) { return String(n).padStart(2, '0'); }

// ============ BWM SUBMIT HANDLER (added 2026-05-20 — Mo' Money funnel build) ============
// On reveal screen entry: POST state to bwm-form-handler /buildwisemedia/fit-diagnostic
// Verdict routing: FIT (>=65) reveals the inline booking calendar; MAYBE (35-64) shows ack screen;
// NO (<35) redirects to /thank-you-resource?reason=fit_check.
// Email is OPTIONAL — diagnostic promise "The reveal is yours regardless" preserved.

(function bwmDiagnosticSubmit(){
  let submitted = false;
  let revealRendered = false;
  let generateLeadSent = false;

  function event(name, params, opts) {
    try {
      let trackingPayload = Object.assign({}, params || {});
      if (typeof window.__bwmGetAttributionPayload === "function") {
        trackingPayload = Object.assign(window.__bwmGetAttributionPayload(), trackingPayload);
      }
      if (typeof window.__bwmTrackEvent === "function") {
        window.__bwmTrackEvent(name, trackingPayload, opts || {});
        return;
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(Object.assign({ event: name }, trackingPayload));
      window.gtag?.("event", name, Object.assign({ transport_type: "beacon" }, trackingPayload));
    } catch (_e) {}
  }

  function addIfPresent(target, key, value) {
    if (value !== undefined && value !== null && value !== "") target[key] = value;
  }

  function fireGenerateLead(data, payload) {
    if (generateLeadSent) return;
    generateLeadSent = true;
    const leadPayload = {
      currency: "USD",
      value: 0,
      form_id: "fit-diagnostic",
    };
    addIfPresent(leadPayload, "tier_routing", data.tier_routing || payload.tier_routing);
    addIfPresent(leadPayload, "classification", data.classification || payload.classification);
    addIfPresent(leadPayload, "contact_id", data.contact_id || payload.contact_id);
    addIfPresent(leadPayload, "capi_event_id", data.capi_event_id || payload.capi_event_id);
    addIfPresent(leadPayload, "booking_event_id", data.booking_event_id || payload.booking_event_id);
    event("generate_lead", leadPayload);
  }

  function getUtms(){
    try {
      const attr = (window.__bwmAttribution && window.__bwmAttribution.last_touch && window.__bwmAttribution.last_touch.utm) || {};
      return {
        utm_source: attr.utm_source || null,
        utm_medium: attr.utm_medium || null,
        utm_campaign: attr.utm_campaign || null,
        utm_content: attr.utm_content || null,
        utm_term: attr.utm_term || null,
        fbclid: attr.fbclid || null,
        gclid: attr.gclid || null,
      };
    } catch (_e) { return {}; }
  }

  async function submitDiagnostic(emailValue){
    if (submitted && !emailValue) return;
    submitted = true;
    const utms = getUtms();
    const exp = window.__BWM_EXP || {};
    const payload = Object.assign({}, state, utms, {
      email: emailValue || "",
      landing_page: location.pathname,
      referrer: document.referrer || "",
      // MVT (PROJ-AUTO-MVT-001): experiment context injected by the edge worker.
      // Distinct names — variant_id is already used for utm_content semantics.
      experiment_id: exp.experiment_id || "",
      experiment_variant_id: exp.variant_id || "",
    });
    try {
      const res = await fetch("https://bwm-form-handler.robert-ba0.workers.dev/buildwisemedia/fit-diagnostic", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      handleVerdict(data, emailValue, payload);
    } catch (err) {
      console.error("fit-diagnostic submit failed:", err);
      // Graceful fallback so a paid click never hits a dead reveal state if the API
      // call fails (network / cold start). Show a working path instead of an empty card.
      submitted = false; // allow a retry on the next reveal
      const card = document.getElementById("verdict-card");
      const status = document.getElementById("verdict-status");
      const explainer = document.getElementById("verdict-explainer");
      const detail = document.getElementById("verdict-detail");
      const pathCta = document.getElementById("path-cta-block");
      if (card && status) {
        card.setAttribute("data-verdict", "maybe");
        status.textContent = "Your map is ready";
        if (explainer) explainer.textContent = "We hit a snag loading your result here. Book a quick call and we'll walk you through your Revenue Leak Map live.";
        if (detail) detail.textContent = "";
        if (pathCta) {
          pathCta.innerHTML = '<a class="cta" href="/book" data-cta-source="fit-diagnostic-fallback">Book The Call <span aria-hidden="true">→</span></a>';
        }
      }
    }
  }

  function handleVerdict(data, hadEmail, payload){
    const card = document.getElementById("verdict-card");
    const status = document.getElementById("verdict-status");
    const explainer = document.getElementById("verdict-explainer");
    const detail = document.getElementById("verdict-detail");
    const pathLead = document.getElementById("path-title-lead");
    const pathY = document.getElementById("path-title-y");
    const pathTail = document.getElementById("path-title-tail");
    const pathBody = document.getElementById("path-body");
    const pathList = document.getElementById("path-list");
    const pathCta = document.getElementById("path-cta-block");
    if (!card || !status) return;

    const v = data.verdict || "MAYBE";
    const idx = typeof data.growth_index === "number" ? data.growth_index : 50;

    // Single source of truth: the server's growth_index drives BOTH the top "Your
    // Growth Index" readout and the verdict score. computeAndReveal() seeds the top
    // value from a lighter client-side calc; sync it to the server number so the two
    // figures never disagree (e.g. "67" up top vs "FIT · 74/100" below).
    const giEl = document.getElementById("growth-index-value");
    if (giEl) giEl.textContent = idx;

    if (v === "FIT") {
      fireGenerateLead(data, payload || {});
      card.setAttribute("data-verdict", "fit");
      status.textContent = "FIT · " + idx + "/100";
      if (explainer) explainer.textContent = "Your shop matches the install profile. The system delivers the most lift here.";
      if (detail) detail.textContent = "What we'd install for you in 30 days: lead capture, qualification, follow-up, attribution, review velocity, and the AI growth engine that runs the marketing department without you in the loop.";
      if (pathLead) pathLead.textContent = "Book a";
      if (pathY) pathY.textContent = " 30-minute strategy call. ";
      if (pathTail) pathTail.textContent = "";
      if (pathBody) pathBody.textContent = "On the call we walk through your specific stack, what the system replaces, and what week one looks like.";
      if (pathCta) pathCta.innerHTML = '<a href="#cal-inline" class="cta" data-cta-source="mo-fit-verdict-cal" onclick="document.getElementById(\'cal-inline\').scrollIntoView({behavior:\'smooth\'});return false;">See If We\'re a Fit <span class="cta-arrow">→</span></a><p class="mono" style="margin-top:14px;font-size:11px;letter-spacing:.18em;color:var(--ink-faint);">For service businesses only.</p>';
      mountCalInline();
    } else if (v === "MAYBE") {
      // MAYBE is an in-range lead the team pursues within 48h (email captured) —
      // count it as a qualified-lead conversion alongside FIT. NOT YET is excluded.
      fireGenerateLead(data, payload || {});
      card.setAttribute("data-verdict", "maybe");
      status.textContent = "MAYBE · " + idx + "/100";
      if (explainer) explainer.textContent = "Your shop is in range, but one or two pieces are still forming. We'll be in touch within 48 hours.";
      if (detail) detail.textContent = "Based on what you shared, the system would help — but timing or stack readiness needs a quick conversation before we'd commit to the install. We'll reach out to figure out the right next step.";
      if (pathLead) pathLead.textContent = "We'll";
      if (pathY) pathY.textContent = " be in touch within 48h. ";
      if (pathTail) pathTail.textContent = "";
      if (pathBody) pathBody.textContent = "Want to speed it up? Drop your email below and we'll send your full audit + a focused next step.";
      if (pathCta && !hadEmail) pathCta.innerHTML = bwmEmailCaptureMarkup();
    } else {
      // NO
      card.setAttribute("data-verdict", "not-yet");
      status.textContent = "NOT YET · " + idx + "/100";
      if (explainer) explainer.textContent = "Your business isn't a fit for the AI growth system yet — and that's a deliberate read, not a brush-off.";
      if (detail) detail.textContent = "The system pays back hardest at a specific stage. Below that stage, the install cost is more than the return. We'll redirect you to a free resource that fits where you are now.";
      if (pathLead) pathLead.textContent = "Get the";
      if (pathY) pathY.textContent = " free Marketing Leverage Diagnostic ";
      if (pathTail) pathTail.textContent = "instead.";
      if (pathBody) pathBody.textContent = "We send it whether you become a client or not. It's the framework we use; you can run it yourself.";
      if (pathCta) pathCta.innerHTML = '<a href="/thank-you-resource?reason=fit_check" class="cta" data-cta-source="mo-fit-verdict-resource">Get the diagnostic <span class="cta-arrow">→</span></a>';
    }
  }

  function bwmEmailCaptureMarkup(){
    return [
      '<form id="bwm-fit-email-form" class="bwm-fit-email-form">',
      '  <label class="mono" for="bwm-fit-email" style="font-size:11px;letter-spacing:.18em;color:var(--ink-dim);">Email me my audit</label>',
      '  <input type="email" id="bwm-fit-email" name="email" required placeholder="you@yourbusiness.com" autocomplete="email" />',
      '  <button type="submit" class="cta">Send my audit <span class="cta-arrow">→</span></button>',
      '  <p id="bwm-fit-email-status" class="mono" style="font-size:10px;letter-spacing:.18em;color:var(--ink-faint);margin-top:8px;"></p>',
      '</form>',
    ].join("");
  }

  function mountCalInline(){
    if (document.getElementById("cal-inline")) return;
    const section = document.querySelector("#diagnostic") || document.body;
    const wrap = document.createElement("div");
    wrap.id = "cal-inline";
    wrap.className = "bwm-cal-inline";
    wrap.style.cssText = "max-width:1200px;margin:48px auto 0;min-height:720px;background:var(--bg-elev);border:1px solid var(--rule);";
    section.appendChild(wrap);
    // Booking-calendar loader (matches /book.astro pattern)
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal; let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {}; cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]);
          } else { p(cal, ar); }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://book.buildwisemedia.com/embed/embed.js", "init");
    window.Cal("init", "discovery-call", { origin: "https://book.buildwisemedia.com" });
    window.Cal.ns["discovery-call"]("inline", {
      elementOrSelector: "#cal-inline",
      config: { layout: "month_view" },
      calLink: "bwm/discovery-call",
    });
    window.Cal.ns["discovery-call"]("ui", {
      theme: "dark",
      styles: { branding: { brandColor: "#F0FF00" } },
      hideEventTypeDetails: false,
      layout: "month_view",
    });
  }

  // Wire MAYBE email capture (delegated)
  document.addEventListener("submit", function (e) {
    if (e.target && e.target.id === "bwm-fit-email-form") {
      e.preventDefault();
      const input = document.getElementById("bwm-fit-email");
      const statusEl = document.getElementById("bwm-fit-email-status");
      const email = input ? input.value.trim() : "";
      if (!email) return;
      submitted = false;  // allow re-submission with email
      if (statusEl) statusEl.textContent = "Sending...";
      submitDiagnostic(email).then(function(){
        if (statusEl) statusEl.textContent = "Done. Check your inbox in the next 48 hours.";
        const btn = e.target.querySelector("button");
        if (btn) btn.disabled = true;
      });
    }
  });

  // Hook into goTo: when we land on reveal, fire submit (anonymous)
  const _origGoTo = window.goTo || goTo;
  window.goTo = function (screen) {
    _origGoTo(screen);
    if (screen === "reveal" && !revealRendered) {
      revealRendered = true;
      submitDiagnostic("");
    }
  };
})();

</script>
