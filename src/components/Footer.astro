---
const currentYear = new Date().getFullYear();
const bookingUrl = 'https://book.buildwisemedia.com';
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Buildwise Media home">
          <span class="footer-logo-mark">BW</span>
          <span class="footer-logo-text">Buildwise Media</span>
        </a>
        <p class="footer-tagline">The Growth Engine for Service Businesses</p>
        <p class="footer-location">Tucker, Georgia</p>
      </div>
      <div class="footer-links">
        <a href="#how-it-works">How It Works</a>
        <a href="#results">Results</a>
        <a href={bookingUrl}>Book a Call</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {currentYear} Buildwise Media. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-3xl) 0 var(--space-xl);
    border-top: 1px solid var(--border-card);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    margin-bottom: var(--space-md);
  }

  .footer-logo-mark {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-terracotta);
    letter-spacing: -0.03em;
  }

  .footer-logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text-primary);
  }

  .footer-tagline {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }

  .footer-location {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-terracotta);
  }

  .footer-bottom {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border-faint);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-xl);
    }
    .footer-links {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
