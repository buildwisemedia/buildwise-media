---
import Wordmark from './Wordmark.astro';
const year = new Date().getFullYear();
const masthead = 'BUILDWISE·MEDIA';
---
<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-row footer-row--top">
      <Wordmark size="footer" />
      <p class="footer-tag mono">Marketing as operations. Verified weekly.</p>
    </div>

    <hr class="divider" />

    <div class="footer-row footer-row--cols">
      <div class="footer-col">
        <p class="footer-label mono">The System</p>
        <ul class="footer-list">
          <li><a href="/services/ascend">Ascend</a></li>
          <li><a href="/how-it-works">How It Works</a></li>
          <li><a href="/results">Results</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-label mono">Talk to us</p>
        <ul class="footer-list">
          <li><a href="/book">Book a discovery call</a></li>
          <li><a href="mailto:hello@buildwisemedia.com">hello@buildwisemedia.com</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-label mono">Legal</p>
        <ul class="footer-list">
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
        </ul>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer-row footer-row--bottom">
      <p class="masthead mono">
        <span>BUILDWISE</span><span class="dot-sep">·</span><span>MEDIA</span>
      </p>
      <p class="copy mono">© {year} Buildwise Media LLC · Atlanta, GA</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--bg);
  border-top: 1px solid var(--rule);
  padding-block: 80px 48px;
}
.footer-inner { display: flex; flex-direction: column; gap: 48px; }

.footer-row { display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; }
.footer-row--cols { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; }

.footer-tag {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.footer-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.20em;
  color: var(--gold);
  margin-bottom: 14px;
}

.footer-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-list a {
  font-family: var(--sans);
  font-size: 15px;
  font-weight: 300;
  color: var(--ink-dim);
  transition: color 180ms ease;
}
.footer-list a:hover { color: var(--gold); }

.masthead {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-dim);
  text-transform: uppercase;
}
.masthead .dot-sep { color: var(--gold); margin: 0 0.5em; }

.copy {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--ink-faint);
  text-transform: uppercase;
}

@media (max-width: 720px) {
  .footer-row--cols { grid-template-columns: 1fr; }
  .footer-row--bottom { flex-direction: column; align-items: flex-start; gap: 12px; }
}
</style>
