---
// A1 — Filled vertex. Y2 #F0FF00 filled circle.
// Canonical R014b primitive · brand/BWM-Geometric-Vocabulary-Locked.md
// Use for: present-state nodes, primary system markers, terminal vertices in process flow.
interface Props {
  size?: number;
  class?: string;
}
const { size = 12, class: cls = '' } = Astro.props;
---
<svg
  class={`atom atom-a1 ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  role="presentation"
  aria-hidden="true"
>
  <circle cx="12" cy="12" r="10" fill="#F0FF00" />
</svg>
