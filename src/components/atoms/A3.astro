---
// A3 — Verdict dot. Small Y2 #F0FF00 filled circle (centroid resolution).
// Canonical R014b primitive · brand/BWM-Geometric-Vocabulary-Locked.md
// Use for: label flanks, list-item markers, trust verdicts, focus signals.
// Distinguished from A1 by scale: A3 is small (~4-8px); A1 is structural (≥12px).
interface Props {
  size?: number;
  class?: string;
}
const { size = 6, class: cls = '' } = Astro.props;
---
<svg
  class={`atom atom-a3 ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 12 12"
  role="presentation"
  aria-hidden="true"
>
  <circle cx="6" cy="6" r="5" fill="#F0FF00" />
</svg>
