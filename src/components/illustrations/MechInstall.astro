---
// MechInstall — D2 archetype (Lead-Gen Architecture)
// 01 INSTALL · system architecture under construction.
// Composes from R014b atoms only: A1 filled-vertex, A4 hollow-vertex, A5 90-hairline.
// Brain · brand/BWM-Geometric-Vocabulary-Locked.md
//
// Visual narrative: central system hub being wired into 4 capability nodes
// (lead capture, qualification, follow-up, attribution). Hollow A4 at the
// growth/content node suggests "to be wired in next" (build-in-progress).
//
// R015 color contract: 100% dark cool (canvas) + Y2 #F0FF00 + Y2-mute #7A8400. No warm.
---
<svg
  class="mech-illust mech-install"
  viewBox="0 0 240 180"
  role="img"
  aria-label="A central system hub wired into four capability nodes — lead capture, qualification, follow-up, attribution — with one node still being installed."
>
  <!-- A5 orthogonal hairlines connecting hub to satellites -->
  <line x1="120" y1="90" x2="40" y2="90" stroke="#7A8400" stroke-width="1.5" stroke-linecap="round" />
  <line x1="120" y1="90" x2="200" y2="90" stroke="#7A8400" stroke-width="1.5" stroke-linecap="round" />
  <line x1="120" y1="90" x2="120" y2="32" stroke="#7A8400" stroke-width="1.5" stroke-linecap="round" />
  <line x1="120" y1="90" x2="120" y2="148" stroke="#7A8400" stroke-width="1.5" stroke-linecap="round" />

  <!-- Secondary radial branches from the top + right satellites (system buildout) -->
  <line x1="120" y1="32" x2="88" y2="20" stroke="#7A8400" stroke-width="1.2" stroke-linecap="round" />
  <line x1="120" y1="32" x2="152" y2="20" stroke="#7A8400" stroke-width="1.2" stroke-linecap="round" />
  <line x1="200" y1="90" x2="218" y2="62" stroke="#7A8400" stroke-width="1.2" stroke-linecap="round" />
  <line x1="200" y1="90" x2="218" y2="118" stroke="#7A8400" stroke-width="1.2" stroke-linecap="round" />

  <!-- Hub vertex (A1 filled, larger — central system node) -->
  <circle cx="120" cy="90" r="8" fill="#F0FF00" />

  <!-- 3 wired-in satellite vertices (A1 filled) -->
  <circle cx="40" cy="90" r="5" fill="#F0FF00" />
  <circle cx="200" cy="90" r="5" fill="#F0FF00" />
  <circle cx="120" cy="148" r="5" fill="#F0FF00" />

  <!-- 1 not-yet-wired satellite (A4 hollow — top, signaling install-in-progress) -->
  <circle cx="120" cy="32" r="5" fill="none" stroke="#7A8400" stroke-width="1.6" />

  <!-- Tiny terminal verdict-dots (A3) at secondary branch ends -->
  <circle cx="88" cy="20" r="2.5" fill="#F0FF00" />
  <circle cx="152" cy="20" r="2.5" fill="#F0FF00" />
  <circle cx="218" cy="62" r="2.5" fill="#F0FF00" />
  <circle cx="218" cy="118" r="2.5" fill="#F0FF00" />
</svg>
