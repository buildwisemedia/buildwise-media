---
// Triangulation V3 mark — three-vertex proof constellation plus verdict dot
interface Props {
  size?: number;
  ariaLabel?: string;
  class?: string;
}
const { size = 32, ariaLabel = 'Buildwise Media', class: className = '' } = Astro.props;
const topFill = size >= 48 ? 'url(#triangulationTopVertex)' : 'var(--y2)';
const showHairlines = size >= 32;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 128 128"
  width={size}
  height={size}
  role="img"
  aria-label={ariaLabel}
  class={`bmark ${className}`}
>
  <defs>
    <linearGradient id="triangulationTopVertex" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFD58" />
      <stop offset="50%" stop-color="#F0FF00" />
      <stop offset="100%" stop-color="#C8D300" />
    </linearGradient>
  </defs>

  {showHairlines && (
    <g stroke="var(--y2)" stroke-width="1.5" stroke-linecap="round">
      <line x1="64" y1="22" x2="22" y2="98" />
      <line x1="64" y1="22" x2="106" y2="98" />
      <line x1="22" y1="98" x2="106" y2="98" />
    </g>
  )}

  <circle cx="64" cy="22" r="7" fill={topFill} />
  <circle cx="22" cy="98" r="7" fill="var(--y2)" />
  <circle cx="106" cy="98" r="7" fill="var(--y2)" />
  <circle cx="64" cy="72.67" r="4.5" fill="var(--y2)" />
</svg>

<style>
.bmark { color: var(--y2); display: block; }
</style>
