---
// Black Gold homepage hero — italic-gold em pattern on H1 (the signature move)
// Source structure: compiled brief lines 120-132
---
<section class="hero" aria-labelledby="hero-headline">
  <div class="container hero-grid">

    <div class="hero-text">
      <p class="eyebrow">Buildwise Media · Marketing as operations</p>

      <h1 id="hero-headline" class="h-hero">
        Marketing run like<br/>
        <em>operations</em>, not<br/>
        like a project.
      </h1>

      <p class="hero-sub">
        Ad spend in. Revenue out. Verified weekly. We install and operate the AI-native lead-generation system that finally makes growth feel like the rest of your business — measurable, accountable, and built to compound.
      </p>

      <p class="icp">
        For ambition-disposed service-business owners who want to run marketing like they run their business — not for those still hunting a savior.
      </p>

      <div class="hero-ctas">
        <a href="/book" class="cta" data-cta-source="hero-primary">
          See If We're a Fit
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/how-it-works" class="cta-ghost" data-cta-source="hero-secondary">See the System</a>
      </div>
    </div>

    <aside class="hero-aside" aria-hidden="true">
      <div class="rail-card">
        <div class="rail-row">
          <span class="rail-label mono">Status</span>
          <span class="rail-value mono"><span class="dot live"></span>Live</span>
        </div>
        <div class="rail-row">
          <span class="rail-label mono">Spend window</span>
          <span class="rail-value">2026 W17</span>
        </div>
        <div class="rail-row rail-row--big">
          <span class="rail-label mono">Pipeline · last 30d</span>
          <span class="rail-num">$1.<em>4M</em></span>
        </div>
        <div class="rail-row rail-row--big">
          <span class="rail-label mono">Verified leads</span>
          <span class="rail-num"><em>312</em></span>
        </div>
        <div class="rail-row">
          <span class="rail-label mono">Connector audit</span>
          <span class="rail-value mono"><span class="dot live"></span>13/13 healthy</span>
        </div>
        <p class="rail-foot mono">Source: BWM operations log · refreshed weekly</p>
      </div>
    </aside>

  </div>

  <a href="#problem" class="scroll-indicator" aria-label="Scroll to problem section">
    <span class="mono">scroll</span>
    <span class="rule" aria-hidden="true"></span>
  </a>
</section>

<style>
.hero {
  padding-top: clamp(56px, 6vw, 88px);
  padding-bottom: clamp(56px, 6vw, 80px);
  position: relative;
  overflow: hidden;
}
.hero::before {
  /* atmospheric gradient field — gold ambient, no decorative shapes (per locked) */
  content: '';
  position: absolute;
  inset: -10%;
  background:
    radial-gradient(ellipse 60% 40% at 75% 30%, rgba(212, 169, 85, 0.08), transparent 60%),
    radial-gradient(ellipse 50% 60% at 20% 80%, rgba(212, 169, 85, 0.04), transparent 60%);
  pointer-events: none;
  z-index: 0;
}
.hero > * { position: relative; z-index: 1; }

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
  gap: clamp(48px, 8vw, 96px);
  align-items: center;
}

.hero-text { display: flex; flex-direction: column; gap: 20px; max-width: 720px; }

.h-hero { color: var(--ink); }

.icp {
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.04em;
  line-height: 1.55;
  color: var(--ink-faint);
  border-left: 1px solid var(--rule);
  padding-left: 16px;
  max-width: 600px;
}

.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 8px; }

/* Hero side rail — atmospheric proof signal */
.hero-aside { display: flex; justify-content: flex-end; }
.rail-card {
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 28px;
  width: 100%;
  max-width: 380px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.rail-row { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--rule); }
.rail-row:last-of-type { border-bottom: none; padding-bottom: 0; }
.rail-row--big { flex-direction: column; align-items: flex-start; gap: 8px; padding-block: 4px 16px; }

.rail-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); }
.rail-value { font-family: var(--sans); font-size: 14px; font-weight: 400; color: var(--ink-dim); display: inline-flex; align-items: center; }
.rail-num {
  font-family: var(--serif);
  font-weight: 400;
  font-size: 44px;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--ink);
}
.rail-foot { font-size: 9px; letter-spacing: 0.18em; color: var(--ink-faint); margin-top: 4px; }

/* Scroll indicator */
.scroll-indicator {
  position: absolute;
  left: var(--container-x);
  bottom: 40px;
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--ink-faint);
}
.scroll-indicator .rule {
  width: 56px;
  height: 1px;
  background: var(--gold);
  display: inline-block;
  position: relative;
}
.scroll-indicator .rule::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  width: 8px;
  height: 1px;
  background: var(--gold);
  transform: translateY(-50%) rotate(45deg);
  transform-origin: right center;
}

@media (max-width: 880px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-aside { justify-content: stretch; }
  .rail-card { max-width: none; }
  .scroll-indicator { display: none; }
}
</style>
