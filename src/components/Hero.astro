---
const bookingUrl = 'https://book.buildwisemedia.com';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-title">
        Stop Losing Jobs to Competitors<br />
        <span class="hero-accent">Who Simply Show Up Online</span>
      </h1>
      <p class="hero-sub">
        Most service businesses waste thousands on marketing that doesn't work.
        We build growth engines that bring qualified leads to your door — so you
        can focus on what you do best.
      </p>
      <a href={bookingUrl} class="cta-btn hero-cta">See If You Qualify</a>
      <p class="hero-micro">Free 15-min strategy call · No obligation</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-top: 72px; /* header height */
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      rgba(196, 112, 75, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-lg);
  }

  .hero-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: var(--space-xl);
    letter-spacing: -0.03em;
  }

  .hero-accent {
    color: var(--color-terracotta);
  }

  .hero-sub {
    font-size: clamp(1.0625rem, 2.5vw, 1.25rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }

  .hero-cta {
    font-size: 1.25rem;
    padding: 1.125rem 2.5rem;
  }

  .hero-micro {
    margin-top: var(--space-md);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
    }
    .hero-inner {
      padding: var(--space-3xl) var(--space-lg);
    }
  }
</style>
