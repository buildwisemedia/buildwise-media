---
// Triangulation hero — buildwisemedia.com flagship
// Numeral-led structure per P-06 lock; locked 2026-04-30 against BWM-Visual-Direction-Locked.md
---
<section class="hero" aria-labelledby="hero-headline">
  <div class="container hero-grid">

    <div class="hero-text">
      <p class="eyebrow">Buildwise Media · Operations Layer for Lead Generation</p>

      <span class="h-hero-num" aria-hidden="true">30 DAYS</span>

      <h1 id="hero-headline" class="h-hero">
        Full lead&#8209;generation system, installed and operated.
      </h1>

      <p class="hero-sub">
        Ad spend in. Revenue out. Verified weekly.
      </p>

      <p class="icp">
        For ambition-disposed service-business owners.
      </p>

      <div class="hero-ctas">
        <a href="/book" class="cta" data-cta-source="hero-primary">
          See If We're a Fit
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/how-it-works" class="cta-ghost" data-cta-source="hero-secondary">See the System</a>
      </div>
    </div>

    <aside class="hero-rail" aria-hidden="true">
      <div class="rail-card">
        <div class="rail-row">
          <span class="rail-label mono">Confidence floor · every claim</span>
          <span class="rail-num">75%</span>
        </div>
        <div class="rail-row">
          <span class="rail-label mono">System operational</span>
          <span class="rail-num">30d</span>
        </div>
        <div class="rail-row">
          <span class="rail-label mono">Connector audit · live</span>
          <span class="rail-num rail-num--small">
            <span class="dot live"></span>13/13
          </span>
        </div>
        <p class="rail-foot mono">Source: BWM operating policy + audit log · refreshed weekly</p>
      </div>
    </aside>

  </div>
</section>

<style>
.hero {
  padding-top: clamp(80px, 8vw, 128px);
  padding-bottom: clamp(64px, 7vw, 96px);
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

/* Optional 32px dot grid at 2.5% opacity per Visual-Direction-Locked §1 */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at center, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
  z-index: 0;
}
.hero > * { position: relative; z-index: 1; }

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.8fr) minmax(0, 0.85fr);
  gap: clamp(40px, 5vw, 72px);
  align-items: center;
}

.hero-text { display: flex; flex-direction: column; gap: 20px; max-width: 880px; }

.h-hero-num {
  margin-bottom: 8px;
}

.h-hero {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(40px, 4.8vw, 64px);
  line-height: 0.92;
  letter-spacing: -0.035em;
  color: var(--ink);
  text-wrap: balance;
}

.hero-sub {
  font-family: var(--sans);
  font-size: clamp(17px, 1.6vw, 19px);
  font-weight: 400;
  line-height: 1.5;
  color: var(--ink-dim);
  max-width: 540px;
}

.icp {
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.04em;
  line-height: 1.55;
  color: var(--ink-faint);
  border-left: 1px solid var(--rule);
  padding-left: 16px;
  max-width: 600px;
}

.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 8px; }

/* Right rail — Triangulation proof signal */
.hero-rail { display: flex; justify-content: flex-end; }
.rail-card {
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 32px;
  width: 100%;
  max-width: 380px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.rail-row {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--rule);
}
.rail-row:last-of-type { border-bottom: none; padding-bottom: 0; }

.rail-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.rail-num {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(36px, 4.5vw, 56px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--ink);
}
.rail-num--small {
  font-size: clamp(28px, 3.5vw, 40px);
  display: inline-flex;
  align-items: center;
  gap: 10px;
}

.rail-foot {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-top: 4px;
}

@media (max-width: 880px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-rail { justify-content: stretch; }
  .rail-card { max-width: none; }
}
</style>
