---
// L7 — The Exponential Capability Curve
// Plan: ~/.claude/plans/based-on-all-nifty-karp.md
// Refactored 2026-05-20 from prior 3-panel "Compounding Edge" component into the
// capability-inheritance arc. Compounding Slider lock satisfied by the new
// EarnBackCalculator (L6) which is a slider with compounding outputs.
// Vendor names BANNED per CLAUDE.md client-voice lock — "frontier AI" / "AI assistant"
// stand in for Anthropic / Google / OpenAI / xAI / Claude / ChatGPT / Gemini.
---
<section class="capability-curve" aria-labelledby="curve-headline">
  <div class="container">

    <header class="curve-head reveal">
      <p class="section-tag">The Curve</p>
      <h2 id="curve-headline" class="h-section">
        Your system inherits every<br/>
        frontier AI improvement.<br/>
        <em>Automatically.</em>
      </h2>
      <p class="lede">
        When a better AI model ships — and a better one ships every few months — your system routes there next session. No re-platforming cost. No contract renegotiation. The capability compounds inside your business.
      </p>
    </header>

    <!-- Panel 1: Capability inheritance curve — 36 months, 4 named milestones -->
    <figure class="curve-panel reveal" aria-labelledby="curve-cap">
      <svg viewBox="0 0 1200 420" aria-hidden="true" preserveAspectRatio="none" class="curve-svg">
        <defs>
          <linearGradient id="curveFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="var(--y2)" stop-opacity="0.22"/>
            <stop offset="100%" stop-color="var(--y2)" stop-opacity="0"/>
          </linearGradient>
          <pattern id="curveGrid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#1f1d27" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="1200" height="420" fill="url(#curveGrid)"/>

        <!-- Reference flat line — typical static agency -->
        <line x1="0" y1="340" x2="1200" y2="320" stroke="#5a5650" stroke-width="1" stroke-dasharray="4 6"/>
        <text x="1180" y="312" text-anchor="end" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">TYPICAL AGENCY — STATIC OVER 36 MONTHS</text>

        <!-- Compounding curve — your Ascend system inheriting frontier AI -->
        <path d="M 0 380 Q 200 380 400 340 Q 600 300 800 220 Q 1000 140 1200 30" fill="none" stroke="var(--y2)" stroke-width="2"/>
        <path d="M 0 380 Q 200 380 400 340 Q 600 300 800 220 Q 1000 140 1200 30 L 1200 420 L 0 420 Z" fill="url(#curveFill)"/>
        <text x="20" y="50" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="12" letter-spacing="3">YOUR ASCEND SYSTEM — CAPABILITY COMPOUNDS</text>

        <!-- 4 milestone markers + labels -->
        <g class="milestone" data-milestone="6mo">
          <circle cx="200" cy="380" r="5" fill="var(--y2)"/>
          <text x="200" y="408" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">6 MO</text>
        </g>
        <g class="milestone" data-milestone="12mo">
          <circle cx="400" cy="340" r="5" fill="var(--y2)"/>
          <text x="400" y="408" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">12 MO</text>
        </g>
        <g class="milestone" data-milestone="24mo">
          <circle cx="800" cy="220" r="6" fill="var(--y2)"/>
          <text x="800" y="408" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">24 MO</text>
        </g>
        <g class="milestone" data-milestone="36mo">
          <circle cx="1180" cy="30" r="7" fill="var(--y2)"/>
          <text x="1180" y="408" text-anchor="end" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">36 MO</text>
        </g>
      </svg>
      <figcaption id="curve-cap" class="curve-cap mono">Capability inheritance · BWM Ascend system vs typical static agency · 36-month horizon</figcaption>
    </figure>

    <!-- 4 milestone tiles below the curve — what each marker actually means -->
    <!-- Iteration 3: each card gets a R018b/c atmospheric thumbnail that fades in on hover (R017 user-input state) -->
    <ol class="milestone-list reveal" role="list">
      <li class="milestone-card">
        <img
          class="milestone-photo"
          src="/images/bwm-services-atmospheric-v1.webp"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="milestone-content">
          <span class="milestone-num mono">6 MO</span>
          <h3 class="card-title">AI video at social scale</h3>
          <p class="card-body">Automated creative testing at 10–100× your current throughput. Every winning concept compounds the next.</p>
        </div>
      </li>
      <li class="milestone-card">
        <img
          class="milestone-photo"
          src="/images/bwm-results-editorial-v1.webp"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="milestone-content">
          <span class="milestone-num mono">12 MO</span>
          <h3 class="card-title">Autonomous workflows running 8+ hours</h3>
          <p class="card-body">Our AI system handles long-running operations end-to-end — uninterrupted, audited, with human signoff at the gates.</p>
        </div>
      </li>
      <li class="milestone-card">
        <img
          class="milestone-photo"
          src="/images/bwm-proof-still-life-v1.webp"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="milestone-content">
          <span class="milestone-num mono">24 MO</span>
          <h3 class="card-title">Self-improving capability</h3>
          <p class="card-body">The system gets better without us touching it. Your business compounds while you keep running operations.</p>
        </div>
      </li>
      <li class="milestone-card">
        <img
          class="milestone-photo"
          src="/images/exploded-triangle-v1.svg"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="milestone-content">
          <span class="milestone-num mono">36 MO</span>
          <h3 class="card-title">Capability beyond what anyone can predict</h3>
          <p class="card-body">Whatever the frontier ships in 2029 lands in your business the same week. No re-platforming. No new contract.</p>
        </div>
      </li>
    </ol>

    <!-- Panel 2: Dot Grid horizon — the system runs while you don't -->
    <div class="curve-grid reveal" aria-label="System runs 24/7">
      <div class="grid-canvas dot-grid" aria-hidden="true"></div>
      <div class="grid-overlay">
        <p class="reveal-num"><em>24/7</em></p>
        <p class="grid-cap">
          The system runs while you don't. Every Monday at 4 a.m. ET, the operating layer audits itself. Drift gets surfaced and routed before you read your inbox.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
.capability-curve { padding-block: var(--section-y); position: relative; background: var(--bg); }

.curve-head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 56px; max-width: 920px; }
.curve-head h2 em { color: var(--y2); font-style: normal; font-weight: inherit; }

.curve-panel { background: var(--bg-elev); border: 1px solid var(--rule); border-radius: 2px; padding: 32px; margin-bottom: 48px; }
.curve-svg { width: 100%; height: clamp(260px, 32vw, 420px); }
.curve-cap { margin-top: 16px; font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); }

/* 4 milestone tiles — Y2 numerals, hairline-divided cards */
.milestone-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 48px;
}
.milestone-card {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: border-color 220ms ease;
  overflow: hidden;
  min-height: 240px;
}
.milestone-card:hover {
  border-color: var(--y2);
}
.milestone-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  z-index: 0;
  pointer-events: none;
  transition: opacity 320ms ease;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 70%);
  -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 70%);
}
.milestone-card:hover .milestone-photo,
.milestone-card:focus-within .milestone-photo {
  opacity: 0.32;
}
.milestone-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
@media (prefers-reduced-motion: reduce) {
  .milestone-photo { transition: none; }
  .milestone-card:hover .milestone-photo,
  .milestone-card:focus-within .milestone-photo { opacity: 0.2; }
}
.milestone-num {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  color: var(--y2);
}
.milestone-card .card-title {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 17px;
  line-height: 1.25;
  color: var(--ink);
}
.milestone-card .card-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* Panel 2 — Dot Grid horizon */
.curve-grid { position: relative; height: clamp(260px, 32vw, 380px); border: 1px solid var(--rule); overflow: hidden; }
.grid-canvas { position: absolute; inset: 0; opacity: 0.35; mask-image: radial-gradient(ellipse 60% 60% at center, black 30%, transparent 100%); }
.grid-overlay { position: absolute; inset: 0; padding: 32px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; gap: 24px; }
.grid-cap { font-family: var(--sans); font-size: clamp(18px, 1.8vw, 24px); line-height: 1.45; color: var(--ink-dim); max-width: 540px; }

@media (max-width: 880px) {
  .milestone-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 520px) {
  .milestone-list { grid-template-columns: 1fr; }
}

/* prefers-reduced-motion: nothing to disable — SVG is static, dot-grid is CSS pattern */
</style>
