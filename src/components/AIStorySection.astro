---
// AI Story Arc — REQUIRED per ai-sections-required lock 2026-03-12
// Three stitched panels: Acceleration Curve · Compounding Slider · Dot Grid (factory horizon)
---
<section class="ai-story">
  <div class="container">

    <header class="ai-head reveal">
      <p class="section-tag">The Compounding Edge</p>
      <h2 class="h-section">
        Two AIs are now<br/>
        <em>building together.</em>
      </h2>
      <p class="lede">
        The marketing engine isn't a static deliverable. Every week it sees more, learns more, and quietly out-performs the last. The leverage compounds whether you're paying attention or not.
      </p>
    </header>

    <!-- Panel 1: AI Acceleration Curve (SVG) -->
    <figure class="ai-panel ai-curve reveal" aria-labelledby="ai-curve-cap">
      <svg viewBox="0 0 1200 360" aria-hidden="true" preserveAspectRatio="none" class="curve-svg">
        <defs>
          <linearGradient id="curveFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="#d4a955" stop-opacity="0.22"/>
            <stop offset="100%" stop-color="#d4a955" stop-opacity="0"/>
          </linearGradient>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#1f1d27" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="1200" height="360" fill="url(#grid)"/>
        <!-- Reference flat line — typical agency -->
        <line x1="0" y1="280" x2="1200" y2="260" stroke="#5a5650" stroke-width="1" stroke-dasharray="4 6"/>
        <text x="1180" y="252" text-anchor="end" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="12" letter-spacing="2">TYPICAL AGENCY</text>
        <!-- Compounding curve — BWM -->
        <path d="M 0 320 Q 300 320 540 280 T 1200 40" fill="none" stroke="#d4a955" stroke-width="2"/>
        <path d="M 0 320 Q 300 320 540 280 T 1200 40 L 1200 360 L 0 360 Z" fill="url(#curveFill)"/>
        <text x="20" y="50" fill="#d4a955" font-family="JetBrains Mono, monospace" font-size="12" letter-spacing="3">BWM REVENUE ENGINE</text>
        <!-- Markers -->
        <circle cx="200" cy="316" r="4" fill="#d4a955"/>
        <circle cx="540" cy="280" r="4" fill="#d4a955"/>
        <circle cx="900" cy="160" r="5" fill="#d4a955"/>
        <text x="200" y="346" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">DAY 1</text>
        <text x="540" y="346" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">DAY 30</text>
        <text x="900" y="346" text-anchor="middle" fill="#5a5650" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">DAY 90</text>
      </svg>
      <figcaption id="ai-curve-cap" class="ai-cap mono">Acceleration curve · BWM operations vs typical agency · 90-day window</figcaption>
    </figure>

    <!-- Panel 2: Compounding Slider — interactive -->
    <div class="ai-panel ai-slider reveal" data-slider>
      <div class="slider-head">
        <p class="kpi-label mono">Compounding model</p>
        <p class="slider-prompt">Drag to see the leverage at different time horizons.</p>
      </div>

      <div class="slider-body">
        <div class="slider-row">
          <span class="slider-label mono">Months in</span>
          <input type="range" min="1" max="24" value="6" class="slider-input" aria-label="Months operating" />
          <output class="slider-out mono"><span data-out-months>6</span> mo</output>
        </div>

        <div class="slider-out-grid">
          <div class="slider-cell">
            <p class="kpi-label mono">Pipeline · model</p>
            <p class="metric-val">$<em data-out-pipeline>180k</em></p>
          </div>
          <div class="slider-cell">
            <p class="kpi-label mono">Hours back · weekly</p>
            <p class="metric-val"><em data-out-hours>14</em></p>
          </div>
          <div class="slider-cell">
            <p class="kpi-label mono">System knowledge</p>
            <p class="metric-val"><em data-out-knowledge>32%</em></p>
          </div>
        </div>

        <p class="slider-foot mono">Range modeled from BWM client cohort baselines · Confidence: 78% · Evidence class: Modeled</p>
      </div>
    </div>

    <!-- Panel 3: Dot Grid factory horizon -->
    <div class="ai-panel ai-grid reveal">
      <div class="grid-canvas dot-grid" aria-hidden="true"></div>
      <div class="grid-overlay">
        <p class="reveal-num"><em>24/7</em></p>
        <p class="grid-cap">
          The system runs while you don't. Connectors audited every Monday at 4 a.m. ET. Drift detected, surfaced, and routed before you read your inbox.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
.ai-story { padding-block: var(--section-y); position: relative; }
.ai-head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; max-width: 880px; }

.ai-panel { margin-bottom: 64px; }
.ai-panel:last-child { margin-bottom: 0; }

/* Panel 1 — Curve */
.ai-curve { background: var(--bg-elev); border: 1px solid var(--rule); border-radius: 2px; padding: 32px; }
.curve-svg { width: 100%; height: clamp(220px, 30vw, 360px); }
.ai-cap { margin-top: 16px; font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); }

/* Panel 2 — Slider */
.ai-slider { background: var(--bg-elev); border: 1px solid var(--rule); border-radius: 2px; padding: 40px 32px; }
.slider-head { display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px; }
.slider-prompt { font-family: var(--serif); font-size: clamp(22px, 2.2vw, 28px); line-height: 1.3; color: var(--ink); }
.slider-row { display: grid; grid-template-columns: 110px minmax(0, 1fr) 90px; gap: 24px; align-items: center; margin-bottom: 32px; }
.slider-label { font-size: 10px; letter-spacing: 0.2em; color: var(--ink-faint); }
.slider-out { font-size: 14px; letter-spacing: 0.1em; color: var(--gold); text-align: right; }

.slider-input {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 2px; background: var(--rule);
  border-radius: 1px; outline: none;
}
.slider-input::-webkit-slider-thumb {
  -webkit-appearance: none; appearance: none;
  width: 18px; height: 18px;
  background: var(--gold);
  border-radius: 50%;
  border: 3px solid var(--bg-elev);
  cursor: pointer;
  box-shadow: 0 0 0 1px var(--gold);
  transition: transform 180ms ease;
}
.slider-input::-webkit-slider-thumb:hover { transform: scale(1.15); }
.slider-input::-moz-range-thumb {
  width: 18px; height: 18px;
  background: var(--gold);
  border-radius: 50%;
  border: 3px solid var(--bg-elev);
  cursor: pointer;
}

.slider-out-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
  padding-block: 24px;
  border-top: 1px solid var(--rule);
}
.slider-cell { display: flex; flex-direction: column; gap: 6px; }

.slider-foot { margin-top: 8px; font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); }

/* Panel 3 — Dot Grid */
.ai-grid { position: relative; height: clamp(280px, 36vw, 420px); border: 1px solid var(--rule); overflow: hidden; }
.grid-canvas { position: absolute; inset: 0; opacity: 0.35; mask-image: radial-gradient(ellipse 60% 60% at center, black 30%, transparent 100%); }
.grid-overlay { position: absolute; inset: 0; padding: 32px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; gap: 24px; }
.grid-cap { font-family: var(--serif); font-size: clamp(20px, 2vw, 26px); line-height: 1.35; color: var(--ink-dim); max-width: 540px; }

@media (max-width: 720px) {
  .slider-row { grid-template-columns: 1fr; gap: 12px; }
  .slider-out { text-align: left; }
  .slider-out-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  const slider = document.querySelector<HTMLInputElement>('.slider-input');
  if (slider) {
    const monthsOut = document.querySelector<HTMLElement>('[data-out-months]');
    const pipelineOut = document.querySelector<HTMLElement>('[data-out-pipeline]');
    const hoursOut = document.querySelector<HTMLElement>('[data-out-hours]');
    const knowledgeOut = document.querySelector<HTMLElement>('[data-out-knowledge]');

    const fmt = (n: number) => {
      if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1) + 'k';
      return String(n);
    };

    const update = () => {
      const m = Number(slider.value);
      // Modeled compounding: pipeline grows with mild curve, hours stabilize, knowledge approaches 100%.
      const pipeline = Math.round(15000 * m * (1 + m / 24));
      const hours = Math.min(20, Math.round(4 + m * 1.1));
      const knowledge = Math.min(98, Math.round(8 + m * 4.5));
      if (monthsOut) monthsOut.textContent = String(m);
      if (pipelineOut) pipelineOut.textContent = fmt(pipeline);
      if (hoursOut) hoursOut.textContent = String(hours);
      if (knowledgeOut) knowledgeOut.textContent = `${knowledge}%`;
    };

    slider.addEventListener('input', update);
    update();
  }
</script>
