---
// Cost-of-Assembly anchor — PROJ-VALUE-STACK-001 Phase 2
// Anchors BWM's price against what it costs to assemble the same scope from a
// separate expert in each discipline. Lands right before Entry Paths so the
// tier prices read as the bargain.
//
// Dual-framing lock: client-visible surface uses CATEGORY DESCRIPTORS ONLY —
// never a competitor's name. Named/sourced figures live internal-only in
// sops/Sales-Value-Stack-Anchor.md + reference/BWM-Value-Stack-Anchor.md (Brain).
// Going rates: reference/BWM-Value-Stack-Anchor.md § Public table (re-verify quarterly).
// BWM prices inherit canonical.json — never hardcoded.
import canonical from '../data/canonical.json';

const ascend = canonical.products.ascend;
// canonical.products.ascend.price.recurring_display / .oneshot_display
const ascendRecurring = ascend.price.recurring_display; // e.g. "$7,000/mo"
const ascendInstall = ascend.price.oneshot_display;     // e.g. "$15,000"

// The eight specialists an owner would otherwise hire — category descriptors only.
const stack = [
  { role: 'A fractional Chief AI Officer', scope: 'Strategy + leadership', rate: '$5K–$30K/mo' },
  { role: 'An AI implementation boutique', scope: 'Build + automation', rate: '$40K–$100K + $5K–$15K/mo' },
  { role: 'An AI-first lead-ops platform', scope: 'The lead engine alone', rate: '~$15K/mo' },
  { role: 'A web design agency', scope: 'The website', rate: '$6K–$50K build' },
  { role: 'A paid-media manager', scope: 'Ads', rate: '$1.5K–$5K/mo' },
  { role: 'A content + creative studio', scope: 'Content', rate: '$3.5K–$10K/mo' },
  { role: 'A social media agency', scope: 'Social', rate: '$2K–$5K/mo' },
  { role: 'A marketing-data retainer', scope: 'Attribution + reporting', rate: '$5K–$15K/mo' },
];
---

<section class="assembly-section elev" aria-labelledby="assembly-title">
  <div class="container">
    <header class="assembly-head">
      <p class="section-tag">What it replaces</p>
      <h2 id="assembly-title" class="h-section">One system — or eight specialists you wire together yourself.</h2>
      <p class="lede">
        To build what Ascend does, most owners hire an expert for each piece — strategy, build, ads, content, follow-up, data. Here is what that stack costs before anyone connects it.
      </p>
    </header>

    {/* @r020:F2 proof: itemized cost-of-assembly ledger vs one integrated price — concrete dollar proof that drives the price reframe. @r020:F3 cta-pull: resolves into the See If We're a Fit CTA. CSS data-display, no raster. */}
    <div class="assembly-grid">
      <div role="group" class="assembly-stack" aria-label="What it costs to assemble the same scope from separate experts">
        <p class="ops-kicker assembly-kicker">Assemble it yourself</p>
        <ul class="assembly-rows" role="list">
          {stack.map((item, i) => (
            <li class={`assembly-row${item.scope === 'The lead engine alone' ? ' assembly-row--anchor' : ''}`}>
              <span class="assembly-num mono">{String(i + 1).padStart(2, '0')}</span>
              <span class="assembly-role">
                {item.role}
                <span class="assembly-scope">{item.scope}</span>
              </span>
              <span class="assembly-rate mono">{item.rate}</span>
            </li>
          ))}
        </ul>
        <div class="assembly-total">
          <span class="ops-kicker">Conservative total, before anyone connects it</span>
          <strong class="assembly-total-figure mono">~$25,000–$50,000<span class="assembly-per">/mo</span></strong>
          <p class="assembly-total-note">+ $45,000–$150,000 to build · across 6–8 vendors who don't share data</p>
        </div>
      </div>

      <aside class="assembly-bwm" aria-label="One Buildwise system">
        <p class="ops-kicker assembly-kicker">Or install one system</p>
        <p class="assembly-bwm-name">One Buildwise system</p>
        <strong class="assembly-bwm-figure mono">{ascendRecurring}</strong>
        <p class="assembly-bwm-install mono">+ {ascendInstall} install</p>
        <ul class="assembly-bwm-points" role="list">
          <li><span class="dot" aria-hidden="true"></span>One team, one bill, one system that actually connects.</li>
          <li><span class="dot" aria-hidden="true"></span>You own the code, the data, and the system.</li>
          <li><span class="dot" aria-hidden="true"></span>It runs for you — so you run the business.</li>
        </ul>
        <a href="/book" class="cta" data-cta-source="cost-of-assembly">Get My Free Revenue Leak Map<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
      </aside>
    </div>

    <p class="assembly-pull">
      Even the lead engine alone — one line on that list — costs more each month than our entire system.
    </p>
  </div>
</section>

<style>
  .assembly-section {
    padding-block: var(--section-y);
    border-top: 1px solid var(--rule);
  }

  .assembly-head {
    max-width: 820px;
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .assembly-head .lede {
    margin-top: 22px;
  }

  .assembly-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.85fr);
    gap: clamp(20px, 3vw, 32px);
    align-items: stretch;
  }

  /* ---- LEFT: the assembled stack (heavy, dim) ---- */
  .assembly-stack {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: clamp(22px, 3.5vw, 38px);
  }

  .assembly-kicker {
    color: var(--ink-faint);
    margin-bottom: 18px;
  }

  .assembly-rows {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .assembly-row {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
  }

  .assembly-row--anchor {
    border-left: 2px solid var(--y2);
    margin-left: -2px;
    padding-left: 14px;
  }

  .assembly-num {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }

  .assembly-role {
    color: var(--ink);
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.3;
  }

  .assembly-scope {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: 5px;
  }

  .assembly-rate {
    color: var(--ink-dim);
    font-size: clamp(12px, 1.4vw, 14px);
    text-align: right;
    white-space: nowrap;
  }

  .assembly-total {
    margin-top: 26px;
    padding-top: 24px;
    border-top: 1px solid var(--rule-bright);
  }

  .assembly-total .ops-kicker {
    color: var(--ink-faint);
    display: block;
    margin-bottom: 12px;
  }

  .assembly-total-figure {
    display: block;
    font-size: clamp(34px, 5.2vw, 52px);
    line-height: 0.95;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .assembly-per {
    font-size: 0.45em;
    color: var(--ink-dim);
    letter-spacing: 0.04em;
  }

  .assembly-total-note {
    margin-top: 14px;
    color: var(--ink-dim);
    font-size: 15px;
    line-height: 1.5;
  }

  /* ---- RIGHT: one Buildwise system (light, Y2 accent) ---- */
  .assembly-bwm {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--y2);
    border-radius: 6px;
    padding: clamp(22px, 3.5vw, 38px);
  }

  .assembly-bwm .assembly-kicker {
    color: var(--y2);
  }

  .assembly-bwm-name {
    font-family: var(--sans);
    font-weight: 800;
    font-stretch: 75%;
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .assembly-bwm-figure {
    display: block;
    font-size: clamp(40px, 5.6vw, 60px);
    line-height: 0.92;
    color: var(--y2);
    letter-spacing: -0.01em;
  }

  .assembly-bwm-install {
    margin-top: 8px;
    font-size: 13px;
    color: var(--ink-dim);
    letter-spacing: 0.02em;
  }

  .assembly-bwm-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 24px 0 28px;
    padding-top: 22px;
    border-top: 1px solid var(--rule);
  }

  .assembly-bwm-points li {
    display: grid;
    grid-template-columns: 14px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    color: var(--ink-dim);
    font-size: 15px;
    line-height: 1.45;
  }

  .assembly-bwm-points .dot {
    width: 7px;
    height: 7px;
    margin-top: 8px;
    border-radius: 50%;
    background: var(--y2);
  }

  .assembly-bwm .cta {
    margin-top: auto;
    align-self: flex-start;
  }

  /* ---- pull line ---- */
  .assembly-pull {
    max-width: 820px;
    margin: clamp(32px, 4vw, 48px) auto 0;
    text-align: center;
    font-family: var(--sans);
    font-weight: 600;
    font-size: clamp(19px, 2.4vw, 26px);
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  @media (max-width: 880px) {
    .assembly-grid {
      grid-template-columns: 1fr;
    }
    .assembly-bwm .cta {
      align-self: stretch;
      width: 100%;
      justify-content: center;
    }
  }
</style>
