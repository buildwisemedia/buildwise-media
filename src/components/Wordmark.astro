---
// BWM Triangulation horizontal lockup - vendored asset, not inline SVG.
interface Props {
  size?: 'nav' | 'footer' | 'large';
  href?: string;
}

const { size = 'nav', href = '/' } = Astro.props;
const widths = { nav: 200, footer: 190, large: 280 };
const width = widths[size];
---
<a href={href} class={`wordmark wordmark--${size}`} aria-label="Buildwise Media - home">
  <img src="/brand/lockup-horizontal.svg" alt="Buildwise Media" width={width} loading={size === 'nav' ? 'eager' : 'lazy'} decoding="async" />
</a>

<style>
.wordmark {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  color: var(--ink);
  transition: opacity 180ms ease;
  flex: 0 0 auto;
}

.wordmark:hover {
  color: var(--ink);
  opacity: 0.85;
}

.wordmark img {
  width: auto;
  max-width: min(52vw, 200px);
  height: 32px;
}

.wordmark--footer img {
  max-width: 190px;
  height: 30px;
}

.wordmark--large img {
  max-width: 280px;
  height: 48px;
}

@media (max-width: 520px) {
  .wordmark img {
    height: 28px;
    max-width: 180px;
  }
}
</style>
