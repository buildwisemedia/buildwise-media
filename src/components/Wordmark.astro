---
// BWM Triangulation lockup — configuration A horizontal
import BMark from './BMark.astro';
interface Props {
  size?: 'nav' | 'footer' | 'large';
  href?: string;
}
const { size = 'nav', href = '/' } = Astro.props;
const heights = { nav: 32, footer: 28, large: 56 };
const h = heights[size];
---
<a href={href} class={`wordmark wordmark--${size}`} aria-label="Buildwise Media — home">
  <BMark size={h} ariaLabel="" />
  <span class="lockup-divider" aria-hidden="true"></span>
  <span class="lockup-text">
    <span class="lockup-line lockup-line--brand">BUILDWISE</span>
    <span class="lockup-line lockup-line--media">MEDIA</span>
  </span>
</a>

<style>
.wordmark {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
  color: var(--ink);
  transition: opacity 180ms ease;
}
.wordmark:hover { color: var(--ink); opacity: 0.85; }

.lockup-divider {
  width: 1px;
  height: 1.5em;
  background: currentColor;
  opacity: 0.35;
}

.lockup-text {
  font-size: 14px;
  line-height: 1.05;
  text-transform: uppercase;
  display: flex;
  flex-direction: column;
}

.lockup-line {
  font-family: var(--sans);
  text-transform: uppercase;
}

.lockup-line--brand {
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ink);
}

.lockup-line--media {
  font-weight: 300;
  letter-spacing: 0.12em;
  color: var(--y2);
}

.wordmark--footer .lockup-text { font-size: 13px; }
.wordmark--large .lockup-text { font-size: 22px; }

@media (max-width: 520px) {
  .lockup-text { font-size: 12px; }
}
</style>
