---
const bookingUrl = 'https://book.buildwisemedia.com';
---

<section class="section section--dark">
  <div class="container">
    <div class="final-cta-inner reveal">
      <span class="section-label">Limited Availability</span>
      <h2 class="final-cta-headline">
        We Take On <span class="final-cta-accent">3 New Clients</span> Per Month
      </h2>
      <p class="final-cta-body">
        To deliver real results, we limit our roster. If you're serious about
        growth and ready to invest in a system that works — let's talk.
      </p>
      <a href={bookingUrl} class="cta-btn final-cta-btn">See If I Qualify</a>
      <p class="final-cta-micro">Free 15-min strategy call · No long-term lock-in</p>
    </div>
  </div>
</section>

<style>
  .final-cta-inner {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .final-cta-headline {
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: var(--space-xl);
    letter-spacing: -0.02em;
  }

  .final-cta-accent {
    color: var(--color-terracotta);
    white-space: nowrap;
  }

  .final-cta-body {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-2xl);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .final-cta-btn {
    margin-bottom: var(--space-lg);
  }

  .final-cta-micro {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
