---
// Fit diagnostic gating the booking embed on /book.
// On submit: POSTs to bwm-form-handler /buildwisemedia/discovery-qualifier.
// On qualified: reveals a Market Leak Map summary, then the booking calendar.
// On disqualified: redirects to /thank-you-resource?reason=<reason>.
const poorFour = [
  { value: 'invisible_market', label: 'Invisible Market', body: 'Buyers search, ask, or compare and your business is not the default answer.' },
  { value: 'leaky_revenue', label: 'Leaky Revenue', body: 'Leads, calls, quotes, reviews, or past customers leak before they turn into booked work.' },
  { value: 'owner_bottleneck', label: 'Owner Bottleneck', body: 'Growth still depends on the owner watching the marketing every week.' },
  { value: 'reactive_growth', label: 'Reactive Growth', body: 'The numbers arrive late, decisions feel rushed, and every fix is a correction.' },
];
---

<form id="qualifier-form" class="qualifier-form" novalidate data-current-step="1">
  <div class="q-progress" aria-label="Diagnostic progress">
    <span class="q-progress-bar" data-progress-bar></span>
  </div>

  <header class="q-head">
    <p class="q-eyebrow mono">FIT DIAGNOSTIC · FIVE MINUTES</p>
    <h2 class="q-heading">Build your Market Leak Map before we put time on the calendar.</h2>
    <p class="q-sub">The goal is not more form friction. The goal is a better call: which gap is costing you, where Ascend would intervene, and whether the numbers justify the next step.</p>
  </header>

  <section class="q-step is-active" data-step="1" aria-labelledby="q-step-1">
    <p class="q-step-kicker mono">Step 1 / 5</p>
    <h3 id="q-step-1" class="q-step-title">Who are we mapping?</h3>
    <div class="q-grid">
      <div class="q-row">
        <label class="q-label" for="q-first-name">First name</label>
        <input id="q-first-name" name="first_name" type="text" required autocomplete="given-name" />
      </div>
      <div class="q-row">
        <label class="q-label" for="q-email">Work email</label>
        <input id="q-email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="q-row">
        <label class="q-label" for="q-company">Company</label>
        <input id="q-company" name="company" type="text" required autocomplete="organization" />
      </div>
      <div class="q-row">
        <label class="q-label" for="q-trade">Trade / category</label>
        <input id="q-trade" name="trade" type="text" required placeholder="HVAC, plumbing, roofing..." />
      </div>
      <div class="q-row q-row--wide">
        <label class="q-label" for="q-service-area">Primary service area</label>
        <input id="q-service-area" name="service_area" type="text" required placeholder="Atlanta north metro, Tampa, Greenville..." />
      </div>
    </div>
  </section>

  <section class="q-step" data-step="2" aria-labelledby="q-step-2">
    <p class="q-step-kicker mono">Step 2 / 5</p>
    <h3 id="q-step-2" class="q-step-title">Which leaks feel active?</h3>
    <div class="q-options q-options--grid">
      {poorFour.map((item) => (
        <label class="q-option-card">
          <input type="checkbox" name="selected_poor_four" value={item.value} />
          <span>
            <strong>{item.label}</strong>
            <em>{item.body}</em>
          </span>
        </label>
      ))}
    </div>
  </section>

  <section class="q-step" data-step="3" aria-labelledby="q-step-3">
    <p class="q-step-kicker mono">Step 3 / 5</p>
    <h3 id="q-step-3" class="q-step-title">Where is revenue leaking now?</h3>
    <fieldset class="q-fieldset">
      <legend class="q-label">Lead flow right now</legend>
      <div class="q-options">
        <label><input type="radio" name="lead_flow_state" value="too_few" required /><span>Too few qualified leads</span></label>
        <label><input type="radio" name="lead_flow_state" value="inconsistent" /><span>Good months, quiet months</span></label>
        <label><input type="radio" name="lead_flow_state" value="enough_but_messy" /><span>Enough leads, messy follow-through</span></label>
      </div>
    </fieldset>
    <fieldset class="q-fieldset">
      <legend class="q-label">Follow-up system</legend>
      <div class="q-options">
        <label><input type="radio" name="follow_up_state" value="manual" required /><span>Mostly manual</span></label>
        <label><input type="radio" name="follow_up_state" value="partial" /><span>Some automation, not trusted</span></label>
        <label><input type="radio" name="follow_up_state" value="instrumented" /><span>Instrumented and visible</span></label>
      </div>
    </fieldset>
  </section>

  <section class="q-step" data-step="4" aria-labelledby="q-step-4">
    <p class="q-step-kicker mono">Step 4 / 5</p>
    <h3 id="q-step-4" class="q-step-title">What have you already tried?</h3>
    <fieldset class="q-fieldset">
      <legend class="q-label">Agency history</legend>
      <div class="q-options">
        <label><input type="radio" name="agency_history" value="burned_before" required /><span>Burned by one or more agencies</span></label>
        <label><input type="radio" name="agency_history" value="mixed_results" /><span>Some wins, not a system</span></label>
        <label><input type="radio" name="agency_history" value="mostly_internal" /><span>Mostly handled internally</span></label>
      </div>
    </fieldset>
    <fieldset class="q-fieldset">
      <legend class="q-label">AI comfort</legend>
      <div class="q-options">
        <label><input type="radio" name="ai_comfort" value="ready" required /><span>Ready if humans approve the gates</span></label>
        <label><input type="radio" name="ai_comfort" value="curious_cautious" /><span>Curious, cautious, want proof</span></label>
        <label><input type="radio" name="ai_comfort" value="skeptical" /><span>Skeptical until the math is clear</span></label>
      </div>
    </fieldset>
  </section>

  <section class="q-step" data-step="5" aria-labelledby="q-step-5">
    <p class="q-step-kicker mono">Step 5 / 5</p>
    <h3 id="q-step-5" class="q-step-title">Is there enough readiness to talk?</h3>
    <div class="q-grid">
      <div class="q-row">
        <label class="q-label" for="q-revenue">Operating scale</label>
        <select id="q-revenue" name="revenue_range" required>
          <option value="">Select one</option>
          <option value="under_1m">Early-stage operation</option>
          <option value="1m_3m">Growing local operator</option>
          <option value="3m_8m">Established service team</option>
          <option value="8m_15m">Multi-location or expansion</option>
          <option value="15m_plus">Market leader</option>
        </select>
      </div>
      <div class="q-row">
        <label class="q-label" for="q-offer">Best-fit entry point</label>
        <select id="q-offer" name="offer_interest" required>
          <option value="">Select one</option>
          <option value="ascend_pilot">Ascend Pilot</option>
          <option value="ascend">Ascend</option>
          <option value="ascend_pro">Ascend Pro</option>
          <option value="not_sure">Not sure yet</option>
        </select>
      </div>
    </div>
    <fieldset class="q-fieldset">
      <legend class="q-label">Ad-spend readiness</legend>
      <div class="q-options">
        <label><input type="radio" name="ad_spend_readiness" value="ready_1to1" required /><span>Ready for the 1:1 ad-spend match if the plan is strong</span></label>
        <label><input type="radio" name="ad_spend_readiness" value="need_math" /><span>Need to see the math first</span></label>
        <label><input type="radio" name="ad_spend_readiness" value="not_ready" /><span>Not ready for meaningful distribution budget</span></label>
      </div>
    </fieldset>
    <fieldset class="q-fieldset">
      <legend class="q-label">Are you the decision-maker on marketing investments?</legend>
      <div class="q-options">
        <label><input type="radio" name="decision_maker" value="yes_i_decide" required /><span>Yes, I make the call</span></label>
        <label><input type="radio" name="decision_maker" value="i_influence" /><span>I influence the decision</span></label>
        <label><input type="radio" name="decision_maker" value="no_someone_else" /><span>No, someone else decides</span></label>
      </div>
    </fieldset>
  </section>

  <div class="q-actions">
    <button type="button" class="q-secondary" data-prev hidden>Back</button>
    <button type="button" class="q-submit" data-next>Continue</button>
    <button type="submit" class="q-submit" id="q-submit-btn" hidden>
      <span class="q-submit-label">Build Market Leak Map</span>
      <span class="q-submit-loading" hidden>Building...</span>
    </button>
  </div>

  <p class="q-error" id="q-error" hidden></p>
</form>

<section id="market-leak-map" class="market-leak-map" hidden aria-live="polite">
  <p class="q-eyebrow mono">MARKET LEAK MAP · PREVIEW</p>
  <h2 class="q-heading">Here is what the call should solve.</h2>
  <div class="map-grid">
    <div>
      <p class="map-label mono">Primary leaks</p>
      <p class="map-value" data-map-leaks>Pending</p>
    </div>
    <div>
      <p class="map-label mono">Revenue state</p>
      <p class="map-value" data-map-revenue>Pending</p>
    </div>
    <div>
      <p class="map-label mono">Readiness</p>
      <p class="map-value" data-map-readiness>Pending</p>
    </div>
  </div>
  <p class="map-note">If there is mutual fit, the discovery call uses this map to decide whether Ascend Pilot, Ascend, or Ascend Pro makes sense.</p>
</section>

<script is:inline>
(function () {
  const form = document.getElementById('qualifier-form');
  const submitBtn = document.getElementById('q-submit-btn');
  const nextBtn = form?.querySelector('[data-next]');
  const prevBtn = form?.querySelector('[data-prev]');
  const errorEl = document.getElementById('q-error');
  const steps = form ? Array.from(form.querySelectorAll('[data-step]')) : [];
  const progress = form?.querySelector('[data-progress-bar]');
  let currentStep = 1;

  if (!form || !submitBtn || !nextBtn || !prevBtn || !errorEl) return;

  function event(name, params) {
    try {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(Object.assign({ event: name }, params || {}));
      window.gtag?.('event', name, params || {});
    } catch (_) {}
  }

  function showStep(step) {
    currentStep = Math.max(1, Math.min(step, steps.length));
    steps.forEach((el) => el.classList.toggle('is-active', Number(el.getAttribute('data-step')) === currentStep));
    form.setAttribute('data-current-step', String(currentStep));
    if (progress) progress.style.transform = `scaleX(${currentStep / steps.length})`;
    prevBtn.hidden = currentStep === 1;
    nextBtn.hidden = currentStep === steps.length;
    submitBtn.hidden = currentStep !== steps.length;
    event('diagnostic_step_complete', { diagnostic_step: currentStep });
  }

  function activeFields() {
    const active = form.querySelector(`[data-step="${currentStep}"]`);
    return active ? Array.from(active.querySelectorAll('input, select, textarea')) : [];
  }

  function validateStep() {
    const fields = activeFields();
    const groups = new Map();
    for (const field of fields) {
      if (field.type === 'checkbox') continue;
      if ((field.type === 'radio') && field.required) {
        groups.set(field.name, fields.filter((f) => f.name === field.name));
        continue;
      }
      if (!field.checkValidity()) {
        field.reportValidity();
        return false;
      }
    }
    for (const group of groups.values()) {
      if (!group.some((field) => field.checked)) {
        group[0].reportValidity();
        return false;
      }
    }
    return true;
  }

  function attributionPayload() {
    let stored = {};
    try { stored = JSON.parse(localStorage.getItem('_bwm_attribution') || '{}'); } catch (_) {}
    const params = new URLSearchParams(window.location.search);
    return {
      attribution: stored,
      referrer: sessionStorage.getItem('bwm_referrer') || document.referrer || '',
      landing_page: sessionStorage.getItem('bwm_landing_page') || window.location.href,
      utm_source: params.get('utm_source') || '',
      utm_medium: params.get('utm_medium') || '',
      utm_campaign: params.get('utm_campaign') || '',
      utm_content: params.get('utm_content') || '',
      utm_term: params.get('utm_term') || '',
      fbclid: params.get('fbclid') || '',
      gclid: params.get('gclid') || '',
    };
  }

  function payloadFromForm() {
    const fd = new FormData(form);
    return Object.assign({
      first_name: fd.get('first_name'),
      email: fd.get('email'),
      company: fd.get('company'),
      trade: fd.get('trade'),
      service_area: fd.get('service_area'),
      selected_poor_four: fd.getAll('selected_poor_four'),
      lead_flow_state: fd.get('lead_flow_state'),
      follow_up_state: fd.get('follow_up_state'),
      agency_history: fd.get('agency_history'),
      ai_comfort: fd.get('ai_comfort'),
      ad_spend_readiness: fd.get('ad_spend_readiness'),
      revenue_range: fd.get('revenue_range'),
      offer_interest: fd.get('offer_interest'),
      decision_maker: fd.get('decision_maker'),
    }, attributionPayload());
  }

  function labelForValue(name, value) {
    const field = form.querySelector(`[name="${name}"][value="${value}"]`);
    const label = field?.closest('label');
    return label ? label.textContent.trim().replace(/\s+/g, ' ') : String(value || 'Pending');
  }

  function poorFourLabel(value) {
    const field = form.querySelector(`[name="selected_poor_four"][value="${value}"]`);
    return field?.closest('label')?.querySelector('strong')?.textContent?.trim() || String(value || 'Pending');
  }

  function revealLeakMap(payload) {
    const map = document.getElementById('market-leak-map');
    if (!map) return;
    const leakLabels = payload.selected_poor_four.length
      ? payload.selected_poor_four.map(poorFourLabel).join(', ')
      : 'No primary leak selected';
    map.querySelector('[data-map-leaks]').textContent = leakLabels;
    map.querySelector('[data-map-revenue]').textContent = labelForValue('lead_flow_state', payload.lead_flow_state);
    map.querySelector('[data-map-readiness]').textContent = labelForValue('ad_spend_readiness', payload.ad_spend_readiness);
    map.hidden = false;
  }

  nextBtn.addEventListener('click', () => {
    if (!validateStep()) return;
    if (currentStep === 1) event('diagnostic_start', { form_id: 'fit-diagnostic' });
    showStep(currentStep + 1);
  });

  prevBtn.addEventListener('click', () => showStep(currentStep - 1));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateStep()) return;
    errorEl.hidden = true;
    submitBtn.disabled = true;
    submitBtn.querySelector('.q-submit-label').hidden = true;
    submitBtn.querySelector('.q-submit-loading').hidden = false;

    const payload = payloadFromForm();

    try {
      const res = await fetch('https://bwm-form-handler.robert-ba0.workers.dev/buildwisemedia/discovery-qualifier', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(`Server ${res.status}`);
      const data = await res.json();

      event('diagnostic_submit', {
        form_id: 'fit-diagnostic',
        classification: data.classification,
        selected_poor_four: payload.selected_poor_four.join(','),
        offer_interest: payload.offer_interest,
      });

      if (data.classification === 'qualified') {
        window.gtag?.('event', 'generate_lead', {
          currency: 'USD',
          value: 0,
          form_id: 'fit-diagnostic',
          tier_routing: data.tier_routing,
        });

        revealLeakMap(payload);
        form.style.display = 'none';
        const calWrap = document.getElementById('cal-inline');
        if (calWrap) {
          calWrap.removeAttribute('hidden');
          calWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        window.__qualifiedPrefill = {
          name: payload.first_name,
          email: payload.email,
          tier_routing: data.tier_routing,
          contact_id: data.contact_id,
        };
        if (window.__loadBwmCalendar) {
          window.__loadBwmCalendar({
            name: payload.first_name,
            email: payload.email,
            tier_routing: data.tier_routing,
            contact_id: data.contact_id,
          });
        } else if (window.Cal && window.Cal.ns && window.Cal.ns['discovery-call']) {
          window.Cal.ns['discovery-call']('inline', {
            elementOrSelector: '#cal-inline',
            calLink: 'bwm/discovery-call',
            config: {
              name: payload.first_name,
              email: payload.email,
              theme: 'dark',
            },
          });
        }
      } else if (data.classification === 'disqualified') {
        const reason = encodeURIComponent(data.reason || 'fit_check');
        window.location.href = `/thank-you-resource?reason=${reason}`;
      } else {
        throw new Error('Unexpected response');
      }
    } catch (err) {
      console.error('Diagnostic submit failed:', err);
      errorEl.textContent = 'Something went wrong. Please try again, or email hello@buildwisemedia.com.';
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitBtn.querySelector('.q-submit-label').hidden = false;
      submitBtn.querySelector('.q-submit-loading').hidden = true;
    }
  });

  showStep(1);
})();
</script>

<style>
.qualifier-form,
.market-leak-map {
  display: flex;
  flex-direction: column;
  gap: 24px;
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  padding: clamp(24px, 4vw, 40px);
}
.market-leak-map[hidden] { display: none; }
.q-progress {
  height: 3px;
  background: var(--rule);
  overflow: hidden;
}
.q-progress-bar {
  display: block;
  width: 100%;
  height: 100%;
  background: var(--y2);
  transform: scaleX(0.2);
  transform-origin: left;
  transition: transform 180ms ease;
}
.q-head {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.q-eyebrow,
.q-step-kicker {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--y2);
  margin: 0;
}
.q-heading {
  font-family: var(--sans);
  font-weight: 800;
  font-size: clamp(22px, 2.5vw, 32px);
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin: 0;
  color: var(--ink);
}
.q-sub {
  font-size: 15px;
  line-height: 1.55;
  color: var(--ink-dim);
  margin: 0;
}
.q-step { display: none; }
.q-step.is-active {
  display: flex;
  flex-direction: column;
  gap: 22px;
}
.q-step-title {
  font-size: clamp(24px, 2.6vw, 36px);
  line-height: 1.1;
  margin: 0;
}
.q-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}
.q-row,
.q-fieldset {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.q-row--wide { grid-column: 1 / -1; }
.q-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-dim);
}
.q-row input,
.q-row select {
  background: transparent;
  border: 1px solid var(--rule);
  color: var(--ink);
  padding: 13px 14px;
  font-family: var(--sans);
  font-size: 15px;
  outline: none;
}
.q-row input:focus,
.q-row select:focus {
  border-color: var(--y2);
}
.q-fieldset {
  border: none;
  padding: 0;
  margin: 0;
}
.q-fieldset legend {
  padding: 0;
  margin-bottom: 4px;
}
.q-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.q-options--grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}
.q-options label,
.q-option-card {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 14px;
  border: 1px solid var(--rule);
  cursor: pointer;
  font-size: 14px;
  color: var(--ink-dim);
  transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
}
.q-options label:hover,
.q-option-card:hover {
  border-color: var(--ink-faint);
}
.q-options input[type="radio"],
.q-options input[type="checkbox"] {
  appearance: none;
  width: 15px;
  height: 15px;
  border: 1px solid var(--ink-faint);
  border-radius: 50%;
  margin: 3px 0 0;
  flex-shrink: 0;
  position: relative;
}
.q-options input[type="checkbox"] {
  border-radius: 2px;
}
.q-options input:checked {
  border-color: var(--y2);
}
.q-options input:checked::after {
  content: '';
  position: absolute;
  inset: 3px;
  background: var(--y2);
  border-radius: inherit;
}
.q-options label:has(input:checked),
.q-option-card:has(input:checked) {
  border-color: var(--y2);
  color: var(--ink);
  background: rgba(240, 255, 0, 0.035);
}
.q-option-card strong {
  display: block;
  color: var(--ink);
  margin-bottom: 5px;
}
.q-option-card em {
  display: block;
  font-style: normal;
  font-size: 13px;
  line-height: 1.45;
  color: var(--ink-dim);
}
.q-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.q-submit,
.q-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 24px;
  font-family: var(--sans);
  font-weight: 700;
  font-size: 15px;
  cursor: pointer;
}
.q-submit {
  background: var(--y2);
  color: var(--bg);
  border: 1px solid var(--y2);
  flex: 1;
}
.q-secondary {
  border: 1px solid var(--rule-bright);
  color: var(--ink);
  min-width: 120px;
}
.q-submit:hover:not(:disabled),
.q-secondary:hover {
  opacity: 0.85;
}
.q-submit:disabled {
  cursor: wait;
  opacity: 0.6;
}
.q-error {
  color: #ff6b6b;
  font-size: 14px;
  margin: 0;
}
.map-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.map-grid > div {
  background: var(--bg);
  padding: 18px;
}
.map-label {
  font-size: 9px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
}
.map-value {
  margin-top: 10px;
  font-size: 18px;
  line-height: 1.25;
  color: var(--ink);
}
.map-note {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

@media (max-width: 680px) {
  .q-grid,
  .q-options--grid,
  .map-grid {
    grid-template-columns: 1fr;
  }
  .q-submit,
  .q-secondary {
    width: 100%;
  }
}
</style>
