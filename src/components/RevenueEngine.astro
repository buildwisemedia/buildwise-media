---
const bookingUrl = 'https://book.buildwisemedia.com';

const stages = [
  {
    num: '01',
    title: 'Market Research & Positioning',
    desc: 'We study your market, competitors, and ideal customers — then craft messaging that makes you the obvious choice.',
  },
  {
    num: '02',
    title: 'Website That Converts',
    desc: 'A fast, mobile-first site built to turn visitors into booked appointments — not just look pretty.',
  },
  {
    num: '03',
    title: 'Search Domination',
    desc: 'Local SEO and Google Business optimization so you show up when homeowners search for what you do.',
  },
  {
    num: '04',
    title: 'Paid Ads That Pay Back',
    desc: 'Targeted campaigns on Google and Meta that put your business in front of buyers ready to hire — today.',
  },
  {
    num: '05',
    title: 'Automated Follow-Up',
    desc: 'AI-powered systems that respond to leads in seconds, nurture them automatically, and book appointments while you sleep.',
  },
  {
    num: '06',
    title: 'Track, Optimize, Scale',
    desc: 'Real-time dashboards and weekly reporting so you always know what\'s working — and where the next dollar is coming from.',
  },
];
---

<section class="section" id="how-it-works">
  <div class="container">
    <div class="engine-header reveal">
      <span class="section-label">How It Works</span>
      <h2 class="section-title">The Revenue Engine</h2>
      <p class="section-subtitle">
        Six integrated stages that turn your business into a lead-generating machine — without adding more to your plate.
      </p>
    </div>
    <div class="engine-grid">
      {stages.map((stage, i) => (
        <div class={`engine-card reveal reveal-delay-${(i % 4) + 1}`}>
          <span class="engine-num">{stage.num}</span>
          <h3 class="engine-card-title">{stage.title}</h3>
          <p class="engine-card-desc">{stage.desc}</p>
        </div>
      ))}
    </div>
    <div class="engine-footer reveal">
      <a href={bookingUrl} class="cta-btn">See If I Qualify</a>
    </div>
  </div>
</section>

<style>
  .engine-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .engine-header .section-subtitle {
    margin: 0 auto;
  }

  .engine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 1000px;
    margin: 0 auto;
  }

  .engine-card {
    padding: var(--space-2xl);
    background: var(--surface-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-base), transform var(--transition-base), box-shadow var(--transition-base);
  }

  .engine-card:hover {
    border-color: var(--border-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .engine-num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-terracotta);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-lg);
  }

  .engine-card-title {
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .engine-card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .engine-footer {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  @media (max-width: 768px) {
    .engine-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    .engine-card {
      padding: var(--space-xl);
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .engine-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
