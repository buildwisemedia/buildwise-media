---
import BaseLayout from '../../layouts/BaseLayout.astro';
import canonical from '../../data/canonical.json';

const title = "Ascend — Buildwise Media";
const description = "Ascend is the 8-layer revenue operating system Buildwise installs and runs for service businesses. Visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy connected as one system.";

const ascend = canonical.products.ascend;
const pro = canonical.products.ascend_pro;
const pilot = canonical.products.pilot;

const publicLayerBody = (body: string) => body
  .replace(/\s*\([^)]*\)/g, '')
  .replace(/GBP \+ AEO \+ local SEO \+ schema \+ citations \+ AI-search readiness/g, 'local search, AEO, schema, citations, and AI-search readiness')
  .replace(/Instant SMS\/email\/call follow-up · automated qualification · appointment routing · .* integration/g, 'instant follow-up, automated qualification, appointment routing, and operations integration')
  .replace(/Campaign monitoring · creative testing · budget alerts · lead-quality feedback · .*/g, 'Campaign monitoring, creative testing, budget alerts, and lead-quality feedback')
  .replace(/\s+/g, ' ')
  .trim();

const layers = canonical.products.ascend.eight_layers.map((raw: string, i: number) => {
  const dashIndex = raw.indexOf('—');
  const dotIndex = raw.indexOf('·');
  const name = dashIndex > 0 ? raw.slice(dotIndex + 1, dashIndex).trim() : raw.slice(dotIndex + 1).trim();
  const body = dashIndex > 0 ? publicLayerBody(raw.slice(dashIndex + 1).trim()) : '';
  return { n: String(i + 1).padStart(2, '0'), name, body };
});

const phases = [
  { n: '01', name: 'Audit', body: 'Capture the baseline, name the Poor Four gaps, and identify the first layer that should move revenue fastest.' },
  { n: '02', name: 'Install', body: 'Wire the site, conversion paths, follow-up, attribution, reporting, and weekly operating rhythm into your business.' },
  { n: '03', name: 'Run', body: 'Operate the system weekly: review the math, clear human signoff gates, adjust what is underperforming, and keep the asset compounding.' },
];

const commitments = [
  '30-day system-live path from diagnostic to operating rhythm.',
  'HITL signoff on every autonomous deploy.',
  'Client owns code, data, ad accounts, customer list, and built assets.',
  '5x attributable ROI within 24 months or Buildwise keeps building.',
  'True month-to-month after Day 90: no clawback, no exit fee.',
];

const offers = [
  { name: pilot.name, price: pilot.price.oneshot_display, note: 'one-time · 45-day proof sprint' },
  { name: ascend.name, price: ascend.price.recurring_display, note: `+ ${ascend.price.oneshot_display} install · main product` },
  { name: pro.name, price: pro.price.recurring_display, note: `+ ${pro.price.oneshot_display} install · multi-location / Pro` },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://buildwisemedia.com/services' },
    { '@type': 'ListItem', position: 3, name: 'Ascend', item: 'https://buildwisemedia.com/services/ascend' },
  ],
};

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/services/ascend#service',
  name: 'Ascend',
  serviceType: '8-layer revenue operating system for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description,
  url: 'https://buildwisemedia.com/services/ascend',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Ascend offers',
    itemListElement: [
      { '@type': 'Offer', name: pilot.name, price: pilot.price.oneshot, priceCurrency: 'USD' },
      { '@type': 'Offer', name: ascend.name, price: ascend.price.recurring, priceCurrency: 'USD' },
      { '@type': 'Offer', name: pro.name, price: pro.price.recurring, priceCurrency: 'USD' },
    ],
  },
};
---
<BaseLayout title={title} description={description} jsonLd={[service, breadcrumb]}>

  <section class="ascend-hero">
    <div class="container ascend-hero-grid">
      <div>
        <p class="eyebrow">Ascend · the operating system</p>
        <h1 class="h-hero">The 8-layer system that makes you the most-chosen name in your market.</h1>
        <p class="hero-sub">
          Ascend is installed on your domain, run by Buildwise, and owned by your business. It connects visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy so marketing behaves like operations.
        </p>
        <div class="hero-ctas">
          <a href="/book" class="cta" data-cta-source="ascend-hero">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href="#layers" class="cta-ghost" data-cta-source="ascend-hero-secondary">See What's Inside</a>
        </div>
      </div>

      <aside class="ascend-panel" aria-label="Ascend operating preview">
        <p class="panel-label mono">System state</p>
        <p class="panel-number">8</p>
        <p class="panel-copy">layers installed, measured, and adjusted as one operating rhythm.</p>
        <div class="panel-bars" aria-hidden="true">
          {layers.map((layer) => <span title={layer.name}></span>)}
        </div>
      </aside>
    </div>
  </section>

  <section id="layers" class="layers-section elev">
    <div class="container">
      <header class="section-head">
        <p class="section-tag">What gets installed</p>
        <h2 class="h-section">Eight layers. One revenue system.</h2>
        <p class="lede">Each layer can improve on its own. The compounding starts when they are wired together.</p>
      </header>
      <div class="layers-grid">
        {layers.map((layer) => (
          <article class="layer-card">
            <p class="layer-num mono">{layer.n}</p>
            <h3>{layer.name}</h3>
            <p>{layer.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="container process-grid">
      <header class="section-head">
        <p class="section-tag">How it runs</p>
        <h2 class="h-section">Audit. Install. Run.</h2>
        <p class="lede">The install is the start. The weekly operating rhythm is the product.</p>
      </header>
      <ol class="process-list" role="list">
        {phases.map((phase) => (
          <li>
            <span class="process-num mono">{phase.n}</span>
            <h3>{phase.name}</h3>
            <p>{phase.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="commitments-section elev">
    <div class="container commitments-grid">
      <header class="section-head">
        <p class="section-tag">Risk reversal</p>
        <h2 class="h-section">The asset stays in your hands.</h2>
        <p class="lede">Ascend is not a black box. The system is yours, the reporting is visible, and the engagement earns its place every month.</p>
      </header>
      <ul class="commitment-list" role="list">
        {commitments.map((item) => (
          <li><span class="dot live"></span><span>{item}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <section class="pricing-snapshot" id="pilot">
    <div class="container">
      <header class="section-head">
        <p class="section-tag">Pricing snapshot</p>
        <h2 class="h-section">Three ways to enter Ascend.</h2>
      </header>
      <div class="offer-grid">
        {offers.map((offer) => (
          <article class="offer-card">
            <p class="offer-name mono">{offer.name}</p>
            <p class="offer-price">{offer.price}</p>
            <p>{offer.note}</p>
          </article>
        ))}
      </div>
      <p class="pricing-link"><a href="/pricing" class="cta-ghost" data-cta-source="ascend-pricing">See full pricing<span class="cta-arrow" aria-hidden="true">→</span></a></p>
    </div>
  </section>

  <section class="ascend-cta elev">
    <div class="container ascend-cta-row">
      <div>
        <h2 class="h-closer">Find the leak before you buy the system.</h2>
        <p class="lede" style="margin-top: 16px;">The fit diagnostic creates the Market Leak Map we use on the discovery call.</p>
      </div>
      <a href="/book" class="cta" data-cta-source="ascend-final">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
    </div>
  </section>

</BaseLayout>

<style>
.ascend-hero { padding-top: clamp(132px, 14vw, 188px); padding-bottom: clamp(64px, 8vw, 112px); }
.ascend-hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
  gap: clamp(40px, 6vw, 88px);
  align-items: center;
}
.hero-sub { margin-top: 24px; }
.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 32px; }
.ascend-panel {
  border: 1px solid var(--rule-bright);
  background: var(--bg-card);
  padding: clamp(28px, 4vw, 44px);
}
.panel-label,
.layer-num,
.process-num,
.offer-name {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--y2);
}
.panel-number {
  font-size: clamp(96px, 13vw, 170px);
  font-weight: 800;
  font-stretch: 75%;
  line-height: 0.8;
  letter-spacing: -0.07em;
  color: var(--y2);
  margin-block: 24px 18px;
}
.panel-copy {
  color: var(--ink-dim);
  font-size: 17px;
  line-height: 1.55;
}
.panel-bars {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 6px;
  margin-top: 34px;
}
.panel-bars span {
  height: clamp(48px, 7vw, 92px);
  border: 1px solid var(--rule);
  background: linear-gradient(to top, rgba(240,255,0,0.18), rgba(240,255,0,0.02));
}
.section-head { max-width: 780px; margin-bottom: 48px; }
.section-head .lede { margin-top: 20px; }
.layers-section,
.process-section,
.commitments-section,
.pricing-snapshot { padding-block: var(--section-y); }
.layers-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.layer-card {
  background: var(--bg-card);
  padding: 28px 24px;
}
.layer-card h3 {
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.1;
  margin-block: 12px;
}
.layer-card p:last-child {
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.55;
}
.process-grid,
.commitments-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
  gap: clamp(40px, 6vw, 80px);
}
.process-list,
.commitment-list {
  list-style: none;
  display: grid;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.process-list li,
.commitment-list li {
  background: var(--bg-card);
  padding: 28px;
}
.process-list h3 {
  font-size: clamp(28px, 3.6vw, 48px);
  line-height: 1;
  margin-block: 12px;
}
.process-list p,
.commitment-list li {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.6;
}
.commitment-list li {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.commitment-list .dot { margin-top: 9px; flex: none; }
.offer-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.offer-card {
  background: var(--bg-card);
  padding: 30px;
}
.offer-price {
  font-size: clamp(36px, 4.6vw, 62px);
  font-weight: 800;
  font-stretch: 75%;
  letter-spacing: -0.05em;
  line-height: 1;
  color: var(--ink);
  margin-block: 18px 12px;
}
.offer-card p:last-child {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.5;
}
.pricing-link { margin-top: 28px; }
.ascend-cta { padding-block: 80px; }
.ascend-cta-row { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }

@media (max-width: 960px) {
  .ascend-hero-grid,
  .process-grid,
  .commitments-grid { grid-template-columns: 1fr; }
  .layers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .offer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .layers-grid { grid-template-columns: 1fr; }
  .hero-ctas .cta,
  .hero-ctas .cta-ghost,
  .ascend-cta .cta {
    width: 100%;
    justify-content: center;
  }
}
</style>
