---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const title = "Services — Buildwise Media";
const description = "Buildwise Media installs one integrated 8-layer revenue operating system: Ascend.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://buildwisemedia.com/services' },
  ],
};

// FAQ — voice-search phrased, mined from on-page copy. FAQPage schema emitted
// alongside the rendered <FAQ> section so answer engines see matching content.
const faqs = [
  {
    q: 'What services does Buildwise Media offer?',
    a: 'One. We install a single integrated product — Ascend, an 8-layer revenue operating system — instead of a menu of separate services. Visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy run as one system, not six invoices.',
  },
  {
    q: 'Why only one product instead of a service menu?',
    a: 'Most agencies pad the menu so every line item bills separately. The real work is one operating system, so that is what we sell — one stack, one source of truth, one dashboard, and nobody left holding the integration.',
  },
  {
    q: 'What is included in Ascend?',
    a: 'All eight layers, wired together and measured against a captured baseline: visibility for search and AI answers, conversion paths, speed-to-lead, sales ops, reputation, paid media, reporting, and weekly strategy. You own the code, data, ad accounts, and customer list.',
  },
  {
    q: 'How is this different from hiring an agency?',
    a: 'You own the system instead of renting a service. The engagement is month-to-month, the math is visible from Day 1, and the agreement holds a 5× attributable ROI floor inside 24 months — or we keep building.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/services#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[breadcrumb, faqSchema]}>

  <section class="services-hero">
    <div class="container">
      <p class="eyebrow">Services · Single product, deeply integrated</p>
      <h1 class="h-hero">
        We don't sell six services.<br class="hero-br"/>
        We install <em>one</em> operating system.
      </h1>
      <p class="hero-sub" style="max-width: 720px;">
        Most agencies pad the menu. We pulled ours down to one offering — Ascend — because that's what the work actually is. Below is what's inside it.
      </p>
      <figure class="section-photo section-photo--diagram">
        <!-- @r020:F4 curiosity: structural visual of the 8-layer architecture -->
        <img src="/images/stacked-planes-v1.svg" alt="Isometric stacked planes — one integrated operating system rendered as layered structure." width="1200" height="675" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="single-card-section elev">
    <div class="container">

      <a href="/services/ascend" class="ascend-card">
        <div class="card-head">
          <p class="kpi-label mono">Single product</p>
          <p class="card-chip mono">Month-to-month</p>
        </div>

        <h2 class="card-h">Ascend — the 8-layer revenue operating system</h2>

        <p class="card-lede">
          Verifiable autonomous marketing system, installed and operated. Visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy — all wired together, all measured against a captured baseline, all observable in one operating rhythm.
        </p>

        <ul class="inside-list" role="list">
          <li><span class="dot live"></span><span>Visibility system for search, AI answers, local presence, schema, and citations</span></li>
          <li><span class="dot live"></span><span>Conversion paths, offers, forms, call tracking, and quote flow improvements</span></li>
          <li><span class="dot live"></span><span>Speed-to-lead automation and appointment routing with human oversight</span></li>
          <li><span class="dot live"></span><span>Sales ops, reputation, paid media, reporting, and strategy connected weekly</span></li>
          <li><span class="dot live"></span><span>Client-owned code, data, ad accounts, customer list, and system assets</span></li>
          <li><span class="dot live"></span><span>5x attributable ROI floor within 24 months or we keep building</span></li>
        </ul>

        <p class="outcome-cue mono">→ All 8 layers wire into one operating system</p>

        <figure class="section-photo section-photo--diagram">
          <!-- @r020:F2 proof: visual data flow showing stage transition values -->
          <img src="/images/funnel-5-layer-v1.svg" alt="Isometric five-layer funnel diagram with stage labels — visits, inquired, leads, booked, won — showing the path from website visitor to paying customer." width="1200" height="733" loading="lazy" decoding="async" />
        </figure>

        <p class="card-cta-row">
          <span class="card-cta-label mono">See the deep dive</span>
          <span class="card-cta-arrow" aria-hidden="true">→</span>
        </p>
      </a>

    </div>
  </section>

  <section class="services-atmosphere">
    <div class="container">
      <figure class="section-photo section-photo--banner">
        <!-- @r020:F4 curiosity: atmospheric dusk studio photo showing system automation -->
        <img src="/images/bwm-services-atmospheric-v1.webp" alt="An empty modern workspace at dusk: laptop glowing cool, coffee mug, notebook — the operator stepped away while the system kept running." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <!-- FAQ — answer-engine extractable Q&A, matches FAQPage schema -->
  <FAQ faqs={faqs} />

  <section class="services-cta">
    <div class="container about-cta-row">
      <div>
        <h2 class="h-closer">Not sure if Ascend is the right <em>fit?</em></h2>
        <p class="lede" style="margin-top: 16px;">Fifteen minutes tells us — and you — whether the system matches your shop.</p>
      </div>
      <a href="/book" class="cta" data-cta-source="services-hub">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
    </div>
  </section>

</BaseLayout>

<style>
.services-hero { padding-top: clamp(100px, 10vw, 132px); padding-bottom: clamp(60px, 8vw, 100px); }
.services-hero .eyebrow { margin-bottom: 22px; }
.services-hero .h-hero {
  font-size: clamp(34px, 4.4vw, 58px);
  line-height: 0.98;
  letter-spacing: -0.03em;
  margin-bottom: 24px;
  text-wrap: balance;
}

.single-card-section { padding-block: var(--section-y); }

.ascend-card {
  display: block;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  padding: clamp(32px, 5vw, 64px);
  text-decoration: none;
  color: var(--ink);
  transition: border-color 220ms ease;
}
.ascend-card:hover {
  border-color: var(--y2);
}
.ascend-card:hover .card-cta-arrow { color: var(--y2); }

.card-head { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding-bottom: 24px; border-bottom: 1px solid var(--rule); margin-bottom: 32px; flex-wrap: wrap; }
.card-chip { border: 1px solid var(--rule-bright); padding: 6px 12px; font-size: 10px; letter-spacing: 0.2em; color: var(--ink-dim); }

.card-h { font-family: var(--sans); font-weight: 800; font-stretch: 75%; font-size: clamp(40px, 5vw, 64px); letter-spacing: -0.02em; line-height: 1.05; text-transform: uppercase; }

.card-lede { font-family: var(--sans); font-weight: 300; font-size: clamp(18px, 1.6vw, 22px); line-height: 1.55; color: var(--ink-dim); margin-block: 28px 32px; max-width: 880px; }

.inside-list { list-style: none; display: flex; flex-direction: column; gap: 14px; padding-top: 24px; border-top: 1px solid var(--rule); }
.inside-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; font-weight: 300; line-height: 1.5; color: var(--ink-dim); }
.inside-list .dot { margin-top: 8px; }

.outcome-cue {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-dim);
  margin-top: 32px;
  margin-bottom: -8px;
  text-align: center;
}

.card-cta-row { display: flex; align-items: center; gap: 12px; padding-top: 32px; margin-top: 24px; border-top: 1px solid var(--rule); }
.card-cta-label { font-size: 11px; letter-spacing: 0.25em; color: var(--y2); }
.card-cta-arrow { color: var(--ink-dim); font-family: var(--mono); font-size: 18px; transition: transform 220ms ease, color 220ms ease; }

.services-cta { padding-block: 80px; }
.services-atmosphere { padding-block: clamp(48px, 7vw, 96px); }
.about-cta-row { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }

.section-photo {
  margin: clamp(40px, 6vw, 72px) 0 0;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--rule);
  aspect-ratio: 21 / 9;
  width: 100%;
}
.section-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.section-photo--banner {
  aspect-ratio: 21 / 9;
  margin-top: 0;
  margin-bottom: 0;
}
.section-photo--diagram {
  aspect-ratio: 16 / 10;
  max-width: 720px;
  margin-inline: auto;
  margin-top: clamp(32px, 5vw, 56px);
  background: #050507;
}
.section-photo--diagram img {
  object-fit: contain;
}

@media (max-width: 880px) {
  .section-photo, .section-photo--banner {
    aspect-ratio: 16 / 10;
  }
}

@media (max-width: 600px) {
  .services-hero .hero-br {
    display: none;
  }
}
</style>
