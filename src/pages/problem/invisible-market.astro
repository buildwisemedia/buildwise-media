---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Invisible Market — Buildwise Media";
const description = "When buyers search for what you do, they can't find you. Invisible Market is a system failure. Here's how we close it.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Invisible Market', item: 'https://buildwisemedia.com/problem/invisible-market' },
  ],
};

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/problem/invisible-market#fix',
  name: 'Invisible Market fix — AI-search and local visibility engine',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Installs AI-search citation coverage, local SEO dominance, and AEO discipline so your business shows up where buyers are already looking — in search results, AI assistants, and local map packs.',
  url: 'https://buildwisemedia.com/problem/invisible-market',
};

const faqs = [
  {
    q: 'How do I get my service business found online in 2026?',
    a: 'Getting found in 2026 means owning three surfaces simultaneously: traditional search rankings, local map packs, and the AI assistants that buyers now ask instead of typing into a search bar. Most service businesses are visible on none of them in any systematic way. We install the full coverage layer — optimized local presence, neighborhood-level content, and the citation signals that AI assistants use to recommend businesses — so buyers find you wherever they look.',
  },
  {
    q: 'Why don\'t AI assistants recommend my business?',
    a: 'AI assistants pull from structured signals: authoritative mentions across the web, consistent business data, review depth, and topic authority. Most service businesses have none of these built intentionally. The result is that AI answers recommend whoever has invested in those signals — usually your largest or most-established competitor. We close the gap by building the citation infrastructure and content authority that AI assistants treat as trust signals.',
  },
  {
    q: 'How fast can I dominate local search in my market?',
    a: 'Meaningful local visibility movement starts within the first 30 days — business profile saturation, foundational citation cleanup, and neighborhood-level content all produce measurable shifts quickly. Full market dominance — where your name appears first across search, map packs, and AI assistants — compounds over 90 days. The system is running and producing data before the second invoice.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/problem/invisible-market#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[service, breadcrumb, faqSchema]}>

  <section class="problem-hero">
    <div class="container problem-hero-grid">
      <div>
        <p class="eyebrow"><a href="/#problem" class="back-link">← The Poor Four</a> · 01</p>
        <h1 class="h-hero">
          Invisible <em>market.</em>
        </h1>
        <p class="hero-sub">
          When buyers search for what you do, they can't find you. When they hear your name, they don't remember it. When competitors show up first in search, in AI answers, and in their friend's recommendation, you start every quarter from behind. Visibility is the foundation everything else depends on.
        </p>
        <p class="cta-row">
          <a class="cta-primary" href="/book" data-cta-source="problem-invisible-market-hero-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
          <a class="cta-ghost" href="/book" data-cta-source="problem-invisible-market-hero-secondary">See If We're a Fit</a>
        </p>
      </div>
      <aside class="problem-panel" aria-label="Visibility signal">
        <div class="problem-panel-head">
          <p class="panel-label mono">VISIBILITY SIGNAL</p>
        </div>
        <!-- @r020:F4 curiosity: the matrix makes the missing-name problem visible across the three surfaces buyers already use. -->
        <figure class="scene-fig panel-fig">
          <svg viewBox="0 0 300 200" role="img" aria-label="Diagram: search, AI assistant, and map pack all show an empty node for you and a filled competitor node.">
            <text class="fx-label" x="144" y="28" text-anchor="middle">YOU</text>
            <text class="fx-label" x="236" y="28" text-anchor="middle">COMPETITOR</text>
            <line class="fx-hair" x1="24" y1="46" x2="276" y2="46" />
            <line class="fx-hair" x1="24" y1="86" x2="276" y2="86" />
            <line class="fx-hair" x1="24" y1="126" x2="276" y2="126" />
            <text class="fx-label" x="24" y="68">SEARCH</text>
            <text class="fx-label" x="24" y="108">AI ASSISTANT</text>
            <text class="fx-label" x="24" y="148">MAP PACK</text>
            <rect class="fx-vertex faint-node" x="140" y="60" width="8" height="8" />
            <rect class="fx-vertex faint-node" x="140" y="100" width="8" height="8" />
            <rect class="fx-vertex faint-node" x="140" y="140" width="8" height="8" />
            <rect class="fx-vertex-filled diag-accent-fill" x="232" y="60" width="8" height="8" />
            <rect class="fx-vertex-filled diag-accent-fill" x="232" y="100" width="8" height="8" />
            <rect class="fx-vertex-filled diag-accent-fill" x="232" y="140" width="8" height="8" />
            <text class="fx-caption" x="24" y="178">THREE SURFACES BUYERS USE.</text>
            <text class="fx-caption" x="24" y="192">A COMPETITOR OWNS ALL THREE.</text>
          </svg>
        </figure>
      </aside>
    </div>
  </section>

  <section class="problem-cost elev">
    <div class="container">
      <p class="section-tag">What it actually costs</p>
      <h2 class="h-section">The cost of staying hidden.</h2>
      <ol class="cost-list" role="list">
        <li><strong>Buyer-intent searches go to someone else.</strong> Every day, buyers in your market search for exactly what you offer. If you're not on the first page — and increasingly, in the AI answer — that search routes to a competitor. You never know the opportunity existed.</li>
        <li><strong>AI assistants recommend your competitors by name.</strong> When a buyer asks an AI assistant who to call for your service, it cites businesses with authoritative citation signals. If you haven't built those signals, your name doesn't come up — and the buyer assumes the recommendation is definitive.</li>
        <li><strong>Brand recall erodes as competitors out-publish you.</strong> Visibility is cumulative. Every piece of content a competitor publishes, every review they earn, every citation they build makes their name stickier. Silence compounds into irrelevance faster than most owners expect.</li>
        <li><strong>High-intent local-pack searches convert to someone else.</strong> Local map pack results drive the highest-intent clicks in local search. If your business profile is incomplete, under-reviewed, or missing neighborhood-level content, you're invisible at the exact moment buyers are ready to call.</li>
      </ol>
      <!-- @r020:F2 proof: the fork diagram shows how a live buyer path routes to the visible competitor when your node is empty. -->
      <figure class="scene-fig" style="max-width: 520px;">
        <svg viewBox="0 0 520 140" role="img" aria-label="Diagram: a buyer search forks toward a lit competitor path and away from an empty you node.">
          <rect class="fx-vertex" x="36" y="66" width="8" height="8" />
          <text class="fx-label" x="40" y="96" text-anchor="middle">BUYER</text>
          <line class="fx-hair" x1="44" y1="70" x2="182" y2="70" />
          <rect class="fx-vertex" x="182" y="66" width="8" height="8" />
          <line class="fx-hair diag-accent" x1="190" y1="70" x2="402" y2="38" />
          <polyline class="diag-accent" points="396,34 402,38 397,44" fill="none" />
          <rect class="fx-vertex-filled diag-accent-fill" x="414" y="34" width="8" height="8" />
          <text class="fx-label diag-accent-label" x="418" y="26" text-anchor="middle">COMPETITOR</text>
          <line class="fx-hair" x1="190" y1="70" x2="402" y2="106" stroke-dasharray="3 4" />
          <polyline class="fx-hair" points="396,100 402,106 394,109" fill="none" />
          <rect class="fx-vertex faint-node" x="414" y="102" width="8" height="8" />
          <text class="fx-label" x="418" y="128" text-anchor="middle">YOU</text>
          <text class="fx-caption" x="24" y="132">EVERY UNANSWERED SEARCH ROUTES TO SOMEONE ELSE.</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="problem-fix">
    <div class="container">
      <p class="section-tag">How we close it</p>
      <h2 class="h-section">Built to be <em>found</em>.</h2>
      <p class="lede">
        Invisible Market isn't a content problem. It's a missing signals system. We install AI-search citation coverage, local SEO dominance, and AEO discipline so your business shows up where buyers are already looking — in search results, AI assistants, and map packs.
      </p>
      <p class="prose">
        The system covers all three surfaces simultaneously: structured local presence so map packs and AI assistants trust your data, neighborhood-level content so you rank for high-intent local searches, and citation authority so the AI assistants buyers now rely on cite you by name. Built in 30 days, not 90.
      </p>
      <!-- @r020:F3 CTA-pull: the convergence diagram turns the offer into a concrete signal-build path that ends with your name being selected. -->
      <figure class="scene-fig" style="max-width: 520px;">
        <svg viewBox="0 0 520 150" role="img" aria-label="Diagram: citations, local SEO, and content converge into a filled your name node across AI answers, map pack, and search.">
          <line class="fx-hair diag-accent" x1="122" y1="32" x2="258" y2="74" />
          <line class="fx-hair diag-accent" x1="122" y1="72" x2="258" y2="74" />
          <line class="fx-hair diag-accent" x1="122" y1="112" x2="258" y2="74" />
          <rect class="fx-vertex" x="112" y="28" width="8" height="8" />
          <rect class="fx-vertex" x="112" y="68" width="8" height="8" />
          <rect class="fx-vertex" x="112" y="108" width="8" height="8" />
          <text class="fx-label" x="104" y="36" text-anchor="end">CITATIONS</text>
          <text class="fx-label" x="104" y="76" text-anchor="end">LOCAL SEO</text>
          <text class="fx-label" x="104" y="116" text-anchor="end">CONTENT</text>
          <rect class="fx-vertex" x="258" y="70" width="8" height="8" />
          <line class="fx-hair-y2" x1="266" y1="74" x2="418" y2="74" />
          <polyline class="fx-hair-y2" points="412,70 418,74 412,78" fill="none" />
          <rect class="fx-vertex-filled" x="430" y="70" width="8" height="8" />
          <text class="fx-label-y2" x="434" y="58" text-anchor="middle">YOUR NAME</text>
          <text class="fx-label" x="500" y="96" text-anchor="end">AI ANSWERS</text>
          <text class="fx-label" x="500" y="112" text-anchor="end">MAP PACK</text>
          <text class="fx-label" x="500" y="128" text-anchor="end">SEARCH</text>
          <text class="fx-caption" x="24" y="140">BUILD THE SIGNALS — GET NAMED ON ALL THREE.</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="problem-cta elev">
    <div class="container">
      <h2 class="h-closer">Being invisible is <em>fixable.</em></h2>
      <p class="lede">If three of the Poor Four sound familiar, the operations gap is bigger than the visibility gap. That's the conversation worth having.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="problem-invisible-market-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="problem-invisible-market-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.problem-hero { padding-block: clamp(80px, 12vw, 144px); }
.problem-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.problem-hero h1 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.problem-fix h2 em, .problem-cta h2 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.problem-panel { border: 1px solid var(--rule); background: var(--bg-card); padding: 28px; border-radius: 4px; }
.problem-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
.panel-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); text-transform: uppercase; }
.panel-fig { margin-top: 24px; max-width: 360px; }
.diag-accent { stroke: var(--signal-cyan); stroke-width: 1; }
.diag-accent-fill { fill: var(--signal-cyan); }
.diag-accent-label { fill: var(--signal-cyan); }
.faint-node { stroke: var(--ink-faint); }

.problem-cost, .problem-fix, .problem-cta { padding-block: clamp(56px, 8vw, 96px); }
.cost-list { list-style: none; counter-reset: cost; display: flex; flex-direction: column; gap: 24px; margin-top: 32px; max-width: 880px; }
.cost-list li {
  counter-increment: cost;
  position: relative;
  padding-left: 56px;
  font-size: 17px;
  line-height: 1.6;
  color: var(--ink-dim);
}
.cost-list li::before {
  content: counter(cost, decimal-leading-zero);
  position: absolute;
  left: 0;
  top: 0;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.18em;
  color: var(--y2);
}
.cost-list strong { color: var(--ink); font-weight: 500; }

.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 720px; margin-top: 24px; }
.problem-fix .lede { margin-top: 32px; }

.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

@media (max-width: 860px) {
  .problem-hero-grid { grid-template-columns: 1fr; }
}
</style>
