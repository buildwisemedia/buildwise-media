---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Leaky Revenue — Buildwise Media";
const description = "Leads come in. Then nothing. Leaky Revenue is a system failure, not a sales problem. Here's how we close it.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Leaky Revenue', item: 'https://buildwisemedia.com/problem/leaky-revenue' },
  ],
};

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/problem/leaky-revenue#fix',
  name: 'Leaky Revenue fix — speed-to-lead and follow-up automation',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Installs speed-to-lead automation, review velocity engine, lost-lead reactivation, and follow-up cadence so every lead that enters the system has a next action — and none fall silently through the gaps.',
  url: 'https://buildwisemedia.com/problem/leaky-revenue',
};

const faqs = [
  {
    q: 'Why do my service-business leads convert at half the rate they should?',
    a: 'Most service business leads convert poorly for one reason: speed. Studies consistently show buyers convert to whoever responds first — and "first" means within five minutes of inquiry. If your process is to check messages at lunch and call back by end of day, you\'re losing the majority of qualified leads to whoever picks up faster. Beyond speed, the other leak points are un-followed-up quotes, un-requested reviews, and no reactivation system for past leads who didn\'t close the first time.',
  },
  {
    q: 'How do I follow up with every lead before competitors do?',
    a: 'The answer is automation — not more hustle. Speed-to-lead automation sends an immediate text or call the moment a lead submits, before a human even sees the notification. Follow-up sequences handle the 3rd, 5th, and 10th touch so no lead goes cold because someone forgot to check back. The system runs whether you\'re on a job site, in a meeting, or taking a day off. We build and run this for you.',
  },
  {
    q: 'What does speed-to-lead actually mean for a service business?',
    a: 'Speed-to-lead means the elapsed time between a buyer submitting an inquiry and your business making contact. The research benchmark is under five minutes for meaningful conversion advantage. Beyond five minutes, conversion rates drop sharply with each passing hour. For most service businesses, this metric is measured in hours or days — which means most qualified leads are already talking to a competitor before your team even knows the lead came in.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/problem/leaky-revenue#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[service, breadcrumb, faqSchema]}>

  <section class="problem-hero">
    <div class="container">
      <p class="eyebrow"><a href="/#problem" class="back-link">← The Poor Four</a> · 02</p>
      <h1 class="h-hero">
        Leaky <em>revenue.</em>
      </h1>
      <p class="hero-sub">
        The leads come in. Then nothing. The phone rings but no one picks up before the buyer calls the next shop. Reviews stay un-requested. Quotes go un-followed-up. Every leak is a revenue line drained quietly. Most owners discover the leaks too late — when the month is already lost.
      </p>
    </div>
  </section>

  <section class="problem-cost elev">
    <div class="container">
      <p class="section-tag">What it actually costs</p>
      <h2 class="h-section">The cost of leaks.</h2>
      <ol class="cost-list" role="list">
        <li><strong>Missed first-touch converts buyers to competitors.</strong> Buyers who submit an inquiry have already decided to hire someone. The business that reaches them first wins the majority of that revenue. A five-minute response window is the threshold — beyond it, conversion rates fall sharply with every passing hour.</li>
        <li><strong>Un-requested reviews compound into invisibility.</strong> Reviews are both a trust signal and a local search ranking factor. Every satisfied customer who doesn't leave a review is a missed asset. The compounding effect is invisible in the short term and devastating over 12 months — your competitor with a review-request system ends up with 4× the review count on a smaller customer base.</li>
        <li><strong>Un-followed-up quotes drain pipeline quietly.</strong> Most service businesses quote, then wait. No second touch. No objection-handling sequence. No "are you still deciding?" cadence. The quote goes cold and the revenue disappears without a single conversation about why.</li>
        <li><strong>No nurture system erodes the customer list.</strong> Past customers who don't hear from you don't come back — they hire whoever markets to them next. Without a reactivation system, every dormant customer in your list is leaking toward a competitor who has one.</li>
      </ol>
    </div>
  </section>

  <section class="problem-fix">
    <div class="container">
      <p class="section-tag">How we close it</p>
      <h2 class="h-section">A system that <em>follows through</em>.</h2>
      <p class="lede">
        Leaky Revenue isn't a sales problem. It's a missing follow-through system. We install speed-to-lead automation that contacts every new lead in under five minutes, a review velocity engine that captures satisfied customers automatically, and a follow-up cadence that works every quote until it closes or formally declines.
      </p>
      <p class="prose">
        Lost-lead reactivation runs in the background — reaching back to past leads and dormant customers on a schedule that keeps your business top of mind without requiring any owner attention. The whole system runs in 30 days, not 90.
      </p>
    </div>
  </section>

  <section class="problem-cta elev">
    <div class="container">
      <h2 class="h-closer">Leaking revenue is <em>fixable.</em></h2>
      <p class="lede">If three of the Poor Four sound familiar, the operations gap is bigger than the conversion gap. That's the conversation worth having.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="problem-leaky-revenue-cta">See If We're a Fit <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/#problem">Back to The Poor Four</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.problem-hero { padding-block: clamp(80px, 12vw, 144px); }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.problem-hero h1 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.problem-fix h2 em, .problem-cta h2 em { color: var(--y2); font-style: normal; font-weight: inherit; }

.cost-list { list-style: none; counter-reset: cost; display: flex; flex-direction: column; gap: 24px; margin-top: 32px; max-width: 880px; }
.cost-list li {
  counter-increment: cost;
  position: relative;
  padding-left: 56px;
  font-size: 17px;
  line-height: 1.6;
  color: var(--ink-dim);
}
.cost-list li::before {
  content: counter(cost, decimal-leading-zero);
  position: absolute;
  left: 0;
  top: 0;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.18em;
  color: var(--y2);
}
.cost-list strong { color: var(--ink); font-weight: 500; }

.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 720px; margin-top: 24px; }
.problem-fix .lede { margin-top: 32px; }

.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
</style>
