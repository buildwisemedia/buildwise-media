---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Lead Attribution for Contractors — Fix Leaky Revenue | Buildwise Media";
const description = "Lead attribution for contractors closes the gap between ad spend and booked work. Buildwise wires attribution on day one — so you know which source, which dollar, which job.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Leaky Revenue', item: 'https://buildwisemedia.com/problem/leaky-revenue' },
  ],
};

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/problem/leaky-revenue#fix',
  name: 'Lead attribution for contractors',
  serviceType: 'Lead attribution and leaky revenue fix for service contractors',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Installs source tracking, speed-to-lead automation, review velocity, lost-lead reactivation, and follow-up cadence so every lead that enters the system has a next action.',
  url: 'https://buildwisemedia.com/problem/leaky-revenue',
};

const faqs = [
  {
    q: 'Why do my service-business leads convert at half the rate they should?',
    a: 'Many service-business leads fail because the next step is slow or unclear. A buyer who needs help often calls more than one company. If your process waits until lunch or end of day, the lead may already be talking to someone else. Other leak points include quiet quotes, missed review asks, and no reactivation path for past leads who did not close the first time.',
  },
  {
    q: 'How do I follow up with every lead before competitors do?',
    a: 'The answer is a system, not more owner hustle. Speed-to-Lead routes a fast next touch the moment a lead submits. Follow-up sequences keep working the quote path so no lead goes cold because someone forgot to check back. The system runs whether you are on a job site, in a meeting, or taking a day off. The Buildwise team builds and runs this for you.',
  },
  {
    q: 'What does speed-to-lead actually mean for a service business?',
    a: 'Speed-to-lead means the time between a buyer submitting an inquiry and your business making contact. For most service businesses, the risk is simple: the buyer keeps searching while your team is busy. The system measures that gap and makes it part of attribution, so a slow reply does not get misread as a bad source.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/problem/leaky-revenue#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[service, breadcrumb, faqSchema]}>

  <section class="problem-hero">
    <div class="container problem-hero-grid">
      <div>
        <p class="eyebrow"><a href="/#problem" class="back-link">← The Poor Four</a> · 02</p>
        <h1 class="h-hero">
          Lead Attribution for Contractors: Stop Guessing Where Your Jobs Come From
        </h1>
        <p class="hero-sub">
          Leads come in. Calls ring. Forms land. Quotes go out. Then the owner has to guess what worked. Lead attribution closes that gap. It connects source, spend, follow-up, quote, and booked work so contractors can see where revenue leaks.
        </p>
        <p class="cta-row">
          <a class="cta-primary" href="/book" data-cta-source="problem-leaky-revenue-hero-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
          <a class="cta-ghost" href="/book" data-cta-source="problem-leaky-revenue-hero-secondary">See If We're a Fit</a>
        </p>
      </div>
      <aside class="problem-panel" aria-label="Revenue pipeline">
        <div class="problem-panel-head">
          <p class="panel-label mono">REVENUE PIPELINE</p>
        </div>
        <!-- @r020:F4 curiosity: the leaking pipeline reframes the issue as many small misses the visitor can inspect rather than one obvious failure. -->
        <figure class="scene-fig panel-fig">
          <svg viewBox="0 0 320 200" role="img" aria-label="Diagram: lead to booked pipeline with red drips under call, quote, and follow-up.">
            <line class="fx-hair" x1="34" y1="84" x2="286" y2="84" />
            <rect class="fx-vertex" x="30" y="80" width="8" height="8" />
            <rect class="fx-vertex" x="92" y="80" width="8" height="8" />
            <rect class="fx-vertex" x="154" y="80" width="8" height="8" />
            <rect class="fx-vertex" x="216" y="80" width="8" height="8" />
            <rect class="fx-vertex" x="282" y="80" width="8" height="8" />
            <line class="diag-accent" x1="96" y1="94" x2="96" y2="116" />
            <circle class="diag-accent-fill" cx="96" cy="124" r="3" />
            <line class="diag-accent" x1="158" y1="94" x2="158" y2="116" />
            <circle class="diag-accent-fill" cx="158" cy="124" r="3" />
            <line class="diag-accent" x1="220" y1="94" x2="220" y2="116" />
            <circle class="diag-accent-fill" cx="220" cy="124" r="3" />
            <text class="fx-label" x="34" y="60" text-anchor="middle">LEAD</text>
            <text class="fx-label" x="96" y="60" text-anchor="middle">CALL</text>
            <text class="fx-label" x="158" y="60" text-anchor="middle">QUOTE</text>
            <text class="fx-label" x="220" y="60" text-anchor="middle">FOLLOW-UP</text>
            <text class="fx-label" x="286" y="60" text-anchor="middle">BOOKED</text>
            <text class="fx-caption" x="20" y="174">THE LEAK IS TEN SMALL MISSES,</text>
            <text class="fx-caption" x="20" y="188">NOT ONE HOLE.</text>
          </svg>
        </figure>
      </aside>
    </div>
  </section>

  <section class="problem-cost elev">
    <div class="container">
      <p class="section-tag">What it actually costs</p>
      <h2 class="h-section">The cost of leaks.</h2>
      <ol class="cost-list" role="list">
        <li><strong>Missed first-touch sends buyers elsewhere.</strong> Buyers who submit an inquiry often need help now. If your team is busy, the buyer keeps moving and the source gets blamed.</li>
        <li><strong>Un-requested reviews weaken search visibility.</strong> Every happy customer who does not leave a review is missed proof for the next buyer.</li>
        <li><strong>Quiet quotes drain the pipeline.</strong> Most service businesses quote, then wait. No second touch. No clear reminder. The quote goes cold and no one can say why.</li>
        <li><strong>No reactivation path erodes the customer list.</strong> Past customers who do not hear from you can forget who solved the last job. The next need goes to whoever is visible then.</li>
      </ol>
      <!-- @r020:F2 proof: the descending step line makes each unmonitored handoff visible as a measurable drop in the pipeline. -->
      <figure class="scene-fig" style="max-width: 520px;">
        <svg viewBox="0 0 520 150" role="img" aria-label="Diagram: lead flow steps down at missed first touch, no review ask, quiet quote, and no reactivation.">
          <line class="fx-hair" x1="32" y1="122" x2="488" y2="122" />
          <line class="fx-hair" x1="32" y1="24" x2="32" y2="122" />
          <polyline class="diag-accent" points="44,42 136,42 136,64 248,64 248,86 360,86 360,108 472,108" fill="none" />
          <rect class="fx-vertex-filled diag-accent-fill" x="132" y="60" width="8" height="8" />
          <rect class="fx-vertex-filled diag-accent-fill" x="244" y="82" width="8" height="8" />
          <rect class="fx-vertex-filled diag-accent-fill" x="356" y="104" width="8" height="8" />
          <text class="fx-label" x="44" y="30">LEAD</text>
          <text class="fx-label" x="136" y="84" text-anchor="middle">MISSED FIRST-TOUCH</text>
          <text class="fx-label" x="248" y="106" text-anchor="middle">NO REVIEW ASK</text>
          <text class="fx-label" x="360" y="128" text-anchor="middle">QUIET QUOTE</text>
          <text class="fx-label" text-anchor="end" x="500" y="100">NO REACTIVATION</text>
          <text class="fx-caption" x="24" y="144">NOT ONE BIG HOLE — TEN SMALL MISSES THAT COST REAL JOBS.</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="problem-fix">
    <div class="container">
      <p class="section-tag">Lead attribution</p>
      <h2 class="h-section">Lead attribution shows which source, which dollar, and which job.</h2>
      <p class="lede">
        Most contractors reach for lead attribution software first: spreadsheets, reports, or dashboards. The real gap is the wiring between source, follow-up, and booked job. The system records where the lead came from, which page or call path they used, how fast the reply happened, whether a quote went out, and whether the work booked.
      </p>
      <p class="prose">
        That wiring matters because speed-to-lead changes the numbers. A strong source can look weak if the answer time is slow. A weak source can look strong if one lucky job closes. Attribution separates those signals. It lets the owner see whether the gap is visibility, follow-up, quote handling, or source quality.
      </p>
      <p class="prose">
        After 30 days, the owner should see a clearer dashboard: source, spend, call, form, quote, booked work, and next move. That view connects to <a href="/system">the system</a>, the <a href="/playbook/revenue-operating-system">revenue operating system</a>, <a href="/services/ascend">Ascend</a>, and the free <a href="/audit">Revenue Leak Map</a>.
      </p>
      <!-- @r020:F2 proof: the attribution chain encodes the one-view trace from source to booked work that this section promises. -->
      <figure class="scene-fig">
        <svg viewBox="0 0 520 130" role="img" aria-label="Diagram: source, page, call, and quote connect to a filled booked node in one attribution chain.">
          <line class="fx-hair" x1="46" y1="58" x2="424" y2="58" />
          <rect class="fx-vertex" x="42" y="54" width="8" height="8" />
          <rect class="fx-vertex" x="132" y="54" width="8" height="8" />
          <rect class="fx-vertex" x="222" y="54" width="8" height="8" />
          <rect class="fx-vertex" x="312" y="54" width="8" height="8" />
          <rect class="fx-vertex-filled" x="420" y="54" width="8" height="8" />
          <text class="fx-label" x="46" y="84" text-anchor="middle">SOURCE</text>
          <text class="fx-label" x="136" y="84" text-anchor="middle">PAGE</text>
          <text class="fx-label" x="226" y="84" text-anchor="middle">CALL</text>
          <text class="fx-label" x="316" y="84" text-anchor="middle">QUOTE</text>
          <text class="fx-label-y2" x="424" y="84" text-anchor="middle">BOOKED</text>
          <line class="fx-hair" x1="32" y1="100" x2="488" y2="100" />
          <line class="fx-hair" x1="32" y1="96" x2="32" y2="100" />
          <line class="fx-hair" x1="488" y1="96" x2="488" y2="100" />
          <text class="fx-caption" x="24" y="122">ONE VIEW — EVERY BOOKED JOB TRACES TO ITS SOURCE.</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="problem-fix elev">
    <div class="container">
      <p class="section-tag">How we close it</p>
      <h2 class="h-section">A system that <em>follows through</em>.</h2>
      <p class="lede">
        Leaky Revenue is not a sales problem. It is a missing follow-through system. We install Speed-to-Lead, review requests, lost-lead reactivation, and follow-up cadence so every new lead has a next action.
      </p>
      <p class="prose">
        Lost-lead reactivation runs in the background. It reaches back to past leads and dormant customers on a schedule that keeps your business present without requiring owner attention. The whole system runs in 30 days, not 90.
      </p>
      <!-- @r020:F3 CTA-pull: the sealed pipeline shows every former leak replaced by a concrete next action. -->
      <figure class="scene-fig" style="max-width: 520px;">
        <svg viewBox="0 0 520 150" role="img" aria-label="Diagram: lead to booked pipeline sealed with next action nodes above call, quote, and follow-up.">
          <line class="fx-hair" x1="42" y1="82" x2="456" y2="82" />
          <rect class="fx-vertex" x="38" y="78" width="8" height="8" />
          <rect class="fx-vertex" x="132" y="78" width="8" height="8" />
          <rect class="fx-vertex" x="226" y="78" width="8" height="8" />
          <rect class="fx-vertex" x="320" y="78" width="8" height="8" />
          <rect class="fx-vertex-filled" x="452" y="78" width="8" height="8" />
          <line class="fx-hair-y2" x1="136" y1="76" x2="136" y2="42" />
          <line class="fx-hair-y2" x1="230" y1="76" x2="230" y2="52" />
          <line class="fx-hair-y2" x1="324" y1="76" x2="324" y2="42" />
          <rect class="fx-vertex-filled" x="132" y="34" width="8" height="8" />
          <rect class="fx-vertex-filled" x="226" y="44" width="8" height="8" />
          <rect class="fx-vertex-filled" x="320" y="34" width="8" height="8" />
          <text class="fx-label" x="136" y="20" text-anchor="middle">SPEED-TO-LEAD</text>
          <text class="fx-label" x="230" y="34" text-anchor="middle">REVIEW ASK</text>
          <text class="fx-label" x="324" y="20" text-anchor="middle">REACTIVATION</text>
          <text class="fx-label" x="42" y="112" text-anchor="middle">LEAD</text>
          <text class="fx-label" x="136" y="112" text-anchor="middle">CALL</text>
          <text class="fx-label" x="230" y="112" text-anchor="middle">QUOTE</text>
          <text class="fx-label" x="324" y="112" text-anchor="middle">FOLLOW-UP</text>
          <text class="fx-label-y2" x="456" y="112" text-anchor="middle">BOOKED</text>
          <text class="fx-caption" x="24" y="142">EVERY LEAD GETS A NEXT ACTION.</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="problem-cta elev">
    <div class="container">
      <h2 class="h-closer">Leaking revenue is <em>fixable.</em></h2>
      <p class="lede">The free Revenue Leak Map shows where source tracking, speed, and follow-up are breaking down.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="problem-leaky-revenue-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="problem-leaky-revenue-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.problem-hero { padding-block: clamp(80px, 12vw, 144px); }
.problem-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.problem-hero h1 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.problem-fix h2 em, .problem-cta h2 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.problem-panel { border: 1px solid var(--rule); background: var(--bg-card); padding: 28px; border-radius: 4px; }
.problem-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
.panel-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-faint); text-transform: uppercase; }
.panel-fig { margin-top: 24px; max-width: 360px; }
.diag-accent { stroke: var(--signal-red); stroke-width: 1; }
.diag-accent-fill { fill: var(--signal-red); }

.problem-cost, .problem-fix, .problem-cta { padding-block: clamp(56px, 8vw, 96px); }
.cost-list { list-style: none; counter-reset: cost; display: flex; flex-direction: column; gap: 24px; margin-top: 32px; max-width: 880px; }
.cost-list li {
  counter-increment: cost;
  position: relative;
  padding-left: 56px;
  font-size: 17px;
  line-height: 1.6;
  color: var(--ink-dim);
}
.cost-list li::before {
  content: counter(cost, decimal-leading-zero);
  position: absolute;
  left: 0;
  top: 0;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.18em;
  color: var(--y2);
}
.cost-list strong { color: var(--ink); font-weight: 500; }

.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 720px; margin-top: 24px; }
.problem-fix .lede { margin-top: 32px; }

.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

@media (max-width: 860px) {
  .problem-hero-grid { grid-template-columns: 1fr; }
}
</style>
