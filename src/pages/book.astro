---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import RevenueLeakMapFlow from '../components/RevenueLeakMapFlow.astro';

const title = "Get Your Free Revenue Leak Map — Buildwise Media";
const description = "Answer seven quick taps. Get your free Revenue Leak Map. Then see your next step from our team.";
const canonical = 'https://buildwisemedia.com/revenue-leak-map';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Revenue Leak Map', item: canonical },
  ],
};
---
<BaseLayout title={title} description={description} canonical={canonical} jsonLd={[breadcrumb]}>
  <RevenueLeakMapFlow />
</BaseLayout>
