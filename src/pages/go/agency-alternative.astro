---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MoChainSection from '../../components/campaign/MoChainSection.astro';
import FitDiagnostic from '../../components/FitDiagnostic.astro';

// AGENCY-DISPLACEMENT offer-funnel arm — /go/agency-alternative
// Angle: burned-by-agency owner; reframe the destination to a CUSTOM AI SYSTEM (a
//        different category), not a better agency. Lead outcomes = proof, not identity.
// Register: category reframe (custom AI system over agency model) · proof-before-CTA.
// UTM contract: utm_content=go-agency-alternative
---

<BaseLayout
  title="A Custom AI System for Service Businesses | Buildwise Media"
  description="More booked jobs, not another report. A custom AI system runs your growth — it captures demand, follows up, and tracks what actually closed, so growth stops depending on you. The free Revenue Leak Map shows where your current setup is leaking."
  ogTitle="A custom AI system that runs your growth — not another agency"
  ogDescription="Get the free Revenue Leak Map. See where your current setup is leaking and what a custom AI system would run for you."
  noindex={true}
>

  <!-- HERO ─────────────────────────────────────────────────────────────── -->
  <section class="aa-hero" aria-labelledby="aa-hero-headline">
    <div class="container aa-hero-grid">
      <div class="aa-hero-text">
        <p class="eyebrow">Buildwise Media · Custom AI systems, run for you</p>

        <!-- @bwm-exp-slot: hero-headline — paid-search agency-alternative H1; bandit patches target this selector -->
        <h1 id="aa-hero-headline" class="aa-headline" data-bwm-exp-slot="hero-headline">
          <span class="aa-line">More booked jobs.</span>
          <span class="aa-line">Not another report.</span>
          <span class="aa-line">A <span class="aa-accent">custom AI system</span></span>
          <span class="aa-line">runs your growth — no agency required.</span>
        </h1>

        <p class="aa-subhead">
          Agencies sell activity and hand you a report. A custom AI system runs the work itself — capturing demand, following up, and tracking what actually closed — so growth stops depending on you. The free Revenue Leak Map shows where your current setup is leaking.
        </p>

        <!-- @r020:F2 proof: report-to-booked-jobs comparison makes the agency frustration visible — the owner sees the gap between activity reporting and real work booked before taking the diagnostic CTA -->
        <figure class="aa-hero-figure">
          <svg class="aa-hero-svg" viewBox="0 0 640 220" role="img" aria-label="A comparison from typical agency reports to a custom AI system that runs the work and tracks what closed." xmlns="http://www.w3.org/2000/svg">
            <text x="8" y="16" font-family="JetBrains Mono, monospace" font-size="9" fill="#62626A" letter-spacing="0.18em">WHAT YOU GET TODAY</text>
            <rect x="8" y="32" width="210" height="126" fill="rgba(168,162,152,0.10)" stroke="rgba(168,162,152,0.22)" stroke-width="1"/>
            <line x1="28" y1="58" x2="178" y2="58" stroke="rgba(168,162,152,0.35)" stroke-width="1.5"/>
            <line x1="28" y1="82" x2="198" y2="82" stroke="rgba(168,162,152,0.24)" stroke-width="1.5"/>
            <line x1="28" y1="106" x2="164" y2="106" stroke="rgba(168,162,152,0.24)" stroke-width="1.5"/>
            <line x1="28" y1="130" x2="190" y2="130" stroke="rgba(168,162,152,0.24)" stroke-width="1.5"/>
            <circle cx="190" cy="58" r="4" fill="none" stroke="rgba(168,162,152,0.38)" stroke-width="1"/>
            <circle cx="210" cy="82" r="4" fill="none" stroke="rgba(168,162,152,0.28)" stroke-width="1"/>
            <text x="8" y="182" font-family="JetBrains Mono, monospace" font-size="8" fill="#62626A" letter-spacing="0.13em">Reports · tasks · vague wins</text>

            <line x1="268" y1="106" x2="304" y2="106" stroke="#F0FF00" stroke-width="1.5" opacity="0.65"/>
            <polyline points="298,102 304,106 298,110" stroke="#F0FF00" stroke-width="1.5" fill="none" opacity="0.65"/>
            <text x="264" y="94" font-family="JetBrains Mono, monospace" font-size="8" fill="rgba(240,255,0,0.55)" letter-spacing="0.10em">REPLACE</text>

            <text x="322" y="16" font-family="JetBrains Mono, monospace" font-size="9" fill="#62626A" letter-spacing="0.18em">WHAT THE SYSTEM RUNS</text>
            <rect x="322" y="32" width="276" height="126" fill="rgba(240,255,0,0.06)" stroke="rgba(240,255,0,0.25)" stroke-width="1"/>
            <circle cx="354" cy="62" r="5" fill="#F0FF00"/>
            <line x1="359" y1="62" x2="420" y2="62" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="432" cy="62" r="5" fill="#F0FF00"/>
            <line x1="437" y1="62" x2="498" y2="62" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="510" cy="62" r="5" fill="#F0FF00"/>
            <line x1="510" y1="67" x2="510" y2="114" stroke="rgba(240,255,0,0.32)" stroke-width="1.4"/>
            <circle cx="510" cy="124" r="5" fill="#F0FF00"/>
            <line x1="432" y1="124" x2="505" y2="124" stroke="rgba(240,255,0,0.32)" stroke-width="1.4"/>
            <circle cx="420" cy="124" r="5" fill="#F0FF00"/>
            <text x="344" y="86" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.70)" letter-spacing="0.10em">CAPTURE</text>
            <text x="422" y="86" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.70)" letter-spacing="0.10em">REPLY</text>
            <text x="500" y="86" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.70)" letter-spacing="0.10em">BOOK</text>
            <text x="396" y="146" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.70)" letter-spacing="0.10em">TRACK WHAT CLOSED</text>
            <text x="322" y="182" font-family="JetBrains Mono, monospace" font-size="8" fill="rgba(240,255,0,0.58)" letter-spacing="0.13em">Booked jobs · owned data · weekly readout</text>
          </svg>
          <figcaption class="aa-hero-caption mono">The agency model vs. a custom AI system</figcaption>
        </figure>

        <!-- @bwm-exp-slot: hero-cta — primary paid-search conversion CTA -->
        <div class="aa-ctas" data-bwm-exp-slot="hero-cta">
          <a href="#diagnostic" class="cta" data-cta-source="f4-agency-alternative-hero">
            Get My Free Revenue Leak Map
            <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <p class="aa-icp mono">For service businesses only. 5 minutes. No pitch.</p>
      </div>
    </div>
  </section>

  <!-- COMPARISON ───────────────────────────────────────────────────────── -->
  <section class="aa-compare" aria-labelledby="aa-compare-heading">
    <div class="container">
      <p class="section-tag">THE SWITCH · SYSTEM OVER AGENCY</p>
      <h2 id="aa-compare-heading" class="h-section">The problem is not that your agency is lazy. It is that the model is built around reports.</h2>
      <p class="lede">
        A typical agency can buy clicks, write posts, and hold meetings. That can help. But it still leaves you managing the manager. A custom AI system replaces the loose parts with one thing you own — it runs the full path from first search to tracked result, and keeps running without you.
      </p>

      <!-- @r020:F2 proof: D4 comparison grid shows present vs absent capabilities using the locked filled/hollow vertex grammar — the visual proves the category reframe without naming rivals -->
      <div class="aa-compare-grid" role="table" aria-label="Buildwise system compared with the typical marketing agency">
        <div role="row" style="display:contents">
          <div class="aa-compare-head aa-system-head" role="columnheader">A custom AI system</div>
          <div class="aa-compare-head aa-agency-head" role="columnheader">Typical agency</div>
        </div>

        <div role="row" style="display:contents">
          <div class="aa-compare-row aa-system" role="cell">
            <span class="aa-dot aa-dot-fill" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OUTPUT</p>
              <h3>Booked jobs and next actions.</h3>
              <p>The system tracks the path from lead to booked work. The weekly readout says what happened and what changes next.</p>
            </div>
          </div>
          <div class="aa-compare-row aa-agency" role="cell">
            <span class="aa-dot aa-dot-hollow" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OUTPUT</p>
              <h3>Reports and activity.</h3>
              <p>You see clicks, impressions, and tasks. You still have to ask what turned into real work.</p>
            </div>
          </div>
        </div>

        <div role="row" style="display:contents">
          <div class="aa-compare-row aa-system" role="cell">
            <span class="aa-dot aa-dot-fill" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OWNERSHIP</p>
              <h3>Your system. Your data.</h3>
              <p>The assets, follow-up paths, lead records, and readouts are built to stay with you.</p>
            </div>
          </div>
          <div class="aa-compare-row aa-agency" role="cell">
            <span class="aa-dot aa-dot-hollow" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OWNERSHIP</p>
              <h3>Scattered accounts.</h3>
              <p>Work often lives in rented tools and disconnected reports. Leaving can feel harder than staying.</p>
            </div>
          </div>
        </div>

        <div role="row" style="display:contents">
          <div class="aa-compare-row aa-system" role="cell">
            <span class="aa-dot aa-dot-fill" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OPERATING LOAD</p>
              <h3>Run-for-you.</h3>
              <p>The team and our AI system run the loop. You review the output and make owner-level calls.</p>
            </div>
          </div>
          <div class="aa-compare-row aa-agency" role="cell">
            <span class="aa-dot aa-dot-hollow" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">OPERATING LOAD</p>
              <h3>You manage them.</h3>
              <p>You chase updates, explain the business again, and keep stitching the pieces together.</p>
            </div>
          </div>
        </div>

        <div role="row" style="display:contents">
          <div class="aa-compare-row aa-system" role="cell">
            <span class="aa-dot aa-dot-fill" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">CONTRACT SHAPE</p>
              <h3>Month-to-month after day 90.</h3>
              <p>If the system is not earning its place, you should not be trapped.</p>
            </div>
          </div>
          <div class="aa-compare-row aa-agency" role="cell">
            <span class="aa-dot aa-dot-hollow" aria-hidden="true"></span>
            <div>
              <p class="aa-compare-kicker mono">CONTRACT SHAPE</p>
              <h3>Long lock-in.</h3>
              <p>You keep paying while the agency gets another month to explain the same report.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- @r020:F2 proof: same ad spend, two destinations — the diagram makes the model difference concrete (activity report vs work booked) before the inline CTA -->
      <figure class="aa-spend-figure">
        <svg class="aa-spend-svg" viewBox="0 0 640 200" role="img" xmlns="http://www.w3.org/2000/svg"
             aria-label="The same ad spend splits two ways: the typical agency turns it into an activity report; the Buildwise system turns it into a booked job.">
          <rect x="14" y="78" width="150" height="44" rx="8" fill="none" stroke="#74748a" stroke-width="1.5"/>
          <text x="89" y="98" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" letter-spacing="1.5" fill="#b6b6c4">YOUR AD</text>
          <text x="89" y="112" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" letter-spacing="1.5" fill="#b6b6c4">SPEND</text>
          <path d="M168 92 C 280 92, 300 44, 430 44" fill="none" stroke="#3a3a48" stroke-width="2" stroke-dasharray="5 5"/>
          <path d="M168 108 C 280 108, 300 156, 430 156" fill="none" stroke="#F0FF00" stroke-width="2.5"/>
          <circle cx="430" cy="44" r="9" fill="none" stroke="#74748a" stroke-width="1.5"/>
          <rect x="450" y="22" width="176" height="44" rx="8" fill="none" stroke="#3a3a48" stroke-width="1.5"/>
          <text x="538" y="42" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" letter-spacing="1.5" fill="#74748a">TYPICAL AGENCY</text>
          <text x="538" y="56" text-anchor="middle" font-family="Inter,sans-serif" font-size="13" fill="#b6b6c4">An activity report</text>
          <circle cx="430" cy="156" r="9" fill="#F0FF00"/>
          <rect x="450" y="134" width="176" height="44" rx="8" fill="none" stroke="#F0FF00" stroke-width="1.5"/>
          <text x="538" y="154" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="11" letter-spacing="1.5" fill="#F0FF00">BUILDWISE SYSTEM</text>
          <text x="538" y="168" text-anchor="middle" font-family="Inter,sans-serif" font-size="13" fill="#f4f4f7">A booked job</text>
        </svg>
      </figure>

      <div class="aa-inline-cta">
        <a href="#diagnostic" class="cta" data-cta-source="f4-agency-alternative-inline">
          Get My Free Revenue Leak Map
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <p class="aa-inline-subtext mono">See which side your current setup is actually on.</p>
      </div>
    </div>
  </section>

  <!-- SHARED CHAIN: Cost + Mechanism (MoChainSection carries F2 data-viz + F3 staircase) -->
  <MoChainSection />

  <!-- TWO PATHS ────────────────────────────────────────────────────────── -->
  <section class="aa-paths" aria-labelledby="aa-paths-heading">
    <div class="container">
      <p class="section-tag">03 · TWO PATHS · SAME OWNER, DIFFERENT WEEK</p>
      <h2 id="aa-paths-heading" class="h-section">A year from now, one version of you is still asking for updates. One version reads the number over coffee.</h2>
      <p class="aa-paths-body">
        Same market. Same service. Same owner. The split happens when marketing stops being a vendor list and starts being a system.
      </p>

      <!-- @r020:F3 cta-pull: two-paths diagram makes the future choice visible — the bright system path points toward the diagnostic CTA that names which leaks to fix first -->
      <div class="aa-path-map">
        <article class="aa-path aa-path-dim">
          <p class="mono aa-path-kicker">PATH A · KEEP THE AGENCY LOOP</p>
          <svg class="aa-path-icon" viewBox="0 0 180 72" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="36" r="5" fill="none" stroke="rgba(168,162,152,0.45)" stroke-width="1"/>
            <line x1="25" y1="36" x2="72" y2="36" stroke="rgba(168,162,152,0.30)" stroke-width="1.4" stroke-dasharray="4,4"/>
            <circle cx="80" cy="36" r="5" fill="none" stroke="rgba(168,162,152,0.35)" stroke-width="1"/>
            <line x1="85" y1="36" x2="132" y2="36" stroke="rgba(168,162,152,0.22)" stroke-width="1.4" stroke-dasharray="4,4"/>
            <circle cx="140" cy="36" r="5" fill="none" stroke="rgba(168,162,152,0.26)" stroke-width="1"/>
            <path d="M140 36 C158 34 164 46 152 54" stroke="rgba(168,162,152,0.26)" stroke-width="1.2" fill="none"/>
            <text x="12" y="64" font-family="JetBrains Mono, monospace" font-size="7" fill="#62626A" letter-spacing="0.10em">meeting → report → wait → repeat</text>
          </svg>
          <h3>You keep managing the marketing.</h3>
          <p>The report lands. You ask what changed. The answer sounds reasonable. The calendar still feels thin.</p>
        </article>

        <article class="aa-path aa-path-bright">
          <p class="mono aa-path-kicker">PATH B · INSTALL THE SYSTEM</p>
          <!-- @r020:F3 cta-pull: the bright capture→reply→book→learn loop is the path the eye should follow toward the Revenue Leak Map CTA -->
          <svg class="aa-path-icon" viewBox="0 0 180 72" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="36" r="5" fill="#F0FF00"/>
            <line x1="25" y1="36" x2="72" y2="20" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="80" cy="18" r="5" fill="#F0FF00"/>
            <line x1="84" y1="22" x2="126" y2="36" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="134" cy="38" r="5" fill="#F0FF00"/>
            <line x1="134" y1="43" x2="134" y2="56" stroke="rgba(240,255,0,0.35)" stroke-width="1.4"/>
            <circle cx="134" cy="61" r="3" fill="#F0FF00"/>
            <text x="12" y="64" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.62)" letter-spacing="0.10em">capture → reply → book → learn</text>
          </svg>
          <h3>The system runs while you run the business.</h3>
          <p>Leads get captured. Follow-up fires. The readout shows what closed. You stop being the project manager.</p>
        </article>
      </div>

      <!-- @r020:identity: Triangulation V3 mark glyph anchors the choice to the BWM owned-system promise -->
      <div class="aa-path-anchor">
        <svg class="aa-path-mark" viewBox="0 0 40 40" aria-hidden="true">
          <polygon points="20,4 36,32 4,32" stroke="#F0FF00" stroke-width="1.5" fill="none" />
          <circle cx="20" cy="22" r="3" fill="#F0FF00" />
        </svg>
        <p class="aa-path-hook mono">
          The Revenue Leak Map tells you which path your setup is on today.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF STRIP ───────────────────────────────────────────────────────── -->
  <!-- @bwm-exp-slot: proof-module — proof composition / placement experiments -->
  <section class="aa-proof" aria-labelledby="aa-proof-heading" data-bwm-exp-slot="proof-module">
    <div class="container">
      <p class="section-tag">04 · PROOF BEFORE THE ASK</p>
      <h2 id="aa-proof-heading" class="h-section">Before we ask for a call, we show you the leak.</h2>
      <p class="lede">
        The diagnostic is not a quiz for our sales team. It is the first proof artifact. You see what is leaking before we talk.
      </p>

      <div class="aa-proof-grid">
        <article class="aa-proof-card">
          <p class="mono aa-proof-num">01</p>
          <!-- @r020:F2 proof: leak-map funnel makes the diagnostic output tangible — the visitor sees the exact artifact they get after submitting -->
          <svg class="aa-proof-icon" viewBox="0 0 120 64" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <polygon points="10,8 110,8 84,30 36,30" fill="rgba(240,255,0,0.08)" stroke="rgba(240,255,0,0.35)" stroke-width="1.4"/>
            <line x1="36" y1="30" x2="30" y2="54" stroke="rgba(240,255,0,0.42)" stroke-width="1.4"/>
            <line x1="84" y1="30" x2="90" y2="54" stroke="rgba(240,255,0,0.42)" stroke-width="1.4"/>
            <polygon points="30,54 90,54 80,62 40,62" fill="rgba(240,255,0,0.18)" stroke="#F0FF00" stroke-width="1.2"/>
            <circle cx="60" cy="42" r="4" fill="#F0FF00"/>
            <text x="24" y="22" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.62)" letter-spacing="0.10em">LEAK FOUND</text>
          </svg>
          <h3>Your leak gets named.</h3>
          <p>Lead capture, response speed, attribution, reviews, or conversion. The map shows which one is costing you most.</p>
        </article>

        <article class="aa-proof-card">
          <p class="mono aa-proof-num">02</p>
          <!-- @r020:F2 proof: response timer makes the follow-up gap measurable — it turns vague "better marketing" into a concrete operating fix -->
          <svg class="aa-proof-icon" viewBox="0 0 120 64" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="34" r="16" fill="rgba(240,255,0,0.08)" stroke="rgba(240,255,0,0.35)" stroke-width="1.4"/>
            <line x1="28" y1="22" x2="28" y2="34" stroke="#F0FF00" stroke-width="1.4"/>
            <line x1="28" y1="34" x2="38" y2="34" stroke="#F0FF00" stroke-width="1.4"/>
            <text x="56" y="30" font-family="JetBrains Mono, monospace" font-size="9" fill="#F0FF00" letter-spacing="0.10em">&lt;60 SEC</text>
            <text x="56" y="44" font-family="JetBrains Mono, monospace" font-size="7" fill="#62626A" letter-spacing="0.10em">REPLY TARGET</text>
          </svg>
          <h3>The fix gets practical.</h3>
          <p>We do not hand you theory. The map points to the next system move that would change the week.</p>
        </article>

        <article class="aa-proof-card">
          <p class="mono aa-proof-num">03</p>
          <!-- @r020:F2 proof: owned-readout loop shows closed-loop attribution — the owner sees how the system proves what booked -->
          <svg class="aa-proof-icon" viewBox="0 0 120 64" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <circle cx="18" cy="32" r="4" fill="#F0FF00"/>
            <line x1="22" y1="32" x2="54" y2="18" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="60" cy="16" r="4" fill="rgba(240,255,0,0.72)"/>
            <line x1="64" y1="18" x2="92" y2="32" stroke="rgba(240,255,0,0.45)" stroke-width="1.4"/>
            <circle cx="98" cy="34" r="4" fill="rgba(240,255,0,0.72)"/>
            <path d="M98 40 C82 58 36 56 18 38" stroke="rgba(240,255,0,0.32)" stroke-width="1.3" fill="none"/>
            <polyline points="21,45 18,38 25,39" stroke="rgba(240,255,0,0.32)" stroke-width="1.3" fill="none"/>
            <text x="10" y="58" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.58)" letter-spacing="0.06em">SOURCE → JOB → READOUT</text>
          </svg>
          <h3>You own the readout.</h3>
          <p>Every lead should trace back to a source. The system is built around that weekly truth.</p>
        </article>
      </div>

      <!-- @r020:F2 proof: results editorial photo grounds the proof section in documented operating evidence — printed readouts, notes, and numbers make the CTA feel earned -->
      <figure class="aa-proof-editorial">
        <img
          src="/images/bwm-results-editorial-v1.webp"
          alt="Open binder with printed weekly marketing performance numbers and notes marking what changed."
          width="640"
          height="426"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="aa-proof-caption mono">Weekly readout · attributed · owned by you</figcaption>
      </figure>

      <div class="aa-proof-cta">
        <a href="#diagnostic" class="cta" data-cta-source="f4-agency-alternative-final">
          Get My Free Revenue Leak Map
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <p class="aa-proof-subtext mono">No email required to see the result. If there is no fit, you still keep the map.</p>
      </div>
    </div>
  </section>

  <!-- REVENUE LEAK MAP DIAGNOSTIC — conversion endpoint -->
  <FitDiagnostic />

</BaseLayout>

<style>
/* ─── HERO ──────────────────────────────────────────────────────────────── */
.aa-hero {
  padding-top: clamp(96px, 11vw, 168px);
  padding-bottom: clamp(64px, 7vw, 112px);
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

.aa-hero-grid {
  display: flex;
  flex-direction: column;
  gap: clamp(40px, 5vw, 72px);
}

.aa-hero-text {
  display: flex;
  flex-direction: column;
  gap: 32px;
