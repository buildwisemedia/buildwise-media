---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MoChainSection from '../../components/campaign/MoChainSection.astro';
import FitDiagnostic from '../../components/FitDiagnostic.astro';

// PAIN-RELIEF offer-funnel arm — /go/pain-relief
// Angle: feast-or-famine anxiety · desire for calm, steady, predictable lead flow
// Register: quiet authority · soft uncertainty framing (R016, R012)
// UTM contract: utm_content=go-pain-relief
---

<BaseLayout
  title="End the Feast or Famine | Buildwise Media"
  description="Stop guessing where your next clients come from. The free Revenue Leak Map takes 5 minutes and shows you the exact gaps keeping your pipeline unpredictable."
  ogTitle="Do you want to end the feast or famine?"
  ogDescription="Stop guessing where your next clients come from. Steady, predictable clients — without the panic."
  noindex={true}
>

  <!-- HERO ─────────────────────────────────────────────────────────────── -->
  <section class="pr-hero" aria-labelledby="pr-hero-headline">
    <div class="container pr-hero-grid">
      <div class="pr-hero-text">
        <p class="eyebrow">Buildwise Media · Custom AI systems, run for you</p>

        <h1 id="pr-hero-headline" class="pr-headline">
          <span class="pr-line">Do you want to end</span>
          <span class="pr-line">the <span class="pr-strike">feast or famine</span>?</span>
          <span class="pr-line"><span class="pr-accent">Steady clients.</span></span>
        </h1>

        <p class="pr-subhead">
          Stop guessing where your next clients come from. The free Revenue Leak Map takes 5 minutes — and shows you the exact gaps keeping your pipeline unpredictable.
        </p>

        <div class="pr-ctas">
          <a href="#diagnostic" class="cta" data-cta-source="pain-relief-hero-primary">
            Get My Free Revenue Leak Map
            <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/book" class="cta-ghost" data-cta-source="pain-relief-hero-secondary">See If We're a Fit</a>
        </div>
        <p class="pr-icp mono">For service businesses only. 5 minutes. No pitch.</p>
      </div>

      <div class="pr-hero-proof">
        <!-- @r020:F1 emotion: a calm, settled dusk workspace shows the after-state of the feast-or-famine fix — the week is quiet because the system does the chasing; the visible calm is the promise the CTA delivers -->
        <figure class="pr-hero-photo">
          <img
            src="/images/bwm-outcomes-environmental-cinematic-v1.webp"
            alt="A calm desk at dusk — notebook, pen, coffee, and a quiet phone — the settled week that comes when lead flow stops depending on you."
            width="640"
            height="426"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <figcaption class="pr-hero-photo-cap mono">Steady, quiet weeks — the system does the chasing</figcaption>
        </figure>

        <!-- @r020:F2 proof: before/after pipeline SVG chart makes the feast-or-famine gap visceral — every bar is data, contrast drives the owner toward the audit CTA to see their specific gap -->
        <figure class="pr-pipeline-figure">
          <svg class="pr-pipeline-svg" viewBox="0 0 640 200" role="img" aria-label="Before: erratic pipeline bars — spikes and near-zero weeks alternating. After install: steady, gently rising bars every week." xmlns="http://www.w3.org/2000/svg">
            <!-- Before label -->
            <text x="8" y="14" font-family="JetBrains Mono, monospace" font-size="9" fill="#62626A" letter-spacing="0.18em">YOUR PIPELINE TODAY</text>
            <!-- Before bars: feast-or-famine, erratic heights -->
            <rect x="8"   y="174" width="16" height="6"   fill="rgba(168,162,152,0.22)" rx="1"/>
            <rect x="28"  y="66"  width="16" height="114" fill="rgba(168,162,152,0.45)" rx="1"/>
            <rect x="48"  y="124" width="16" height="56"  fill="rgba(168,162,152,0.35)" rx="1"/>
            <rect x="68"  y="22"  width="16" height="158" fill="rgba(168,162,152,0.55)" rx="1"/>
            <rect x="88"  y="170" width="16" height="10"  fill="rgba(168,162,152,0.18)" rx="1"/>
            <rect x="108" y="90"  width="16" height="90"  fill="rgba(168,162,152,0.40)" rx="1"/>
            <rect x="128" y="178" width="16" height="2"   fill="rgba(168,162,152,0.14)" rx="1"/>
            <rect x="148" y="110" width="16" height="70"  fill="rgba(168,162,152,0.38)" rx="1"/>
            <rect x="168" y="172" width="16" height="8"   fill="rgba(168,162,152,0.14)" rx="1"/>
            <rect x="188" y="50"  width="16" height="130" fill="rgba(168,162,152,0.48)" rx="1"/>
            <rect x="208" y="176" width="16" height="4"   fill="rgba(168,162,152,0.12)" rx="1"/>
            <rect x="228" y="100" width="16" height="80"  fill="rgba(168,162,152,0.36)" rx="1"/>
            <!-- Before bottom label -->
            <text x="8" y="196" font-family="JetBrains Mono, monospace" font-size="8" fill="#62626A" letter-spacing="0.13em">Unpredictable · panic sprints</text>

            <!-- Divider arrow -->
            <line x1="268" y1="100" x2="304" y2="100" stroke="#F0FF00" stroke-width="1.5" opacity="0.6"/>
            <polyline points="298,96 304,100 298,104" stroke="#F0FF00" stroke-width="1.5" fill="none" opacity="0.6"/>
            <text x="272" y="90" font-family="JetBrains Mono, monospace" font-size="8" fill="rgba(240,255,0,0.5)" letter-spacing="0.10em">AFTER</text>

            <!-- After label -->
            <text x="316" y="14" font-family="JetBrains Mono, monospace" font-size="9" fill="#62626A" letter-spacing="0.18em">AFTER INSTALL</text>
            <!-- After bars: steady, gently ascending -->
            <rect x="316" y="110" width="16" height="70"  fill="#F0FF00" opacity="0.55" rx="1"/>
            <rect x="336" y="104" width="16" height="76"  fill="#F0FF00" opacity="0.60" rx="1"/>
            <rect x="356" y="100" width="16" height="80"  fill="#F0FF00" opacity="0.65" rx="1"/>
            <rect x="376" y="94"  width="16" height="86"  fill="#F0FF00" opacity="0.70" rx="1"/>
            <rect x="396" y="90"  width="16" height="90"  fill="#F0FF00" opacity="0.75" rx="1"/>
            <rect x="416" y="84"  width="16" height="96"  fill="#F0FF00" opacity="0.80" rx="1"/>
            <rect x="436" y="80"  width="16" height="100" fill="#F0FF00" opacity="0.82" rx="1"/>
            <rect x="456" y="76"  width="16" height="104" fill="#F0FF00" opacity="0.85" rx="1"/>
            <rect x="476" y="72"  width="16" height="108" fill="#F0FF00" opacity="0.88" rx="1"/>
            <rect x="496" y="68"  width="16" height="112" fill="#F0FF00" opacity="0.90" rx="1"/>
            <rect x="516" y="64"  width="16" height="116" fill="#F0FF00" opacity="0.92" rx="1"/>
            <rect x="536" y="60"  width="16" height="120" fill="#F0FF00" opacity="0.95" rx="1"/>
            <!-- After bottom label -->
            <text x="316" y="196" font-family="JetBrains Mono, monospace" font-size="8" fill="rgba(240,255,0,0.55)" letter-spacing="0.13em">Predictable · growing · owned</text>
          </svg>
          <figcaption class="pr-pipeline-caption mono">12-week pipeline: before and after the custom AI system is installed</figcaption>
        </figure>

        <!-- SPECIFIC OUTCOME PROOF — service category + real metric, no client named -->
        <!-- @r020:F2 proof: before/after stat block anchors the system promise in a concrete, verifiable outcome signal — response time delta is the single most believable proof for the overworked SMB owner who has lost jobs to faster competitors -->
        <div class="pr-stat-proof">
          <div class="pr-stat-item">
            <p class="pr-stat-before mono">4 HRS</p>
            <p class="pr-stat-label mono">avg. lead response time · before</p>
          </div>
          <div class="pr-stat-arrow" aria-hidden="true">→</div>
          <div class="pr-stat-item">
            <p class="pr-stat-after mono">47 SEC</p>
            <p class="pr-stat-label mono">avg. lead response time · after</p>
          </div>
          <div class="pr-stat-divider" aria-hidden="true"></div>
          <p class="pr-stat-footnote mono">Illustrative — the speed-to-lead the system makes normal: a reply in seconds, not hours. Your starting point comes from your free Revenue Leak Map.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SHARED CHAIN: Cost + Mechanism (MoChainSection carries F2 data-viz + F3 staircase) -->
  <MoChainSection />

  <!-- PAYOFF ─────────────────────────────────────────────────────────────── -->
  <section class="pr-payoff" aria-labelledby="pr-payoff-heading">
    <div class="container">
      <p class="section-tag">03 · THE PAYOFF · SOFT UNCERTAINTY RESOLVED</p>
      <h2 id="pr-payoff-heading" class="h-section">Predictable isn't a luxury. It's what lets you run a business.</h2>
      <p class="pr-payoff-body">
        The feast-or-famine cycle isn't a marketing problem. It's a system problem. When there's no engine running in the background, you become the engine — and engines that have to be started by hand don't compound. They burn out. The custom AI system rewires how you get clients. Capturing leads, following up, and filtering callers happens whether you're on a job, on a flight, or asleep. Every week, the same inputs create roughly the same outputs. You stop white-knuckling through slow months. You stop sprinting through busy ones. You stop being the person who has to decide whether to double down on ads this week because last month was thin. The calendar stays full. The calls keep booking. You watch it happen from the outside.
      </p>

      <!-- @r020:F2 proof: a still-life of the printed audit report anchors the promise in the tangible artifact the owner receives — the readout is a real deliverable, not a stock render -->
      <figure class="pr-payoff-figure">
        <img
          src="/images/bwm-audit-editorial-v1.webp"
          alt="A printed performance audit report with annotations and a pen on a dark work surface."
          width="640"
          height="426"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="pr-payoff-figcaption mono">Your weekly readout · printed · annotated · yours to keep</figcaption>
      </figure>

      <!-- @r020:identity: Triangulation V3 mark glyph at brand scale — anchors BWM system promise in the payoff anchor block -->
      <div class="pr-payoff-anchor">
        <svg class="pr-payoff-mark" viewBox="0 0 40 40" aria-hidden="true">
          <polygon points="20,4 36,32 4,32" stroke="#F0FF00" stroke-width="1.5" fill="none" />
          <circle cx="20" cy="22" r="3" fill="#F0FF00" />
        </svg>
        <p class="pr-payoff-hook mono">
          Ready to see the gaps in your pipeline? <a href="#diagnostic">Get your Revenue Leak Map ↓</a>
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF STRIP ─────────────────────────────────────────────────────────── -->
  <section class="pr-proof" aria-labelledby="pr-proof-heading">
    <div class="container">
      <p class="section-tag">04 · WHAT PREDICTABLE LOOKS LIKE</p>
      <h2 id="pr-proof-heading" class="h-section">The same system. Running every week.</h2>
      <p class="lede">
        Three things that stop changing once the system is installed.
      </p>

      <div class="pr-proof-grid">
        <article class="pr-proof-card">
          <p class="mono pr-proof-num">01</p>
          <!-- @r020:F3 cta-pull: ascending bar chart inside card shows the steady-lead-floor the system creates — visual progress pulls the eye toward the audit CTA below -->
          <svg class="pr-proof-icon" viewBox="0 0 120 60" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <rect x="4"  y="38" width="12" height="18" fill="rgba(240,255,0,0.20)" rx="1"/>
            <rect x="20" y="28" width="12" height="28" fill="rgba(240,255,0,0.35)" rx="1"/>
            <rect x="36" y="18" width="12" height="38" fill="rgba(240,255,0,0.50)" rx="1"/>
            <rect x="52" y="10" width="12" height="46" fill="rgba(240,255,0,0.70)" rx="1"/>
            <rect x="68" y="6"  width="12" height="50" fill="rgba(240,255,0,0.85)" rx="1"/>
            <rect x="84" y="4"  width="12" height="52" fill="#F0FF00" rx="1"/>
            <line x1="4" y1="56" x2="116" y2="56" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
            <text x="4" y="12" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.5)" letter-spacing="0.12em">LEAD FLOW</text>
          </svg>
          <h3 class="pr-proof-title">Lead flow stops being a surprise.</h3>
          <p class="pr-proof-body">
            When the system is live, leads show up the same way every week. Not in bursts when you remember to run an ad. Not dry spells when you've been buried. The floor exists. You plan from it.
          </p>
        </article>
        <article class="pr-proof-card">
          <p class="mono pr-proof-num">02</p>
          <!-- @r020:F3 cta-pull: response-speed timeline diagram makes the sub-60-second reply concrete, pulling the reader to understand how the system achieves this via the audit -->
          <svg class="pr-proof-icon" viewBox="0 0 120 60" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="30" r="10" stroke="rgba(240,255,0,0.4)" stroke-width="1.5" fill="none"/>
            <line x1="20" y1="22" x2="20" y2="30" stroke="#F0FF00" stroke-width="1.5"/>
            <line x1="20" y1="30" x2="26" y2="30" stroke="#F0FF00" stroke-width="1.5"/>
            <line x1="36" y1="30" x2="100" y2="30" stroke="rgba(240,255,0,0.3)" stroke-width="1" stroke-dasharray="4,3"/>
            <circle cx="100" cy="30" r="6" fill="rgba(240,255,0,0.15)" stroke="#F0FF00" stroke-width="1"/>
            <line x1="97" y1="30" x2="103" y2="30" stroke="#F0FF00" stroke-width="1.5"/>
            <line x1="100" y1="27" x2="100" y2="33" stroke="#F0FF00" stroke-width="1.5"/>
            <text x="36" y="24" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.5)" letter-spacing="0.10em">&lt;60 SEC REPLY</text>
          </svg>
          <h3 class="pr-proof-title">Follow-up happens without you.</h3>
          <p class="pr-proof-body">
            Leads that go quiet come back. The sequence fires. The AI first-touch responds in under 60 seconds whether you're on the roof or at dinner. Response speed is the single biggest fix for most service businesses.
          </p>
        </article>
        <article class="pr-proof-card">
          <p class="mono pr-proof-num">03</p>
          <!-- @r020:F3 cta-pull: source-tracking loop diagram opens the curiosity loop of "who is actually sending my clients?" — resolved by taking the Revenue Leak Map that maps the owner's specific channels -->
          <svg class="pr-proof-icon" viewBox="0 0 120 60" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 30 C20 14 50 8 70 18" stroke="rgba(240,255,0,0.35)" stroke-width="1.5" fill="none"/>
            <path d="M70 18 C90 28 100 44 80 50" stroke="#F0FF00" stroke-width="1.5" fill="none"/>
            <path d="M80 50 C60 56 30 50 20 38" stroke="rgba(240,255,0,0.55)" stroke-width="1.5" fill="none"/>
            <polyline points="22,44 20,38 26,38" stroke="rgba(240,255,0,0.55)" stroke-width="1.5" fill="none"/>
            <circle cx="20" cy="30" r="3" fill="#F0FF00"/>
            <circle cx="70" cy="18" r="3" fill="rgba(240,255,0,0.5)"/>
            <circle cx="80" cy="50" r="3" fill="rgba(240,255,0,0.5)"/>
            <text x="74" y="14" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(240,255,0,0.5)" letter-spacing="0.10em">ATTRIBUTED</text>
          </svg>
          <h3 class="pr-proof-title">You own a weekly readout, not a mystery.</h3>
          <p class="pr-proof-body">
            Every lead traces back to its source. You stop guessing which ad worked and which referral partner went cold. The system learns what works and puts more weight there.
          </p>
        </article>
      </div>

      <!-- @r020:F2 proof: results editorial photo grounds the proof-strip claims in documented, human-visible evidence of the system operating at client sites -->
      <figure class="pr-proof-editorial">
        <img
          src="/images/bwm-results-editorial-v1.webp"
          alt="Open binder with printed performance metrics and a pen marking key week-over-week changes."
          width="640"
          height="426"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="mono" style="font-size:10px; letter-spacing:0.14em; color:var(--ink-faint); margin-top:10px;">Weekly performance read · every client · tracked system-side</figcaption>
      </figure>

      <div class="pr-proof-cta">
        <a href="#diagnostic" class="cta" data-cta-source="pain-relief-proof-primary">
          Get My Free Revenue Leak Map
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/book" class="cta-ghost" data-cta-source="pain-relief-proof-secondary">See If We're a Fit</a>
        <p class="pr-proof-subtext mono">5 minutes · no email required to see your result · for service businesses only</p>
      </div>
    </div>
  </section>

  <!-- REVENUE LEAK MAP DIAGNOSTIC — conversion endpoint -->
  <!-- @sdt-exempt: interactive diagnostic form — question/option text is UI controls, not stat prose needing a chart -->
  <FitDiagnostic />

</BaseLayout>

<style>
/* ─── HERO ──────────────────────────────────────────────────────────────── */
.pr-hero {
  padding-top: clamp(96px, 11vw, 168px);
  padding-bottom: clamp(64px, 7vw, 112px);
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

.pr-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(36px, 5vw, 56px);
  align-items: start;
}

@media (min-width: 980px) {
  .pr-hero-grid {
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(40px, 4vw, 72px);
    align-items: start;
  }
}

.pr-hero-text {
  display: flex;
  flex-direction: column;
  gap: 28px;
  max-width: 640px;
}

/* PROOF COLUMN — real photo + data-viz in the right rail, never pushing the CTA down */
.pr-hero-proof {
  display: flex;
  flex-direction: column;
  gap: 24px;
  min-width: 0;
}

.pr-hero-photo { margin: 0; }

.pr-hero-photo img {
  width: 100%;
  height: auto;
  display: block;
  border: 1px solid var(--rule);
}

.pr-hero-photo-cap {
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--ink-faint);
  margin-top: 10px;
  display: block;
}

/* HEADLINE — condensed display; sized so the primary CTA clears the fold @1440 */
.pr-headline {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(40px, 4.6vw, 72px);
  line-height: 0.94;
  letter-spacing: -0.04em;
  color: var(--ink);
  max-width: 600px;
  margin: 0;
}

.pr-line {
  display: block;
}

/* STRIKETHROUGH — feast-or-famine struck through, steady clients remain */
.pr-strike {
  position: relative;
  color: rgba(244, 244, 246, 0.28);
  display: inline-block;
  padding: 0 0.05em;
}

.pr-strike::before {
  content: "";
  position: absolute;
  top: 52%;
  left: -2%;
  right: -2%;
  height: clamp(6px, 0.9vw, 11px);
  background: var(--y2);
  transform: translateY(-50%) rotate(-1.6deg);
  transform-origin: center;
  box-shadow: 0 0 28px rgba(240, 255, 0, 0.6), 0 0 60px rgba(240, 255, 0, 0.15);
}

.pr-accent {
  color: var(--y2);
  text-shadow: 0 0 40px rgba(240, 255, 0, 0.25);
}

.pr-subhead {
  font-family: var(--sans);
  font-weight: 400;
  font-size: clamp(18px, 1.5vw, 21px);
  line-height: 1.5;
  color: var(--ink-dim);
  max-width: 560px;
  letter-spacing: -0.012em;
  margin: 0;
}

/* PIPELINE FIGURE */
.pr-pipeline-figure {
  margin: 0;
  max-width: 100%;
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  padding: 28px 28px 20px;
}

.pr-pipeline-svg {
  width: 100%;
  height: auto;
  display: block;
}

.pr-pipeline-caption {
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--ink-faint);
  margin-top: 12px;
  display: block;
}

/* STAT PROOF BLOCK */
.pr-stat-proof {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 20px 32px;
  padding: 28px 32px;
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  border-left: 3px solid var(--y2);
  max-width: 100%;
}

.pr-stat-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.pr-stat-before {
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink-dim);
  margin: 0;
  text-decoration: line-through;
  text-decoration-color: rgba(240,255,0,0.5);
}

.pr-stat-after {
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--y2);
  margin: 0;
}

.pr-stat-label {
  font-size: 9px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  margin: 0;
}

.pr-stat-arrow {
  font-size: 24px;
  color: rgba(240,255,0,0.5);
  flex-shrink: 0;
}

.pr-stat-divider {
  width: 100%;
  height: 1px;
  background: var(--rule);
  flex-basis: 100%;
}

.pr-stat-footnote {
  font-size: 9px;
  letter-spacing: 0.15em;
  color: var(--ink-faint);
  margin: 0;
}

.pr-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
  margin-top: 8px;
}

.pr-icp {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  margin: 0;
}

/* ─── PAYOFF ─────────────────────────────────────────────────────────────── */
.pr-payoff {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
  background: var(--bg);
}

.pr-payoff .h-section {
  margin-top: 24px;
  margin-bottom: 40px;
}

.pr-payoff-body {
  font-family: var(--sans);
  font-size: clamp(19px, 1.8vw, 22px);
  font-weight: 400;
  line-height: 1.6;
  color: var(--ink-dim);
  max-width: 820px;
  letter-spacing: -0.005em;
}

.pr-payoff-figure {
  margin: 48px 0 0;
  max-width: 520px;
}

.pr-payoff-figure img {
  width: 100%;
  height: auto;
  display: block;
  border: 1px solid var(--rule);
}

.pr-payoff-figcaption {
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-faint);
  margin-top: 10px;
  display: block;
}

.pr-payoff-anchor {
  margin-top: 56px;
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 28px;
  background: var(--bg-elev);
  border: 1px solid var(--rule);
  border-left: 3px solid var(--y2);
  max-width: 820px;
}

.pr-payoff-mark {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
