      }

      .diagnostic-readouts {
        grid-template-columns: 1.05fr 1.05fr 0.75fr;
      }

      .gap-meter {
        height: 8px;
        margin-top: 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
      }

      .gap-meter span {
