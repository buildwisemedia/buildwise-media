      }

      .arc-card {
        min-height: 116px;
        overflow: hidden;
      }

      .gap-feel-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
      }

      .gap-arc {
        width: 38px;
        height: 38px;
        flex: 0 0 38px;
        transform: rotate(-90deg);
      }

      .arc-track,
      .arc-fill {
        fill: none;
        stroke-width: 7;
      }

      .arc-track {
        stroke: rgba(255, 255, 255, 0.08);
      }

      .arc-fill {
        stroke: var(--yellow);
