    <script is:inline>
      (() => {
        const app = document.querySelector("[data-app]");
        const welcome = document.querySelector('[data-panel="welcome"]');
        const cockpit = document.querySelector('[data-panel="cockpit"]');
        const startButton = document.querySelector("[data-start]");
        const backWelcomeButton = document.querySelector("[data-back-welcome]");
        const nextTargetButton = document.querySelector("[data-next-target]");
        const prevLeakButton = document.querySelector("[data-prev-leak]");
        const finishButton = document.querySelector("[data-finish]");
        const leakOptions = Array.from(document.querySelectorAll(".leak-option"));
        const railSteps = Array.from(document.querySelectorAll(".rail-step"));
        const q5Step = document.querySelector('[data-step="q5"]');
        const q7Step = document.querySelector('[data-step="q7"]');
        const q5Insight = document.querySelector("[data-q5-insight]");
        const q7Insight = document.querySelector("[data-q7-insight]");
        const liveCanvas = document.querySelector("[data-live-canvas]");
        const scoreOutput = document.querySelector("[data-score-output]");
        const miniScore = document.querySelector("[data-mini-score]");
        const miniLeak = document.querySelector("[data-mini-leak]");
        const currentLeak = document.querySelector("[data-current-leak]");
        const currentLeakCopy = document.querySelector("[data-current-leak-copy]");
        const mapTitle = document.querySelector("[data-map-title]");
        const leakBadge = document.querySelector("[data-leak-badge]");
        const leakBadgeText = document.querySelector("[data-leak-badge-text]");
        const mapNodes = Array.from(document.querySelectorAll("[data-map-node]"));
        const gapBar = document.querySelector("[data-gap-bar]");
        const gapArc = document.querySelector("[data-gap-arc]");
        const gapLabel = document.querySelector("[data-gap-label]");
        const gapPercent = document.querySelector("[data-gap-percent]");
        const targetInputs = Array.from(document.querySelectorAll("[data-target-input]"));
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const state = {
          leak: null,
          leakNode: null,
          leakLabel: "Pick the first break",
          score: 0,
          target: {
            revenue: "",
            team: "",
            hours: "",
          },
        };

        const copyByNode = {
          demand: "Calendar gaps show up before the work does.",
          fit: "Bad-fit leads waste quotes and drain time.",
          capacity: "The schedule is the ceiling before demand is.",
          speed: "Fast competitors win while the lead waits.",
          close: "The money is in the sales gap.",
        };

        function showPanel(name) {
          const isWelcome = name === "welcome";
          welcome.classList.toggle("is-active", isWelcome);
          cockpit.classList.toggle("is-active", !isWelcome);
          cockpit.setAttribute("aria-hidden", String(isWelcome));
          app.dataset.screen = name;
        }

        function showStep(step) {
          const showTarget = step === "q7";
          q5Step.hidden = showTarget;
          q7Step.hidden = !showTarget;
          q5Step.classList.toggle("is-active", !showTarget);
          q7Step.classList.toggle("is-active", showTarget);
          updateRail(showTarget ? "target" : "leak");
          liveCanvas.classList.toggle("has-target", showTarget);
          mapNodes
            .filter((node) => node.dataset.mapNode === "target")
            .forEach((node) => node.classList.toggle("is-target", showTarget));
        }

        function updateRail(activeKey) {
          railSteps.forEach((step) => {
            const key = step.dataset.rail;
            const isActive = key === activeKey;
            step.classList.toggle("is-active", isActive);
            if (activeKey === "target") {
              step.classList.toggle("is-done", key !== "target");
            } else {
              step.classList.toggle(
                "is-done",
                ["service", "demand", "stage", "owner-time"].includes(key),
              );
            }
          });
        }

        function animateScore(to) {
          const from = state.score;
          const next = Number(to) || 0;
          state.score = next;

          if (reducedMotion) {
            writeScore(next);
            return;
          }

          const start = performance.now();
          const duration = 420;

          function frame(now) {
            const pct = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - pct, 3);
            const value = Math.round(from + (next - from) * eased);
            writeScore(value);
            if (pct < 1) requestAnimationFrame(frame);
          }

          requestAnimationFrame(frame);
        }

        function writeScore(value) {
          const padded = String(value).padStart(2, "0");
          scoreOutput.textContent = padded;
          miniScore.textContent = padded;
        }

        function selectLeak(button) {
          const value = button.dataset.value;
          const node = button.dataset.node;
          const label = button.dataset.label;
          const score = Number(button.dataset.score);

          state.leak = value;
          state.leakNode = node;
          state.leakLabel = label;

          leakOptions.forEach((option) => {
            const selected = option === button;
            option.classList.toggle("is-selected", selected);
            option.classList.toggle("is-muted", !selected);
            option.setAttribute("aria-checked", String(selected));
          });

          mapNodes.forEach((mapNode) => {
            const key = mapNode.dataset.mapNode;
            const isLeak = key === node;
            const unlocked = isLeak || key === "service";
            mapNode.classList.toggle("is-leak", isLeak);
            mapNode.classList.toggle("is-unlocked", unlocked);
            mapNode.classList.toggle("is-dim", !unlocked && key !== "target");
          });

          liveCanvas.classList.remove("has-trace");
          void liveCanvas.offsetWidth;
          liveCanvas.classList.add("has-trace");

          leakBadge.hidden = false;
          leakBadgeText.textContent = label.replace(" leak", "");
          currentLeak.textContent = label;
          currentLeakCopy.textContent = copyByNode[node];
          mapTitle.textContent = `${label} found`;
          miniLeak.textContent = label;
          q5Insight.textContent = button.dataset.insight;
          nextTargetButton.disabled = false;
          animateScore(score);
          updateTargetGap();
        }

        function setPreset(button) {
          const card = button.closest("[data-dial]");
          const key = card.dataset.dial;
          const input = card.querySelector("[data-target-input]");
          const value = button.dataset.preset;

          card.querySelectorAll("[data-preset]").forEach((preset) => {
            preset.classList.toggle("is-selected", preset === button);
          });

          input.value = value;
          state.target[key] = value;
          updateTargetGap();
        }

        function updateTargetGap() {
          const filled = Object.values(state.target).filter(Boolean).length;
          const pct = Math.round((filled / 3) * 100);
          const arcOffset = 176 - 176 * (pct / 100);
          const scoreLift = state.leak ? filled * 10 : 0;

          gapBar.style.width = `${pct}%`;
          gapArc.style.strokeDashoffset = String(arcOffset);
          gapPercent.textContent = `${pct}%`;
          gapLabel.textContent = filled ? `${filled} of 3 targets set` : "No target set";

          if (filled > 0) {
            q7Insight.textContent = "Target gap is now visible.";
            liveCanvas.classList.add("has-target");
            mapNodes
              .filter((node) => node.dataset.mapNode === "target")
              .forEach((node) => node.classList.add("is-target", "is-unlocked"));
          } else {
            q7Insight.textContent = "Each target tightens the gap.";
          }

          if (state.leak) {
            const selected = leakOptions.find((option) => option.dataset.value === state.leak);
            const baseScore = selected ? Number(selected.dataset.score) : state.score;
            animateScore(Math.min(88, baseScore + scoreLift));
          }
        }

        startButton.addEventListener("click", () => {
          showPanel("cockpit");
          showStep("q5");
        });

        backWelcomeButton.addEventListener("click", () => {
          showPanel("welcome");
        });

        nextTargetButton.addEventListener("click", () => {
          showStep("q7");
        });

        prevLeakButton.addEventListener("click", () => {
          showStep("q5");
        });

        finishButton.addEventListener("click", () => {
          const finalScore = Math.max(state.score, 72);
          mapTitle.textContent = "Leak Map ready";
          q7Insight.textContent = "Map ready. Your first leak and target gap are set.";
          miniLeak.textContent = "Leak Map ready";
          animateScore(finalScore);
        });

        leakOptions.forEach((button) => {
          button.addEventListener("click", () => selectLeak(button));
        });

        document.querySelectorAll("[data-preset]").forEach((button) => {
          button.addEventListener("click", () => setPreset(button));
        });

        targetInputs.forEach((input) => {
          input.addEventListener("input", () => {
            const key = input.dataset.targetInput;
            state.target[key] = input.value.trim();
            const card = input.closest("[data-dial]");
            card.querySelectorAll("[data-preset]").forEach((preset) => preset.classList.remove("is-selected"));
            updateTargetGap();
          });
        });
      })();
    </script>
  </body>
</html>
