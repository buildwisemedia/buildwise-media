          welcome.setAttribute("aria-hidden", String(!isWelcome));
          cockpit.setAttribute("aria-hidden", String(!isCockpit));
          reveal.setAttribute("aria-hidden", String(!isReveal));
          welcome.inert = !isWelcome;
          cockpit.inert = !isCockpit;
          reveal.inert = !isReveal;
          app.dataset.screen = name;
        }

        function showStep(step) {
          currentStep = step;
          questionCards.forEach((card) => {
            const isActive = card.dataset.step === step;
            card.hidden = !isActive;
            card.classList.toggle("is-active", isActive);
            card.setAttribute("aria-hidden", String(!isActive));
            card.inert = !isActive;
          });
          updateRail();
          updateNextStates();
          updateLiveMap();
          announce(`${STEP_LABEL[step]} step`);

          const activeCard = questionCards.find((card) => card.dataset.step === step);
          const heading = activeCard && activeCard.querySelector("h2");
          if (heading) {
            heading.tabIndex = -1;
            requestAnimationFrame(() => heading.focus({ preventScroll: true }));
          }
        }

        function updateRail() {
          const activeRail = RAIL_BY_STEP[currentStep];
          const activeIndex = STEP_ORDER.indexOf(currentStep);
          railSteps.forEach((step) => {
            const key = step.dataset.rail;
            const railStep = STEP_ORDER.find((item) => RAIL_BY_STEP[item] === key);
            const index = STEP_ORDER.indexOf(railStep);
            step.classList.toggle("is-active", key === activeRail);
            step.classList.toggle("is-done", index >= 0 && index < activeIndex && isStepComplete(railStep));
          });
        }

        function isStepComplete(step) {
          if (step === "q1") return Boolean(state.service);
          if (step === "q2") return state.leadSources.length > 0;
          if (step === "q3") return Boolean(state.revenue);
          if (step === "q4") return Boolean(state.opsRatio);
          if (step === "q5") return Boolean(state.bottleneck);
          if (step === "q6") return true;
          if (step === "q7") return true;
          return false;
        }

        function updateNextStates() {
          nextButtons.forEach((button) => {
            const card = button.closest("[data-step]");
            const step = card && card.dataset.step;
            button.disabled = step === "q6" ? false : !isStepComplete(step);
          });
        }

        function announce(message) {
          if (!liveAnnouncer) return;
          liveAnnouncer.textContent = message;
        }

        function animateScore(to) {
          const from = state.score;
          const next = Number(to) || 0;
          state.score = next;

          if (reducedMotion) {
            writeScore(next);
            return;
          }

          const start = performance.now();
          const duration = 420;

          function frame(now) {
            const pct = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - pct, 3);
            const value = Math.round(from + (next - from) * eased);
            writeScore(value);
            if (pct < 1) requestAnimationFrame(frame);
          }

          requestAnimationFrame(frame);
        }

        function writeScore(value) {
          const padded = String(value).padStart(2, "0");
          scoreOutput.textContent = padded;
          miniScore.textContent = padded;
        }

        function calculateScore() {
          let score = 0;
          if (state.service) score += SCORE_STEPS.service;
          if (state.leadSources.length) {
            score += SCORE_STEPS.sourceBase + Math.max(0, state.leadSources.length - 1) * SCORE_STEPS.sourceExtra;
          }
          if (state.revenue) score += SCORE_STEPS.stage;
          if (state.opsRatio) score += SCORE_STEPS.ops;
          if (state.bottleneck) {
            const selected = leakOptions.find((option) => option.dataset.value === state.bottleneck);
            const leakScore = selected ? Number(selected.dataset.score) : score;
            score = Math.max(score, leakScore);
          }
          score += state.capacityGaps.length * SCORE_STEPS.capacity;
          score += Object.values(state.target).filter(Boolean).length * SCORE_STEPS.target;
          return Math.min(99, score);
        }

        function updateScoreFromAnswers() {
          animateScore(calculateScore());
        }

        function getLitSegmentCount() {
          if (Object.values(state.target).some(Boolean)) return 6;
          if (state.capacityGaps.length) return 5;
          if (state.bottleneck) return 4;
          if (state.opsRatio) return 3;
          if (state.revenue) return 2;
          if (state.leadSources.length) return 1;
          return 0;
        }

        function updatePipeSegments() {
          const litCount = getLitSegmentCount();
          pipeSegments.forEach((segment) => {
            const index = Number(segment.dataset.pipeSegment);
            segment.classList.toggle("is-lit", index <= litCount);
          });
        }

        function getSourceInsight(sources) {
          const has = (value) => sources.includes(value);
          const realSources = sources.filter((source) => source !== "unsure");
          if (!sources.length) return "Pick at least one source to light demand.";
          if (has("referrals") && realSources.length === 1) {
            return "Referrals are gold, but you cannot turn them up on a slow month.";
          }
          if (has("paid-ads") && has("social")) {
            return "Wide reach, but nothing is filtering who reaches your calendar.";
          }
          if (has("unsure") && realSources.length === 0) {
            return "If the source is fuzzy, you cannot know what to double down on.";
          }
          if (has("google-organic") && realSources.length === 1) {
            return "Local search catches ready buyers, but only after they know they need help.";
          }
          if (has("paid-ads") && realSources.length === 1) {
            return "Paid leads can scale, but weak filters turn spend into busywork.";
          }
          if (has("social") && realSources.length === 1) {
            return "Social can warm people up, but likes do not fill the calendar by themselves.";
          }
          if (has("cold-outreach") && realSources.length === 1) {
            return "Cold outreach can create shots, but follow-up decides if they become jobs.";
          }
          if (has("referrals")) {
            return "You have reach plus trust. The leak is knowing which source sends buyers.";
          }
          if (has("unsure")) {
            return "Some demand is working, but the fuzzy source makes the next bet harder.";
          }
          return "More sources helps only if the best one is clear.";
        }

        function getCapacityInsight() {
          if (!state.capacityGaps.length) return "Optional stress-test. You can skip this or pick more than one.";
          if (state.capacityGaps.length === 1) {
            const selected = capacityButtons.find((button) => button.dataset.capacityValue === state.capacityGaps[0]);
            return selected ? selected.dataset.insight : "More leads need a stronger catch first.";
          }
          const labels = state.capacityGaps.map((gap) => CAPACITY_LABELS[gap]).filter(Boolean).slice(0, 2);
          return `More demand would hit ${labels.join(" and ")} first. Build the catch before volume climbs.`;
        }

        function getTargetInsight() {
          const filled = Object.entries(state.target).filter(([, value]) => Boolean(value));
          if (!filled.length) return "Each target tightens the gap.";
          const keys = filled.map(([key]) => key);
          if (filled.length === 3) return "Now the gap has a shape: money, crew, and your week have to line up.";
          if (keys.includes("revenue") && filled.length === 1) {
            return "The revenue goal sets the size of the climb. Now we need the crew and time shape.";
          }
          if (keys.includes("team") && filled.length === 1) {
            return "The crew goal shows how much work the system has to carry.";
          }
          if (keys.includes("hours") && filled.length === 1) {
            return "The time-back goal shows how much owner load the system must remove.";
          }
          return "The target is sharper now. The system has to grow without buying it with your week.";
        }

        function setRadioSelection(buttons, selectedButton) {
          buttons.forEach((button) => {
            const selected = button === selectedButton;
            button.classList.toggle("is-selected", selected);
            button.classList.toggle("is-muted", !selected);
            button.setAttribute("aria-checked", String(selected));
          });
        }

        function toggleMultiSelection(button, key, buttons) {
          const value = button.dataset[key];
          const selected = !button.classList.contains("is-selected");
          button.classList.toggle("is-selected", selected);
          button.classList.toggle("is-muted", false);
          button.setAttribute("aria-pressed", String(selected));

          const selectedValues = buttons
            .filter((item) => item.classList.contains("is-selected"))
            .map((item) => item.dataset[key]);

          buttons.forEach((item) => {
            item.classList.toggle("is-muted", selectedValues.length > 0 && !item.classList.contains("is-selected"));
          });

          return selectedValues.filter(Boolean);
        }

        function setStepInsight(step, text) {
          const insight = document.querySelector(`[data-step-insight="${step}"]`);
          if (insight) insight.textContent = text;
        }

        function pulseTrace() {
          liveCanvas.classList.remove("has-trace");
          void liveCanvas.offsetWidth;
          liveCanvas.classList.add("has-trace");
        }

        function updateLiveMap() {
          const targetFilled = Object.values(state.target).some(Boolean);
          const unlocked = new Set();
          if (state.service) unlocked.add("service");
          if (state.leadSources.length) unlocked.add("demand");
          if (state.revenue) unlocked.add("fit");
          if (state.opsRatio) unlocked.add("capacity");
          if (state.bottleneck) unlocked.add("speed");
          if (state.capacityGaps.length) unlocked.add("close");
          if (state.bottleneck && state.leakNode) unlocked.add(state.leakNode);
          if (targetFilled) unlocked.add("target");
          updatePipeSegments();

          mapNodes.forEach((mapNode) => {
            const key = mapNode.dataset.mapNode;
            const isLeak = state.bottleneck && key === state.leakNode;
            const isTarget = key === "target" && targetFilled;
            const isUnlocked = unlocked.has(key);
            mapNode.classList.toggle("is-leak", Boolean(isLeak));
            mapNode.classList.toggle("is-target", Boolean(isTarget));
            mapNode.classList.toggle("is-unlocked", Boolean(isUnlocked));
            mapNode.classList.toggle("is-dim", !isUnlocked && key !== "target");
          });

          liveCanvas.classList.toggle("has-target", targetFilled);
          leakBadge.hidden = !state.bottleneck;
          if (state.bottleneck) leakBadgeText.textContent = cleanLeakLabel(state.leakLabel);

          if (state.bottleneck) {
            const hunchLabel = cleanLeakLabel(state.leakLabel);
            currentLeak.textContent = hunchLabel;
            currentLeakCopy.textContent = "Hunch locked - we'll test it against your time, your channels, and your target.";
            mapTitle.textContent = `Your hunch: ${hunchLabel}`;
            miniLeak.textContent = `Hunch: ${hunchLabel}`;
          } else if (state.leadSources.length) {
            currentLeak.textContent = "Demand mapped";
            currentLeakCopy.textContent = getSourceInsight(state.leadSources);
            mapTitle.textContent = "Demand source mapped";
            miniLeak.textContent = "Demand mapped";
          } else if (state.service) {
            currentLeak.textContent = "Service mapped";
            const selected = serviceButtons.find((button) => button.classList.contains("is-selected"));
            currentLeakCopy.textContent = selected ? selected.dataset.insight : "Service context set.";
            mapTitle.textContent = "Service context set";
            miniLeak.textContent = "Service mapped";
          } else {
            currentLeak.textContent = "Pick one break";
            currentLeakCopy.textContent = "The map will start with your hunch.";
            mapTitle.textContent = "Your map is waking up";
            miniLeak.textContent = "Pick the first break";
          }
        }

        function getSelectedLabel(buttons) {
          const selected = buttons.find((button) => button.classList.contains("is-selected"));
          return selected ? selected.dataset.label : "";
        }

        function selectService(button) {
          state.service = button.dataset.serviceValue;
          setRadioSelection(serviceButtons, button);
          setStepInsight("q1", button.dataset.insight);
          updateScoreFromAnswers();
          pulseTrace();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(`Service set to ${button.dataset.label}`);
        }

        function selectSource(button) {
          state.leadSources = toggleMultiSelection(button, "sourceValue", sourceButtons);
          const count = state.leadSources.length;
          setStepInsight("q2", getSourceInsight(state.leadSources));
          updateScoreFromAnswers();
          if (count) pulseTrace();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(count ? `${count} lead source${count === 1 ? "" : "s"} selected` : "Lead sources cleared");
        }

        function selectStage(button) {
          state.revenue = Number(button.dataset.revenueValue);
          state.revenueLabel = button.dataset.revenueLabel;
          setRadioSelection(stageButtons, button);
          stageReadout.textContent = `${state.revenue} ${state.revenueLabel}`;
          setStepInsight("q3", STAGE_INSIGHTS[state.revenue] || "The stage sets how hard the next jump has to work.");
          updateScoreFromAnswers();
          pulseTrace();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(`Stage set to ${state.revenueLabel}`);
        }

        function selectOps(button) {
          state.opsRatio = Number(button.dataset.opsRatio);
          setRadioSelection(opsButtons, button);
          opsReadout.textContent = button.dataset.opsLabel;
          setStepInsight("q4", OPS_INSIGHTS[state.opsRatio] || "Your week shows how much room growth has.");
          updateScoreFromAnswers();
          pulseTrace();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(`Owner time set to ${button.dataset.opsLabel}`);
        }

        function selectLeak(button) {
          const value = button.dataset.value;
          const node = button.dataset.node;
          const label = button.dataset.label;

          state.bottleneck = value;
          state.leakNode = node;
          state.leakLabel = label;

          setRadioSelection(leakOptions, button);
          pulseTrace();
          q5Insight.textContent = "Hunch locked - we'll test it against your time, your channels, and your target.";
          updateScoreFromAnswers();
          updateTargetGap();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(`${label} selected`);
        }

        function selectCapacity(button) {
          state.capacityGaps = toggleMultiSelection(button, "capacityValue", capacityButtons);
          const count = state.capacityGaps.length;
          setStepInsight("q6", getCapacityInsight());
          updateScoreFromAnswers();
          if (count) pulseTrace();
          updateLiveMap();
          updateRail();
          updateNextStates();
          announce(count ? `${count} stress point${count === 1 ? "" : "s"} selected` : "Stress-test cleared");
        }

        function setPreset(button) {
          const card = button.closest("[data-dial]");
          const key = card.dataset.dial;
          const input = card.querySelector("[data-target-input]");
          const value = button.dataset.preset;

          card.querySelectorAll("[data-preset]").forEach((preset) => {
            preset.classList.toggle("is-selected", preset === button);
          });

          input.value = value;
          state.target[key] = value;
          updateTargetGap();
          updateLiveMap();
          updateRail();
        }

        function updateTargetGap() {
          const filled = Object.values(state.target).filter(Boolean).length;
          const pct = Math.round((filled / 3) * 100);
          const arcOffset = 176 - 176 * (pct / 100);

          gapBar.style.width = `${pct}%`;
          gapArc.style.strokeDashoffset = String(arcOffset);
          gapPercent.textContent = `${pct}%`;
          gapLabel.textContent = filled ? `${filled} of 3 targets set` : "No target set";
          q7Insight.textContent = getTargetInsight();

          if (filled > 0) {
            liveCanvas.classList.add("has-target");
            mapNodes
              .filter((node) => node.dataset.mapNode === "target")
              .forEach((node) => node.classList.add("is-target", "is-unlocked"));
          } else {
            liveCanvas.classList.remove("has-target");
          }

          updateScoreFromAnswers();
        }

        function cleanLeakLabel(label) {
          return label.replace(" leak", "");
        }

        function getScoreRead(score) {
          if (score >= 65) return "system-ready";
          if (score >= 35) return "close — a few gaps to lock";
          return "foundations first";
        }

        function formatRevenueTarget(value) {
          if (!value) return "";
          return /\/mo|month/i.test(value) ? value : `${value}/mo`;
        }

        function formatTeamTarget(value) {
          return value ? `${value} people` : "Not set";
        }

        function formatHoursTarget(value) {
          return value ? `${value} hrs/wk` : "Not set";
        }

        function renderInstallMoves(outcomes) {
          installList.replaceChildren();

          outcomes.forEach((title, index) => {
            const card = document.createElement("article");
            card.className = "install-move";

            const number = document.createElement("span");
            number.textContent = String(index + 1).padStart(2, "0");

            const heading = document.createElement("strong");
            heading.textContent = title;

            card.append(number, heading);
            installList.append(card);
          });
        }

        function renderCtaProof(derived) {
          const proof = CTA_PROOF_BY_LEAK[derived] || CTA_PROOF_BY_LEAK.demand;
          const bridgeLabel = CTA_BRIDGE_BY_LEAK[derived] || "first leak";
          if (ctaBridge) {
            ctaBridge.textContent = `We do not hand you a to-do list - we build and run the system that closes this ${bridgeLabel} in 30 days.`;
          }
          if (ctaProof) {
            ctaProof.textContent = proof.text;
            ctaProof.dataset.proofWin = proof.win;
          }
          if (ctaProofComment) ctaProofComment.nodeValue = ` @cta-proof: ${proof.win} `;
        }

        function runRevealJargonGate() {
          const text = ` ${(reveal.innerText || reveal.textContent || "").toLowerCase().replace(/\s+/g, " ")} `;
          const banned = [
            "fit gate",
            "value proof",
            "follow-up path",
            "demand floor",
            "capacity signal",
            "dispatch rules",
            "opsratio",
            "ops ratio",
            "growth index",
            "bottleneck",
            "module",
            " utm ",
            " crm ",
            "attribution",
            "qualifier",
          ];
          const hits = banned.filter((term) => text.includes(term));
          if (hits.length) console.warn("[LEAKQA] jargon gate warning", hits);
        }

        function renderReveal() {
          const ins = diagnose(state);
          console.log('[LEAKQA]', JSON.stringify({selected_pain:ins.selected_pain, derived_constraint:ins.derived_constraint, is_reframe:ins.is_reframe, input_refs:ins.input_refs, headline:ins.headline}));
          if (ins.input_refs.length < 2) console.warn("[LEAKQA] echo gate warning", ins.input_refs);
          const leakNode = DERIVED_NODE[ins.derived_constraint] || "demand";
          const score = Number(state.score) || 0;
          const revenueTarget = formatRevenueTarget(state.target.revenue);

          revealHeadline.textContent = ins.headline;
          revealScore.textContent = String(score).padStart(2, "0");
          revealScoreRead.textContent = getScoreRead(score);
          revealMapTitle.textContent = `${ins.derived_tag} is the first fix`;
          revealLeakLabel.textContent = ins.derived_tag;
          revealDiagnosisTitle.textContent = ins.headline;
          revealLeakCopy.textContent = ins.why_it_matters;

          revealNodes.forEach((node) => {
            const isLeak = node.dataset.revealNode === leakNode;
            node.classList.toggle("is-leak", isLeak);
          });

          renderInstallMoves(ins.install_outcomes);
          renderCtaProof(ins.derived_constraint);

          revealGapTitle.textContent = revenueTarget ? `Today → ${revenueTarget}` : "Today → target not set";
          revealGapCopy.textContent = revenueTarget
            ? `From where you are today toward ${revenueTarget}. This is the gap the system closes.`
            : "Set the revenue target, team, and owner hours to size the gap.";
          revealTargetRevenue.textContent = revenueTarget || "Not set";
          revealTargetTeam.textContent = formatTeamTarget(state.target.team);
          revealTargetHours.textContent = formatHoursTarget(state.target.hours);
          submitRevealState(ins);
          runRevealJargonGate();
        }

        startButton.addEventListener("click", () => {
          trackLeakEvent("diagnostic_start", {
            form_id: FORM_ID,
          });
          showPanel("cockpit");
          showStep("q1");
        });

        backWelcomeButton.addEventListener("click", () => {
          showPanel("welcome");
        });

        nextButtons.forEach((button) => {
          button.addEventListener("click", () => {
            if (!button.disabled) {
              const card = button.closest("[data-step]");
              if (card) fireStepComplete(card.dataset.step);
              showStep(button.dataset.nextStep);
            }
          });
        });

        prevButtons.forEach((button) => {
          button.addEventListener("click", () => showStep(button.dataset.prevStep));
        });

        finishButton.addEventListener("click", () => {
          fireStepComplete("q7");
          mapTitle.textContent = "Leak Map ready";
          q7Insight.textContent = "Map ready. Your hunch and target gap are set.";
          miniLeak.textContent = "Leak Map ready";
          renderReveal();
          showPanel("reveal");
          window.scrollTo({ top: 0, behavior: reducedMotion ? "auto" : "smooth" });
          reveal.scrollTo({ top: 0, behavior: reducedMotion ? "auto" : "smooth" });
        });

        backRevealButton.addEventListener("click", () => {
          showPanel("cockpit");
          showStep("q7");
        });

        bookCtas.forEach((cta) => {
          cta.addEventListener("click", () => {
            trackLeakEvent("cta_click", {
              cta_source: cta.dataset.ctaSource || "unknown",
              form_id: FORM_ID,
            });
          });
        });

        if (emailCaptureForm) {
          emailCaptureForm.addEventListener("submit", submitEmailCapture);
        }

        window.addEventListener("scroll", checkScrollDepth, { passive: true });
        cockpit.addEventListener("scroll", checkScrollDepth, { passive: true });
        reveal.addEventListener("scroll", checkScrollDepth, { passive: true });
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") fireAbandon();
        });
        window.addEventListener("pagehide", fireAbandon);

        serviceButtons.forEach((button) => {
          button.addEventListener("click", () => selectService(button));
        });

        sourceButtons.forEach((button) => {
          button.addEventListener("click", () => selectSource(button));
        });

        stageButtons.forEach((button) => {
          button.addEventListener("click", () => selectStage(button));
        });

        opsButtons.forEach((button) => {
          button.addEventListener("click", () => selectOps(button));
        });

        leakOptions.forEach((button) => {
          button.addEventListener("click", () => selectLeak(button));
        });

        capacityButtons.forEach((button) => {
          button.addEventListener("click", () => selectCapacity(button));
        });

        document.querySelectorAll("[data-dial] [data-preset]").forEach((button) => {
          button.addEventListener("click", () => setPreset(button));
        });

        targetInputs.forEach((input) => {
          input.addEventListener("input", () => {
            const key = input.dataset.targetInput;
            state.target[key] = input.value.trim();
            const card = input.closest("[data-dial]");
            card.querySelectorAll("[data-preset]").forEach((preset) => preset.classList.remove("is-selected"));
            updateTargetGap();
            updateLiveMap();
          });
        });

        showPanel("welcome");
        showStep("q1");
      })();
    </script>
  </body>
</html>
