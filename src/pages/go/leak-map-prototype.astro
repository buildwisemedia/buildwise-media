        margin-top: 4px;
        color: var(--yellow);
      }

      .map-foot,
      .diagnostic-readouts {
        display: grid;
        gap: 12px;
        padding: 0 18px 18px;
      }

      .map-foot {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .map-foot > div,
      .readout-card {
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
