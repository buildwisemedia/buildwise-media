      .micro-insight {
        min-height: 22px;
        margin: auto 0 0;
        color: rgba(240, 255, 0, 0.78);
        font-size: 0.72rem;
      }

      .step-actions {
        position: sticky;
        bottom: 0;
        z-index: 4;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding-top: 14px;
