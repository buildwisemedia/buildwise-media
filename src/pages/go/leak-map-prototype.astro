    <style is:global>
      @font-face {
        font-family: "Inter";
        src: url("/fonts/inter-variable-v1.woff2") format("woff2");
        font-weight: 300 900;
        font-display: swap;
      }

      @font-face {
        font-family: "JetBrains Mono";
        src: url("/fonts/jetbrains-mono-variable-v1.woff2") format("woff2");
        font-weight: 300 700;
        font-display: swap;
      }

      :root {
        color-scheme: dark;
        --canvas: #050507;
        --yellow: #F0FF00;
        --panel-1: #0b0b0f;
        --panel-2: #121217;
        --panel-3: #18181d;
        --line: rgba(255, 255, 255, 0.08);
        --line-y: rgba(240, 255, 0, 0.1);
        --text: #f5f5f5;
        --text-soft: #d7d7dc;
        --muted: #8d8d94;
        --dim: #56565d;
        --ease: cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
        background: var(--canvas);
        color: var(--text);
        font-family: "Inter", Arial, sans-serif;
      }

      body {
        overflow-x: hidden;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .prototype {
        min-height: 100svh;
        position: relative;
        isolation: isolate;
        background:
          linear-gradient(115deg, rgba(255, 255, 255, 0.03), transparent 38%),
          linear-gradient(180deg, var(--canvas), #0b0b0f 58%, var(--canvas));
      }

      .prototype::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: linear-gradient(180deg, rgba(255, 255, 255, 0.4), transparent 70%);
      }

      .mono {
        font-family: "JetBrains Mono", monospace;
        text-transform: uppercase;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .welcome-screen,
      .cockpit,
      .reveal-screen {
        min-height: 100svh;
        display: none;
      }

      .welcome-screen.is-active,
      .cockpit.is-active,
      .reveal-screen.is-active {
        display: block;
      }

      .welcome-grid {
        width: min(1480px, 100%);
        min-height: 100svh;
        margin: 0 auto;
        padding: clamp(24px, 4vw, 52px);
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) minmax(500px, 1.18fr);
        gap: clamp(24px, 4vw, 64px);
        align-items: center;
      }

      .welcome-copy {
        max-width: 650px;
      }

      .eyebrow,
      .step-eyebrow,
      .panel-kicker,
      .muted {
        margin: 0;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 650;
      }

      .welcome-copy h1 {
        margin: 22px 0 18px;
        font-size: clamp(3.2rem, 6.3vw, 7.8rem);
        line-height: 0.88;
        font-weight: 850;
        letter-spacing: 0;
      }

      .welcome-copy h1 span {
        color: var(--yellow);
        text-shadow: 0 0 30px rgba(240, 255, 0, 0.2);
      }

      .welcome-sub {
        max-width: 560px;
        margin: 0 0 32px;
        color: var(--text-soft);
        font-size: clamp(1.02rem, 1.25vw, 1.2rem);
        line-height: 1.55;
      }

      .primary-action,
      .next-action,
      .ghost-action {
        min-height: 48px;
        border: 1px solid transparent;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 0 20px;
        font-weight: 800;
        transition:
          transform 180ms var(--ease),
          border-color 180ms var(--ease),
          background 180ms var(--ease),
          opacity 180ms var(--ease);
      }

      .primary-action,
      .next-action {
        background: var(--yellow);
        color: var(--canvas);
        box-shadow:
          0 0 0 1px rgba(240, 255, 0, 0.18),
          0 18px 44px rgba(240, 255, 0, 0.14);
      }

      .primary-action:hover,
      .next-action:hover {
        transform: translateY(-1px);
      }

      .primary-action.compact {
        min-height: 44px;
      }

      .ghost-action {
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-soft);
        border-color: rgba(255, 255, 255, 0.08);
      }

      .next-action:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
      }

      .map-panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 19%),
          var(--panel-1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 22px 70px rgba(5, 5, 7, 0.62);
        overflow: hidden;
      }

      .map-head {
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 20px 22px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .map-head h2 {
        margin: 7px 0 0;
        font-size: clamp(1.2rem, 1.55vw, 1.65rem);
        line-height: 1;
      }

      .score-card {
        min-width: 92px;
        border: 1px solid rgba(240, 255, 0, 0.12);
        border-radius: 8px;
        padding: 10px 12px;
        text-align: right;
        background: rgba(240, 255, 0, 0.035);
      }

      .score-card span {
        display: block;
        color: var(--muted);
        font-size: 0.64rem;
      }

      .score-card strong {
        display: block;
        color: var(--yellow);
        font-family: "JetBrains Mono", monospace;
        font-size: 2rem;
        line-height: 0.96;
        font-weight: 700;
      }

      .map-canvas {
        position: relative;
        margin: 18px;
        min-height: 460px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        background:
          radial-gradient(circle, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
          linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
          var(--panel-2);
        background-size: 18px 18px, 100% 100%, 100% 100%;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          inset 0 -24px 60px rgba(5, 5, 7, 0.5);
        overflow: hidden;
      }

      .pipe-svg {
        position: absolute;
        inset: 0;
        z-index: 1;
        width: 100%;
        height: 100%;
        overflow: visible;
        pointer-events: none;
      }

      .base-pipe,
      .active-pipe,
      .target-pipe {
        fill: none;
        vector-effect: non-scaling-stroke;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .base-pipe {
        stroke: rgba(255, 255, 255, 0.14);
        stroke-width: 2;
      }

      .active-pipe {
        stroke: var(--yellow);
        stroke-width: 2.4;
        opacity: 0;
        filter: drop-shadow(0 0 10px rgba(240, 255, 0, 0.34));
        transition: opacity 220ms var(--ease);
      }

      .target-pipe {
        stroke: var(--yellow);
        stroke-width: 3.1;
        opacity: 0;
      }

      .pipe-segment.is-lit {
        opacity: 1;
      }

      .live-canvas.has-trace .pipe-segment.is-lit {
        animation: tracePipe 700ms var(--ease) forwards;
      }

      .live-canvas.has-target .target-pipe {
        animation: tracePipe 550ms var(--ease) forwards;
      }

      .map-node {
        --node-size: 58px;
        position: absolute;
        z-index: 2;
        left: calc(var(--x) * 1%);
        top: calc(var(--y) * 1%);
        width: var(--node-size);
        min-height: 72px;
        transform: translate(-50%, -17px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        color: var(--muted);
        text-align: center;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.68rem;
        font-weight: 650;
        text-transform: uppercase;
        transition:
          color 180ms var(--ease),
          opacity 180ms var(--ease),
          transform 220ms var(--ease);
      }

      .node-ring {
        position: relative;
        z-index: 2;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(5, 5, 7, 0.62);
        box-shadow:
          inset 0 0 0 7px rgba(255, 255, 255, 0.03),
          0 0 0 4px rgba(255, 255, 255, 0.02);
        transition:
          border-color 180ms var(--ease),
          background 180ms var(--ease),
          box-shadow 180ms var(--ease);
      }

      .map-node > span:not(.node-ring) {
        position: relative;
        z-index: 3;
        display: inline-block;
        padding: 2px 5px;
        border-radius: 4px;
        background: var(--panel-2);
        box-shadow: 0 0 0 3px var(--panel-2);
        line-height: 1;
        white-space: nowrap;
      }

      .map-node.is-unlocked {
        color: var(--text-soft);
      }

      .map-node.is-unlocked .node-ring {
        border-color: rgba(255, 255, 255, 0.38);
        background: rgba(255, 255, 255, 0.06);
      }

      .map-node.is-dim {
        opacity: 0.36;
      }

      .map-node.is-leak {
        color: var(--yellow);
        transform: translate(-50%, -17px) scale(1.03);
      }

      .map-node.is-leak .node-ring {
        border-color: var(--yellow);
        background: rgba(240, 255, 0, 0.18);
        box-shadow:
          inset 0 0 0 8px rgba(240, 255, 0, 0.08),
          0 0 0 9px rgba(240, 255, 0, 0.07),
          0 0 28px rgba(240, 255, 0, 0.38);
        animation: leakPulse 720ms var(--ease);
      }

      .map-node.is-target {
        color: var(--yellow);
      }

      .map-node.is-target .node-ring {
        border-color: rgba(240, 255, 0, 0.8);
        box-shadow:
          inset 0 0 0 7px rgba(240, 255, 0, 0.07),
          0 0 28px rgba(240, 255, 0, 0.22);
      }

      .leak-badge {
        position: absolute;
        z-index: 3;
        right: 18px;
        bottom: 18px;
        min-width: 170px;
        border: 1px solid rgba(240, 255, 0, 0.18);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(5, 5, 7, 0.76);
        box-shadow: 0 0 32px rgba(240, 255, 0, 0.1);
      }

      .leak-badge span {
        display: block;
        color: var(--muted);
        font-size: 0.64rem;
      }

      .leak-badge strong {
        display: block;
        margin-top: 4px;
        color: var(--yellow);
      }

      .map-foot,
      .diagnostic-readouts {
        display: grid;
        gap: 12px;
        padding: 0 18px 18px;
      }

      .map-foot {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .map-foot > div,
      .readout-card {
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
        padding: 18px 14px 14px;
        background: rgba(255, 255, 255, 0.035);
      }

      .map-foot strong,
      .readout-card strong {
        display: block;
        margin-top: 7px;
        color: var(--text);
        font-size: 0.96rem;
      }

      .readout-card small {
        display: block;
        margin-top: 8px;
        color: var(--muted);
        line-height: 1.35;
      }

      .diagnostic-readouts {
        grid-template-columns: 1.05fr 1.05fr 0.75fr;
      }

      .gap-meter {
        height: 8px;
        margin-top: 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
      }

      .gap-meter span {
        display: block;
        width: 0%;
        height: 100%;
        border-radius: inherit;
        background: var(--yellow);
        box-shadow: 0 0 20px rgba(240, 255, 0, 0.32);
        transition: width 260ms var(--ease);
      }

      .arc-card {
        min-height: 116px;
        overflow: hidden;
      }

      .gap-feel-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
      }

      .gap-arc {
        width: 38px;
        height: 38px;
        flex: 0 0 38px;
        transform: rotate(-90deg);
      }

      .arc-track,
      .arc-fill {
        fill: none;
        stroke-width: 7;
      }

      .arc-track {
        stroke: rgba(255, 255, 255, 0.08);
      }

      .arc-fill {
        stroke: var(--yellow);
        stroke-linecap: round;
        stroke-dasharray: 176;
        stroke-dashoffset: 176;
        filter: drop-shadow(0 0 8px rgba(240, 255, 0, 0.36));
        transition: stroke-dashoffset 260ms var(--ease);
      }

      .arc-card strong[data-gap-percent] {
        margin-top: 0;
        color: var(--yellow);
        font-family: "JetBrains Mono", monospace;
        line-height: 1;
      }

      .cockpit-shell {
        width: min(1500px, 100%);
        margin: 0 auto;
        min-height: 100svh;
        padding: clamp(14px, 2vw, 24px);
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        gap: 14px;
      }

      .progress-rail {
        min-height: 52px;
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.035);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .rail-step {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 9px;
        color: var(--dim);
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(0.58rem, 0.74vw, 0.72rem);
        font-weight: 650;
        text-transform: uppercase;
        border-right: 1px solid rgba(255, 255, 255, 0.055);
      }

      .rail-step:last-child {
        border-right: 0;
      }

      .rail-dot {
        width: 8px;
        height: 8px;
        flex: 0 0 auto;
        border-radius: 50%;
        border: 1px solid currentColor;
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.02);
      }

      .rail-step.is-done {
        color: var(--muted);
      }

      .rail-step.is-active {
        color: var(--yellow);
        background: rgba(240, 255, 0, 0.045);
      }

      .rail-step.is-active .rail-dot {
        background: var(--yellow);
        box-shadow: 0 0 18px rgba(240, 255, 0, 0.55);
      }

      .cockpit-grid {
        min-height: 0;
        display: grid;
        grid-template-columns: minmax(380px, 0.42fr) minmax(520px, 0.58fr);
        gap: 14px;
      }

      .question-pane {
        min-height: 0;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 22%),
          var(--panel-1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 22px 70px rgba(5, 5, 7, 0.5);
        overflow: hidden;
      }

      .question-card {
        min-height: 100%;
        height: auto;
        padding: clamp(18px, 2.35vh, 28px);
        display: flex;
        flex-direction: column;
        gap: clamp(12px, 1.6vh, 18px);
      }

      .question-card[hidden] {
        display: none;
      }

      .question-head h2 {
        max-width: 680px;
        margin: 8px 0 9px;
        font-size: clamp(2rem, 3.4vw, 4.25rem);
        line-height: 0.96;
        font-weight: 850;
        letter-spacing: 0;
      }

      .question-head p:not(.step-eyebrow) {
        margin: 0;
        color: var(--text-soft);
        font-size: clamp(0.95rem, 1vw, 1.06rem);
        line-height: 1.4;
      }

      .leak-options {
        min-height: 0;
        display: grid;
        gap: clamp(8px, 1vh, 12px);
      }

      .chip-options {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .leak-option {
        min-height: clamp(66px, 9.2vh, 88px);
        width: 100%;
        display: grid;
        grid-template-columns: 52px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
        padding: 10px 12px;
        border: 1px solid rgba(255, 255, 255, 0.075);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
          var(--panel-2);
        color: var(--text);
        text-align: left;
        transition:
          transform 180ms var(--ease),
          border-color 180ms var(--ease),
          background 180ms var(--ease),
          opacity 180ms var(--ease);
      }

      .leak-option:hover {
        transform: translateY(-1px);
        border-color: rgba(240, 255, 0, 0.2);
      }

      .leak-option.is-selected {
        border-color: rgba(240, 255, 0, 0.55);
        background:
          linear-gradient(180deg, rgba(240, 255, 0, 0.08), rgba(240, 255, 0, 0.025)),
          var(--panel-2);
        box-shadow:
          inset 0 1px 0 rgba(240, 255, 0, 0.16),
          0 0 28px rgba(240, 255, 0, 0.08);
      }

      .leak-option.is-muted {
        opacity: 0.58;
      }

      .leak-option.text-option {
        grid-template-columns: minmax(0, 1fr);
        min-height: clamp(68px, 8.4vh, 84px);
      }

      .leak-option.text-option .option-copy strong {
        display: block;
      }

      .leak-option.text-option .option-copy em {
        font-size: 0.84rem;
      }

      .option-icon {
        width: 44px;
        height: 44px;
        color: var(--muted);
      }

      .option-icon line,
      .option-icon circle,
      .option-icon polyline {
        fill: none;
        stroke: currentColor;
        stroke-width: 1.7;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .leak-option.is-selected .option-icon {
        color: var(--yellow);
        filter: drop-shadow(0 0 10px rgba(240, 255, 0, 0.4));
      }

      .option-copy {
        min-width: 0;
        display: grid;
        gap: 3px;
      }

      .option-copy strong {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        font-size: clamp(0.95rem, 1vw, 1.08rem);
      }

      .option-copy strong span {
        color: var(--muted);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
      }

      .option-copy em {
        color: var(--text-soft);
        font-style: normal;
        font-size: 0.88rem;
        line-height: 1.25;
      }

      .option-copy small {
        color: var(--muted);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.68rem;
        text-transform: uppercase;
      }

      .micro-insight {
        min-height: 22px;
        margin: auto 0 0;
        color: rgba(240, 255, 0, 0.78);
        font-size: 0.72rem;
      }

      .step-actions {
        position: sticky;
        bottom: 0;
        z-index: 4;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding-top: 14px;
        background:
          linear-gradient(180deg, rgba(11, 11, 15, 0), var(--panel-1) 38%),
          var(--panel-1);
      }

      .target-dials {
        min-height: 0;
        display: grid;
        gap: clamp(10px, 1.25vh, 14px);
      }

      .target-step {
        gap: clamp(8px, 1.15vh, 14px);
      }

      .target-step .question-head h2 {
        font-size: clamp(1.9rem, 2.8vw, 3.4rem);
        margin: 6px 0 6px;
      }

      .target-step .target-dials {
        gap: 9px;
      }

      .target-step .dial-card {
        padding: 11px 12px;
      }

      .target-step .dial-top {
        margin-bottom: 8px;
      }

      .target-step .preset-row {
        margin-bottom: 8px;
      }

      .target-step .dial-card input {
        min-height: 34px;
      }

      .stage-card {
        margin-top: auto;
        margin-bottom: auto;
      }

      .dial-card {
        border: 1px solid rgba(255, 255, 255, 0.075);
        border-radius: 8px;
        padding: clamp(12px, 1.45vh, 16px);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
          var(--panel-2);
      }

      .dial-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 10px;
      }

      .dial-note {
        margin: -2px 0 8px;
        color: var(--text-soft);
        font-size: 0.82rem;
        line-height: 1.3;
      }

      .dial-top span,
      .dial-card label span {
        color: var(--muted);
        font-size: 0.64rem;
        font-weight: 650;
      }

      .dial-top strong {
        font-size: 1.02rem;
      }

      .preset-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 10px;
      }

      .preset-row button {
        min-height: 36px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.035);
        color: var(--text-soft);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.76rem;
        font-weight: 700;
        transition:
          border-color 160ms var(--ease),
          background 160ms var(--ease),
          color 160ms var(--ease);
      }

      .preset-row button:hover,
      .preset-row button.is-selected {
        border-color: rgba(240, 255, 0, 0.5);
        background: rgba(240, 255, 0, 0.09);
        color: var(--yellow);
      }

      .stage-row,
      .ops-row {
        margin-bottom: 0;
      }

      .stage-row {
        grid-template-columns: 1fr;
      }

      .ops-row {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .stage-row button,
      .ops-row button {
        min-height: 42px;
        padding: 6px 10px;
        line-height: 1.12;
        white-space: normal;
        text-transform: none;
      }

      .dial-card label {
        display: grid;
        gap: 6px;
      }

      .dial-card input {
        width: 100%;
        min-height: 38px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background: rgba(5, 5, 7, 0.55);
        color: var(--text);
        outline: none;
        padding: 0 11px;
      }

      .dial-card input:focus {
        border-color: rgba(240, 255, 0, 0.48);
        box-shadow: 0 0 0 3px rgba(240, 255, 0, 0.08);
      }

      .live-map {
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
      }

      .live-map .map-canvas {
        min-height: 0;
        height: 100%;
        margin-bottom: 12px;
      }

      .reveal-screen {
        background:
          linear-gradient(125deg, rgba(240, 255, 0, 0.055), transparent 28%),
          linear-gradient(180deg, var(--canvas), var(--panel-1) 60%, var(--canvas));
      }

      .reveal-shell {
        width: min(1500px, 100%);
        min-height: 100svh;
        margin: 0 auto;
        padding: clamp(12px, 1.45vw, 18px);
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 0.28fr);
        gap: 12px;
        align-items: start;
      }

      .reveal-main,
      .reveal-side {
        min-width: 0;
      }

      .reveal-main {
        display: grid;
        gap: 12px;
      }

      .reveal-back {
        width: max-content;
      }

      .reveal-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(210px, 0.3fr);
        gap: 14px;
        align-items: end;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: clamp(16px, 1.75vw, 24px);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
          var(--panel-1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 22px 70px rgba(5, 5, 7, 0.5);
      }

      .reveal-copy h2 {
        max-width: 820px;
        margin: 8px 0 0;
        font-size: clamp(2.5rem, 3.55vw, 3.8rem);
        line-height: 0.95;
        font-weight: 860;
        letter-spacing: 0;
      }

      .reveal-score-card {
        border: 1px solid rgba(240, 255, 0, 0.18);
        border-radius: 8px;
        padding: 16px;
        background: rgba(240, 255, 0, 0.045);
        box-shadow:
          inset 0 1px 0 rgba(240, 255, 0, 0.14),
          0 18px 50px rgba(240, 255, 0, 0.08);
      }

      .reveal-score-card > span {
        display: block;
        color: var(--muted);
        font-size: 0.66rem;
        font-weight: 700;
      }

      .reveal-score-card strong {
        display: flex;
        align-items: baseline;
        gap: 6px;
        margin-top: 6px;
        color: var(--yellow);
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(3rem, 4vw, 4.1rem);
        line-height: 0.85;
        font-weight: 700;
      }

      .reveal-score-card em {
        color: rgba(245, 245, 245, 0.66);
        font-size: 1.2rem;
        font-style: normal;
      }

      .reveal-score-card p,
      .gap-panel p,
      .reveal-cta p,
      .reveal-diagnosis p {
        margin: 10px 0 0;
        color: var(--text-soft);
        line-height: 1.4;
      }

      .reveal-map-panel {
        overflow: hidden;
      }

      .reveal-map-head h3,
      .install-head h3,
      .gap-panel h3,
      .reveal-cta h3 {
        margin: 7px 0 0;
        font-size: 1.55rem;
        line-height: 1.05;
      }

      .reveal-leak-tag {
        min-width: 180px;
        border: 1px solid rgba(240, 255, 0, 0.16);
        border-radius: 8px;
        padding: 11px 13px;
        background: rgba(240, 255, 0, 0.04);
        text-align: right;
      }

      .reveal-leak-tag span {
        display: block;
        color: var(--muted);
        font-size: 0.62rem;
        font-weight: 700;
      }

      .reveal-leak-tag strong {
        display: block;
        margin-top: 4px;
        color: var(--yellow);
      }

      .reveal-map-canvas {
        min-height: 250px;
      }

      .reveal-map-canvas .active-pipe {
        opacity: 1;
      }

      .reveal-map-canvas .map-node {
        color: var(--text-soft);
      }

      .reveal-map-canvas .map-node .node-ring {
        border-color: rgba(240, 255, 0, 0.42);
        background: rgba(240, 255, 0, 0.075);
        box-shadow:
          inset 0 0 0 7px rgba(240, 255, 0, 0.045),
          0 0 18px rgba(240, 255, 0, 0.14);
      }

      .reveal-map-canvas .map-node.is-leak .node-ring {
        border-color: var(--yellow);
        background: rgba(240, 255, 0, 0.2);
        animation: revealLeakPulse 1400ms var(--ease) infinite;
      }

      .reveal-diagnosis {
        margin: 0 18px 18px;
        border: 1px solid rgba(240, 255, 0, 0.16);
        border-radius: 8px;
        padding: 15px;
        background: rgba(240, 255, 0, 0.035);
      }

      .reveal-diagnosis strong {
        display: block;
        margin-top: 6px;
        color: var(--text);
        font-size: 1.02rem;
      }

      .reveal-diagnosis strong span {
        color: var(--yellow);
      }

      .install-panel,
      .gap-panel,
      .reveal-cta {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.018)),
          var(--panel-1);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
      }

      .install-panel {
        padding: 15px;
      }

      .install-head {
        display: grid;
        gap: 7px;
        margin-bottom: 11px;
      }

      .install-list {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
      }

      .install-move {
        min-height: 82px;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
        padding: 11px;
        background: rgba(255, 255, 255, 0.035);
      }

      .install-move span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border: 1px solid rgba(240, 255, 0, 0.22);
        border-radius: 50%;
        color: var(--yellow);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
      }

      .install-move strong {
        display: block;
        margin-top: 8px;
        color: var(--text);
        font-size: 0.94rem;
        line-height: 1.2;
      }

      .install-move p {
        margin: 7px 0 0;
        color: var(--text-soft);
        font-size: 0.92rem;
        line-height: 1.35;
      }

      .reveal-side {
        display: grid;
        gap: 12px;
      }

      .gap-panel,
      .reveal-cta {
        padding: 15px;
      }

      .target-stack {
        display: grid;
        gap: 10px;
        margin-top: 16px;
      }

      .target-stack > div {
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
        padding: 12px;
        background: rgba(255, 255, 255, 0.035);
      }

      .target-stack strong {
        display: block;
        margin-top: 5px;
        color: var(--text);
      }

      .reveal-cta {
        border-color: rgba(240, 255, 0, 0.2);
        box-shadow:
          inset 0 1px 0 rgba(240, 255, 0, 0.12),
          0 18px 60px rgba(240, 255, 0, 0.08);
      }

      .cta-bridge {
        margin-top: 10px;
        color: var(--text-soft);
        font-size: 0.95rem;
        line-height: 1.35;
      }

      .cta-proof {
        margin: 10px 0 0;
        border: 1px solid rgba(240, 255, 0, 0.18);
        border-radius: 8px;
        padding: 10px 11px;
        background: rgba(240, 255, 0, 0.045);
        color: var(--text);
        font-size: 0.93rem;
        font-weight: 720;
        line-height: 1.3;
      }

      .reveal-cta .primary-action {
        width: 100%;
        margin-top: 10px;
        text-decoration: none;
      }

      .email-capture {
        display: grid;
        gap: 7px;
        margin-top: 14px;
      }

      .email-capture label {
        color: var(--muted);
        font-size: 0.62rem;
        font-weight: 700;
      }

      .email-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: stretch;
      }

      .email-capture input {
        min-height: 42px;
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background: rgba(5, 5, 7, 0.62);
        color: var(--text);
        outline: none;
        padding: 0 12px;
      }

      .email-capture input:focus {
        border-color: rgba(240, 255, 0, 0.5);
        box-shadow: 0 0 0 3px rgba(240, 255, 0, 0.08);
      }

      .email-capture button {
        min-height: 42px;
        border: 1px solid rgba(240, 255, 0, 0.35);
        border-radius: 8px;
        background: rgba(240, 255, 0, 0.08);
        color: var(--yellow);
        cursor: pointer;
        font: 800 0.72rem/1 "JetBrains Mono", monospace;
        letter-spacing: 0;
        padding: 0 14px;
        text-transform: uppercase;
      }

