---
export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Live Revenue Leak Map Prototype | Buildwise Media</title>
    <meta
      name="description"
      content="A high-fidelity prototype of the Buildwise Media Revenue Leak Map funnel experience."
    />
  </head>
  <body>
    <main class="prototype" data-app>
      <section class="welcome-screen is-active" data-panel="welcome" aria-labelledby="welcome-title">
        <div class="welcome-grid">
          <div class="welcome-copy">
            <p class="mono eyebrow">FOR SERVICE BUSINESSES · ~2 MINUTES · NO EMAIL TO SEE YOUR RESULT</p>
            <!-- @bwm-exp-slot: hero-headline - promise framing -->
            <h1 id="welcome-title" data-bwm-exp-slot="hero-headline">
              Find the leak that's keeping <span>growth on your desk.</span>
            </h1>
            <p class="welcome-sub">
              Build your map as you answer. See where growth gets stuck before you book.
            </p>
            <button class="primary-action" type="button" data-start data-cta-source="leakmap-hero">
              <span>Start my Leak Map</span>
              <span aria-hidden="true">→</span>
            </button>
          </div>

          <aside class="map-panel teaser-map" aria-label="Empty Revenue Leak Map preview">
            <div class="map-head">
              <div>
                <p class="mono panel-kicker">LIVE REVENUE LEAK MAP</p>
                <h2>Empty map</h2>
              </div>
              <div class="score-card">
                <span class="mono">SCORE</span>
                <strong>00</strong>
              </div>
            </div>
            <div class="map-canvas teaser-canvas">
              <svg class="pipe-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                <polyline class="base-pipe" points="8,22 22,22 22,51 39,51 39,78 56,78 56,51 73,51 73,22 91,22" />
              </svg>
              <div class="map-node node-service is-locked" style="--x: 8; --y: 22">
                <span class="node-ring"></span><span>Service</span>
              </div>
              <div class="map-node node-demand is-locked" style="--x: 22; --y: 22">
                <span class="node-ring"></span><span>Demand</span>
              </div>
              <div class="map-node node-fit is-locked" style="--x: 22; --y: 51">
                <span class="node-ring"></span><span>Fit</span>
              </div>
              <div class="map-node node-capacity is-locked" style="--x: 39; --y: 51">
                <span class="node-ring"></span><span>Capacity</span>
              </div>
              <div class="map-node node-speed is-locked" style="--x: 39; --y: 78">
                <span class="node-ring"></span><span>Speed</span>
              </div>
              <div class="map-node node-close is-locked" style="--x: 56; --y: 78">
                <span class="node-ring"></span><span>Close</span>
              </div>
              <div class="map-node node-target is-locked" style="--x: 91; --y: 22">
                <span class="node-ring"></span><span>Target</span>
              </div>
            </div>
            <div class="map-foot">
              <div>
                <span class="mono muted">CURRENT LEAK</span>
                <strong>Not mapped yet</strong>
              </div>
              <div>
                <span class="mono muted">NEXT</span>
                <strong>Pick the first break</strong>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="cockpit" data-panel="cockpit" aria-hidden="true">
        <div class="cockpit-shell">
          <nav class="progress-rail" aria-label="Revenue Leak Map steps">
            <span class="rail-step is-done" data-rail="service">
              <span class="rail-dot"></span><span>Service</span>
            </span>
            <span class="rail-step is-done" data-rail="demand">
              <span class="rail-dot"></span><span>Demand</span>
            </span>
            <span class="rail-step is-done" data-rail="stage">
              <span class="rail-dot"></span><span>Stage</span>
            </span>
            <span class="rail-step is-done" data-rail="owner-time">
              <span class="rail-dot"></span><span>Owner-Time</span>
            </span>
            <span class="rail-step is-active" data-rail="leak">
              <span class="rail-dot"></span><span>Leak</span>
            </span>
            <span class="rail-step" data-rail="stress-test">
              <span class="rail-dot"></span><span>Stress-Test</span>
            </span>
            <span class="rail-step" data-rail="target">
              <span class="rail-dot"></span><span>Target</span>
            </span>
          </nav>

          <div class="cockpit-grid">
            <section class="question-pane" aria-live="polite">
              <article class="question-card is-active" data-step="q1">
                <div class="question-head">
                  <p class="mono step-eyebrow">01 · SERVICE</p>
                  <h2>What kind of work do you sell?</h2>
                  <p>Pick the closest fit. This sets the map context.</p>
                </div>

                <div class="leak-options chip-options" role="radiogroup" aria-label="Service type">
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="hvac" data-label="HVAC" data-insight="HVAC demand swings fast. Slow follow-up turns calls into open slots.">
                    <span class="option-copy">
                      <strong>HVAC</strong>
                      <em>Repair, replacement, maintenance, or comfort work.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="roofing" data-label="Roofing" data-insight="Roof jobs are big tickets. A weak filter can burn whole afternoons.">
                    <span class="option-copy">
                      <strong>Roofing</strong>
                      <em>Repair, replacement, storm, or exterior work.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="plumbing" data-label="Plumbing" data-insight="Urgent calls reward speed. Miss the first touch and the job moves on.">
                    <span class="option-copy">
                      <strong>Plumbing</strong>
                      <em>Service calls, installs, emergency, or project work.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="pest" data-label="Pest Control" data-insight="Pest work grows on timing. Miss the renewal cue and the route stays thin.">
                    <span class="option-copy">
                      <strong>Pest Control</strong>
                      <em>One-time jobs, plans, inspections, or prevention.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="realtor" data-label="Real Estate" data-insight="Listings need trust before the call. Weak follow-up lets warm sellers cool off.">
                    <span class="option-copy">
                      <strong>Real Estate</strong>
                      <em>Listings, buyers, sellers, or local market work.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="concrete" data-label="Concrete" data-insight="Concrete jobs stack around crew time. Bad-fit quotes can fill the week fast.">
                    <span class="option-copy">
                      <strong>Concrete</strong>
                      <em>Flatwork, repair, patios, drives, or crews.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="cleaning" data-label="Cleaning" data-insight="Cleaning grows on repeat work. One missed handoff can cost months of jobs.">
                    <span class="option-copy">
                      <strong>Cleaning</strong>
                      <em>Homes, offices, turns, deep cleans, or recurring work.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" role="radio" aria-checked="false" data-service-value="other" data-label="Other" data-insight="The trade matters less than the path. We need to see where demand stalls.">
                    <span class="option-copy">
                      <strong>Other</strong>
                      <em>Use this if the closest fit is not listed.</em>
                    </span>
                  </button>
                </div>

                <p class="mono micro-insight" data-step-insight="q1">Pick a service to light the first node.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-back-welcome>Back</button>
                  <button class="next-action" type="button" data-next-step="q2" disabled>
                    <span>Map demand</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card" data-step="q2" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">02 · CHANNELS</p>
                  <h2>Where do most leads come from today?</h2>
                  <p>Pick all that matter. The map needs the mix, not a perfect answer.</p>
                </div>

                <div class="leak-options chip-options multi-options" role="group" aria-label="Lead sources">
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="referrals" data-label="Referrals" data-insight="Referrals are gold, but you cannot turn them up on a slow month.">
                    <span class="option-copy">
                      <strong>Referrals</strong>
                      <em>Past clients, partners, neighbors, or local names.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="google-organic" data-label="Local Search" data-insight="Local search catches ready buyers, but only after they know they need help.">
                    <span class="option-copy">
                      <strong>Local Search</strong>
                      <em>People find you when they search nearby.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="paid-ads" data-label="Paid Ads" data-insight="Paid leads can scale, but weak filters turn spend into busywork.">
                    <span class="option-copy">
                      <strong>Paid Ads</strong>
                      <em>You buy traffic or calls from search or social.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="social" data-label="Social" data-insight="Social can warm people up, but likes do not fill the calendar by themselves.">
                    <span class="option-copy">
                      <strong>Social</strong>
                      <em>Posts, groups, messages, or local shares.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="cold-outreach" data-label="Cold Outreach" data-insight="Cold outreach can create shots, but follow-up decides if they become jobs.">
                    <span class="option-copy">
                      <strong>Cold Outreach</strong>
                      <em>Direct calls, mail, email, or door knocking.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-source-value="unsure" data-label="Not sure / word of mouth" data-insight="If the source is fuzzy, you cannot know what to double down on.">
                    <span class="option-copy">
                      <strong>Not sure / word of mouth</strong>
                      <em>You get work, but the source is fuzzy.</em>
                    </span>
                  </button>
                </div>

                <p class="mono micro-insight" data-step-insight="q2">Pick at least one source to light demand.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-step="q1">Back</button>
                  <button class="next-action" type="button" data-next-step="q3" disabled>
                    <span>Set stage</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card stage-step" data-step="q3" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">03 · STAGE</p>
                  <h2>What stage is the business in right now?</h2>
                  <p>Use the closest snap point. This sets how hard the target jump is.</p>
                </div>

                <div class="dial-card stage-card">
                  <div class="dial-top">
                    <span class="mono">CURRENT.STAGE</span>
                    <strong data-stage-readout>Pick one</strong>
                  </div>
                  <div class="preset-row stage-row" role="radiogroup" aria-label="Business stage">
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="1" data-revenue-label="Just starting">1 Just starting</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="2" data-revenue-label="Early-stage">2 Early-stage</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="3" data-revenue-label="Growing local team">3 Growing local team</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="4" data-revenue-label="Established service team">4 Established service team</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="5" data-revenue-label="Scaling up">5 Scaling up</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="6" data-revenue-label="Expansion mode">6 Expansion mode</button>
                    <button type="button" role="radio" aria-checked="false" data-revenue-value="7" data-revenue-label="Market leader">7 Market leader</button>
                  </div>
                </div>

                <p class="mono micro-insight" data-step-insight="q3">Pick a stage to mark the rail.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-step="q2">Back</button>
                  <button class="next-action" type="button" data-next-step="q4" disabled>
                    <span>Map owner time</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card owner-step" data-step="q4" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">04 · OWNER-TIME</p>
                  <h2>What share of YOUR week goes to running the day-to-day vs growing the business?</h2>
                  <p>Pick the split that feels most true this month.</p>
                </div>

                <div class="dial-card stage-card">
                  <div class="dial-top">
                    <span class="mono">OWNER.WEEK</span>
                    <strong data-ops-readout>Pick one</strong>
                  </div>
                  <div class="preset-row ops-row" role="radiogroup" aria-label="Owner week split">
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="90" data-ops-label="90% / 10%">90% / 10%</button>
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="80" data-ops-label="80% / 20%">80% / 20%</button>
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="70" data-ops-label="70% / 30%">70% / 30%</button>
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="60" data-ops-label="60% / 40%">60% / 40%</button>
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="50" data-ops-label="50% / 50%">50% / 50%</button>
                    <button type="button" role="radio" aria-checked="false" data-ops-ratio="40" data-ops-label="40% / 60%">40% / 60%</button>
                  </div>
                </div>

                <p class="mono micro-insight" data-step-insight="q4">Pick the owner-time split to mark the rail.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-step="q3">Back</button>
                  <button class="next-action" type="button" data-next-step="q5" disabled>
                    <span>Pick the leak</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card" data-step="q5" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">05 · LEAK</p>
                  <h2>When you try to grow, what breaks first?</h2>
                  <p>Pick your hunch. The reveal will test it.</p>
                </div>

                <div class="leak-options" role="radiogroup" aria-label="Growth leak">
                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="leads"
                    data-node="demand"
                    data-score="60"
                    data-label="Demand"
                    data-insight="Calendar gaps are a symptom. The real test is whether you can create demand on purpose."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <circle cx="8" cy="22" r="3" />
                      <line x1="11" y1="22" x2="25" y2="22" />
                      <line x1="25" y1="22" x2="34" y2="13" />
                      <line x1="25" y1="22" x2="34" y2="22" />
                      <line x1="25" y1="22" x2="34" y2="31" />
                      <circle cx="37" cy="13" r="3" />
                      <circle cx="37" cy="22" r="3" />
                      <circle cx="37" cy="31" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Demand <span>Lead volume</span></strong>
                      <em>Not enough qualified people raising a hand.</em>
                      <small>Calendar gaps.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="quality"
                    data-node="fit"
                    data-score="66"
                    data-label="Fit"
                    data-insight="Bad-fit leads do not just waste quotes. They steal the week from good buyers."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="22" x2="37" y2="22" />
                      <circle cx="12" cy="22" r="3" />
                      <circle cx="22" cy="22" r="3" />
                      <circle cx="32" cy="22" r="3" />
                      <line x1="22" y1="19" x2="22" y2="10" />
                      <circle cx="22" cy="7" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Fit <span>Lead quality</span></strong>
                      <em>Plenty of leads, mostly price-shoppers.</em>
                      <small>Wasted quotes.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="capacity"
                    data-node="capacity"
                    data-score="70"
                    data-label="Capacity"
                    data-insight="Capacity is the honest ceiling. More demand only helps if the week can hold it."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="9" y1="13" x2="35" y2="13" />
                      <line x1="9" y1="22" x2="30" y2="22" />
                      <line x1="9" y1="31" x2="24" y2="31" />
                      <circle cx="36" cy="13" r="3" />
                      <circle cx="31" cy="22" r="3" />
                      <circle cx="25" cy="31" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Capacity <span>Delivery</span></strong>
                      <em>Crew or schedule can't absorb more without slipping.</em>
                      <small>Turned-away work.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="speed"
                    data-node="speed"
                    data-score="72"
                    data-label="Speed"
                    data-insight="Fast reply wins trust before the other shop even calls back."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="22" x2="34" y2="22" />
                      <line x1="26" y1="14" x2="34" y2="22" />
                      <line x1="26" y1="30" x2="34" y2="22" />
                      <circle cx="9" cy="22" r="3" />
                      <line x1="7" y1="14" x2="18" y2="14" />
                      <line x1="7" y1="30" x2="15" y2="30" />
                    </svg>
                    <span class="option-copy">
                      <strong>Speed <span>Response</span></strong>
                      <em>Leads go cold before you reach them.</em>
                      <small>Lost to whoever called first.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="conversion"
                    data-node="close"
                    data-score="68"
                    data-label="Close"
                    data-insight="Close gaps often hide after the estimate, when warm buyers go quiet."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="13" x2="23" y2="22" />
                      <line x1="7" y1="31" x2="23" y2="22" />
                      <line x1="23" y1="22" x2="36" y2="22" />
                      <circle cx="7" cy="13" r="3" />
                      <circle cx="7" cy="31" r="3" />
                      <circle cx="37" cy="22" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Close <span>Conversion</span></strong>
                      <em>You talk to plenty but close too few.</em>
                      <small>Margin left on the table.</small>
                    </span>
                  </button>
                </div>

                <p class="mono micro-insight" data-q5-insight>Pick your hunch to light the map.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-step="q4">Back</button>
                  <button class="next-action" type="button" data-next-step="q6" disabled>
                    <span>Test the hunch</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card" data-step="q6" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">06 · STRESS-TEST</p>
                  <h2>If we sent you 10x leads tomorrow, what would break first?</h2>
                  <p>Optional. Pick every pressure point that would show up fast.</p>
                </div>

                <div class="leak-options chip-options multi-options" role="group" aria-label="Capacity gaps">
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="sales-closing" data-label="Sales / closing" data-insight="If closing buckles, more leads become more unfinished estimates.">
                    <span class="option-copy">
                      <strong>Sales / closing</strong>
                      <em>More calls, quotes, or estimates would stall.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="ops-dispatch" data-label="Ops / dispatch" data-insight="If dispatch buckles, the calendar gets full before the work is ready.">
                    <span class="option-copy">
                      <strong>Ops / dispatch</strong>
                      <em>The schedule would get hard to route or assign.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="quality" data-label="Delivery quality" data-insight="If quality slips, more volume can cost tomorrow's referrals.">
                    <span class="option-copy">
                      <strong>Delivery quality</strong>
                      <em>Standards would slip if volume jumped fast.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="hiring" data-label="Hiring / training" data-insight="If hiring lags, demand grows faster than the crew.">
                    <span class="option-copy">
                      <strong>Hiring / training</strong>
                      <em>You would need people ready sooner than they are.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="tech" data-label="Tech / systems" data-insight="If systems get messy, good leads vanish in handoffs.">
                    <span class="option-copy">
                      <strong>Tech / systems</strong>
                      <em>Tools, handoffs, or records would get messy.</em>
                    </span>
                  </button>
                  <button class="leak-option text-option" type="button" aria-pressed="false" data-capacity-value="cash" data-label="Cash flow" data-insight="If cash timing gets tight, growth can feel like stress.">
                    <span class="option-copy">
                      <strong>Cash flow</strong>
                      <em>Cash timing would get tight before work caught up.</em>
                    </span>
                  </button>
                </div>

                <p class="mono micro-insight" data-step-insight="q6">Optional stress-test. You can skip this or pick more than one.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-step="q5">Back</button>
                  <button class="next-action" type="button" data-next-step="q7">
                    <span>Set target</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card target-step" data-step="q7" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">07 · TARGET</p>
