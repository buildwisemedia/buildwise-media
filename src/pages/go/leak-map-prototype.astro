---
export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Live Revenue Leak Map Prototype | Buildwise Media</title>
    <meta
      name="description"
      content="A high-fidelity prototype of the Buildwise Media Revenue Leak Map funnel experience."
    />
  </head>
  <body>
    <main class="prototype" data-app>
      <section class="welcome-screen is-active" data-panel="welcome" aria-labelledby="welcome-title">
        <div class="welcome-grid">
          <div class="welcome-copy">
            <p class="mono eyebrow">FOR SERVICE BUSINESSES · ~2 MINUTES · NO EMAIL TO SEE YOUR RESULT</p>
            <h1 id="welcome-title">
              Find the leak that's keeping <span>growth on your desk.</span>
            </h1>
            <p class="welcome-sub">
              Build your map as you answer. See where growth gets stuck before you book.
            </p>
            <button class="primary-action" type="button" data-start>
              <span>Start my Leak Map</span>
              <span aria-hidden="true">→</span>
            </button>
          </div>

          <aside class="map-panel teaser-map" aria-label="Empty Revenue Leak Map preview">
            <div class="map-head">
              <div>
                <p class="mono panel-kicker">LIVE REVENUE LEAK MAP</p>
                <h2>Empty map</h2>
              </div>
              <div class="score-card">
                <span class="mono">SCORE</span>
                <strong>00</strong>
              </div>
            </div>
            <div class="map-canvas teaser-canvas">
              <svg class="pipe-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                <polyline class="base-pipe" points="8,22 22,22 22,51 39,51 39,78 56,78 56,51 73,51 73,22 91,22" />
              </svg>
              <div class="map-node node-service is-locked" style="--x: 8; --y: 22">
                <span class="node-ring"></span><span>Service</span>
              </div>
              <div class="map-node node-demand is-locked" style="--x: 22; --y: 22">
                <span class="node-ring"></span><span>Demand</span>
              </div>
              <div class="map-node node-fit is-locked" style="--x: 22; --y: 51">
                <span class="node-ring"></span><span>Fit</span>
              </div>
              <div class="map-node node-capacity is-locked" style="--x: 39; --y: 51">
                <span class="node-ring"></span><span>Capacity</span>
              </div>
              <div class="map-node node-speed is-locked" style="--x: 39; --y: 78">
                <span class="node-ring"></span><span>Speed</span>
              </div>
              <div class="map-node node-close is-locked" style="--x: 56; --y: 78">
                <span class="node-ring"></span><span>Close</span>
              </div>
              <div class="map-node node-target is-locked" style="--x: 91; --y: 22">
                <span class="node-ring"></span><span>Target</span>
              </div>
            </div>
            <div class="map-foot">
              <div>
                <span class="mono muted">CURRENT LEAK</span>
                <strong>Not mapped yet</strong>
              </div>
              <div>
                <span class="mono muted">NEXT</span>
                <strong>Pick the first break</strong>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="cockpit" data-panel="cockpit" aria-hidden="true">
        <div class="cockpit-shell">
          <nav class="progress-rail" aria-label="Revenue Leak Map steps">
            <span class="rail-step is-done" data-rail="service">
              <span class="rail-dot"></span><span>Service</span>
            </span>
            <span class="rail-step is-done" data-rail="demand">
              <span class="rail-dot"></span><span>Demand</span>
            </span>
            <span class="rail-step is-done" data-rail="stage">
              <span class="rail-dot"></span><span>Stage</span>
            </span>
            <span class="rail-step is-done" data-rail="owner-time">
              <span class="rail-dot"></span><span>Owner-Time</span>
            </span>
            <span class="rail-step is-active" data-rail="leak">
              <span class="rail-dot"></span><span>Leak</span>
            </span>
            <span class="rail-step" data-rail="stress-test">
              <span class="rail-dot"></span><span>Stress-Test</span>
            </span>
            <span class="rail-step" data-rail="target">
              <span class="rail-dot"></span><span>Target</span>
            </span>
          </nav>

          <div class="cockpit-grid">
            <section class="question-pane" aria-live="polite">
              <article class="question-card is-active" data-step="q5">
                <div class="question-head">
                  <p class="mono step-eyebrow">05 · LEAK</p>
                  <h2>When you try to grow, what breaks first?</h2>
                  <p>Pick the one that bites before the others.</p>
                </div>

                <div class="leak-options" role="radiogroup" aria-label="Growth leak">
                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="leads"
                    data-node="demand"
                    data-score="38"
                    data-label="Demand leak"
                    data-insight="Single-channel risk flagged."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <circle cx="8" cy="22" r="3" />
                      <line x1="11" y1="22" x2="25" y2="22" />
                      <line x1="25" y1="22" x2="34" y2="13" />
                      <line x1="25" y1="22" x2="34" y2="22" />
                      <line x1="25" y1="22" x2="34" y2="31" />
                      <circle cx="37" cy="13" r="3" />
                      <circle cx="37" cy="22" r="3" />
                      <circle cx="37" cy="31" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Demand <span>Lead volume</span></strong>
                      <em>Not enough qualified people raising a hand.</em>
                      <small>Calendar gaps.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="quality"
                    data-node="fit"
                    data-score="44"
                    data-label="Fit leak"
                    data-insight="Price-shopper drag flagged."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="22" x2="37" y2="22" />
                      <circle cx="12" cy="22" r="3" />
                      <circle cx="22" cy="22" r="3" />
                      <circle cx="32" cy="22" r="3" />
                      <line x1="22" y1="19" x2="22" y2="10" />
                      <circle cx="22" cy="7" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Fit <span>Lead quality</span></strong>
                      <em>Plenty of leads, mostly price-shoppers.</em>
                      <small>Wasted quotes.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="capacity"
                    data-node="capacity"
                    data-score="49"
                    data-label="Capacity leak"
                    data-insight="Delivery ceiling flagged."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="9" y1="13" x2="35" y2="13" />
                      <line x1="9" y1="22" x2="30" y2="22" />
                      <line x1="9" y1="31" x2="24" y2="31" />
                      <circle cx="36" cy="13" r="3" />
                      <circle cx="31" cy="22" r="3" />
                      <circle cx="25" cy="31" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Capacity <span>Delivery</span></strong>
                      <em>Crew or schedule can't absorb more without slipping.</em>
                      <small>Turned-away work.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="speed"
                    data-node="speed"
                    data-score="53"
                    data-label="Speed leak"
                    data-insight="Response-time loss flagged."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="22" x2="34" y2="22" />
                      <line x1="26" y1="14" x2="34" y2="22" />
                      <line x1="26" y1="30" x2="34" y2="22" />
                      <circle cx="9" cy="22" r="3" />
                      <line x1="7" y1="14" x2="18" y2="14" />
                      <line x1="7" y1="30" x2="15" y2="30" />
                    </svg>
                    <span class="option-copy">
                      <strong>Speed <span>Response</span></strong>
                      <em>Leads go cold before you reach them.</em>
                      <small>Lost to whoever called first.</small>
                    </span>
                  </button>

                  <button
                    class="leak-option"
                    type="button"
                    role="radio"
                    aria-checked="false"
                    data-value="conversion"
                    data-node="close"
                    data-score="46"
                    data-label="Close leak"
                    data-insight="Close-rate gap flagged."
                  >
                    <svg class="option-icon" viewBox="0 0 44 44" aria-hidden="true">
                      <line x1="7" y1="13" x2="23" y2="22" />
                      <line x1="7" y1="31" x2="23" y2="22" />
                      <line x1="23" y1="22" x2="36" y2="22" />
                      <circle cx="7" cy="13" r="3" />
                      <circle cx="7" cy="31" r="3" />
                      <circle cx="37" cy="22" r="3" />
                    </svg>
                    <span class="option-copy">
                      <strong>Close <span>Conversion</span></strong>
                      <em>You talk to plenty but close too few.</em>
                      <small>Margin left on the table.</small>
                    </span>
                  </button>
                </div>

                <p class="mono micro-insight" data-q5-insight>Pick a leak to light the map.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-back-welcome>Back</button>
                  <button class="next-action" type="button" data-next-target disabled>
                    <span>Set target</span><span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>

              <article class="question-card target-step" data-step="q7" hidden>
                <div class="question-head">
                  <p class="mono step-eyebrow">07 · TARGET</p>
                  <h2>Where do you want to be in 12 months?</h2>
                  <p>Set the target. The map shows the gap.</p>
                </div>

                <div class="target-dials">
                  <div class="dial-card" data-dial="revenue">
                    <div class="dial-top">
                      <span class="mono">TARGET.REVENUE</span>
                      <strong>Monthly revenue</strong>
                    </div>
                    <div class="preset-row" role="group" aria-label="Monthly revenue presets">
                      <button type="button" data-preset="$50K">$50K</button>
                      <button type="button" data-preset="$100K">$100K</button>
                      <button type="button" data-preset="$250K">$250K</button>
                      <button type="button" data-preset="$500K+">$500K+</button>
                    </div>
                    <label>
                      <span class="mono">OVERRIDE</span>
                      <input data-target-input="revenue" name="target.revenue" inputmode="text" placeholder="Type target" />
                    </label>
                  </div>

                  <div class="dial-card" data-dial="team">
                    <div class="dial-top">
                      <span class="mono">TARGET.TEAM</span>
                      <strong>Team size</strong>
                    </div>
                    <div class="preset-row" role="group" aria-label="Team size presets">
                      <button type="button" data-preset="5">5</button>
                      <button type="button" data-preset="10">10</button>
                      <button type="button" data-preset="25">25</button>
                      <button type="button" data-preset="50+">50+</button>
                    </div>
                    <label>
                      <span class="mono">OVERRIDE</span>
                      <input data-target-input="team" name="target.team" inputmode="numeric" placeholder="Type team" />
                    </label>
                  </div>

                  <div class="dial-card" data-dial="hours">
                    <div class="dial-top">
                      <span class="mono">TARGET.HOURS</span>
                      <strong>Owner hours/week on ops</strong>
                    </div>
                    <div class="preset-row" role="group" aria-label="Owner hours presets">
                      <button type="button" data-preset="30">30</button>
                      <button type="button" data-preset="20">20</button>
                      <button type="button" data-preset="10">10</button>
                      <button type="button" data-preset="&lt;5">&lt;5</button>
                    </div>
                    <label>
                      <span class="mono">OVERRIDE</span>
                      <input data-target-input="hours" name="target.hours" inputmode="numeric" placeholder="Type hours" />
                    </label>
                  </div>
                </div>

                <p class="mono micro-insight" data-q7-insight>Each target tightens the gap.</p>

                <div class="step-actions">
                  <button class="ghost-action" type="button" data-prev-leak>Back</button>
                  <button class="primary-action compact" type="button" data-finish>
                    <span>See My Leak Map</span>
                    <span aria-hidden="true">→</span>
                  </button>
                </div>
              </article>
            </section>

            <aside class="map-panel live-map" aria-label="Live Revenue Leak Map">
              <div class="map-head">
                <div>
                  <p class="mono panel-kicker">LIVE REVENUE LEAK MAP</p>
                  <h2 data-map-title>Your map is waking up</h2>
                </div>
                <div class="score-card is-live">
                  <span class="mono">SCORE</span>
                  <strong data-score-output>00</strong>
                </div>
              </div>

              <div class="map-canvas live-canvas" data-live-canvas>
                <svg class="pipe-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                  <polyline class="base-pipe" points="8,22 22,22 22,51 39,51 39,78 56,78 56,51 73,51 73,22 91,22" />
                  <polyline class="active-pipe" data-active-pipe points="8,22 22,22 22,51 39,51 39,78 56,78 56,51 73,51 73,22 91,22" />
                  <polyline class="target-pipe" data-target-pipe points="73,22 91,22" />
                </svg>

                <div class="map-node node-service is-unlocked" data-map-node="service" style="--x: 8; --y: 22">
                  <span class="node-ring"></span><span>Service</span>
                </div>
                <div class="map-node node-demand" data-map-node="demand" style="--x: 22; --y: 22">
                  <span class="node-ring"></span><span>Demand</span>
                </div>
                <div class="map-node node-fit" data-map-node="fit" style="--x: 22; --y: 51">
                  <span class="node-ring"></span><span>Fit</span>
                </div>
                <div class="map-node node-capacity" data-map-node="capacity" style="--x: 39; --y: 51">
                  <span class="node-ring"></span><span>Capacity</span>
                </div>
                <div class="map-node node-speed" data-map-node="speed" style="--x: 39; --y: 78">
                  <span class="node-ring"></span><span>Speed</span>
                </div>
                <div class="map-node node-close" data-map-node="close" style="--x: 56; --y: 78">
                  <span class="node-ring"></span><span>Close</span>
                </div>
                <div class="map-node node-target" data-map-node="target" style="--x: 91; --y: 22">
                  <span class="node-ring"></span><span>Target</span>
                </div>

                <div class="leak-badge" data-leak-badge hidden>
                  <span class="mono">LEAK</span>
                  <strong data-leak-badge-text>Demand</strong>
                </div>
              </div>

              <div class="diagnostic-readouts">
                <div class="readout-card">
                  <span class="mono muted">CURRENT LEAK</span>
                  <strong data-current-leak>Pick one break</strong>
                  <small data-current-leak-copy>The map will flag the first loss point.</small>
                </div>
                <div class="readout-card">
                  <span class="mono muted">TODAY → TARGET</span>
                  <strong data-gap-label>No target set</strong>
                  <div class="gap-meter" aria-hidden="true">
                    <span data-gap-bar></span>
                  </div>
                </div>
                <div class="readout-card arc-card">
                  <span class="mono muted">GAP FEEL</span>
                  <div class="gap-feel-row">
                    <svg class="gap-arc" viewBox="0 0 72 72" aria-hidden="true">
                      <circle class="arc-track" cx="36" cy="36" r="28" />
                      <circle class="arc-fill" data-gap-arc cx="36" cy="36" r="28" />
                    </svg>
                    <strong data-gap-percent>0%</strong>
                  </div>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <div class="mini-readout" aria-live="polite">
        <span class="mono">LEAK MAP</span>
        <strong data-mini-score>00</strong>
        <em data-mini-leak>Pick the first break</em>
      </div>
    </main>

    <style is:global>
      @font-face {
        font-family: "Inter";
        src: url("/fonts/inter-variable-v1.woff2") format("woff2");
        font-weight: 300 900;
        font-display: swap;
      }

      @font-face {
        font-family: "JetBrains Mono";
        src: url("/fonts/jetbrains-mono-variable-v1.woff2") format("woff2");
        font-weight: 300 700;
        font-display: swap;
      }

      :root {
        color-scheme: dark;
        --canvas: #050507;
        --yellow: #F0FF00;
        --panel-1: #0b0b0f;
        --panel-2: #121217;
        --panel-3: #18181d;
        --line: rgba(255, 255, 255, 0.08);
        --line-y: rgba(240, 255, 0, 0.1);
        --text: #f5f5f5;
        --text-soft: #d7d7dc;
        --muted: #8d8d94;
        --dim: #56565d;
        --ease: cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
        background: var(--canvas);
        color: var(--text);
        font-family: "Inter", Arial, sans-serif;
      }

      body {
        overflow-x: hidden;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .prototype {
        min-height: 100svh;
        position: relative;
        isolation: isolate;
        background:
          linear-gradient(115deg, rgba(255, 255, 255, 0.03), transparent 38%),
          linear-gradient(180deg, var(--canvas), #0b0b0f 58%, var(--canvas));
      }

      .prototype::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: linear-gradient(180deg, rgba(255, 255, 255, 0.4), transparent 70%);
      }

      .mono {
        font-family: "JetBrains Mono", monospace;
        text-transform: uppercase;
      }

      .welcome-screen,
      .cockpit {
        min-height: 100svh;
        display: none;
      }

      .welcome-screen.is-active,
      .cockpit.is-active {
        display: block;
      }

      .welcome-grid {
        width: min(1480px, 100%);
        min-height: 100svh;
        margin: 0 auto;
        padding: clamp(24px, 4vw, 52px);
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) minmax(500px, 1.18fr);
        gap: clamp(24px, 4vw, 64px);
        align-items: center;
      }

      .welcome-copy {
        max-width: 650px;
      }

      .eyebrow,
      .step-eyebrow,
      .panel-kicker,
      .muted {
        margin: 0;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 650;
      }

      .welcome-copy h1 {
        margin: 22px 0 18px;
        font-size: clamp(3.2rem, 6.3vw, 7.8rem);
        line-height: 0.88;
        font-weight: 850;
        letter-spacing: 0;
      }

      .welcome-copy h1 span {
        color: var(--yellow);
        text-shadow: 0 0 30px rgba(240, 255, 0, 0.2);
      }

      .welcome-sub {
        max-width: 560px;
        margin: 0 0 32px;
        color: var(--text-soft);
        font-size: clamp(1.02rem, 1.25vw, 1.2rem);
        line-height: 1.55;
      }

      .primary-action,
      .next-action,
      .ghost-action {
        min-height: 48px;
        border: 1px solid transparent;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 0 20px;
        font-weight: 800;
        transition:
          transform 180ms var(--ease),
          border-color 180ms var(--ease),
          background 180ms var(--ease),
          opacity 180ms var(--ease);
      }

      .primary-action,
      .next-action {
        background: var(--yellow);
        color: var(--canvas);
        box-shadow:
          0 0 0 1px rgba(240, 255, 0, 0.18),
          0 18px 44px rgba(240, 255, 0, 0.14);
      }

      .primary-action:hover,
      .next-action:hover {
        transform: translateY(-1px);
      }

      .primary-action.compact {
        min-height: 44px;
      }

      .ghost-action {
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-soft);
        border-color: rgba(255, 255, 255, 0.08);
      }

      .next-action:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
      }

      .map-panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 19%),
          var(--panel-1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 22px 70px rgba(5, 5, 7, 0.62);
        overflow: hidden;
      }

      .map-head {
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 20px 22px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .map-head h2 {
        margin: 7px 0 0;
        font-size: clamp(1.2rem, 1.55vw, 1.65rem);
        line-height: 1;
      }

      .score-card {
        min-width: 92px;
        border: 1px solid rgba(240, 255, 0, 0.12);
        border-radius: 8px;
        padding: 10px 12px;
        text-align: right;
        background: rgba(240, 255, 0, 0.035);
      }

      .score-card span {
        display: block;
        color: var(--muted);
        font-size: 0.64rem;
      }

      .score-card strong {
        display: block;
        color: var(--yellow);
        font-family: "JetBrains Mono", monospace;
        font-size: 2rem;
        line-height: 0.96;
        font-weight: 700;
      }

      .map-canvas {
        position: relative;
        margin: 18px;
        min-height: 460px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        background:
          radial-gradient(circle, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
          linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
          var(--panel-2);
        background-size: 18px 18px, 100% 100%, 100% 100%;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          inset 0 -24px 60px rgba(5, 5, 7, 0.5);
        overflow: hidden;
      }

      .pipe-svg {
        position: absolute;
        inset: 0;
        z-index: 1;
        width: 100%;
        height: 100%;
        overflow: visible;
        pointer-events: none;
      }

      .base-pipe,
      .active-pipe,
      .target-pipe {
        fill: none;
        vector-effect: non-scaling-stroke;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .base-pipe {
        stroke: rgba(255, 255, 255, 0.14);
        stroke-width: 2;
      }

      .active-pipe {
        stroke: var(--yellow);
        stroke-width: 2.4;
        opacity: 0;
        filter: drop-shadow(0 0 10px rgba(240, 255, 0, 0.34));
      }

      .target-pipe {
        stroke: var(--yellow);
        stroke-width: 3.1;
        opacity: 0;
      }

      .live-canvas.has-trace .active-pipe {
        animation: tracePipe 700ms var(--ease) forwards;
      }

      .live-canvas.has-target .target-pipe {
        animation: tracePipe 550ms var(--ease) forwards;
      }

      .map-node {
        --node-size: 58px;
        position: absolute;
        z-index: 2;
        left: calc(var(--x) * 1%);
        top: calc(var(--y) * 1%);
        width: var(--node-size);
        min-height: 72px;
        transform: translate(-50%, -17px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        color: var(--muted);
        text-align: center;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.68rem;
        font-weight: 650;
        text-transform: uppercase;
        transition:
          color 180ms var(--ease),
          opacity 180ms var(--ease),
          transform 220ms var(--ease);
      }

      .node-ring {
        position: relative;
        z-index: 2;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(5, 5, 7, 0.62);
        box-shadow:
          inset 0 0 0 7px rgba(255, 255, 255, 0.03),
          0 0 0 4px rgba(255, 255, 255, 0.02);
        transition:
          border-color 180ms var(--ease),
          background 180ms var(--ease),
          box-shadow 180ms var(--ease);
      }

      .map-node > span:not(.node-ring) {
        position: relative;
        z-index: 3;
        display: inline-block;
        padding: 2px 5px;
        border-radius: 4px;
        background: var(--panel-2);
        box-shadow: 0 0 0 3px var(--panel-2);
        line-height: 1;
        white-space: nowrap;
      }

      .map-node.is-unlocked {
        color: var(--text-soft);
      }

      .map-node.is-unlocked .node-ring {
        border-color: rgba(255, 255, 255, 0.38);
        background: rgba(255, 255, 255, 0.06);
      }

      .map-node.is-dim {
        opacity: 0.36;
      }

      .map-node.is-leak {
        color: var(--yellow);
        transform: translate(-50%, -17px) scale(1.03);
      }

      .map-node.is-leak .node-ring {
        border-color: var(--yellow);
        background: rgba(240, 255, 0, 0.18);
        box-shadow:
          inset 0 0 0 8px rgba(240, 255, 0, 0.08),
          0 0 0 9px rgba(240, 255, 0, 0.07),
          0 0 28px rgba(240, 255, 0, 0.38);
        animation: leakPulse 720ms var(--ease);
      }

      .map-node.is-target {
        color: var(--yellow);
      }

      .map-node.is-target .node-ring {
        border-color: rgba(240, 255, 0, 0.8);
        box-shadow:
          inset 0 0 0 7px rgba(240, 255, 0, 0.07),
          0 0 28px rgba(240, 255, 0, 0.22);
      }

      .leak-badge {
        position: absolute;
        z-index: 3;
        right: 18px;
        bottom: 18px;
        min-width: 170px;
        border: 1px solid rgba(240, 255, 0, 0.18);
