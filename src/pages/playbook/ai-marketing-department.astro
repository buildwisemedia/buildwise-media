---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "AI Marketing Department — Buildwise Media";
const description = "An AI marketing department is a run-for-you marketing function built on automation and operator judgment — installed in 30 days, owned by the client.";

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department#term',
  name: 'AI Marketing Department',
  description: 'An AI marketing department is a full marketing team — research, content, ads, follow-up, tracking — run by AI plus operators. It takes the place of a marketing hire. The owner stops being the bottleneck. The system runs the week. Results grow from month one.',
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/',
    name: 'Buildwise Media Playbook',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'AI Marketing Department', item: 'https://buildwisemedia.com/playbook/ai-marketing-department' },
  ],
};

const faqs = [
  {
    q: 'How is an AI marketing department different from a traditional project-based firm?',
    a: 'A project-based firm sells deliverables — a website, a set of ads, a content calendar. An AI marketing department runs the marketing function as an ongoing operations layer. Deliverables are a byproduct. The system runs every week, audits itself, reports against a baseline, and compounds over time. Projects end. Operations don\'t.',
  },
  {
    q: 'How long does it take to get an AI marketing department running?',
    a: 'The Buildwise team installs the full system in 30 days. The website is live. Attribution is wired. The first content is in market. Paid acquisition follows once the conversion surface is ready. The 30-day window is a hard commitment — not a range. Full compound effect builds over 90 days and beyond.',
  },
  {
    q: 'Does the client need to manage the system day-to-day?',
    a: "No. The AI marketing department is designed to run without daily owner input. One 30-minute strategy call per month is the standard client touchpoint. The system handles production, follow-up, and reporting. The owner reviews outcomes — they don't run the operations.",
  },
  {
    q: 'Who owns the assets and data if the engagement ends?',
    a: 'The client owns everything the Buildwise team builds. Website files, ad creatives, automations, CRM data, analytics — all of it belongs to the client. The Buildwise team operates the infrastructure during the engagement. Ownership is transferred on request. Nothing is locked to a proprietary system.',
  },
  {
    q: 'Is this the right fit for every service business?',
    a: 'No. The AI marketing department is scoped to service businesses ready to stop being their own marketing department and run on a system that compounds. It is not for owners who want to approve every piece of content or commit to nothing. The fit question gets answered in a single discovery call.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a></p>
      <h1 class="h-hero">AI Marketing Department</h1>
      <p class="lede">
        An AI marketing department is a full marketing team — research, content, ads, follow-up, tracking — run by AI plus operators. It takes the place of a marketing hire. The owner stops being the bottleneck. The system runs the week. Results grow from month one.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">How it works</p>
      <h2 class="h-section">How it works.</h2>
      <p class="prose">
        AI handles the production layer: content, ad creative, follow-up sequences, weekly audits, and attribution reporting. Human operators set strategy, maintain brand voice, and manage the client. Neither works without the other.
      </p>
      <p class="prose">
        The system is up in 30 days. The website goes live. Attribution is wired on day one. Paid ads start only after the conversion surface is ready. No traffic goes to a dead end.
      </p>
      <p class="prose">
        Everything the Buildwise team builds belongs to the client. Website, content, automations, data, ad accounts — all of it transfers if the engagement ever ends. The system is the product. Ownership is built in, not buried in a contract.
      </p>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Why it matters</p>
      <h2 class="h-section">Why it matters.</h2>
      <p class="prose">
        Most service business owners start their mornings buried in operations. By the time they surface, marketing has gone untouched for another week. Hiring a full marketing director costs more than most owners can absorb. Hiring a project-based firm produces deliverables without accountability. Neither option closes the gap.
      </p>
      <p class="prose">
        The AI marketing department exists to close that gap. It runs the marketing function as an operations layer — not a project with a start and end date, but a system that runs weekly, audits itself, and reports against a captured baseline. The owner sees what changed. They don't manage it.
      </p>
      <p class="prose">
        The businesses stuck in feast-or-famine cycles aren't stuck because they lack ambition. They're stuck because they're doing the work of three roles at once. An AI marketing department removes the marketing role from the owner's plate entirely.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">How Buildwise Media uses it</p>
      <h2 class="h-section">How Buildwise Media uses it.</h2>
      <p class="prose">
        The Buildwise team ships the AI marketing department as the Ascend tier family. Each tier is scoped to the client's stage — <a href="/services/ascend">Ascend Pilot</a> for early-stage validation, <a href="/services/ascend">Ascend</a> for full done-for-you operations, and Ascend Pro for clients who want the complete run-for-you marketing function at scale.
      </p>
      <p class="prose">
        Every Ascend engagement follows a <a href="/how-it-works">dependency-gated build sequence</a>: research first, offer architecture second, website third, attribution fourth, paid acquisition last. Nothing advances until the prior stage is verified. This is how <a href="/playbook/poor-four">the Poor Four failure modes</a> get prevented before they start — not patched after the fact.
      </p>
      <p class="prose">
        Outcomes are measured against a captured baseline from day one. Every numeric claim carries a confidence floor and an evidence class — Measured, Attributed, Modeled, or Benchmark. The client knows what was true on day one and what changed. Verified weekly.
      </p>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-related elev">
    <div class="container">
      <p class="section-tag">Related</p>
      <h2 class="h-section">More from the playbook.</h2>
      <ul class="related-list">
        <li><a href="/playbook/poor-four">The Poor Four</a> — the four ways a lead system fails before it starts, and how to prevent each one</li>
        <li><a href="/playbook/captured-baseline">Captured Baseline</a> — why every outcome needs a starting point before the system turns on</li>
        <li><a href="/playbook/fractional-cmo-alternative">Fractional CMO Alternative</a> — why fractional CMO solves the strategy problem but leaves the execution gap open</li>
        <li><a href="/playbook/category-of-one-marketing">Category-of-One Marketing</a> — what it means to be the most-chosen name in your service area, not just a competitor</li>
      </ul>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see if we're a fit?</h2>
      <p class="lede">If the operations gap is bigger than the lead gap, that's the conversation worth having.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="playbook-ai-marketing-department-cta">See If We're a Fit <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/playbook">Back to Playbook</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }

.playbook-section { padding-block: clamp(56px, 8vw, 96px); }
.playbook-section .prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 720px; }
.playbook-section .prose + .prose { margin-top: 16px; }

.playbook-faq { padding-block: clamp(64px, 10vw, 112px); }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "−"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

.playbook-related { padding-block: clamp(56px, 8vw, 96px); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.related-list a { color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 180ms ease, color 180ms ease; }
.related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }

.playbook-cta { padding-block: clamp(64px, 10vw, 112px); }
.playbook-cta .lede { margin-top: 16px; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
</style>
