---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "AI Marketing Department — Buildwise Media";
const description = "An AI marketing department installs and runs your whole marketing — getting found, following up, proving results — in 30 days. See how it works.";

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department#term',
  name: 'AI Marketing Department',
  description: 'An AI marketing department is a full marketing function. It covers research, content, ads, follow-up, and tracking. AI and operators run it together. It can replace a marketing hire. The owner stops being the bottleneck. The system runs the week.',
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/',
    name: 'Buildwise Media Playbook',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'AI Marketing Department', item: 'https://buildwisemedia.com/playbook/ai-marketing-department' },
  ],
};

const faqs = [
  {
    q: 'How is an AI marketing department different from a traditional agency or freelancer?',
    a: 'A traditional agency or freelancer sells outputs. That might be a website, ads, or a content plan. An AI marketing department runs the full marketing function each week. The system checks itself, reports against a baseline, and builds over time.',
  },
  {
    q: 'How long does it take to get an AI marketing department running?',
    a: 'The Buildwise team installs the full system in 30 days. The website is live. Attribution is wired. The first content is in market. Paid ads follow once the conversion surface is ready. The 30-day window is a firm commitment — not a range. Full effect builds over 90 days and beyond.',
  },
  {
    q: 'Does the client need to manage the system day-to-day?',
    a: "No. The AI marketing department is built to run without daily owner input. One 30-minute call per month is the standard touchpoint. The system handles content, follow-up, and reporting. The owner reviews results — they don't run the day-to-day.",
  },
  {
    q: 'Who owns the assets and data if the engagement ends?',
    a: 'The client owns everything the Buildwise team builds. Website files, ad creatives, workflows, follow-up records, and reports all belong to the client. The Buildwise team runs the setup during the engagement. Ownership transfers on request. Nothing is locked to a closed system.',
  },
  {
    q: 'Is this the right fit for every service business?',
    a: 'No. The AI marketing department is built for service businesses ready to stop doing their own marketing and run on a system that builds over time. It is not for owners who want to approve every piece of content or commit to nothing. The fit question gets answered in one discovery call.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a></p>
      <h1 class="h-hero">What an AI Marketing Department Actually Does for a Home Service Business</h1>
      <p class="lede">
        An AI marketing department is a full marketing function for a small business owner who cannot keep carrying the load. Research, content, ads, follow-up, and tracking run through AI plus operators. It can replace a marketing hire. The owner stops being the bottleneck. The system runs the week.
      </p>
      <figure class="hero-photo">
        <!-- @r020:F2 proof: editorial still-life makes the operating method concrete instead of abstract -->
        <img src="/images/bwm-method-editorial-v1.webp" alt="Editorial still-life: a worn leather notebook open to a hand-annotated diagram, a mechanical pencil resting across the page, diffuse window light picking out the texture of the paper." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">System explainer</p>
      <h2 class="h-section">This is the system behind the agency alternative.</h2>
      <p class="prose">
        If you are comparing the Buildwise team with an agency, this page explains what sits under the work. The AI marketing department is not a batch of posts, reports, or campaigns. It is the weekly system that makes the work, checks the work, and keeps the next step moving.
      </p>
      <p class="prose">
        The <a href="/playbook/ai-marketing-agency-alternative">AI Marketing Agency Alternative</a> page handles the choice: keep buying agency outputs, or move to an owned system. This page explains how that system runs once you choose the second path.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">How it works</p>
      <h2 class="h-section">How it works.</h2>
      <p class="prose">
        AI makes the work: content, ad ideas, follow-up steps, weekly audits, and reports. The Buildwise team runs the weekly ops. We keep the voice clear. We clear the human gates. Both parts are needed.
      </p>
      <p class="prose">
        The system is up in 30 days. The website goes live. Attribution is wired on day one. Paid ads start only after the conversion surface is ready. No traffic goes to a dead end.
      </p>
      <p class="prose">
        Everything the Buildwise team builds belongs to the client. Website, content, workflows, data, and ad accounts can transfer if the engagement ends. The system is the product. Ownership is built in, not buried in a contract.
      </p>
      <figure class="section-photo section-photo--diagram">
        <!-- @r020:F2 proof: node-mesh diagram shows the connected layers that make the department run as a system -->
        <img src="/images/node-mesh-ascending-v1.svg" alt="Isometric ascending node mesh — six interconnected layers wired as one coherent operating system, each node feeding the next in the stack." width="1200" height="900" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Home service fit</p>
      <h2 class="h-section">What this means for a small business home service owner.</h2>
      <p class="prose">
        Home service businesses feel the gap fast. An HVAC shop gets seasonal spikes. A roofing company needs proof after storms. A plumbing company needs fast replies when the job is urgent. A pest control company needs repeat demand and review growth. The owner cannot pause field work to run all of that by hand.
      </p>
      <p class="prose">
        The <a href="/system">eight-layer system</a> gives each part a job: visibility, conversion, Speed-to-Lead, Sales Ops, reputation, Paid Media, reporting, and strategy. The <a href="/industries/hvac">HVAC page</a> shows how this works in one trade. The same rhythm fits many home service markets.
      </p>
      <p class="prose">
        That is why <a href="/services/ascend">Ascend</a> is not framed as another task list. It is a run-for-you marketing function. A small business owner gets the work of a department without hiring one person to cover every layer. The free <a href="/audit">Revenue Leak Map</a> shows which layer should move first.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">Why it matters</p>
      <h2 class="h-section">Why it matters.</h2>
      <p class="prose">
        Most service business owners start their mornings buried in ops. By the time they come up for air, marketing has gone untouched for another week. A full marketing director costs more than many owners can absorb. A firm can send outputs with no weekly accountability. Neither option closes the gap.
      </p>
      <figure class="section-photo">
        <!-- @r020:F1 emotion: owner-at-work image reflects the bottleneck this operating system removes -->
        <img src="/images/bwm-hero-atmospheric-v1.webp" alt="An operator's hands at a laptop keyboard at first light, a faint dashboard on a second monitor showing a single accent metric — the system running quietly while the work continues." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
      <p class="prose" style="margin-top: 32px;">
        The AI marketing department exists to close that gap. It runs marketing as weekly ops. It is a system that runs every week, checks itself, and reports against a captured baseline. The owner sees what changed. They don't run it.
      </p>
      <p class="prose">
        The businesses stuck in choppy demand do not lack drive. They are doing the work of three roles at once. An AI marketing department takes the marketing role off the owner's plate.
      </p>
      <blockquote class="pull-quote">
        <p>The owner stops being the bottleneck. The system runs the week. Results grow from month one.</p>
      </blockquote>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">How Buildwise Media uses it</p>
      <h2 class="h-section">How Buildwise Media uses it.</h2>
      <p class="prose">
        The Buildwise team ships the AI marketing department as the Ascend tier family. Each tier is scoped to the client's stage. <a href="/services/ascend">Ascend Pilot</a> covers early proof. <a href="/services/ascend">Ascend</a> covers full done-for-you ops. Ascend Pro covers a deeper run-for-you function at scale.
      </p>
      <p class="prose">
        Every Ascend engagement follows a <a href="/how-it-works">gated build sequence</a>. Research comes first. Offer design comes second. Website comes third. Attribution comes fourth. Paid ads come last. Nothing moves forward until the prior stage is verified. This is how <a href="/playbook/poor-four">the Poor Four failure modes</a> get stopped before they start.
      </p>
      <p class="prose">
        Outcomes are measured against a captured baseline from day one. Each numeric claim carries a confidence floor and an evidence class. The client knows what was true on day one and what changed. Verified weekly.
      </p>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-related elev">
    <div class="container">
      <p class="section-tag">Related</p>
      <h2 class="h-section">More from the playbook.</h2>
      <ul class="related-list">
        <li><a href="/system">The System</a> — the eight connected layers behind the AI marketing department</li>
        <li><a href="/playbook/in-house-marketing-alternative">In-House Marketing Alternative</a> — why one hire rarely covers the full operating load</li>
        <li><a href="/playbook/poor-four">The Poor Four</a> — the four ways a lead system fails before it starts, and how to prevent each one</li>
        <li><a href="/playbook/captured-baseline">Captured Baseline</a> — why every outcome needs a starting point before the system turns on</li>
        <li><a href="/playbook/fractional-cmo-alternative">Fractional CMO Alternative</a> — why fractional CMO solves the strategy problem but leaves the execution gap open</li>
        <li><a href="/playbook/ai-marketing-department-small-business">AI Marketing Department for Small Business</a> — the small-business version of the department model</li>
        <li><a href="/playbook/ai-marketing-agency-alternative">AI Marketing Agency Alternative</a> — why an owned AI marketing system can replace agency output buying</li>
        <li><a href="/audit">Revenue Leak Map</a> — the diagnostic that shows which layer needs the first move</li>
      </ul>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see where the system should start?</h2>
      <p class="lede">The free Revenue Leak Map shows which layer is leaking revenue now.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/revenue-leak-map" data-cta-source="playbook-ai-marketing-department-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="playbook-ai-marketing-department-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }

.h-hero em { color: var(--y2); font-style: normal; font-weight: inherit; }
.h-section em { color: var(--y2); font-style: normal; font-weight: inherit; }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-section { padding-block: clamp(56px, 8vw, 96px); }
.playbook-section .prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 720px; }
.playbook-section .prose + .prose { margin-top: 16px; }

.section-photo { margin: 48px 0 0; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.section-photo img { width: 100%; height: auto; display: block; }
.section-photo--diagram { max-width: 980px; border-color: transparent; background: transparent; }
.section-photo--diagram img { background: transparent; }

.pull-quote { margin: 56px 0; padding: 32px 0; border-block: 1px solid var(--rule); max-width: 880px; }
.pull-quote p { font-size: 24px; line-height: 1.35; color: var(--ink); font-weight: 500; font-style: italic; }

.playbook-faq { padding-block: clamp(64px, 10vw, 112px); }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "−"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

.playbook-related { padding-block: clamp(56px, 8vw, 96px); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.related-list a { color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 180ms ease, color 180ms ease; }
.related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }

.playbook-cta { padding-block: clamp(64px, 10vw, 112px); }
.playbook-cta .lede { margin-top: 16px; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
</style>
