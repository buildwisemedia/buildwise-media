---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Plumbing Lead Generation, Run For You | Buildwise Media";
const description = "Stop buying shared plumbing leads. See the owned-system way to get found, build trust, and book better plumbing jobs.";

const leakTypes = [
  {
    n: '01',
    name: 'Shared-lead leak',
    body: 'The same job request goes to several plumbers, so you race on speed and price before trust is built.',
  },
  {
    n: '02',
    name: 'Search leak',
    body: 'Homeowners search for urgent plumbing help, but stronger local proof shows up before your company.',
  },
  {
    n: '03',
    name: 'Proof leak',
    body: 'Good jobs finish, but reviews, photos, and service proof do not turn into new booked work fast enough.',
  },
  {
    n: '04',
    name: 'Source leak',
    body: 'Calls come in, but the owner cannot see which town, service, page, or referral path made the phone ring.',
  },
];

const systemCovers = [
  'Local plumbing pages for the services and towns you actually want.',
  'A faster first step for calls, forms, and booking requests.',
  'Review and proof capture after finished work, with human signoff where needed.',
  'Clear source tracking from lead to booked job.',
  'A weekly operating rhythm, so the owner sees what changed and what to fix next.',
];

const faqs = [
  {
    q: 'What is plumbing lead generation?',
    a: 'Plumbing lead generation is the system that helps homeowners find you, trust you, contact you, and book a job. The owned-system version uses your site, proof, reviews, and follow-up path instead of depending on shared lead sellers.',
  },
  {
    q: 'Why are shared plumbing leads hard to win?',
    a: 'Shared leads often go to several companies at once. That makes the job feel like a race, pushes the owner toward price cuts, and hides which work is really building the business.',
  },
  {
    q: 'Is Buildwise Media a plumbing marketing agency?',
    a: 'No. Buildwise Media is the alternative to another agency or lead vendor. The team installs and runs the lead system, while your company owns the assets, data, and proof.',
  },
  {
    q: 'What should a plumbing owner measure first?',
    a: 'Start with source, response speed, calls, forms, booked jobs, reviews, and the leaks between each step. Those numbers show whether the system is creating better work or just more noise.',
  },
  {
    q: 'How long should the first install take?',
    a: 'The first install is built around a 30-day window. That gives the team enough time to set the baseline, fix the first leaks, and show the owner what is working.',
  },
];

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/plumbing-lead-generation#term',
  name: 'Plumbing lead generation',
  description,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/#terms',
    name: 'Buildwise Media Playbook',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/plumbing-lead-generation#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://buildwisemedia.com/playbook/plumbing-lead-generation#article',
  headline: title,
  description,
  author: { '@id': 'https://buildwisemedia.com/#org' },
  publisher: { '@id': 'https://buildwisemedia.com/#org' },
  mainEntityOfPage: 'https://buildwisemedia.com/playbook/plumbing-lead-generation',
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'Plumbing Lead Generation', item: 'https://buildwisemedia.com/playbook/plumbing-lead-generation' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={[articleSchema, breadcrumb, definedTerm, faqSchema]}>

  <section class="playbook-hero">
    <div class="container playbook-hero-grid">
      <div>
        <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a> · plumbing lead generation</p>
        <h1 class="h-hero">Plumbing lead generation, built around owned demand</h1>
        <p class="lede">
          Shared plumbing leads put your company in the same pile as everyone else. A run-for-you system helps the right homeowners find you first, trust you sooner, and book better plumbing jobs through assets your business owns.
        </p>
        <p class="cta-row">
          <a class="cta-primary" href="/book" data-cta-source="plumbing-lead-gen-hero-primary">See If We're a Fit <span class="cta-arrow">→</span></a>
          <a class="cta-ghost" href="/system" data-cta-source="plumbing-lead-gen-hero-secondary">See the System</a>
        </p>
      </div>
      <aside class="proof-panel ops-panel" aria-label="Plumbing lead path">
        <p class="panel-label mono">Plumbing lead path</p>
        <strong>4</strong>
        <p>Search, trust, speed, and source clarity connect before the owner decides what worked.</p>
      </aside>
    </div>
    <div class="container">
      <figure class="hero-photo">
        <!-- @r020:F1 emotion: field-service atmosphere shows the pressure of urgent owner-led lead flow -->
        <img src="/images/bwm-services-atmospheric-v1.webp" alt="Dark service-business operations space with tools, notes, and a glowing work screen." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Shared-lead problem</p>
        <h2 class="h-section">Most plumbing lead plans rent attention from someone else.</h2>
        <p class="prose">
          A lot of plumbing lead generation starts with the same promise: pay for more calls. The problem is that many of those calls are not really yours. The same homeowner may be sent to several companies, and the job turns into a race before the buyer knows why they should trust you.
        </p>
        <p class="prose">
          That is hard on an owner-led plumbing company. You are already managing crews, emergency calls, estimates, parts, reviews, and the jobs that went sideways. You do not need another vendor report or another monthly agency bill. You need a system that makes your company easier to find and easier to choose.
        </p>
        <p class="prose">
          Buildwise Media installs and runs that system for <a href="/industries/plumbing">plumbing companies</a>. The point is not more busy work. The point is to build a lead path your company owns, then improve it with proof from real jobs.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F2 proof: layered funnel diagram makes rented attention versus owned lead flow visible -->
        <img src="/images/funnel-5-layer-v1.svg" alt="Layered funnel diagram showing connected lead stages." width="1200" height="900" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Where leads leak</p>
      <h2 class="h-section">Four places plumbing leads leak before they book.</h2>
      <div class="leak-grid">
        {leakTypes.map((leak) => (
          <article class="leak-card">
            <p class="leak-num mono">{leak.n}</p>
            <h3>{leak.name}</h3>
            <p>{leak.body}</p>
          </article>
        ))}
      </div>
      <p class="prose">
        Better plumbing leads rarely come from one trick. They come from a connected path. Homeowners need to find the right service page, see proof that feels local, get a fast next step, and leave a trail the owner can read later. If one part breaks, the company pays for activity without knowing what turned into booked work.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Run-for-you system</p>
        <h2 class="h-section">What the system covers instead of another agency contract.</h2>
        <p class="prose">
          A list of tactics still leaves the owner in the middle. A run-for-you system gives every layer a job. Service pages help buyers understand what you fix. Local proof helps them believe you. Fast routing protects urgent calls. Source tracking shows which work created booked jobs.
        </p>
        <ul class="system-list" role="list">
          {systemCovers.map((item) => <li>{item}</li>)}
        </ul>
        <p class="prose">
          That is why Buildwise Media is the alternative to the usual <a href="/playbook/contractor-lead-generation-company-alternative">contractor lead generation company</a>. The team does not hand you a task list and call it strategy. We install the path, run the rhythm, and make the owner view clear enough to act on.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F3 CTA-pull: architecture diagram points toward the owned system page instead of a vendor marketplace -->
        <img src="/images/funnel-3-layer-v1.svg" alt="Three-layer system diagram showing connected visibility, proof, and booked work." width="1200" height="900" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Better plumbing jobs</p>
        <h2 class="h-section">Owned lead flow helps you choose better work.</h2>
        <p class="prose">
          Not every plumbing lead is worth chasing. Emergency work, drain cleaning, water heater jobs, repipes, and sewer calls each have a different value and a different buyer. If every source is treated the same, the owner cannot tell whether the company is growing or just getting louder.
        </p>
        <p class="prose">
          The owned-system path helps sort the work. Pages can match the jobs you want. Proof can show the kind of work you do well. Follow-up can move faster when the need is urgent. Weekly review can show which jobs came from the system and which gaps still cost money.
        </p>
        <p class="prose">
          This is also the difference between a real operating system and a standard <a href="/playbook/lead-generation-company-alternative">lead generation company alternative</a>. The goal is not to buy more names. The goal is to build a path that improves with every finished job.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F2 proof: proof still life shows how finished work can turn into local trust assets -->
        <img src="/images/bwm-proof-still-life-v1.webp" alt="Documents, notes, and visual proof arranged on a dark operations desk." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-related">
    <div class="container">
      <p class="section-tag">Related</p>
      <h2 class="h-section">Keep reading.</h2>
      <ul class="related-list">
        <li><a href="/industries/plumbing">Plumbing Companies</a> — how the system fits owner-led plumbing teams</li>
        <li><a href="/playbook/contractor-lead-generation-company-alternative">Contractor Lead Generation Company Alternative</a> — what changes when the business owns the path</li>
        <li><a href="/playbook/lead-generation-company-alternative">Lead Generation Company Alternative</a> — the broader owner-led service playbook</li>
        <li><a href="/playbook/agency-alternative">Agency Alternative</a> — why the usual agency model keeps work on your plate</li>
      </ul>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see where plumbing leads are leaking?</h2>
      <p class="lede">The first step is a clear look at the path from search to trust to booked work.</p>
      <!-- approved-proof: 008 de-id concrete contractor, organic-playbook use approved by Robert 2026-06-18 -->
      <blockquote class="pull-quote"><p>A concrete contractor we run went from almost no inbound calls to about 150 leads since launch.</p></blockquote>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="plumbing-lead-gen-final-primary">See If We're a Fit <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/system" data-cta-source="plumbing-lead-gen-final-secondary">See the System</a>
      </p>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 360px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.proof-panel { padding: 28px; }
.proof-panel strong { display: block; margin-top: 18px; font-size: clamp(54px, 8vw, 92px); line-height: 0.9; color: var(--y2); font-weight: 600; }
.proof-panel p:last-child { margin-top: 18px; color: var(--ink-dim); line-height: 1.6; }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-section, .playbook-related, .playbook-cta, .playbook-faq { padding-block: clamp(56px, 8vw, 96px); }
.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; margin-top: 24px; }
.prose + .prose { margin-top: 16px; }
.prose a, .related-list a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.prose a:hover, .related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }

.leak-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-block: 40px; }
.leak-card { border: 1px solid var(--rule); background: rgba(255,255,255,0.025); padding: 24px; border-radius: 4px; }
.leak-num { color: var(--y2); font-size: 10px; letter-spacing: 0.18em; }
.leak-card h3 { margin-top: 18px; font-size: 22px; line-height: 1.15; color: var(--ink); }
.leak-card p:last-child { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }

.article-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: start; }
.section-photo { margin: 0; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.section-photo img { width: 100%; height: auto; display: block; }
.system-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: 28px; max-width: 760px; }
.system-list li { color: var(--ink-dim); line-height: 1.55; padding-left: 20px; position: relative; }
.system-list li::before { content: ""; position: absolute; left: 0; top: 0.72em; width: 7px; height: 7px; border-radius: 50%; background: var(--y2); }

.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.pull-quote { margin-top: 32px; max-width: 820px; border-left: 3px solid var(--y2); padding: 18px 0 18px 24px; color: var(--ink); background: rgba(255,255,255,0.025); }
.pull-quote p { font-size: clamp(22px, 3vw, 34px); line-height: 1.25; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
.playbook-faq { padding-top: 0; }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

@media (max-width: 900px) {
  .playbook-hero-grid, .article-grid { grid-template-columns: 1fr; }
  .leak-grid { grid-template-columns: 1fr; }
}
</style>
