---
import BaseLayout from '../../layouts/BaseLayout.astro';
import canonical from '../../data/canonical.json';

const title = 'What Is a Custom AI System for Service Businesses | Buildwise Media';
const description = "A custom AI system is built on your domain, run for you, and owned by you. Here's what that means for a service business - and what it isn't.";

const categoryClaim = canonical.company.category_claim;
const categoryClaimSentence = `${categoryClaim.charAt(0).toLowerCase()}${categoryClaim.slice(1)}`;
const ascendName = canonical.products.ascend.name;
const pilotName = canonical.products.pilot.name;

const systemLinks = [
  {
    href: '/playbook/ai-for-business-operations',
    label: 'AI for Business Operations',
    body: 'Clear the owner week before the day gets away.',
  },
  {
    href: '/playbook/ai-answering-service-service-business',
    label: 'After-Hours Call Capture',
    body: 'Catch, qualify, and route demand when you are not at the desk.',
  },
  {
    href: '/playbook/ai-marketing-department-small-business',
    label: 'AI Marketing Department',
    body: 'Move the weekly growth work off the owner plate.',
  },
  {
    href: '/playbook/ai-website-for-business',
    label: 'AI Website',
    body: 'Turn the site into a working lead path.',
  },
  {
    href: '/playbook/show-up-in-ai-recommendations',
    label: 'AI Search Visibility',
    body: 'Make the proof clear when buyers ask who to hire.',
  },
  {
    href: '/playbook/revenue-operating-system',
    label: 'Revenue Operating System',
    body: 'Tie source, follow-up, proof, and decisions into one loop.',
  },
];

const faqs = [
  {
    q: 'What is a custom AI system for a service business?',
    a: 'It is a run-for-you growth system built around how the business already sells. It connects the site, intake, follow-up, proof, reporting, and weekly decisions so the owner is not the glue.',
  },
  {
    q: 'How is it different from a normal AI tool?',
    a: 'A tool waits for someone to manage it, while a custom AI system runs the handoffs, shows the next move, and keeps the work tied to source truth.',
  },
  {
    q: 'What work can the system run?',
    a: 'It can run the visible lead path, intake, fast response, quote follow-up, review proof, reporting, and weekly growth moves. The full layer map lives on the system page.',
  },
  {
    q: 'Do we own the system?',
    a: 'Yes, the core assets, data, and accounts stay in the client environment while the Buildwise team and our AI system run the weekly work.',
  },
  {
    q: 'When is this not a fit?',
    a: 'It is not a fit for one-off tasks, cheap lead lists, or owners who want a new dashboard to manage. It is built for owners ready to let proof run the next move.',
  },
];

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/custom-ai-solutions#term',
  name: 'Custom AI System',
  description: 'A custom AI system is a run-for-you growth system for a service business. It is built on the client domain, operated by the Buildwise team and our AI system, and owned by the client.',
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/',
    name: 'Buildwise Media Playbook',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'Custom AI System', item: 'https://buildwisemedia.com/playbook/custom-ai-solutions' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/custom-ai-solutions#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow"><a href="/playbook" class="back-link">&larr; Playbook</a></p>
      <h1 class="h-hero">A custom AI system does the growth work, so you don't have to</h1>
      <p class="lede">
        A custom AI system is a run-for-you growth system built around your service business. It connects the site, intake, follow-up, reports, and weekly moves so you're not the person holding every piece together.
      </p>
      <p class="lede lede-tight">
        It's not a loose tool or one more dashboard — it should take work off your week. If you still check every form, chase missed calls, and ask what the report means, the system isn't doing enough.
      </p>
      <figure class="hero-photo">
        <!-- @r020:F4 curiosity: dark system corridor gives the custom AI category a concrete owned-infrastructure signal -->
        <img src="/images/bwm-system-architecture-atmospheric-v1.webp" alt="Dark connected infrastructure corridor with one yellow signal at the end." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container definition-grid">
      <div>
        <p class="section-tag">Plain answer</p>
        <h2 class="h-section">The plain answer: what it is and what it is not.</h2>
        <p class="prose">
          If you searched for custom AI solutions, the plain answer is this: a custom AI system runs the growth work a busy owner keeps doing by hand. It is built around the way your business already sells, then run each week by the Buildwise team and our AI system.
        </p>
        <p class="prose">
          The category is <strong>{categoryClaimSentence}</strong>. The system should make the next lead, next follow-up, next proof request, and next decision easier to see. What would change if the work kept moving without you chasing it?
        </p>
      </div>
      <figure class="definition-visual" aria-label="Custom AI system definition diagram">
        <!-- @r020:F2 proof: diagram separates run-for-you system work from another owner-managed tool -->
        <svg viewBox="0 0 680 430" role="img" aria-labelledby="definitionTitle">
          <title id="definitionTitle">A custom AI system runs handoffs and decisions instead of adding another tool.</title>
          <rect x="24" y="24" width="632" height="382" rx="4" class="panel" />
          <text x="64" y="78" class="kicker">CUSTOM AI SYSTEM</text>
          <path d="M86 150h150l46 64-46 64H86l46-64z" class="node node-a" />
          <path d="M265 150h150l46 64-46 64H265l46-64z" class="node node-b" />
          <path d="M444 150h150l46 64-46 64H444l46-64z" class="node node-c" />
          <text x="162" y="204" class="node-text" text-anchor="middle">capture</text>
          <text x="162" y="228" class="node-sub" text-anchor="middle">the lead</text>
          <text x="341" y="204" class="node-text" text-anchor="middle">move</text>
          <text x="341" y="228" class="node-sub" text-anchor="middle">the handoff</text>
          <text x="520" y="204" class="node-text" text-anchor="middle">show</text>
          <text x="520" y="228" class="node-sub" text-anchor="middle">the next step</text>
          <line x1="112" y1="330" x2="568" y2="330" class="rail" />
          <circle cx="112" cy="330" r="7" class="dot" />
          <circle cx="340" cy="330" r="7" class="dot" />
          <circle cx="568" cy="330" r="7" class="dot hot" />
          <text x="340" y="366" class="caption" text-anchor="middle">not another dashboard for the owner to manage</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Why owners start looking</p>
      <h2 class="h-section">The week is full by 9am, and the tools still don't talk.</h2>
      <p class="prose">
        The first sign isn't usually a lack of leads — it's the owner losing the morning to handoffs. A form came in, a call got missed, a quote needs a nudge, and a report landed without saying what to do next.
      </p>
      <p class="prose">
        That is the <a href="/problem/owner-bottleneck">owner bottleneck</a>. It creates <a href="/problem/leaky-revenue">leaky revenue</a>: demand enters the business, but the next step depends on the one person who already has too much to carry. Where does your day start slipping first?
      </p>
      <figure class="section-photo">
        <!-- @r020:F1 emotion: after-hours storefront shows the owner pain of demand arriving outside a normal workday -->
        <img src="/images/bwm-urgency-cinematic-v1.webp" alt="Dark service storefront at dusk with one bright workroom still active after hours." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">What it runs</p>
      <h2 class="h-section">What the system runs for you.</h2>
      <p class="prose">
        The system runs the visible lead path, the intake, the fast response, the follow-up, the proof loop, the reporting, and the weekly decision rhythm. The full 8-layer map lives on <a href="/system">the system page</a>, and the step-by-step install path lives on <a href="/how-it-works">how it works</a>.
      </p>
      <div class="hub-grid">
        {systemLinks.map((item) => (
          <a class="hub-card" href={item.href}>
            <span class="mono">PLAYBOOK</span>
            <strong>{item.label}</strong>
            <span>{item.body}</span>
          </a>
        ))}
      </div>
      <figure class="section-photo">
        <!-- @r020:F3 CTA-pull: stacked system asset makes the run-for-you parts feel installed, not theoretical -->
        <img src="/images/bwm-ascend-still-life-v1.webp" alt="Three dark system blocks labeled website, attribution, and operations." width="1704" height="959" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container compare-grid">
      <div>
        <p class="section-tag">System vs tools</p>
        <h2 class="h-section">Custom system vs off-the-shelf tools.</h2>
      <p class="prose">
          A tool can help with one task, but the owner still has to set it up, watch it, connect it, and decide what it means. That is why many business AI solutions look useful in a demo and still add work by Friday.
        </p>
        <p class="prose">
          A custom system is built around the real handoffs: who asked, what they need, where they came from, what should happen next, and what proof changed. If you're weighing the do-it-yourself path, start with the owner-time math in <a href="/playbook/build-your-own-ai">build your own AI</a>.
        </p>
      </div>
      <figure class="compare-visual" aria-label="Tool versus system comparison">
        <!-- @r020:F4 curiosity: comparison diagram shows why disconnected tools pull the owner back into the middle -->
        <svg viewBox="0 0 640 430" role="img" aria-labelledby="compareTitle">
          <title id="compareTitle">A tool needs a manager while a system carries the handoff.</title>
          <rect x="24" y="24" width="592" height="382" rx="4" class="panel" />
          <text x="78" y="78" class="kicker">TOOL</text>
          <text x="420" y="78" class="kicker">SYSTEM</text>
          <circle cx="148" cy="178" r="42" class="island" />
          <circle cx="232" cy="178" r="42" class="island" />
          <circle cx="190" cy="266" r="42" class="island" />
          <text x="190" y="356" class="caption" text-anchor="middle">owner connects the pieces</text>
          <path d="M382 166h116l52 52-52 52H382l52-52z" class="node node-b" />
          <line x1="354" y1="218" x2="382" y2="218" class="rail" />
          <line x1="550" y1="218" x2="586" y2="218" class="rail" />
          <circle cx="354" cy="218" r="7" class="dot" />
          <circle cx="586" cy="218" r="7" class="dot hot" />
          <text x="466" y="211" class="node-text" text-anchor="middle">handoff</text>
          <text x="466" y="237" class="node-sub" text-anchor="middle">keeps moving</text>
          <text x="468" y="356" class="caption" text-anchor="middle">system carries the path</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">Ownership</p>
      <h2 class="h-section">What you own.</h2>
      <p class="prose ownership-line">
        You own the core assets, data, and accounts; the plain ownership test lives on <a href="/playbook/agency-alternative">this ownership page</a>.
      </p>
      <figure class="section-photo">
        <!-- @r020:F2 proof: proof still-life reinforces owned records and clear evidence without adding an ownership deep dive -->
        <img src="/images/bwm-proof-still-life-v1.webp" alt="Dark proof packet with a magnifier, pen, and marked measurement notes." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container proof-grid">
      <div>
        <p class="section-tag">Proof before CTA</p>
        <h2 class="h-section">Proof comes before the next step.</h2>
        <p class="prose">
          We don't ask you to trust a claim without receipts. One custom-home builder we work with grew from $300K to $10M+. A concrete contractor we launched has booked about 150 leads since going live. The receipts live on <a href="/results">our results</a>.
        </p>
        <p class="prose">
          The free Revenue Leak Map starts smaller: it shows which part of your lead path is leaking now, then points to the first move worth making.
        </p>
        <p class="cta-row">
          <a class="cta-primary" href="/revenue-leak-map" data-cta-source="custom-ai-solutions-proof-primary">Get My Free Revenue Leak Map <span class="cta-arrow">&rarr;</span></a>
          <a class="cta-ghost" href="/system" data-cta-source="custom-ai-solutions-proof-secondary">See the System</a>
        </p>
      </div>
      <figure class="proof-photo">
        <!-- @r020:F3 CTA-pull: audit desk image connects the proof claim to the free diagnostic action -->
        <img src="/images/bwm-audit-editorial-v1.webp" alt="Dark desk with an audit packet, pen, notebook, and yellow proof marks." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container fit-grid">
      <div>
        <p class="section-tag">Fit</p>
        <h2 class="h-section">Who it's for, and who it's not for.</h2>
        <p class="prose">
          This is for owner-led service businesses where demand exists, but growth still depends on the owner pushing the work forward. If the business needs the first proof sprint, start with <a href="/services/ascend-pilot">{pilotName}</a>. If it is ready for the full run-for-you operating layer, see <a href="/services/ascend">{ascendName}</a>.
        </p>
        <p class="prose">
          It's not for one-off tasks, cheap lead lists, or owners who want every tactic routed back to their desk — the point is to reduce your management load, not rename it. What would you stop doing first if the system worked?
        </p>
      </div>
      <div class="fit-board" aria-label="Fit and not fit comparison">
        <!-- @r020:F1 emotion: fit board helps the overworked owner self-identify without blame -->
        <svg viewBox="0 0 620 420" role="img" aria-labelledby="fitTitle">
          <title id="fitTitle">Who a custom AI system is for and not for.</title>
          <rect x="24" y="24" width="572" height="372" rx="4" class="panel" />
          <text x="70" y="78" class="kicker">FOR</text>
          <text x="360" y="78" class="kicker">NOT FOR</text>
          <rect x="66" y="116" width="216" height="64" rx="4" class="fit-good" />
          <rect x="66" y="204" width="216" height="64" rx="4" class="fit-good" />
          <rect x="338" y="116" width="216" height="64" rx="4" class="fit-bad" />
          <rect x="338" y="204" width="216" height="64" rx="4" class="fit-bad" />
          <text x="174" y="153" class="node-text" text-anchor="middle">owner bottleneck</text>
          <text x="174" y="241" class="node-text" text-anchor="middle">proof-led growth</text>
          <text x="446" y="153" class="node-text" text-anchor="middle">one-off tasks</text>
          <text x="446" y="241" class="node-text" text-anchor="middle">cheap lead lists</text>
          <line x1="106" y1="324" x2="514" y2="324" class="rail" />
          <circle cx="514" cy="324" r="7" class="dot hot" />
          <text x="310" y="358" class="caption" text-anchor="middle">fit means the system can remove owner load</text>
        </svg>
      </div>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container faq-grid">
      <div>
        <p class="section-tag">FAQ</p>
        <h2 class="h-section">Common questions.</h2>
        <div class="faq-list">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary class="faq-q">{f.q}</summary>
              <div class="faq-a">
                <p>{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
      <figure class="faq-visual" aria-label="FAQ signal map">
        <!-- @r020:F4 curiosity: FAQ signal map turns common questions into a short decision path -->
        <svg viewBox="0 0 520 430" role="img" aria-labelledby="faqTitle">
          <title id="faqTitle">Common questions move from definition to fit.</title>
          <rect x="24" y="24" width="472" height="382" rx="4" class="panel" />
          <text x="70" y="78" class="kicker">DECISION PATH</text>
          <path d="M104 126h240" class="rail" />
          <path d="M168 190h240" class="rail" />
          <path d="M104 254h240" class="rail" />
          <path d="M168 318h240" class="rail" />
          <circle cx="104" cy="126" r="9" class="dot" />
          <circle cx="344" cy="126" r="9" class="dot" />
          <circle cx="168" cy="190" r="9" class="dot" />
          <circle cx="408" cy="190" r="9" class="dot" />
          <circle cx="104" cy="254" r="9" class="dot" />
          <circle cx="344" cy="254" r="9" class="dot" />
          <circle cx="168" cy="318" r="9" class="dot" />
          <circle cx="408" cy="318" r="9" class="dot hot" />
          <text x="260" y="370" class="caption" text-anchor="middle">define it, test it, map the first leak</text>
        </svg>
      </figure>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero .lede { margin-top: 24px; }
.playbook-hero .lede-tight { margin-top: 16px; max-width: 780px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-section { padding-block: clamp(56px, 8vw, 96px); }
.playbook-section .prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; }
.playbook-section .prose + .prose { margin-top: 16px; }
.playbook-section .prose a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.playbook-section .prose a:hover { color: var(--y2); border-bottom-color: var(--y2); }
.playbook-section strong { color: var(--ink); font-weight: 600; }

.definition-grid,
.compare-grid,
.proof-grid,
.fit-grid,
.faq-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(300px, 520px);
  gap: clamp(32px, 6vw, 72px);
  align-items: start;
}

.definition-visual,
.compare-visual,
.fit-board,
.faq-visual {
  margin: 0;
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
  background: rgba(255,255,255,0.02);
}

.definition-visual svg,
.compare-visual svg,
.fit-board svg,
.faq-visual svg {
  display: block;
  width: 100%;
  height: auto;
}

.panel { fill: rgba(5,5,7,0.72); stroke: rgba(255,255,255,0.08); }
.kicker { fill: var(--y2); font: 600 13px var(--mono); }
.caption { fill: var(--ink-faint); font: 500 15px var(--sans); }
.node { stroke: rgba(240,255,0,0.38); stroke-width: 1.5; }
.node-a { fill: rgba(255,255,255,0.035); }
.node-b { fill: rgba(184,255,58,0.08); }
.node-c { fill: rgba(240,255,0,0.11); }
.node-text { fill: var(--ink); font: 700 18px var(--sans); }
.node-sub { fill: var(--ink-dim); font: 500 14px var(--sans); }
.rail { stroke: rgba(255,255,255,0.18); stroke-width: 2; }
.dot { fill: var(--ink-faint); }
.dot.hot { fill: var(--y2); }
.island { fill: rgba(255,255,255,0.045); stroke: rgba(255,255,255,0.13); stroke-width: 1.5; }
.fit-good { fill: rgba(184,255,58,0.08); stroke: rgba(184,255,58,0.32); }
.fit-bad { fill: rgba(255,255,255,0.035); stroke: rgba(255,255,255,0.12); }

.section-photo,
.proof-photo {
  margin: 48px 0 0;
  max-width: 1120px;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid var(--rule);
}
.section-photo img,
.proof-photo img { width: 100%; height: auto; display: block; }
.proof-photo { margin-top: 0; }

.hub-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 36px;
}

.hub-card {
  display: flex;
  min-height: 160px;
  flex-direction: column;
  justify-content: space-between;
  gap: 16px;
  padding: 20px;
  border: 1px solid var(--rule);
  border-radius: 4px;
  background: rgba(255,255,255,0.025);
  color: var(--ink-dim);
  text-decoration: none;
  transition: border-color 180ms ease, background 180ms ease;
}

.hub-card:hover {
  border-color: rgba(240,255,0,0.55);
  background: rgba(240,255,0,0.045);
}

.hub-card .mono { color: var(--y2); font-size: 12px; }
.hub-card strong { color: var(--ink); font-size: 18px; line-height: 1.25; }
.hub-card span:last-child { line-height: 1.55; }

.ownership-line { padding: 24px 0; border-block: 1px solid var(--rule); }

.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

.playbook-faq { padding-block: clamp(64px, 10vw, 112px); }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

@media (max-width: 980px) {
  .definition-grid,
  .compare-grid,
  .proof-grid,
  .fit-grid,
  .faq-grid,
  .hub-grid {
    grid-template-columns: 1fr;
  }

  .proof-photo { margin-top: 24px; }
}

@media (max-width: 620px) {
  .hub-card { min-height: 0; }
  .node-text { font-size: 15px; }
  .node-sub,
  .caption { font-size: 12px; }
}
</style>
