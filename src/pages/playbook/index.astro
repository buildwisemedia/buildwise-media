---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Playbook — Buildwise Media";
const description = "How a service business becomes the category of one in its market — the terms, mechanisms, and measurement discipline that make it work.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
  ],
};

const definedTermSet = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': 'https://buildwisemedia.com/playbook/',
  name: 'Buildwise Media Playbook',
  description: 'The terms, mechanisms, and measurement discipline behind how Buildwise Media installs an AI marketing department for service businesses.',
  hasDefinedTerm: [
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/category-of-one-marketing#term', name: 'Category-of-One Marketing', url: 'https://buildwisemedia.com/playbook/category-of-one-marketing' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department#term', name: 'AI Marketing Department', url: 'https://buildwisemedia.com/playbook/ai-marketing-department' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/ai-marketing-department-small-business#term', name: 'AI Marketing Department for Small Business', url: 'https://buildwisemedia.com/playbook/ai-marketing-department-small-business' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/captured-baseline#term', name: 'Captured Baseline', url: 'https://buildwisemedia.com/playbook/captured-baseline' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/poor-four#term', name: 'The Poor Four', url: 'https://buildwisemedia.com/playbook/poor-four' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/fractional-cmo-alternative#term', name: 'Fractional CMO Alternative', url: 'https://buildwisemedia.com/playbook/fractional-cmo-alternative' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/agency-alternative#term', name: 'Agency Alternative', url: 'https://buildwisemedia.com/playbook/agency-alternative' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/in-house-marketing-alternative#term', name: 'In-House Marketing Alternative', url: 'https://buildwisemedia.com/playbook/in-house-marketing-alternative' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/diy-marketing-alternative#term', name: 'DIY Marketing Alternative', url: 'https://buildwisemedia.com/playbook/diy-marketing-alternative' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/capability-inheritance#term', name: 'Capability Inheritance', url: 'https://buildwisemedia.com/playbook/capability-inheritance' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/hyper-personalized-seo#term', name: 'Hyper-Personalized SEO', url: 'https://buildwisemedia.com/playbook/hyper-personalized-seo' },
    { '@type': 'DefinedTerm', '@id': 'https://buildwisemedia.com/playbook/capability-overhang#term', name: 'Capability Overhang', url: 'https://buildwisemedia.com/playbook/capability-overhang' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTermSet, breadcrumb]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow">Playbook · 12 terms</p>
      <h1 class="h-hero">The terms <em>behind the system.</em></h1>
      <p class="lede">
        How a service business becomes the category of one in its market — the mechanisms, measurement discipline, and failure modes the Buildwise team works against every week.
      </p>
      <figure class="hero-photo">
        <!-- @r020:F4 curiosity: command-center atmosphere opens the "terms behind the system" exploration the page invites -->
        <img src="/images/bwm-system-architecture-atmospheric-v1.webp" alt="Wide-angle atmospheric shot of a dark command center — three monitors casting cool blue light across a matte desk surface, a single accent metric glowing on the rightmost screen." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-index elev">
    <div class="container">
      <ul class="term-list">
        <li>
          <a href="/playbook/category-of-one-marketing">
            <span class="term-name">Category-of-One Marketing</span>
            <span class="term-gloss">Being the undisputed first choice in your service area — through signal volume, not branding exercises.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/ai-marketing-department">
            <span class="term-name">AI Marketing Department</span>
            <span class="term-gloss">A run-for-you marketing function delivered by AI plus operators — the alternative to a marketing hire.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/ai-marketing-department-small-business">
            <span class="term-name">AI Marketing Department for Small Business</span>
            <span class="term-gloss">A plain-language version of the model for owners who need marketing off their plate.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/captured-baseline">
            <span class="term-name">Captured Baseline</span>
            <span class="term-gloss">The instrumented snapshot of lead flow taken before any marketing change runs — the only honest measurement floor.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/poor-four">
            <span class="term-name">The Poor Four</span>
            <span class="term-gloss">The four operating gaps that stall most service businesses — Invisible Market, Leaky Revenue, Owner Bottleneck, Reactive Growth.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/capability-inheritance">
            <span class="term-name">Capability Inheritance</span>
            <span class="term-gloss">Why the Ascend system inherits frontier AI improvements without re-platforming.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/hyper-personalized-seo">
            <span class="term-name">Hyper-Personalized SEO</span>
            <span class="term-gloss">How the system researches the business, niche, locality, customer journey, and actual competitors.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/capability-overhang">
            <span class="term-name">Capability Overhang</span>
            <span class="term-gloss">Why focused service-business context gets more useful output from the same frontier AI models.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/fractional-cmo-alternative">
            <span class="term-name">Fractional CMO Alternative</span>
            <span class="term-gloss">Strategy vs execution — when a fractional CMO is the right call, and when an AI marketing department is.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/agency-alternative">
            <span class="term-name">Agency Alternative</span>
            <span class="term-gloss">Owning the system versus renting an agency retainer — and why ownership compounds.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/in-house-marketing-alternative">
            <span class="term-name">In-House Marketing Alternative</span>
            <span class="term-gloss">The whole marketing function installed in 30 days — without assembling and managing a six-person team.</span>
          </a>
        </li>
        <li>
          <a href="/playbook/diy-marketing-alternative">
            <span class="term-name">DIY Marketing Alternative</span>
            <span class="term-gloss">Taking marketing off the owner's plate — for when you have become the bottleneck of your own growth.</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">See the system <em>in motion.</em></h2>
      <p class="lede">If the Poor Four sound familiar and the operations gap is bigger than the lead gap, that's the conversation worth having.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="playbook-hub-cta">See If We're a Fit <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/services/ascend">See the System</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero h1 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.playbook-hero .lede { margin-top: 24px; max-width: 720px; }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-index { padding-block: clamp(64px, 10vw, 112px); }
.term-list { list-style: none; display: flex; flex-direction: column; gap: 24px; max-width: 880px; }
.term-list a { display: block; padding: 24px 28px; border: 1px solid var(--rule); border-radius: 6px; text-decoration: none; transition: border-color 180ms ease, transform 180ms ease; }
.term-list a:hover { border-color: var(--y2); transform: translateX(2px); }
.term-name { display: block; font-size: 22px; font-weight: 600; color: var(--ink); margin-bottom: 8px; }
.term-gloss { display: block; font-size: 16px; line-height: 1.6; color: var(--ink-dim); }

.playbook-cta { padding-block: clamp(64px, 10vw, 112px); }
.playbook-cta h2 em { color: var(--y2); font-style: normal; font-weight: inherit; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
</style>
