---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Playbook — Buildwise Media";
const description = "How a service business becomes the category of one in its market — the terms, mechanisms, and measurement discipline that make it work.";
const siteUrl = 'https://buildwisemedia.com';

const clusters = [
  {
    id: '01',
    title: 'What it is',
    label: '01 · What it is',
    chip: '01 What it is',
    framing: 'Different names for one thing: a custom AI system that runs your growth — on your domain, owned by you.',
    accent: 'var(--y2)',
  },
  {
    id: '02',
    title: 'Where it hurts',
    label: '02 · Where it hurts',
    chip: '02 Where it hurts',
    framing: 'The gaps that stall most service businesses — and the honest floor we measure from.',
    accent: 'var(--signal-orange)',
  },
  {
    id: '03',
    title: 'What gets installed',
    label: '03 · What gets installed',
    chip: '03 What gets installed',
    framing: "The working parts. Each one takes a job off the owner's plate.",
    accent: 'var(--signal-cyan)',
  },
  {
    id: '04',
    title: 'What you become',
    label: '04 · What you become',
    chip: '04 What you become',
    framing: 'Why the system pulls further ahead the longer it runs.',
    accent: 'var(--signal-green)',
  },
  {
    id: '05',
    title: 'Versus your options',
    label: '05 · Versus your options',
    chip: '05 Versus your options',
    framing: 'An agency, a hire, a fractional CMO, or doing it yourself — and where a custom AI system fits.',
    accent: 'var(--y2)',
  },
];

const terms = [
  {
    slug: 'custom-ai-solutions',
    name: 'Custom AI System',
    cluster: '01',
    pillar: true,
    gloss: 'The run-for-you growth system built around your business, on your domain, owned by you. The category in plain words — and the hub for everything below.',
  },
  {
    slug: 'ai-marketing-department',
    name: 'AI Marketing Department',
    cluster: '01',
    gloss: 'Marketing that is run for you by AI plus real operators. It takes the place of a marketing hire.',
  },
  {
    slug: 'ai-marketing-department-small-business',
    name: 'AI Marketing Department for Small Business',
    cluster: '01',
    gloss: 'The same model in plain words. For owners who need marketing off their plate.',
  },
  {
    slug: 'revenue-operating-system',
    name: 'Revenue Operating System',
    cluster: '01',
    gloss: 'Eight connected layers that turn marketing from projects into weekly operations.',
  },
  {
    slug: 'poor-four',
    name: 'The Poor Four',
    cluster: '02',
    gloss: 'The four gaps that stall most service businesses. They are Invisible Market, Leaky Revenue, Owner Bottleneck, and Reactive Growth.',
  },
  {
    slug: 'captured-baseline',
    name: 'Captured Baseline',
    cluster: '02',
    gloss: 'The starting number we lock before changes run, so wins and leaks are measured honestly.',
  },
  {
    slug: 'build-your-own-ai',
    name: 'Build vs Buy AI',
    cluster: '02',
    gloss: 'Building your own AI system costs more than the tools — it costs your nights. The real owner-time math.',
  },
  {
    slug: 'ai-for-business-operations',
    name: 'AI for Business Operations',
    cluster: '03',
    gloss: 'Where AI belongs inside the business: intake, follow-up, scheduling, and reporting — so the week stops running you.',
  },
  {
    slug: 'ai-answering-service-service-business',
    name: 'After-Hours Call Capture',
    cluster: '03',
    gloss: 'Catch, qualify, and route the calls you miss. The first handoff in a system that turns calls into booked jobs.',
  },
  {
    slug: 'ai-website-for-business',
    name: 'AI Website',
    cluster: '03',
    gloss: 'A site that does work: it qualifies, proves trust, routes the next step, and feeds follow-up. Not just a new look.',
  },
  {
    slug: 'show-up-in-ai-recommendations',
    name: 'AI Search Visibility',
    cluster: '03',
    gloss: 'When buyers ask AI who to hire, the clearest proof wins. How to be the answer.',
  },
  {
    slug: 'hyper-personalized-seo',
    name: 'Hyper-Personalized SEO',
    cluster: '03',
    gloss: 'Search content built from your niche, market, buyers, proof, and real local rivals.',
  },
  {
    slug: 'category-of-one-marketing',
    name: 'Category-of-One Marketing',
    cluster: '04',
    gloss: "When buyers in your area already know why you're the clear choice before they call.",
  },
  {
    slug: 'capability-inheritance',
    name: 'Capability Inheritance',
    cluster: '04',
    gloss: 'Why the Ascend system gets each new AI gain with no rebuild.',
  },
  {
    slug: 'capability-overhang',
    name: 'Capability Overhang',
    cluster: '04',
    gloss: 'Why deep context on your business pulls more useful work from the same AI models.',
  },
  {
    slug: 'hvac-lead-generation',
    name: 'HVAC Lead Generation',
    cluster: '04',
    gloss: 'How HVAC companies get more booked jobs without hiring another agency.',
  },
  {
    slug: 'fractional-cmo-alternative',
    name: 'Fractional CMO Alternative',
    cluster: '05',
    gloss: 'Strategy versus execution. When a fractional CMO is the right call, and when an AI marketing department is.',
  },
  {
    slug: 'agency-alternative',
    name: 'AI-Agency Alternative',
    cluster: '05',
    gloss: 'Thinking of hiring an AI agency? Own the custom AI system instead of renting a retainer. Ownership compounds.',
  },
  {
    slug: 'digital-marketing-agency-alternative',
    name: 'Digital Marketing Agency Alternative',
    cluster: '05',
    gloss: 'When you need growth work handled, not another monthly list of tasks. The system owns the follow-through.',
  },
  {
    slug: 'seo-agency-alternative',
    name: 'SEO Agency Alternative',
    cluster: '05',
    gloss: 'Search work that ties back to booked opportunities, not just rankings. Clear proof, clearer next steps.',
  },
  {
    slug: 'ppc-agency-alternative',
    name: 'PPC Agency Alternative',
    cluster: '05',
    gloss: 'Paid traffic only works when the path after the click is tight. The system fixes the full path.',
  },
  {
    slug: 'lead-generation-company-alternative',
    name: 'Lead Generation Company Alternative',
    cluster: '05',
    gloss: 'More leads are not enough if they leak. Own the intake, follow-up, proof, and reporting together.',
  },
  {
    slug: 'contractor-lead-generation-company-alternative',
    name: 'Contractor Lead Generation Alternative',
    cluster: '05',
    gloss: 'For contractors who need booked jobs, not another vendor sending names into a broken follow-up path.',
  },
  {
    slug: 'ai-marketing-agency-alternative',
    name: 'AI Marketing Agency Alternative',
    cluster: '05',
    gloss: 'Use AI to own the growth system, not rent another layer of strategy, tools, and reports.',
  },
  {
    slug: 'social-media-agency-alternative',
    name: 'Social Media Agency Alternative',
    cluster: '05',
    gloss: 'Social should support trust and demand. It should not become another thing the owner has to manage.',
  },
  {
    slug: 'marketing-agency-cost',
    name: 'What a Marketing Agency Costs',
    cluster: '05',
    gloss: 'The real cost is the retainer plus the owner time, missed handoffs, and unclear proof around it.',
  },
  {
    slug: 'in-house-marketing-alternative',
    name: 'In-House Marketing Alternative',
    cluster: '05',
    gloss: 'The whole marketing function installed in 30 days. No need to hire and manage a six-person team.',
  },
  {
    slug: 'diy-marketing-alternative',
    name: 'DIY Marketing Alternative',
    cluster: '05',
    gloss: "Marketing comes off the owner's plate. For when you have become the bottleneck of your own growth.",
  },
  {
    slug: 'plumbing-lead-generation',
    name: 'Plumbing Lead Generation',
    cluster: '04',
    gloss: 'Owned plumbing demand — get found, build trust, and book better jobs instead of buying shared leads.',
  },
  {
    slug: 'roofing-lead-generation',
    name: 'Roofing Lead Generation',
    cluster: '04',
    gloss: 'Owned roofing demand — proof and pages that win the right jobs, not a list everyone else can buy.',
  },
  {
    slug: 'restoration-lead-generation',
    name: 'Restoration Lead Generation',
    cluster: '04',
    gloss: 'Restoration runs on speed — get found fast and book better water and fire jobs from your own demand.',
  },
  {
    slug: 'electrician-lead-generation',
    name: 'Electrician Lead Generation',
    cluster: '04',
    gloss: 'Owned electrical demand — get found, show proof, and book better jobs without renting shared leads.',
  },
  {
    slug: 'pest-control-lead-generation',
    name: 'Pest Control Lead Generation',
    cluster: '04',
    gloss: 'Owned pest demand — get found and book better recurring jobs instead of buying the same shared leads.',
  },
  {
    slug: 'marketing-for-service-businesses',
    name: 'Marketing for Service Businesses',
    cluster: '05',
    gloss: 'The whole picture: one owned system the team builds and runs so marketing books work, not busywork.',
  },
  {
    slug: 'content-marketing-agency-alternative',
    name: 'Content Marketing Agency Alternative',
    cluster: '05',
    gloss: 'More content is not a system. Proof and pages that turn into booked work — owned by you, not a vendor.',
  },
];

const hrefFor = (slug: string) => `/playbook/${slug}`;
const urlFor = (slug: string) => `${siteUrl}${hrefFor(slug)}`;
const termBySlug = new Map(terms.map((term) => [term.slug, term]));
const termHref = (slug: string) => urlFor(termBySlug.get(slug)?.slug ?? slug);

const termsWithMeta = terms.map((term, index) => {
  const cluster = clusters.find((item) => item.id === term.cluster);
  if (!cluster) throw new Error(`Missing cluster for ${term.slug}`);

  return {
    ...term,
    href: hrefFor(term.slug),
    url: urlFor(term.slug),
    index: index + 1,
    clusterMeta: cluster,
  };
});

const clustersWithTerms = clusters.map((cluster) => ({
  ...cluster,
  terms: termsWithMeta.filter((term) => term.cluster === cluster.id),
}));

const mapNodes = [
  { cluster: clustersWithTerms[0], x: 92, y: 86 },
  { cluster: clustersWithTerms[1], x: 704, y: 86 },
  { cluster: clustersWithTerms[2], x: 704, y: 262 },
  { cluster: clustersWithTerms[3], x: 92, y: 262 },
  { cluster: clustersWithTerms[4], x: 398, y: 420 },
];

const faqItems = [
  {
    question: 'What is a custom AI system?',
    answerHtml: `It is the run-for-you growth system we install around your business. It can answer, route, follow up, prove trust, and show the team what to fix next. <a href="${termHref('custom-ai-solutions')}">Read Custom AI System.</a>`,
  },
  {
    question: 'How is this different from hiring an agency?',
    answerHtml: `An agency often sells tasks and reports. We install one owned system the team runs with you, so the work, data, and code stay yours. <a href="${termHref('agency-alternative')}">Read AI-Agency Alternative.</a>`,
  },
  {
    question: 'What is the Poor Four?',
    answerHtml: `The Poor Four are the four gaps we check first: buyers cannot find you, leads leak, the owner is the bottleneck, and growth stays reactive. <a href="${termHref('poor-four')}">Read The Poor Four.</a>`,
  },
  {
    question: 'How fast does it go live?',
    answerHtml: `The install is built for 30 days. We map the leaks, set the first baseline, then put the first working path live with human signoff. <a href="${termHref('revenue-operating-system')}">Read Revenue Operating System.</a>`,
  },
  {
    question: 'Do I own it?',
    answerHtml: `Yes. The client owns the system, data, and code. We run it with our AI system, but it is built to live on your domain. <a href="${termHref('custom-ai-solutions')}">Read Custom AI System.</a>`,
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
  ],
};

const definedTermSet = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': 'https://buildwisemedia.com/playbook/',
  name: 'Buildwise Media Playbook',
  description: 'The terms, mechanisms, and measurement discipline behind how Buildwise Media installs a custom AI system for service businesses.',
  hasDefinedTerm: termsWithMeta.map((term) => ({
    '@type': 'DefinedTerm',
    '@id': `${term.url}#term`,
    name: term.name,
    url: term.url,
    description: term.gloss,
  })),
};

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': 'https://buildwisemedia.com/playbook/#itemlist',
  name: 'Buildwise Media Playbook Terms',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: termsWithMeta.length,
  itemListElement: termsWithMeta.map((term) => ({
    '@type': 'ListItem',
    position: term.index,
    name: term.name,
    url: term.url,
    item: term.url,
  })),
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/#faq',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answerHtml,
    },
  })),
};

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': ['WebPage', 'CollectionPage'],
  '@id': 'https://buildwisemedia.com/playbook/#collection',
  url: 'https://buildwisemedia.com/playbook/',
  name: title,
  description,
  isPartOf: { '@id': 'https://buildwisemedia.com/#website' },
  mainEntity: { '@id': 'https://buildwisemedia.com/playbook/' },
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTermSet, breadcrumb, itemList, faqPage, collectionPage]}>
  <main class="playbook-hub" data-playbook-hub>
    <section class="playbook-hero">
      <div class="container">
        <p class="eyebrow">PLAYBOOK · 28 TERMS · ONE SYSTEM</p>
        <h1 class="playbook-title">The terms <em>behind the system.</em></h1>
        <p class="lede playbook-lede">
          Twenty-eight plain-English terms for how a service business becomes the obvious choice in its market — what we install, why it keeps paying off, and how we prove it. Tap any part of the map to jump in.
        </p>

        <div class="system-map-shell">
          <!-- @sdt-interactive-proof: visual system map of the 20 terms -->
          <!-- @r020:F4 curiosity -->
          <div class="system-map-graph" data-system-map>
            <svg class="system-map" viewBox="0 0 1120 620" role="img" aria-labelledby="playbook-map-title playbook-map-desc">
              <title id="playbook-map-title">Playbook system map</title>
              <desc id="playbook-map-desc">A central Custom AI System node connects to five clusters of playbook terms.</desc>
              <g class="map-lines" aria-hidden="true">
                {mapNodes.map((node) => (
                  <path
                    class={`map-line map-line--${node.cluster.id}`}
                    d={`M560 300 L${node.x + 160} ${node.y + 54}`}
                    pathLength="1"
                  />
                ))}
              </g>

              {mapNodes.map((node) => (
                <a
                  href={`#cluster-${node.cluster.id}`}
                  class="map-node map-node--cluster"
                  data-scroll-target={`cluster-${node.cluster.id}`}
                  data-cluster-node={node.cluster.id}
                  aria-label={`Jump to ${node.cluster.label}`}
                >
                  <g transform={`translate(${node.x} ${node.y})`}>
                    <rect class="map-node-box" width="320" height="108" rx="6" />
                    <text class="map-node-title" x="24" y="42">{node.cluster.label}</text>
                    <text class="map-node-count" x="24" y="72">{node.cluster.terms.length} terms</text>
                  </g>
                </a>
              ))}

              <a
                href="#cluster-01"
                class="map-node map-node--core"
                data-scroll-target="cluster-01"
                aria-label="Jump to Custom AI System"
              >
                <g transform="translate(414 236)">
                  <rect class="map-core-box" width="292" height="128" rx="8" />
                  <text class="map-core-kicker" x="146" y="42" text-anchor="middle">CORE</text>
                  <text class="map-core-title" x="146" y="78" text-anchor="middle">Custom AI System</text>
                  <text class="map-core-sub" x="146" y="104" text-anchor="middle">owned growth layer</text>
                </g>
              </a>
            </svg>
          </div>

          <ul class="system-map-legend" aria-label="Playbook clusters">
            {clustersWithTerms.map((cluster) => (
              <li>
                <a
                  href={`#cluster-${cluster.id}`}
                  data-scroll-target={`cluster-${cluster.id}`}
                  style={`--cluster-accent: ${cluster.accent};`}
                >
                  <span class="legend-label">{cluster.label}</span>
                  <span class="legend-count">{cluster.terms.length} terms</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="playbook-controls-wrap" aria-label="Playbook filters">
      <div class="container">
        <div class="playbook-controls">
          <div class="filter-chip-group" role="group" aria-label="Filter terms by cluster">
            <button class="filter-chip is-active" type="button" aria-pressed="true" data-cluster-filter="all">All</button>
            {clustersWithTerms.map((cluster) => (
              <button class="filter-chip" type="button" aria-pressed="false" data-cluster-filter={cluster.id}>{cluster.chip}</button>
            ))}
          </div>

          <label class="term-search" for="playbook-term-search">
            <span class="term-search-label">Find a term</span>
            <input id="playbook-term-search" type="search" name="q" placeholder="Find a term" autocomplete="off" data-term-search />
          </label>

          <p class="filter-results" aria-live="polite" data-results-count>{termsWithMeta.length} terms shown</p>
        </div>
        <p class="filter-empty" data-empty-state hidden>No matching terms. Clear the search or pick All.</p>
      </div>
    </section>

    {clustersWithTerms.map((cluster) => (
      <section
        class="playbook-cluster"
        id={`cluster-${cluster.id}`}
        data-cluster-section={cluster.id}
        style={`--cluster-accent: ${cluster.accent};`}
      >
        <!-- @sdt-exempt: playbook term cluster index — static navigation cards, not a narrative prose section; the hero map carries the page creative -->
        <div class="cluster-ghost" aria-hidden="true">{cluster.id}</div>
        <div class="container">
          <div class="cluster-heading">
            <h2 class="cluster-title">
              <span class="cluster-number">{cluster.id}</span>
              <span>{cluster.title}</span>
              <span class="cluster-count">{cluster.terms.length} terms</span>
            </h2>
            <p>{cluster.framing}</p>
          </div>

          <div class="term-grid">
            {cluster.terms.map((term, index) => (
              <a
                href={term.href}
                class:list={['term-card', term.pillar ? 'term-card--pillar' : '']}
                data-term-card
                data-cluster={term.cluster}
                data-name={term.name.toLowerCase()}
                data-gloss={term.gloss.toLowerCase()}
                style={`--cluster-accent: ${term.clusterMeta.accent}; --reveal-index: ${index};`}
              >
                <span class="term-card-rule" aria-hidden="true"></span>
                <span class="term-topline">
                  <span class="term-index">{String(term.index).padStart(2, '0')}</span>
                  {term.pillar && <span class="pillar-tag">START HERE</span>}
                </span>
                <h3>{term.name}</h3>
                <p>{term.gloss}</p>
                <span class="term-affordance">Read term <span aria-hidden="true">→</span></span>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <section class="playbook-faq elev" id="common-questions">
      <!-- @sdt-exempt: FAQ accordion answers search intent directly; it is structured answer UI, not a narrative prose section -->
      <div class="container">
        <div class="faq-heading">
          <p class="section-tag">FAQ</p>
          <h2 class="section-title">Common questions</h2>
        </div>
        <div class="faq-list">
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p><Fragment set:html={item.answerHtml} /></p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="playbook-cta elev">
      <div class="container">
        <h2 class="cta-title">See the system <em>on your business.</em></h2>
        <p class="lede">You just read how it works. Let's map where the leaks are for you.</p>
        <p class="cta-row">
          <a class="cta-primary" href="/book" data-cta-source="playbook-hub-cta-primary">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
          <a class="cta-ghost" href="/services/ascend" data-cta-source="playbook-hub-cta-secondary">See the System</a>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
.playbook-hub {
  background: var(--bg);
}

.playbook-hero {
  padding-block: 128px 72px;
}

.playbook-title,
.section-title,
.cluster-title,
.cta-title,
.term-card h3 {
  letter-spacing: 0;
}

.playbook-title {
  max-width: 860px;
  margin-top: 28px;
  font-size: 76px;
  line-height: 0.95;
  font-weight: 800;
  color: var(--ink);
}

.playbook-title em,
.cta-title em {
  color: var(--y2);
  font-style: normal;
  font-weight: inherit;
}

.playbook-lede {
  margin-top: 26px;
  max-width: 800px;
}

.system-map-shell {
  margin-top: 56px;
}

.system-map-graph {
  border: 1px solid var(--rule);
  border-radius: 8px;
  background:
    linear-gradient(90deg, color-mix(in srgb, var(--rule) 38%, transparent) 1px, transparent 1px),
    linear-gradient(180deg, color-mix(in srgb, var(--rule) 38%, transparent) 1px, transparent 1px),
    var(--bg-elev);
  background-size: 48px 48px;
  overflow: hidden;
}

.system-map {
  width: 100%;
  min-height: 420px;
}

.map-line {
  fill: none;
  stroke: var(--rule-bright);
  stroke-width: 1.5;
  stroke-dasharray: 1;
  stroke-dashoffset: 1;
  animation: signalRoute 900ms ease forwards;
}

.map-line--02 { animation-delay: 80ms; }
.map-line--03 { animation-delay: 160ms; }
.map-line--04 { animation-delay: 240ms; }
.map-line--05 { animation-delay: 320ms; }

.map-node {
  cursor: pointer;
  outline: none;
}

.map-node-box,
.map-core-box {
  fill: var(--bg-card);
  stroke: var(--rule-bright);
  stroke-width: 1;
  transition: stroke 180ms ease, fill 180ms ease, transform 180ms ease;
}

.map-core-box {
  fill: color-mix(in srgb, var(--bg-card) 82%, var(--y2));
  stroke: var(--y2);
}

.map-node-title,
.map-node-count,
.map-core-kicker,
.map-core-title,
.map-core-sub {
  font-family: var(--mono);
  letter-spacing: 0;
  pointer-events: none;
}

.map-node-title {
  fill: var(--ink);
  font-size: 18px;
  font-weight: 600;
}

.map-node-count,
.map-core-sub {
  fill: var(--ink-dim);
  font-size: 14px;
}

.map-core-kicker {
  fill: var(--y2);
  font-size: 12px;
}

.map-core-title {
  fill: var(--ink);
  font-size: 20px;
  font-weight: 700;
}

.map-node:hover .map-node-box,
.map-node:focus-visible .map-node-box,
.system-map-graph[data-active-cluster="01"] .map-node[data-cluster-node="01"] .map-node-box,
.system-map-graph[data-active-cluster="02"] .map-node[data-cluster-node="02"] .map-node-box,
