</style>

<script>
  const playbookHub = document.querySelector('[data-playbook-hub]');

  if (playbookHub) {
    const cards = Array.from(playbookHub.querySelectorAll('[data-term-card]'));
    const chips = Array.from(playbookHub.querySelectorAll('[data-cluster-filter]'));
    const search = playbookHub.querySelector('[data-term-search]');
    const count = playbookHub.querySelector('[data-results-count]');
    const empty = playbookHub.querySelector('[data-empty-state]');
    const sections = Array.from(playbookHub.querySelectorAll('[data-cluster-section]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeCluster = 'all';

    const normalize = (value) => String(value || '').toLowerCase().trim();

    const updateFilters = () => {
      const query = normalize(search ? search.value : '');
      let visibleCount = 0;

      sections.forEach((section) => {
        const sectionCards = cards.filter((card) => card.dataset.cluster === section.dataset.clusterSection);
        let sectionVisibleCount = 0;

        sectionCards.forEach((card) => {
          const clusterMatch = activeCluster === 'all' || card.dataset.cluster === activeCluster;
          const searchText = `${card.dataset.name || ''} ${card.dataset.gloss || ''}`;
          const searchMatch = !query || searchText.includes(query);
          const visible = clusterMatch && searchMatch;

          card.hidden = !visible;
          if (visible) {
            visibleCount += 1;
            sectionVisibleCount += 1;
          }
        });

        section.hidden = sectionVisibleCount === 0;
      });

      chips.forEach((chip) => {
        const pressed = chip.dataset.clusterFilter === activeCluster;
        chip.classList.toggle('is-active', pressed);
        chip.setAttribute('aria-pressed', String(pressed));
      });

      if (count) {
        count.textContent = `${visibleCount} ${visibleCount === 1 ? 'term' : 'terms'} shown`;
      }

      if (empty) {
        empty.hidden = visibleCount !== 0;
      }
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeCluster = chip.dataset.clusterFilter || 'all';
        updateFilters();
      });
    });

    if (search) {
      search.addEventListener('input', updateFilters);
    }

    playbookHub.querySelectorAll('[data-scroll-target]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const id = link.getAttribute('data-scroll-target');
        const target = id ? document.getElementById(id) : null;

        if (!target) return;

        event.preventDefault();
        target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
        history.pushState(null, '', `#${id}`);
      });
    });

    const map = playbookHub.querySelector('[data-system-map]');
    playbookHub.querySelectorAll('[data-cluster-node]').forEach((node) => {
      const cluster = node.getAttribute('data-cluster-node');
      const setActive = () => {
        if (map && cluster) map.setAttribute('data-active-cluster', cluster);
      };
      const clearActive = () => {
        if (map) map.removeAttribute('data-active-cluster');
      };

      node.addEventListener('mouseenter', setActive);
      node.addEventListener('focus', setActive);
      node.addEventListener('mouseleave', clearActive);
      node.addEventListener('blur', clearActive);
    });

    playbookHub.classList.add('playbook-reveal-ready');

    if (reduceMotion || !('IntersectionObserver' in window)) {
      sections.forEach((section) => section.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -10% 0px' });

      sections.forEach((section) => observer.observe(section));
    }

    updateFilters();
  }
</script>
