---
import BaseLayout from '../../layouts/BaseLayout.astro';
import canonical from '../../data/canonical.json';

const title = "Revenue Operating System for Contractors — Buildwise Media";
const description = "A revenue operating system is the AI system that runs revenue work for a service business — visibility, follow-up, attribution, and reporting in one weekly loop you own.";

const layerBodies: Record<string, string> = {
  Visibility: 'Make the business easier to find before the buyer asks for a quote.',
  Conversion: 'Turn visits, calls, forms, and quote paths into clean next steps.',
  'Speed-to-Lead': 'Answer fast while the buyer still wants the work solved.',
  'Sales Ops': 'Keep quotes, reminders, and past leads moving until they close or decline.',
  Reputation: 'Turn finished work into reviews, replies, and proof.',
  'Paid Media': 'Track spend against lead quality and booked work.',
  Reporting: 'Show source, calls, quotes, booked jobs, and next moves in one place.',
  Strategy: 'Use a weekly scoreboard to decide what changes next.',
};

const layers = canonical.products.ascend.eight_layers.map((raw: string, index: number) => {
  const dashIndex = raw.indexOf('—');
  const dotIndex = raw.indexOf('·');
  const name = dashIndex > 0 ? raw.slice(dotIndex + 1, dashIndex).trim() : raw.slice(dotIndex + 1).trim();
  return {
    n: String(index + 1).padStart(2, '0'),
    name,
    body: layerBodies[name] ?? '',
    tone: ['cyan', 'green', 'yellow', 'orange', 'green', 'cyan', 'yellow', 'green'][index],
  };
});

const operatingSteps = [
  { label: 'Capture', body: 'Lock the starting numbers before changing the market surface.' },
  { label: 'Install', body: 'Wire the eight layers into one run-for-you system.' },
  { label: 'Run', body: 'Review the scoreboard, clear gates, and adjust the work each week.' },
  { label: 'Prove', body: 'Tie source, spend, follow-up, and booked jobs back to the baseline.' },
];

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/revenue-operating-system#term',
  name: 'Revenue Operating System',
  description: 'A revenue operating system is an owned marketing and sales operations layer for contractors. It connects visibility, follow-up, attribution, reporting, and weekly decisions into one system measured against a captured baseline.',
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/',
    name: 'Buildwise Media Playbook',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'Revenue Operating System', item: 'https://buildwisemedia.com/playbook/revenue-operating-system' },
  ],
};

const faqs = [
  {
    q: 'What is a revenue operating system for contractors?',
    a: 'It is the connected system that runs visibility, follow-up, attribution, reporting, and weekly decisions. It replaces scattered tactics with one owned operating layer.',
  },
  {
    q: 'How is it different from a marketing campaign?',
    a: 'A campaign starts and stops. A revenue operating system runs every week. It measures the baseline, tracks the work, and shows what changed.',
  },
  {
    q: 'Who owns the system?',
    a: 'The client owns the core assets, data, and records. The Buildwise team and our AI system run the operating rhythm while the business keeps ownership.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/revenue-operating-system#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a></p>
      <h1 class="h-hero">What Is a Revenue Operating System for Contractors?</h1>
      <p class="lede">
        A revenue operating system is the owned layer that connects marketing, follow-up, source tracking, reporting, and weekly decisions. It is not a campaign. It is how a contracting business runs demand without making the owner chase every loose part.
      </p>
      <figure class="hero-photo">
        <!-- @r020:F2 proof: system architecture image gives the revenue operating system a concrete physical metaphor -->
        <img src="/images/bwm-system-architecture-atmospheric-v1.webp" alt="Dark infrastructure corridor with a single yellow signal suggesting a connected operating layer." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">AI system vs AI tool</p>
      <h2 class="h-section">Is it an AI system, or just an AI tool?</h2>
      <p class="prose">
        Most "AI" for a small business is a tool. It does one task and waits for someone to run it. An AI system for a service business is different — it runs the work across the whole revenue path and keeps it moving without you in the middle. Here's the plain test:
      </p>
      <ul style="margin:28px 0 8px;padding-left:22px;max-width:720px;display:flex;flex-direction:column;gap:12px;font-size:17px;line-height:1.6;color:var(--ink-dim);">
        <li>A tool waits for you to open it. A system runs on its own schedule.</li>
        <li>A tool does one step. A system carries the handoff from lead to booked job.</li>
        <li>A tool gives you a screen to check. A system gives you the next move and the proof.</li>
        <li>A tool is one more login. A system is one fewer thing you carry.</li>
      </ul>
      <p class="prose">
        That's why a revenue operating system is an AI system for a service business, not a stack of tools. If you have to be the one connecting the parts, it's still a tool. What are you connecting by hand right now?
      </p>
      <figure class="section-photo">
        <!-- @r020:F2 proof: system still-life shows a connected operating layer, not a single tool -->
        <img src="/images/bwm-system-architecture-atmospheric-v1.webp" alt="Dark connected infrastructure with one bright signal — an operating system, not a single tool." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">Definition</p>
      <h2 class="h-section">A campaign is a push. A system is how the work runs.</h2>
      <p class="prose">
        Most contractors have pieces. A website. A few ads. A call log. A quote sheet. A review request that happens when someone remembers. Those pieces can bring in work, but they do not explain what happened. The owner still has to ask where the lead came from, who answered, which quote went cold, and what should change next.
      </p>
      <p class="prose">
        A revenue operating system replaces that guesswork with a connected rhythm. Every layer has a job. Every week has a scoreboard. Every claim sits on a captured baseline. The goal is simple: know what drove booked work, know where the leak happened, and know the next move.
      </p>
      <p class="prose">
        That is why the word "campaign" is too small. Campaigns can help. They cannot run the full revenue loop. Contractors need the loop itself.
      </p>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Eight layers</p>
      <h2 class="h-section">The eight layers connect around booked work.</h2>
      <p class="prose">
        Ascend installs the same eight layers for contractors and runs them as one system. The names stay simple because the work has to be clear to the owner.
      </p>
      <div class="layers-grid">
        {layers.map((layer) => (
          <article class={`layer-card tone-${layer.tone}`}>
            <p class="layer-num mono">{layer.n}</p>
            <h3>{layer.name}</h3>
            <p>{layer.body}</p>
          </article>
        ))}
      </div>
      <p class="prose">
        Visibility creates the chance to be chosen. Conversion makes the next step clear. Speed-to-Lead protects urgent demand. Sales Ops keeps quotes from going quiet. Reputation turns finished work into trust. Paid Media gets judged by job quality. Reporting shows the truth. Strategy turns that truth into the next week of work.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container operating-grid">
      <div>
        <p class="section-tag">Baseline first</p>
        <h2 class="h-section">The baseline makes each layer measurable.</h2>
        <p class="prose">
          Contractors do not need prettier reports. They need a starting point they can trust. A captured baseline records what was true before the system changes anything. Source, page, call, quote, booked job, and follow-up timing all matter.
        </p>
        <p class="prose">
          Once the baseline is locked, the team can compare later work to a real floor. Did the source improve, or did answer speed improve? Did booked work rise, or did the sales team clean up old quotes? The system separates those signals so the owner can make better decisions.
        </p>
      </div>
      <div class="operating-board" aria-label="Revenue operating system weekly rhythm">
        {operatingSteps.map((step, index) => (
          <article>
            <span class="mono">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.label}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Where contractors leak revenue</p>
      <h2 class="h-section">Speed-to-lead and sales follow-up are usually the fastest leaks to find.</h2>
      <p class="prose">
        A contractor can buy attention and still lose the job. If the buyer waits too long for a reply, the work goes elsewhere. If a quote gets sent and no one follows up, the job fades. If a past customer never hears from the company again, the next need goes to whoever shows up first.
      </p>
      <p class="prose">
        The revenue operating system treats those moments as operating signals. A slow reply is not a bad lead. An old quote is not dead until the system has worked it. A review request is not a nice extra; it is proof for the next buyer. This is how the system turns everyday follow-through into measurable growth.
      </p>
      <figure class="section-photo">
        <!-- @r020:F2 proof: proof packet image shows that attribution and follow-up are tracked as evidence, not vibes -->
        <img src="/images/bwm-proof-still-life-v1.webp" alt="Proof packet still-life with marked notes and measurement artifacts." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">Week over week</p>
      <h2 class="h-section">Running marketing as operations changes the meeting.</h2>
      <p class="prose">
        The weekly question stops being, "Did marketing work?" It becomes, "Which layer needs the next move?" If calls are strong but booked work is weak, the follow-up system gets attention. If spend rose but close rate fell, the source quality gets checked. If reviews are flat after a strong service week, the reputation layer gets fixed.
      </p>
      <p class="prose">
        This is the operating rhythm the Buildwise team runs inside <a href="/services/ascend">Ascend</a>. It connects to <a href="/system">the full system</a>, the <a href="/playbook/ai-marketing-department">AI marketing department</a>, and the <a href="/problem/leaky-revenue">leaky revenue</a> problem most contractors feel before they can name it.
      </p>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Fit check</p>
      <h2 class="h-section">Who this is built for.</h2>
      <p class="prose">
        The Ascend revenue operating system is built for owner-led service businesses with enough demand to support a full operating layer. HVAC, roofing, plumbing, concrete, cleaning, and related trades can all fit when the market is dense enough and the owner is ready to be run by proof.
      </p>
      <p class="prose">
        It is not built for owners who want one-off tasks, cheap lead lists, or public claims without measurement. It is built for teams that want the system installed, run, and measured against a baseline they own.
      </p>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-related elev">
    <div class="container">
      <p class="section-tag">Related</p>
      <h2 class="h-section">More from the playbook.</h2>
      <ul class="related-list">
        <li><a href="/system">The System</a> — the full eight-layer operating model</li>
        <li><a href="/playbook/ai-marketing-department">AI Marketing Department</a> — the run-for-you function that operates the system</li>
        <li><a href="/problem/leaky-revenue">Leaky Revenue</a> — the common failure mode this system closes</li>
        <li><a href="/services/ascend">Ascend</a> — the installed system Buildwise runs each week</li>
      </ul>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see where revenue leaks now?</h2>
      <p class="lede">The free Revenue Leak Map shows which layer needs the first move.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="revenue-os-cta-primary">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="revenue-os-cta-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-section { padding-block: clamp(56px, 8vw, 96px); }
.playbook-section .prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; }
.playbook-section .prose + .prose { margin-top: 16px; }
.playbook-section .prose a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.playbook-section .prose a:hover { color: var(--y2); border-bottom-color: var(--y2); }

.layers-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-block: 40px; }
.layer-card { border: 1px solid var(--rule); padding: 20px; border-radius: 4px; background: rgba(255,255,255,0.02); }
.layer-card h3 { margin-top: 16px; font-size: 18px; color: var(--ink); }
.layer-card p:last-child { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }
.layer-num { color: var(--y2); }

.operating-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 440px); gap: clamp(32px, 6vw, 72px); align-items: start; }
.operating-board { display: grid; gap: 12px; }
.operating-board article { border: 1px solid var(--rule); background: rgba(255,255,255,0.025); border-radius: 4px; padding: 20px; }
.operating-board span { color: var(--y2); }
.operating-board h3 { margin-top: 12px; color: var(--ink); font-size: 20px; }
.operating-board p { margin-top: 8px; color: var(--ink-dim); line-height: 1.55; }

.section-photo { margin: 48px 0 0; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.section-photo img { width: 100%; height: auto; display: block; }

.playbook-faq { padding-block: clamp(64px, 10vw, 112px); }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

.playbook-related, .playbook-cta { padding-block: clamp(56px, 8vw, 96px); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.related-list a { color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 180ms ease, color 180ms ease; }
.related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

@media (max-width: 860px) {
  .layers-grid, .operating-grid { grid-template-columns: 1fr; }
}
</style>
