---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "The Poor Four — Buildwise Media";
const description = "The Poor Four are the four operating gaps that cap service-business growth: Invisible Market, Leaky Revenue, Owner Bottleneck, and Reactive Growth.";

const problems = [
  {
    n: '01',
    name: 'Invisible Market',
    href: '/problem/invisible-market',
    body: "Buyers search, ask AI tools, check maps, and ask peers. Your business is not the answer they keep seeing.",
  },
  {
    n: '02',
    name: 'Leaky Revenue',
    href: '/problem/leaky-revenue',
    body: "The lead arrives, then the follow-through breaks: slow response, no review request, no quote cadence, no reactivation.",
  },
  {
    n: '03',
    name: 'Owner Bottleneck',
    href: '/problem/owner-bottleneck',
    body: "The business can grow only as fast as the owner's attention. Step away and the pipeline gets quiet.",
  },
  {
    n: '04',
    name: 'Reactive Growth',
    href: '/problem/reactive-growth',
    body: "The score shows up late. Decisions are made from tiny data, and course corrections happen after the quarter is already expensive.",
  },
];

const faqs = [
  {
    q: 'What are the Poor Four?',
    a: 'The Poor Four are Invisible Market, Leaky Revenue, Owner Bottleneck, and Reactive Growth. They are operating gaps, not isolated marketing tasks.',
  },
  {
    q: 'Why did the names change?',
    a: 'The evolved names match the full Ascend system. They cover visibility, conversion, follow-up, owner load, and measurement instead of reducing the issue to lead volume alone.',
  },
  {
    q: 'Can one gap be fixed alone?',
    a: 'Sometimes, but it rarely holds. A visibility fix still leaks if follow-up breaks. A reporting fix still stalls if the owner remains the operating layer. Ascend closes the gaps as a connected system.',
  },
];

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/poor-four#term',
  name: 'The Poor Four',
  description,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/',
    name: 'Buildwise Media Playbook',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/poor-four#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'The Poor Four', item: 'https://buildwisemedia.com/playbook/poor-four' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container">
      <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a></p>
      <h1 class="h-hero">The <em>Poor Four.</em></h1>
      <p class="lede">
        Most service businesses do not have one lead problem. They have four operating gaps compounding against each other. Name the gaps and the fix becomes much less abstract.
      </p>
    </div>
  </section>

  <section class="problem-section elev">
    <div class="container">
      <p class="section-tag">The diagnostic</p>
      <h2 class="h-section">Four gaps. One operating drain.</h2>
      <div class="problem-grid">
        {problems.map((problem) => (
          <a class="problem-card" href={problem.href}>
            <span class="problem-num mono">{problem.n}</span>
            <h3>{problem.name}</h3>
            <p>{problem.body}</p>
            <span class="problem-link mono">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">How Buildwise uses it</p>
      <h2 class="h-section">The diagnostic becomes the install order.</h2>
      <p class="prose">
        Buildwise runs the Poor Four before recommending Ascend. If visibility is the gap, the first layer moves search, citations, AI-answer readiness, and local proof. If revenue is leaking, speed-to-lead and follow-up move first. If the owner is the bottleneck, the operating cadence and routing layer move first.
      </p>
      <p class="prose">
        The point is not to sell every owner the same story. The point is to identify which operating constraint makes the rest of the marketing feel broken.
      </p>
    </div>
  </section>

  <section class="playbook-faq elev">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="playbook-cta">
    <div class="container">
      <h2 class="h-closer">Want your Revenue Leak Map?</h2>
      <p class="lede">The fit diagnostic names the active Poor Four gaps before the call.</p>
      <p class="cta-row">
        <a class="cta" href="/book" data-cta-source="playbook-poor-four-cta">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/playbook">Back to Playbook</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(96px, 13vw, 168px) clamp(64px, 8vw, 100px); }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); }
.back-link:hover { color: var(--y2); }
.h-hero em { color: var(--y2); font-style: normal; }
.problem-section,
.playbook-section,
.playbook-faq,
.playbook-cta { padding-block: var(--section-y); }
.problem-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  margin-top: 42px;
}
.problem-card {
  background: var(--bg-card);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.problem-card:hover { color: var(--ink); background: var(--bg-elev); }
.problem-num,
.problem-link {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--y2);
}
.problem-card h3 {
  font-size: clamp(22px, 2.4vw, 32px);
  line-height: 1.1;
}
.problem-card p {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
  flex: 1;
}
.playbook-section .prose {
  font-size: 18px;
  line-height: 1.7;
  color: var(--ink-dim);
  max-width: 760px;
}
.playbook-section .prose + .prose { margin-top: 18px; }
.faq-list { display: grid; gap: 14px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-q { list-style: none; cursor: pointer; font-size: 18px; color: var(--ink); }
.faq-q::-webkit-details-marker { display: none; }
.faq-a { margin-top: 12px; color: var(--ink-dim); }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
@media (max-width: 980px) {
  .problem-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 560px) {
  .problem-grid { grid-template-columns: 1fr; }
}
</style>
