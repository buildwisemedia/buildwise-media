---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Restoration Lead Generation, Run For You | Buildwise";
const description = "Water and fire restoration runs on speed. See the owned-system way to get found fast and book better restoration jobs.";

const leakTypes = [
  {
    n: '01',
    name: 'Search leak',
    body: 'A homeowner or property manager needs help now, but your company is not easy to find for the service and town.',
  },
  {
    n: '02',
    name: 'Speed leak',
    body: 'The job is real, but the first clear reply comes too late. In restoration, late often means lost.',
  },
  {
    n: '03',
    name: 'Trust leak',
    body: 'The buyer cannot see proof that you handle water, fire, mold, and storm jobs with care.',
  },
  {
    n: '04',
    name: 'Source leak',
    body: 'The phone rings, but you cannot see which pages, towns, or referrals turned into booked work.',
  },
];

const systemCovers = [
  'Local service pages for the restoration jobs and towns that matter most.',
  'Fast routing for calls, forms, and booking requests, so urgent jobs do not sit.',
  'Proof capture from finished jobs, reviews, photos, and clear service notes.',
  'Plain reporting from lead to booked job, so you can see what worked.',
  'A weekly operating rhythm run by the Buildwise team, with a real person reviewing what matters each week.',
];

const faqs = [
  {
    q: 'What is restoration lead generation?',
    a: 'Restoration lead generation is the work of helping water, fire, mold, and storm damage buyers find you, trust you, and book a job. The best version is a run-for-you system, not another task list for the owner.',
  },
  {
    q: 'How can a restoration company get more jobs without hiring another agency?',
    a: 'Use an owned system that connects local pages, fast follow-up, proof, reviews, and reporting. Buildwise is the alternative to another agency or lead vendor because the company owns the system and the data.',
  },
  {
    q: 'Why does speed matter so much for water and fire restoration leads?',
    a: 'The buyer has damage now. If the first reply is slow or unclear, they keep calling. A fast lead path helps protect good jobs before they move to someone else.',
  },
  {
    q: 'What should a restoration owner measure after 30 days?',
    a: 'Measure calls, forms, booked jobs, response speed, review movement, source quality, and the first leaks. The goal is a clearer system, not a bigger pile of reports.',
  },
  {
    q: 'Does this replace referral work?',
    a: 'No. It supports it. Referral relationships still matter, but an owned system helps you get found outside the referral circle and proves which channels are producing better jobs.',
  },
];

const definedTerm = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': 'https://buildwisemedia.com/playbook/restoration-lead-generation#term',
  name: 'restoration lead generation',
  description: 'A run-for-you way for restoration companies to get found, respond fast, build trust, and book better jobs through owned systems.',
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://buildwisemedia.com/playbook/#terms',
    name: 'Buildwise Playbook',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/playbook/restoration-lead-generation#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://buildwisemedia.com/playbook/restoration-lead-generation#article',
  headline: title,
  description,
  author: { '@id': 'https://buildwisemedia.com/#org' },
  publisher: { '@id': 'https://buildwisemedia.com/#org' },
  mainEntityOfPage: 'https://buildwisemedia.com/playbook/restoration-lead-generation',
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Playbook', item: 'https://buildwisemedia.com/playbook/' },
    { '@type': 'ListItem', position: 3, name: 'Restoration Lead Generation', item: 'https://buildwisemedia.com/playbook/restoration-lead-generation' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={[definedTerm, articleSchema, breadcrumb, faqSchema]}>

  <section class="playbook-hero">
    <div class="container playbook-hero-grid">
      <div>
        <p class="eyebrow"><a href="/playbook" class="back-link">← Playbook</a> · Restoration lead generation</p>
        <h1 class="h-hero">Restoration lead generation, built on a system your company owns</h1>
        <p class="lede">
          Water, fire, mold, and storm jobs do not wait. When someone needs help, they search fast, compare fast, and book the company that looks ready. Restoration lead generation has to match that pace without turning you into the full-time follow-up desk.
        </p>
        <p class="cta-row">
          <a class="cta-primary" href="/book" data-cta-source="restoration-lead-gen-hero-primary">See If We're a Fit <span class="cta-arrow">→</span></a>
          <a class="cta-ghost" href="/system" data-cta-source="restoration-lead-gen-hero-secondary">See the System</a>
        </p>
      </div>
      <aside class="proof-panel ops-panel" aria-label="Restoration lead path">
        <p class="panel-label mono">Restoration lead path</p>
        <strong>4</strong>
        <p>Search, speed, trust, and source clarity have to work together before a damage call becomes booked work.</p>
      </aside>
    </div>
    <div class="container">
      <figure class="hero-photo">
        <!-- @r020:F1 emotion: urgent operations image mirrors the restoration owner managing damage calls before the day settles -->
        <img src="/images/bwm-urgency-cinematic-v1.webp" alt="A focused operations desk with cool light, phones, and job notes ready for urgent response." width="1920" height="1080" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Owner bottleneck</p>
        <h2 class="h-section">Most restoration marketing advice moves the work back to you.</h2>
        <p class="prose">
          The usual advice says to publish more pages, ask for more reviews, chase more referral partners, and answer faster. Each step can help, but the owner often becomes the person who has to remember, route, check, and fix it all.
        </p>
        <p class="prose">
          That breaks down fast in restoration. You may be handling a wet basement, a smoke-damage call, an insurance question, and a crew issue in the same hour. If lead work depends on your spare time, the system will always run behind the damage.
        </p>
        <p class="prose">
          Buildwise installs and runs the path inside <a href="/industries/restoration">restoration companies</a> so the work does not sit on the owner. The company keeps the system, the data, and the learning, while the Buildwise team handles the weekly operating rhythm.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F2 proof: system architecture image makes the run-for-you operating layer visible before the owner trusts the claim -->
        <img src="/images/bwm-system-architecture-atmospheric-v1.webp" alt="A dark operations workspace showing connected system layers and proof signals." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container">
      <p class="section-tag">Where jobs leak</p>
      <h2 class="h-section">Four leaks can cost a restoration company the job.</h2>
      <div class="leak-grid">
        {leakTypes.map((leak) => (
          <article class="leak-card">
            <p class="leak-num mono">{leak.n}</p>
            <h3>{leak.name}</h3>
            <p>{leak.body}</p>
          </article>
        ))}
      </div>
      <p class="prose">
        A restoration lead system needs all four pieces. Being found creates the chance. Speed protects the job. Trust helps the buyer choose you. Source clarity shows which work brought real booked jobs, not just noise.
      </p>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Run-for-you system</p>
        <h2 class="h-section">What the system covers instead of another pile of tactics.</h2>
        <p class="prose">
          A lead vendor sells you contact names. A traditional agency often sells activity. A run-for-you system connects the full path from search to booked job, then keeps improving it from the numbers you can understand.
        </p>
        <ul class="system-list" role="list">
          {systemCovers.map((item) => <li>{item}</li>)}
        </ul>
        <p class="prose">
          That is why this fits as a <a href="/playbook/contractor-lead-generation-company-alternative">contractor lead generation company alternative</a> and a <a href="/playbook/lead-generation-company-alternative">lead generation company alternative</a>. The goal is not more vendor dependency. The goal is an owned system that books better work and gets clearer each week.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F2 proof: results editorial shows the owner-view reporting that replaces vague activity claims -->
        <img src="/images/bwm-results-editorial-v1.webp" alt="An operator reviewing performance signals on a dashboard in cool light." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Speed and trust</p>
        <h2 class="h-section">Restoration buyers choose the company that looks ready.</h2>
        <p class="prose">
          A homeowner with water in the basement does not want a slow form reply. A property manager with smoke damage does not want a vague promise. They want clear service, fast next steps, and proof that your team has handled this kind of job before.
        </p>
        <p class="prose">
          The system helps your best proof show up where buyers are checking. Service pages answer the simple questions. Reviews and job proof build trust. The follow-up path makes the next step clear. You are not positioned as the cheapest option. You are positioned as the company that is ready.
        </p>
        <p class="prose">
          This is the same reason many owners look for an <a href="/playbook/agency-alternative">agency alternative</a>. They do not need more meetings about marketing work. They need the work to run, the proof to grow, and the call path to stay tight.
        </p>
      </div>
      <figure class="section-photo">
        <!-- @r020:F1 emotion: proof still life turns trust into a visible restoration decision moment instead of abstract copy -->
        <img src="/images/bwm-proof-still-life-v1.webp" alt="A dark proof workspace with job records, notes, and clear visual evidence under focused light." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="playbook-section elev">
    <div class="container">
      <p class="section-tag">30-day baseline</p>
      <h2 class="h-section">The first month should show the leaks clearly.</h2>
      <p class="prose">
        The first 30 days should not bury you in a thick report. It should show what happened: where calls came from, how fast they were answered, which pages helped, which jobs booked, and where good demand still leaked out.
      </p>
      <p class="prose">
        Once that baseline is clear, the next moves are easier. The team can tighten the page, improve the proof, fix slow follow-up, or build around the towns and services that are already showing real signal. You get fewer guesses and a system that gets clearer with every job.
      </p>
    </div>
  </section>

  <section class="playbook-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see where restoration leads are leaking?</h2>
      <p class="lede">The free Revenue Leak Map shows the first gap in your visibility, speed, proof, or source tracking.</p>
      <!-- approved-proof: 008 de-id concrete contractor, organic-playbook use, internal-signoff 2026-06-18 -->
      <blockquote class="pull-quote"><p>A concrete contractor we run went from almost no inbound calls to about 150 leads since launch.</p></blockquote>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="restoration-lead-gen-final-primary">See If We're a Fit <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/system" data-cta-source="restoration-lead-gen-final-secondary">See the System</a>
      </p>
    </div>
  </section>

  <section class="playbook-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.playbook-hero { padding-block: clamp(80px, 12vw, 144px); }
.playbook-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 360px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.playbook-hero .lede { margin-top: 24px; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.proof-panel { padding: 28px; }
.proof-panel strong { display: block; margin-top: 18px; font-size: clamp(54px, 8vw, 92px); line-height: 0.9; color: var(--y2); font-weight: 600; }
.proof-panel p:last-child { margin-top: 18px; color: var(--ink-dim); line-height: 1.6; }

.hero-photo { margin-top: 56px; max-width: 1120px; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.hero-photo img { width: 100%; height: auto; display: block; }

.playbook-section, .playbook-related, .playbook-cta, .playbook-faq { padding-block: clamp(56px, 8vw, 96px); }
.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; margin-top: 24px; }
.prose + .prose { margin-top: 16px; }
.prose a, .related-list a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.prose a:hover, .related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }

.leak-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-block: 40px; }
.leak-card { border: 1px solid var(--rule); background: rgba(255,255,255,0.025); padding: 24px; border-radius: 4px; }
.leak-num { color: var(--y2); font-size: 10px; letter-spacing: 0.18em; }
.leak-card h3 { margin-top: 18px; font-size: 22px; line-height: 1.15; color: var(--ink); }
.leak-card p:last-child { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }

.article-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: start; }
.section-photo { margin: 0; border-radius: 4px; overflow: hidden; border: 1px solid var(--rule); }
.section-photo img { width: 100%; height: auto; display: block; }
.system-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: 28px; max-width: 760px; }
.system-list li { color: var(--ink-dim); line-height: 1.55; padding-left: 20px; position: relative; }
.system-list li::before { content: ""; position: absolute; left: 0; top: 0.72em; width: 7px; height: 7px; border-radius: 50%; background: var(--y2); }

.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.pull-quote { margin: 32px 0 0; max-width: 760px; border-left: 2px solid var(--y2); padding-left: 24px; }
.pull-quote p { color: var(--ink); font-size: clamp(22px, 3vw, 34px); line-height: 1.25; font-weight: 500; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
.playbook-faq { padding-top: 0; }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

@media (max-width: 900px) {
  .playbook-hero-grid, .article-grid { grid-template-columns: 1fr; }
  .leak-grid { grid-template-columns: 1fr; }
}
</style>
