---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Contact — Buildwise Media";
const description = "Send a note to the Buildwise team about your service business and the growth work that needs a clearer system.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://buildwisemedia.com/contact' },
  ],
};

const contactPage = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': 'https://buildwisemedia.com/contact#contactpage',
  name: title,
  description,
  url: 'https://buildwisemedia.com/contact',
  about: { '@id': 'https://buildwisemedia.com/#org' },
};
---
<BaseLayout title={title} description={description} jsonLd={[contactPage, breadcrumb]}>
  <section class="contact-page" aria-labelledby="contact-title">
    <div class="container contact-grid">
      <div class="contact-copy">
        <p class="eyebrow">Contact</p>
        <h1 id="contact-title" class="h-hero">Tell us where the work is stuck.</h1>
        <p class="hero-sub">
          If you run an owner-led service business and growth keeps landing back on your desk, send the team the short version. We will route it to the right next step.
        </p>
      </div>

      <form id="contact-form" class="contact-form" novalidate>
        <div class="contact-hp" aria-hidden="true">
          <label for="contact-business-url">Business URL</label>
          <input id="contact-business-url" name="business_url" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="contact-field">
          <label class="mono" for="contact-name">Name</label>
          <input id="contact-name" name="name" type="text" required autocomplete="name" />
        </div>

        <div class="contact-field">
          <label class="mono" for="contact-email">Email</label>
          <input id="contact-email" name="email" type="email" required autocomplete="email" inputmode="email" />
        </div>

        <div class="contact-field">
          <label class="mono" for="contact-message">Message</label>
          <textarea id="contact-message" name="message" required rows="6"></textarea>
        </div>

        <button type="submit" class="cta contact-submit">
          <span data-submit-label>Send message</span>
          <span data-submit-loading hidden>Sending...</span>
        </button>

        <p id="contact-status" class="contact-status mono" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('contact-status');
    const submit = form?.querySelector('.contact-submit');
    const submitLabel = form?.querySelector('[data-submit-label]');
    const submitLoading = form?.querySelector('[data-submit-loading]');

    if (!form || !status || !submit || !submitLabel || !submitLoading) return;

    function setStatus(message, type) {
      status.textContent = message;
      status.dataset.state = type || '';
    }

    function setSubmitting(isSubmitting) {
      submit.disabled = isSubmitting;
      submitLabel.hidden = isSubmitting;
      submitLoading.hidden = !isSubmitting;
    }

    function value(name) {
      return String(form.elements[name]?.value || '').trim();
    }

    form.addEventListener('submit', async function (event) {
      event.preventDefault();
      setStatus('', '');

      if (value('business_url')) {
        form.reset();
        return;
      }

      const payload = {
        name: value('name'),
        email: value('email'),
        message: value('message'),
        intent: 'contact',
      };

      if (!payload.name || !payload.email || !payload.message || !form.reportValidity()) {
        setStatus('Add your name, email, and message.', 'error');
        return;
      }

      setSubmitting(true);
      try {
        const response = await fetch('https://bwm-form-handler.robert-ba0.workers.dev/buildwisemedia/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!response.ok) throw new Error(`Server ${response.status}`);
        form.reset();
        setStatus('Message received. The team will follow up with the next step.', 'success');
      } catch (_) {
        setStatus('Message did not send. Try again or email hello@buildwisemedia.com.', 'error');
      } finally {
        setSubmitting(false);
      }
    });
  })();
</script>

<style>
.contact-page {
  padding-top: clamp(132px, 14vw, 184px);
  padding-bottom: var(--section-y);
}

.contact-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.72fr);
  gap: clamp(48px, 7vw, 96px);
  align-items: start;
}

.contact-copy {
  display: flex;
  flex-direction: column;
  gap: 24px;
  max-width: 760px;
}

.contact-copy .h-hero {
  max-width: 10ch;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding: clamp(24px, 4vw, 38px);
  border: 1px solid var(--rule);
  background: var(--bg-card);
}

.contact-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.contact-field label {
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--ink-dim);
}

.contact-field input,
.contact-field textarea {
  width: 100%;
  border: 1px solid var(--rule);
  background: rgba(5, 5, 7, 0.78);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.45;
  padding: 14px;
}

.contact-field input {
  min-height: 52px;
}

.contact-field textarea {
  min-height: 156px;
  resize: vertical;
}

.contact-field input:hover,
.contact-field textarea:hover {
  border-color: var(--rule-bright);
}

.contact-field input:focus-visible,
.contact-field textarea:focus-visible,
.contact-submit:focus-visible {
  outline: 2px solid var(--y2);
  outline-offset: 3px;
}

.contact-submit {
  width: fit-content;
  justify-content: center;
}

.contact-submit:disabled {
  opacity: 0.68;
  cursor: wait;
}

.contact-status {
  min-height: 18px;
  font-size: 10px;
  letter-spacing: 0.14em;
  color: var(--ink-faint);
}

.contact-status[data-state="success"] {
  color: var(--signal-green);
}

.contact-status[data-state="error"] {
  color: var(--signal-orange);
}

.contact-hp {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0 0 0 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}

@media (max-width: 880px) {
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .contact-form {
    padding: 24px;
  }

  .contact-submit {
    width: 100%;
  }
}
</style>
