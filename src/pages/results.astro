---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Results — Buildwise Media";
const description = "Verified outcomes from the Ascend system. Baseline-first attribution. Performance commitment, 5× ROI floor. Receipts every Monday.";

const proofLedger = [
  { label: 'Measured', value: 'source truth', body: 'Numbers tied to captured baseline, CRM events, call tracking, or analytics records.', tone: 'green' },
  { label: 'Attributed', value: 'path visible', body: 'Lead source, landing page, first touch, last touch, and booked-work handoff are stitched.', tone: 'cyan' },
  { label: 'Modeled', value: 'confidence stated', body: 'When proof is directional, it carries a confidence label instead of pretending to be absolute.', tone: 'yellow' },
  { label: 'Benchmark', value: 'risk priced', body: 'External benchmarks are used only to frame risk, not to manufacture a client result.', tone: 'orange' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Results', item: 'https://buildwisemedia.com/results' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does the Performance Commitment and 5× ROI floor work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Our Performance Commitment is written into the MSA as a locked contractual clause. We back the install with a 5× attributable ROI floor inside 24 months, measured against the baseline captured on Day 0. If the system is at 4× at Month 24, we keep working on our own dime until it hits the floor. It\'s a run-for-you operational floor, not an aspirational marketing promise.'
      }
    },
    {
      '@type': 'Question',
      name: 'How fast is the system operational?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Inside 30 days the system is live, conversion paths are instrumented, operating reports are active, and first qualified signals are visible. We map, install, and deploy in parallel so you are operational, not theoretical, by day 30.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I speak with your references, and why are client names anonymous?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We protect the operational privacy of our clients to prevent competitors from reverse-engineering their search dominance and ad funnels. While public case studies are anonymized, we share verified underlying data, attribution dashboards, and connect you with active client references during the discovery process once we verify mutual fit.'
      }
    }
  ]
};
---
<BaseLayout title={title} description={description} jsonLd={[breadcrumb, faqSchema]}>

  <!-- SECTION 1: HERO & SCOREBOARD -->
  <section class="results-hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="eyebrow">Outcomes</p>
        <h1 class="h-hero">
          Proof should feel like a ledger, not a testimonial wall.
        </h1>
        <p class="hero-sub" style="max-width: 600px;">
          Every outcome is measured against the baseline captured on Day 0. The persuasive thing is not a big claim. The persuasive thing is being able to see what moved, why it moved, and how confident the system is.
        </p>
      </div>

      <div class="scoreboard-panel">
        <p class="kpi-label mono">Aggregated Receipts</p>
        <div class="scoreboard-grid">
          <div class="score-card">
            <span class="score-num font-condensed">$10.4M+</span>
            <span class="score-label mono">Attributable Pipeline</span>
          </div>
          <div class="score-card">
            <span class="score-num font-condensed">33.2×</span>
            <span class="score-label mono">Average Client Return</span>
          </div>
          <div class="score-card">
            <span class="score-num font-condensed">34</span>
            <span class="score-label mono">Active Operational Channels</span>
          </div>
          <div class="score-card">
            <span class="score-num font-condensed">3.2×</span>
            <span class="score-label mono">Lead Increase (Average)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="proof-ledger-section" aria-labelledby="proof-ledger-title">
    <div class="container proof-ledger-grid">
      <header>
        <p class="section-tag">Proof ledger</p>
        <h2 id="proof-ledger-title" class="h-section">The labels matter because owners have been trained to distrust marketing math.</h2>
        <p class="lede">Ascend separates hard evidence from directional signal. That is how the weekly report becomes useful instead of performative.</p>
      </header>
      <div class="ledger-grid">
        {proofLedger.map((item) => (
          <article class={`ledger-card tone-${item.tone}`}>
            <p class="ops-kicker">{item.label}</p>
            <strong>{item.value}</strong>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 2: ANCHOR CASE STUDY & TIMELINE -->
  <section class="case-study-section elev">
    <div class="container study-grid">

      <!-- Left Column: Timeline -->
      <div class="timeline-col">
        <p class="section-tag">Case Timeline</p>
        <h2 class="h-section">$300K to <em>$10M+</em></h2>
        <p class="study-sub">The operational progression of a specialty service business scaling on the Ascend system.</p>

        <div class="timeline">
          <div class="timeline-line"></div>

          <div class="timeline-item">
            <div class="timeline-node"></div>
            <div class="timeline-content">
              <span class="timeline-meta mono">Month 01 · System Install</span>
              <h3 class="timeline-title">Infrastructure Deployment</h3>
              <p class="timeline-body">Baselines captured. Web infrastructure deployed. Acquisition channels connected. Attribution connector audit healthy.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-node"></div>
            <div class="timeline-content">
              <span class="timeline-meta mono">Month 06 · Optimization</span>
              <h3 class="timeline-title">Multi-Channel Expansion</h3>
              <p class="timeline-body">Paid search integrated. Lead qualification forms tested. System confidence score hits 92%. Monthly run-rate climbs to $350K.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-node"></div>
            <div class="timeline-content">
              <span class="timeline-meta mono">Month 18 · Scale & Automation</span>
              <h3 class="timeline-title">Operations Integration</h3>
              <p class="timeline-body">Custom intake workflows connected directly to CRM. Automated SMS speed-to-lead responders and reputation request loops activated. Annualized pipeline reaches $5.2M.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-node"></div>
            <div class="timeline-content">
              <span class="timeline-meta mono">Month 24 · Dominance</span>
              <h3 class="timeline-title">The Payoff</h3>
              <p class="timeline-body">Attributable client return reaches 33.2× against baseline. Service capacity fully booked, total revenue run-rate scales past $10M without adding marketing overhead.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Evidence & Quote -->
      <div class="evidence-col">
        <figure class="study-image">
          <!-- @r020:F2 proof: premium photo of operator analyzing dashboard telemetry on site -->
          <img src="/images/bwm-results-editorial-v1.webp" alt="Service business operator reviewing telemetry on dashboard, warm lights reflecting off industrial desk surfaces." width="800" height="450" loading="lazy" decoding="async" />
        </figure>

        <div class="quote-card">
          <blockquote class="pull">
            "For the first time, our marketing budget feels like a P&L operations line, not a black hole. We see what spent, what closed, and what's next. The system is just infrastructure now."
          </blockquote>
          <cite class="quote-cite">
            <span class="cite-author">Founder & Operator</span>
            <span class="cite-meta mono">Specialty Service Brand · Southeast US</span>
          </cite>
        </div>

        <div class="badges-row">
          <span class="badge mono">33.2× ROI</span>
          <span class="badge mono">Month-to-Month</span>
          <span class="badge mono">Data Sovereignty</span>
        </div>

        <div class="comparison-strip">
          <p class="kpi-label mono">Baseline Shift</p>
          <div class="comparison-grid">
            <div class="comp-box">
              <span class="comp-label mono">Before</span>
              <p class="comp-text">No attribution, 5 disconnected vendors, manual intake, template site with zero CRM flows.</p>
            </div>
            <div class="comp-box active">
              <span class="comp-label mono">After (Ascend)</span>
              <p class="comp-text">100% baseline-attributable mix, 1 system running 24/7, automated quoting flows, optimized static app.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- SECTION 3: FAQ ACCORDION -->
  <section class="results-faq">
    <div class="container faq-grid">
      <div class="faq-head">
        <p class="section-tag">Performance Framework</p>
        <h2 class="h-section">Real systems.<br/><em>Real</em> answers.</h2>
        <p class="hero-sub" style="max-width: 400px;">How we structure agreements, timelines, and confidentiality to protect operations.</p>
      </div>

      <div class="faq-list-col">
        <ul class="faq-list" role="list">
          <li class="faq-item">
            <details open>
              <summary>
                <span class="faq-q">How does the Performance Commitment and 5× ROI floor work?</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <div class="faq-a">
                <p>Our Performance Commitment is written into the MSA as a locked contractual clause. We back the install with a 5× attributable ROI floor inside 24 months, measured against the baseline captured on Day 0. If the system is at 4× at Month 24, we keep working on our own dime until it hits the floor. It's a run-for-you operational floor, not an aspirational marketing promise.</p>
              </div>
            </details>
          </li>
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-q">How fast is the system operational?</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <div class="faq-a">
                <p>Inside 30 days the system is live, conversion paths are instrumented, operating reports are active, and first qualified signals are visible. We map, install, and deploy in parallel so you are operational, not theoretical, by day 30.</p>
              </div>
            </details>
          </li>
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-q">Can I speak with your references, and why are client names anonymous?</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <div class="faq-a">
                <p>We protect the operational privacy of our clients to prevent competitors from reverse-engineering their search dominance and ad funnels. While public case studies are anonymized, we share verified underlying data, attribution dashboards, and connect you with active client references during the discovery process once we verify mutual fit.</p>
              </div>
            </details>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SECTION 4: FINAL CTA -->
  <section class="final-cta elev">
    <div class="container cta-container">
      <div class="cta-text-side">
        <h2 class="h-closer">See what the system can <em>do</em> for yours.</h2>
        <p class="lede" style="margin-top: 16px;">
          Bring your current numbers — monthly spend, lead volume, close rate. Fifteen minutes on a discovery call tells us whether your shop matches our operational framework.
        </p>
        <div class="badges-row text-side-badges" style="margin-top: 24px;">
          <span class="badge badge-subtle mono">Month-to-Month Contract</span>
          <span class="badge badge-subtle mono">Data Sovereignty Guaranteed</span>
        </div>
      </div>
      <div class="cta-button-side">
        <a href="/book" class="cta" data-cta-source="results-final">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* --- General Page Grid & Hero --- */
.results-hero {
  padding-top: clamp(140px, 14vw, 180px);
  padding-bottom: clamp(60px, 8vw, 100px);
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: clamp(40px, 5vw, 80px);
  align-items: center;
}
.hero-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* --- Scoreboard Panel --- */
.scoreboard-panel {
  background:
    linear-gradient(135deg, rgba(56,216,255,0.045), transparent 42%),
    var(--bg-card);
  border: 1px solid var(--rule-bright);
  padding: clamp(24px, 4vw, 40px);
  border-radius: 6px;
}
.scoreboard-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(20px, 3vw, 36px);
  margin-top: 24px;
}
.score-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-top: 1px solid var(--rule-bright);
  padding-top: 20px;
}
.score-num {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(36px, 4vw, 56px);
  line-height: 1;
  color: var(--y2);
  letter-spacing: -0.02em;
}
.score-label {
  font-size: 11px;
  letter-spacing: 0.15em;
  color: var(--ink-dim);
  text-transform: uppercase;
  line-height: 1.4;
}

/* --- Proof Ledger --- */
.proof-ledger-section {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
}
.proof-ledger-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}
.proof-ledger-grid header {
  position: sticky;
  top: 104px;
}
.proof-ledger-grid .lede { margin-top: 22px; }
.ledger-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.ledger-card {
  background: var(--bg-card);
  border-top: 3px solid currentColor;
  padding: clamp(24px, 3vw, 34px);
}
.ledger-card strong {
  display: block;
  margin-block: 12px;
  font-size: clamp(28px, 3.2vw, 46px);
  line-height: 1;
  letter-spacing: -0.045em;
  color: var(--ink);
}
.ledger-card p:last-child {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

/* --- Case Study & Timeline Grid --- */
.case-study-section {
  padding-block: var(--section-y);
}
.study-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: clamp(48px, 6vw, 96px);
  align-items: start;
}
.study-sub {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 18px;
  line-height: 1.6;
  color: var(--ink-dim);
  margin-top: 16px;
  margin-bottom: 40px;
  max-width: 520px;
}

/* Timeline Components */
.timeline {
  position: relative;
  padding-left: 32px;
}
.timeline-line {
  position: absolute;
  left: 6px;
  top: 10px;
  bottom: 10px;
  width: 1px;
  background: var(--rule-bright);
}
.timeline-item {
  position: relative;
  margin-bottom: 40px;
}
.timeline-item:last-child {
  margin-bottom: 0;
}
.timeline-node {
  position: absolute;
  left: -32px;
  top: 8px;
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: var(--bg);
  border: 2px solid var(--y2);
}
.timeline-meta {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--ink-faint);
  text-transform: uppercase;
}
.timeline-title {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: 20px;
  color: var(--ink);
  margin-block: 4px 8px;
  text-transform: uppercase;
}
.timeline-body {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 15px;
  line-height: 1.6;
  color: var(--ink-dim);
}

/* Evidence / Pull Quote Column */
.evidence-col {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.study-image {
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--rule);
  aspect-ratio: 16 / 9;
}
.study-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.quote-card {
  background: var(--bg-card);
  border: 1px solid var(--rule);
  padding: 32px;
  border-radius: 6px;
}
.pull {
  font-family: var(--sans);
  font-weight: 400;
  font-size: 18px;
  line-height: 1.5;
  color: var(--ink);
  border-left: 2px solid var(--y2);
  padding-left: 20px;
  margin-bottom: 20px;
}
.quote-cite {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-left: 22px;
}
.cite-author {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 15px;
  color: var(--ink);
}
.cite-meta {
  font-size: 11px;
  letter-spacing: 0.1em;
  color: var(--ink-dim);
}

.badges-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.badge {
  border: 1px solid var(--y2);
  color: var(--y2);
  font-size: 10px;
  letter-spacing: 0.15em;
  padding: 6px 12px;
  text-transform: uppercase;
  background: rgba(240, 255, 0, 0.03);
}
.badge-subtle {
  border: 1px solid var(--rule-bright);
  color: var(--ink-dim);
  background: none;
}

/* Comparison Strip */
.comparison-strip {
  border-top: 1px solid var(--rule);
  padding-top: 24px;
}
.comparison-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 16px;
}
.comp-box {
  padding: 16px;
  border: 1px solid var(--rule);
  background: rgba(255, 255, 255, 0.01);
}
.comp-box.active {
  border-color: var(--rule-bright);
  background: rgba(240, 255, 0, 0.01);
}
.comp-label {
  font-size: 9px;
  letter-spacing: 0.2em;
  color: var(--ink-faint);
  text-transform: uppercase;
  margin-bottom: 8px;
  display: block;
}
.comp-box.active .comp-label {
  color: var(--y2);
}
.comp-text {
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-dim);
}

/* --- FAQ Accordion Grid --- */
.results-faq {
  padding-block: var(--section-y);
}
.faq-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
  gap: clamp(48px, 6vw, 96px);
  align-items: start;
}
.faq-head {
  position: sticky;
  top: 100px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.faq-list-col {
  display: flex;
  flex-direction: column;
}
.faq-list {
  list-style: none;
}
.faq-item {
  border-top: 1px solid var(--rule);
}
.faq-item:last-child {
  border-bottom: 1px solid var(--rule);
}
.faq-item details summary {
  list-style: none;
  cursor: pointer;
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
}
.faq-item details summary::-webkit-details-marker {
  display: none;
}
.faq-q {
  font-family: var(--sans);
  font-weight: 700;
  font-size: clamp(18px, 2vw, 24px);
  letter-spacing: -0.015em;
  line-height: 1.35;
  color: var(--ink);
}
.faq-toggle {
  font-family: var(--mono);
  font-size: 24px;
  color: var(--y2);
  flex: none;
  width: 32px;
  text-align: center;
  line-height: 1;
  transition: transform 220ms ease;
}
.faq-item details[open] .faq-toggle {
  transform: rotate(45deg);
}
.faq-a {
  padding: 0 0 28px 0;
}
.faq-a p {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.65;
  color: var(--ink-dim);
}

/* --- Final CTA --- */
.final-cta {
  padding-block: var(--section-y);
}
.cta-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 48px;
  flex-wrap: wrap;
}
.cta-text-side {
  flex: 1;
  min-width: 300px;
}
.cta-button-side {
  flex: none;
}

/* --- Responsive Adjustments --- */
@media (max-width: 880px) {
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .proof-ledger-grid {
    grid-template-columns: 1fr;
  }
  .proof-ledger-grid header {
    position: static;
  }
  .study-grid {
    grid-template-columns: 1fr;
    gap: 56px;
  }
  .faq-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .faq-head {
    position: static;
  }
  .cta-container {
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }
}

@media (max-width: 560px) {
  .results-hero {
    padding-top: 104px;
  }

  .results-hero .h-hero {
    font-size: 38px;
    line-height: 1.03;
    letter-spacing: 0;
  }

  .results-hero .hero-sub {
    font-size: 17px;
    line-height: 1.5;
  }

  .scoreboard-grid,
  .ledger-grid,
  .comparison-grid {
    grid-template-columns: 1fr;
  }
}
</style>
