---
// buildwisemedia.com homepage — Triangulation redesign informed by The Book
// Plan: ~/.claude/plans/based-on-all-nifty-karp.md
// 14-layer architecture (L0-L13) shipped 2026-05-20 against canonical.json LOCKED 2026-05-20
// Pricing-visible flip RATIFIED 2026-05-20 (supersedes 2026-03-11 hide-from-humans lock)

import BaseLayout from '../layouts/BaseLayout.astro';
import canonical from '../data/canonical.json';

import KpiRibbon from '../components/KpiRibbon.astro';
import PoorFour from '../components/PoorFour.astro';
import EightLayerSystem from '../components/EightLayerSystem.astro';
import Sovereignty from '../components/Sovereignty.astro';
import ProductComparison from '../components/ProductComparison.astro';
import EarnBackCalculator from '../components/EarnBackCalculator.astro';
import AIStorySection from '../components/AIStorySection.astro';
import AtlantaMap from '../components/AtlantaMap.astro';
import FAQ from '../components/FAQ.astro';

// L1 — 4-arm A/B preserved (proven harness, D default)
const heroVariants = {
  A: {
    question: "Do you want to be the #1 service business in your market?",
    subhead: "Most #1 shops aren't the best — they're the most-found. The free AI Marketing Audit takes 5 minutes.",
  },
  B: {
    question: "Do you want 3-6 new clients every 90 days?",
    subhead: "Stop running the same playbook and hoping for more leads. The free AI Marketing Audit takes 5 minutes.",
  },
  C: {
    question: "Do you want to add $1M+ to your service business?",
    subhead: "Stop leaving the next $1M on the table. The free AI Marketing Audit takes 5 minutes.",
  },
  D: {
    question: "Do you want to end the feast or famine?",
    subhead: "Stop guessing where your next clients come from. The free AI Marketing Audit takes 5 minutes.",
  },
} as const;

type HeroArm = keyof typeof heroVariants;
const isHeroArm = (v: string | null): v is HeroArm => v === 'A' || v === 'B' || v === 'C' || v === 'D';
const requestedArm = Astro.url.searchParams.get('arm')?.toUpperCase() ?? null;
const arm = isHeroArm(requestedArm) ? requestedArm : 'D';
const heroVariant = heroVariants[arm];

const title = `${heroVariant.subhead} | Buildwise Media`;
const description = heroVariant.subhead;

// L1 KPI trust ribbon — sourced live from canonical.json (no hard-coded counts)
const heroKpiTiles = [
  { num: '30 DAYS', label: 'INSTALL TIMELINE' },
  { num: '5×', label: 'ROI FLOOR · 24 MO' },
  { num: `${canonical.clients.current_paying} / ${canonical.clients.cap_phase_1}`, label: 'CLIENTS · PHASE 1 CAP' },
];

// L12 final-CTA mini ribbon — scarcity reinforced at close
const finalKpiTiles = [
  { num: '30 DAYS', label: 'TO LIVE' },
  { num: '5×', label: 'ROI FLOOR' },
  { num: `${canonical.clients.current_paying} / ${canonical.clients.cap_phase_1}`, label: 'CLIENTS · CAPPED' },
];

// L11 FAQ — refreshed against canonical voice + adversarial 5x objection added
const faqs = [
  {
    q: 'What does Buildwise Media actually do?',
    a: 'We install and run an 8-layer revenue operating system for your service business — visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy operated as one engine. The website is the visible layer. Behind it, our AI system runs the marketing operation 24/7 with human signoff at the gates. We treat marketing as operations: investment in, qualified revenue out, verified weekly.',
  },
  {
    q: 'Who is Buildwise Media for?',
    a: 'Service-business owners who are already generating real revenue and want to stop running their marketing on hope. Owners who want a system that runs whether they watch it or not tend to thrive. Owners looking for a savior, or hoping for comfort, tend to bounce off our process — and that is the right outcome for both of us.',
  },
  {
    q: 'How fast does the system go live?',
    a: 'Inside 30 days the website is live, ad accounts are wired, the CRM is instrumented, and the first qualified leads start to flow. Full-system instrumentation completes in the same window. We do not run a 90-day waiting period before anything is observable.',
  },
  {
    q: 'How do you measure success?',
    a: 'Every commitment carries a confidence percentage (75% floor), an evidence class (Measured / Attributed / Modeled / Benchmark), and a captured baseline. The Outcomes Commitment Card is the contract. Headline floor: 5× attributable ROI inside 24 months, measured against the baseline we capture on Day 0.',
  },
  {
    q: 'What if the system doesn\'t hit 5×?',
    a: 'We keep building until it does. That is contractual — written into the MSA as a locked clause, not aspirational marketing copy. The 5× ROI floor is the floor we hold ourselves to. If your business is at 4× at Month 24, we are still working. That is what the floor means.',
  },
  {
    q: 'Is there a long-term contract?',
    a: 'No long-term lock-in. The paid Pilot runs 45 days. The 90-day initial operating period starts on the Ascend handoff. After Day 90, the engagement is true month-to-month with no penalty, no clawback, no exit fee. We earn the retainer every month or we don\'t.',
  },
  {
    q: 'Why Atlanta?',
    a: 'Atlanta home services is our beachhead — the market where we install the system in person and prove the playbook block by block. Outside Atlanta we serve service businesses across the United States. The system installs the same way; the local-SEO depth gets tuned to your metro.',
  },
  {
    q: 'How do I own my data?',
    a: 'Everything we build, you own. The code lives in your repository. The customer list lives in your CRM. The ad accounts are in your business. The custom AI agents are configured against your workflows. If you leave, you take the whole system. We walk empty-handed. That sovereignty is in the MSA as a locked clause.',
  },
];

// L3 anchor for "See the System" secondary CTA
const SYSTEM_ANCHOR = '#system';

// JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/#service-ascend',
  name: 'Ascend',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Ascend installs an 8-layer revenue operating system inside the business — qualified leads, review velocity, local search strength, and AI-search presence operated as one system. Client owns the code, data, ad accounts, and customer list.',
  url: 'https://buildwisemedia.com/services/ascend',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Ascend tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: canonical.products.pilot.name,
        price: canonical.products.pilot.price.oneshot,
        priceCurrency: 'USD',
        description: 'Ascend Pilot — 45-day proof sprint. One-time investment. Converts to Ascend with install fee waived.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend.name,
        price: canonical.products.ascend.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend — full 8-layer revenue operating system installed and operated. Month-to-month after day 90.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend_pro.name,
        price: canonical.products.ascend_pro.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend Pro — multi-location operator build with custom AI agents, RevOps, and territorial cap.',
      },
    ],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/#faq-home',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const playbookItems = [
  { title: 'The AI marketing department', sub: 'What a run-for-you marketing operation looks like.', href: '/playbook/ai-marketing-department' },
  { title: 'Category-of-one marketing', sub: 'Becoming the most-chosen name in your market.', href: '/playbook/category-of-one-marketing' },
  { title: 'Captured baseline', sub: 'Measuring the floor before the system turns on.', href: '/playbook/captured-baseline' },
  { title: 'The Poor Four', sub: 'The four operating gaps that cap service-business growth.', href: '/playbook/poor-four' },
  { title: 'Fractional CMO alternative', sub: 'Strategy without execution leaves the gap open.', href: '/playbook/fractional-cmo-alternative' },
  { title: 'Capability inheritance guarantee', sub: 'Why your system gets better without renegotiation.', href: '/playbook/capability-inheritance' },
  { title: 'Hyper-personalized SEO', sub: 'Five axes that separate your audit from a templated one.', href: '/playbook/hyper-personalized-seo' },
  { title: 'Capability overhang + harness', sub: 'Why frontier AI in a service-business harness compounds.', href: '/playbook/capability-overhang' },
];
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[serviceSchema, breadcrumb, faqSchema]}
>

  <!-- ============================================ -->
  <!-- L1 · Hero (4-arm A/B preserved) + KPI ribbon -->
  <!-- ============================================ -->
  <section class="home-hero" aria-labelledby="home-hero-title" data-arm={arm} data-hero-arm-root>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The AI Marketing Audit</p>
        <h1 id="home-hero-title" class="h-hero">{heroVariant.question}</h1>
        <p class="hero-sub" data-hero-subhead>{heroVariant.subhead}</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a href="/book" class="cta" data-cta-source="home-hero">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href={SYSTEM_ANCHOR} class="cta-ghost" data-cta-source="home-hero-system">See the System</a>
        </div>
      </div>
      <aside class="hero-illustration" aria-hidden="true">
        <!-- L1 visual: 8-layer system stack scene illustration. LOAD-triggered fade-in;
             prefers-reduced-motion: reduce renders static. -->
        <svg viewBox="0 0 480 360" class="hero-stack-svg" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="stackY2" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="var(--y2)" stop-opacity="0.85"/>
              <stop offset="100%" stop-color="var(--y2)" stop-opacity="0.35"/>
            </linearGradient>
          </defs>
          <g class="stack-layer" style="--d:0">
            <rect x="40" y="20" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="39" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">01 · VISIBILITY</text>
          </g>
          <g class="stack-layer" style="--d:1">
            <rect x="40" y="56" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="75" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">02 · CONVERSION</text>
          </g>
          <g class="stack-layer" style="--d:2">
            <rect x="40" y="92" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="111" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">03 · SPEED-TO-LEAD</text>
          </g>
          <g class="stack-layer" style="--d:3">
            <rect x="40" y="128" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="147" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">04 · SALES OPS</text>
          </g>
          <g class="stack-layer" style="--d:4">
            <rect x="40" y="164" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="183" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">05 · REPUTATION</text>
          </g>
          <g class="stack-layer" style="--d:5">
            <rect x="40" y="200" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="219" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">06 · PAID MEDIA</text>
          </g>
          <g class="stack-layer" style="--d:6">
            <rect x="40" y="236" width="400" height="28" fill="none" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="255" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">07 · REPORTING</text>
          </g>
          <g class="stack-layer" style="--d:7">
            <rect x="40" y="272" width="400" height="28" fill="url(#stackY2)" stroke="var(--y2)" stroke-width="1"/>
            <text x="58" y="291" fill="var(--bg)" font-family="JetBrains Mono, monospace" font-weight="600" font-size="11" letter-spacing="2">08 · STRATEGY</text>
          </g>
          <text x="40" y="328" fill="var(--ink-faint)" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="3">YOUR 8-LAYER REVENUE OPERATING SYSTEM</text>
        </svg>
      </aside>
    </div>
    <div class="hero-kpi container">
      <KpiRibbon tiles={heroKpiTiles} />
    </div>
  </section>

  <!-- L1.5 · transitional editorial photo (R020 F1-Emotion) — sets the persona scene -->
  <figure class="scene-photo scene-photo--hero" aria-labelledby="scene-hero-cap">
    <img
      src="/images/bwm-hero-atmospheric-v1.webp"
      alt="An empty leather chair pulled back from a clean desk in a small-business owner's office at first light, a monitor glowing dim with a soft accent of light on the screen — the moment before the work begins, with the system already running."
      width="1920"
      height="1080"
      loading="lazy"
      decoding="async"
    />
    <figcaption id="scene-hero-cap" class="scene-cap mono">The system runs before you sit down. That is the difference.</figcaption>
  </figure>

  <!-- Per-arm rewrite for client-side fetch persistence -->
  <script is:inline>
    (function () {
      var c = String.fromCharCode(36);
      var variants = {
        A: { question: "Do you want to be the #1 service business in your market?", subhead: "Most #1 shops aren't the best — they're the most-found. The free AI Marketing Audit takes 5 minutes." },
        B: { question: "Do you want 3-6 new clients every 90 days?", subhead: "Stop running the same playbook and hoping for more leads. The free AI Marketing Audit takes 5 minutes." },
        C: { question: "Do you want to add " + c + "1M+ to your service business?", subhead: "Stop leaving the next " + c + "1M on the table. The free AI Marketing Audit takes 5 minutes." },
        D: { question: "Do you want to end the feast or famine?", subhead: "Stop guessing where your next clients come from. The free AI Marketing Audit takes 5 minutes." },
      };
      var arm = new URL(window.location.href).searchParams.get('arm');
      arm = arm ? arm.toUpperCase() : 'D';
      if (!Object.prototype.hasOwnProperty.call(variants, arm)) arm = 'D';
      var variant = variants[arm];
      var root = document.querySelector('[data-hero-arm-root]');
      var title = document.getElementById('home-hero-title');
      var sub = document.querySelector('[data-hero-subhead]');
      var meta = document.querySelector('meta[name="description"]');
      var og = document.querySelector('meta[property="og:description"]');
      if (root) root.setAttribute('data-arm', arm);
      if (title) title.textContent = variant.question;
      if (sub) sub.textContent = variant.subhead;
      document.title = variant.subhead + ' | Buildwise Media';
      if (meta) meta.setAttribute('content', variant.subhead);
      if (og) og.setAttribute('content', variant.subhead);
      window.__bwmHeroArm = arm;
    })();
  </script>

  <!-- ============================================ -->
  <!-- L2 · Poor Four (evolved framing)            -->
  <!-- ============================================ -->
  <PoorFour />

  <!-- L2.5 · transitional scene (R020 F1-Emotion) — the audit moment of recognition -->
  <figure class="scene-photo scene-photo--recognition" aria-labelledby="scene-recognition-cap">
    <img
      src="/images/bwm-method-editorial-v1.webp"
      alt="A dark, ordered workspace caught mid-audit — the documentary moment when the four leaks become visible on paper, before the operations layer takes them off the owner's plate."
      width="1920"
      height="1080"
      loading="lazy"
      decoding="async"
    />
    <figcaption id="scene-recognition-cap" class="scene-cap mono">The audit moment · where the four leaks become visible · before the system takes over.</figcaption>
  </figure>

  <!-- ============================================ -->
  <!-- L3 · 8-Layer Revenue Operating System       -->
  <!-- ============================================ -->
  <EightLayerSystem />

  <!-- ============================================ -->
  <!-- L4 · Sovereignty                             -->
  <!-- ============================================ -->
  <Sovereignty />

  <!-- L4.5 · transitional scene (R020 F2-Proof) — sovereignty as a material object -->
  <figure class="scene-photo scene-photo--receipts" aria-labelledby="scene-receipts-cap">
    <img
      src="/images/bwm-ascend-still-life-v1.webp"
      alt="A precise stack of slate-black hardware — website, attribution, operations — with a single accent indicator illuminated. The physical signature of a system that belongs to its owner."
      width="1920"
      height="1080"
      loading="lazy"
      decoding="async"
    />
    <figcaption id="scene-receipts-cap" class="scene-cap mono">Your stack · website · attribution · operations · one indicator at a time.</figcaption>
  </figure>

  <!-- ============================================ -->
  <!-- L5 · Product Comparison                      -->
  <!-- ============================================ -->
  <ProductComparison />

  <!-- ============================================ -->
  <!-- L6 · Earn-Back Calculator                    -->
  <!-- ============================================ -->
  <EarnBackCalculator />

  <!-- ============================================ -->
  <!-- L7 · Capability Curve (AIStorySection)      -->
  <!-- ============================================ -->
  <AIStorySection />

  <!-- L7.5 · transitional scene (R020 F4-Curiosity + F1-Emotion) — the horizon you're building toward -->
  <figure class="scene-photo scene-photo--horizon" aria-labelledby="scene-horizon-cap">
    <img
      src="/images/bwm-outcomes-environmental-cinematic-v1.webp"
      alt="A cool, expansive dusk landscape stretching toward a horizon — the long-arc view a service business owner gets back once the operating layer is running and the days stop being defensive."
      width="1920"
      height="1080"
      loading="lazy"
      decoding="async"
    />
    <figcaption id="scene-horizon-cap" class="scene-cap mono">The long arc · what compounding capability looks like at month thirty-six.</figcaption>
  </figure>

  <!-- ============================================ -->
  <!-- L8 · Atlanta Local Dominance                 -->
  <!-- ============================================ -->
  <AtlantaMap />

  <!-- ============================================ -->
  <!-- L9 · Proof — mini outcome tiles + anchor    -->
  <!-- ============================================ -->
  <section class="proof-section" aria-labelledby="proof-title">
    <div class="container">

      <header class="proof-head">
        <p class="section-tag">Proof</p>
        <h2 id="proof-title" class="h-section">Real numbers. <em>Real receipts.</em></h2>
      </header>

      <!-- 3 mini-outcome tiles — peer validation for the $78K commitment -->
      <ul class="outcome-tiles" role="list">
        <li class="outcome-tile">
          <span class="kpi-label">QUALIFIED-LEAD SHARE LIFT · MEASURED</span>
          <p class="outcome-num">3.2×</p>
        </li>
        <li class="outcome-tile">
          <span class="kpi-label">SPEED-TO-LEAD · ATTRIBUTED</span>
          <p class="outcome-num">&lt; 5<span class="outcome-num-unit">MIN</span></p>
        </li>
        <li class="outcome-tile">
          <span class="kpi-label">DAY-90 ATTRIBUTION · MODELED</span>
          <p class="outcome-num">LIVE</p>
        </li>
      </ul>

      <figure class="scene-photo scene-photo--proof" aria-labelledby="scene-proof-cap">
        <img
          src="/images/bwm-receipts-still-life-v1.webp"
          alt="Macro still-life: an illegible printed performance graph on aged paper beside a fountain pen and a magnifying glass picking up a hint of accent light — the receipts behind the claim."
          width="1920"
          height="1080"
          loading="lazy"
          decoding="async"
        />
        <figcaption id="scene-proof-cap" class="scene-cap mono">Real numbers · captured baseline · evidence class on every commitment.</figcaption>
      </figure>

      <article class="proof-card">
        <p class="proof-headline">
          One service business went from $300K to $10M in 12 months.<br/>
          Same owner. Same hours. <em>Different system.</em>
        </p>
        <ul class="proof-evidence" role="list">
          <li>
            <span class="tri-tag tri-tag-y2">Measured</span>
            3.2× lift in qualified-lead share at Day-90.
          </li>
          <li>
            <span class="tri-tag tri-tag-y2">Attributed</span>
            Booked-job stitching via UTM + first-touch / last-touch attribution.
          </li>
          <li>
            <span class="tri-tag tri-tag-y2">Modeled</span>
            Review velocity, local search, and AI-search citation moved as one system.
          </li>
        </ul>
        <div class="proof-cta-row">
          <a href="/book" class="cta" data-cta-source="proof-cta">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href="/results" class="cta-ghost" data-cta-source="proof-results">See more receipts</a>
        </div>
      </article>

    </div>
  </section>

  <!-- ============================================ -->
  <!-- L10 · Playbook teaser (expanded to 8)        -->
  <!-- ============================================ -->
  <section class="playbook-teaser" aria-labelledby="playbook-teaser-title">
    <div class="container">
      <p class="section-tag">The Playbook</p>
      <h2 id="playbook-teaser-title" class="h-section">What we believe.</h2>

      <!-- 8-node diagram above the link list — satisfies Show-Don't-Tell -->
      <figure class="playbook-diagram" aria-hidden="true">
        <svg viewBox="0 0 480 120" preserveAspectRatio="xMidYMid meet">
          <!-- Row 1: 3 nodes (existing pillars 1-3) -->
          <circle cx="80" cy="30" r="6" fill="var(--y2)"/>
          <circle cx="240" cy="30" r="6" fill="var(--y2)"/>
          <circle cx="400" cy="30" r="6" fill="var(--y2)"/>
          <line x1="86" y1="30" x2="234" y2="30" stroke="var(--rule-bright)" stroke-width="0.5"/>
          <line x1="246" y1="30" x2="394" y2="30" stroke="var(--rule-bright)" stroke-width="0.5"/>
          <!-- Row 2: 3 nodes (existing pillars 4-5 + new 6) -->
          <circle cx="80" cy="70" r="6" fill="var(--y2)"/>
          <circle cx="240" cy="70" r="6" fill="var(--y2)"/>
          <circle cx="400" cy="70" r="5" fill="none" stroke="var(--y2)" stroke-width="1"/>
          <line x1="86" y1="70" x2="234" y2="70" stroke="var(--rule-bright)" stroke-width="0.5"/>
          <line x1="246" y1="70" x2="395" y2="70" stroke="var(--rule-bright)" stroke-width="0.5"/>
          <!-- Row 3: 2 nodes (new 7-8) -->
          <circle cx="160" cy="110" r="5" fill="none" stroke="var(--y2)" stroke-width="1"/>
          <circle cx="320" cy="110" r="5" fill="none" stroke="var(--y2)" stroke-width="1"/>
          <line x1="165" y1="110" x2="315" y2="110" stroke="var(--rule-bright)" stroke-width="0.5"/>
          <!-- Cross-connectors -->
          <line x1="80" y1="36" x2="80" y2="64" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="240" y1="36" x2="240" y2="64" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="400" y1="36" x2="400" y2="64" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="80" y1="76" x2="160" y2="104" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="240" y1="76" x2="160" y2="104" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="240" y1="76" x2="320" y2="104" stroke="var(--rule)" stroke-width="0.5"/>
          <line x1="400" y1="76" x2="320" y2="104" stroke="var(--rule)" stroke-width="0.5"/>
        </svg>
        <figcaption class="diagram-cap mono">Eight ideas · five shipped · three expanding · all connected</figcaption>
      </figure>

      <ul class="playbook-list" role="list">
        {playbookItems.map((p) => (
          <li>
            <a href={p.href}>
              <span class="playbook-link-title">{p.title}</span>
              <span class="playbook-link-sub">{p.sub}</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- L10 bridge CTA per plan -->
      <div class="playbook-bridge">
        <p class="bridge-text">If any of these match how you think about your business, the audit will recognize you.</p>
