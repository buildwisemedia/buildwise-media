---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import PoorFour from '../components/PoorFour.astro';
import SolutionBridge from '../components/SolutionBridge.astro';
import AIStorySection from '../components/AIStorySection.astro';
import SocialProof from '../components/SocialProof.astro';
import FinalCta from '../components/FinalCta.astro';
import FAQ from '../components/FAQ.astro';

const title = "Buildwise Media — Marketing run like operations.";
const description = "AI-native lead-generation system for ambition-disposed service-business owners. Ad spend in. Revenue out. Verified weekly. Full system live in 30 days, month-to-month.";

const proService = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://buildwisemedia.com/#org',
  name: 'Buildwise Media',
  legalName: 'Buildwise Media LLC',
  url: 'https://buildwisemedia.com',
  email: 'hello@buildwisemedia.com',
  telephone: '+14049993258',
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Atlanta',
    addressRegion: 'GA',
    addressCountry: 'US',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
  priceRange: '$$$',
  image: 'https://buildwisemedia.com/og-image.svg',
  sameAs: [], // TODO: populate with verified LinkedIn / X / GitHub URLs once Robert confirms canonical slugs
};

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Ascend — The Buildwise Revenue Engine',
  serviceType: 'AI-native lead-generation system',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description: 'Complete AI-native lead-generation system installed and operated for ambition-disposed service-business owners. Includes website built to AI-search-era standards, paid acquisition wired to baseline-first attribution, AI-assisted content production with human QA, integrated operations layer (CRM, analytics, weekly connector audit), AI business tools.',
  url: 'https://buildwisemedia.com/services/ascend',
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: 'USD',
      price: '7000',
      unitText: 'MONTH',
      description: '$7,000/mo total ($6,000/mo management + $1,000/mo included ad spend) + $2,500 one-time Engine Build at signup. Layer 3 — machine readable. Month-to-month, no long-term lock-in.',
    },
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' }],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What does Buildwise Media actually do?', acceptedAnswer: { '@type': 'Answer', text: 'We install and operate one integrated lead-generation system — the Buildwise Revenue Engine. That includes the website built to AI-search-era standards, paid acquisition wired to baseline-first attribution, AI-assisted content production with a human quality gate, and an integrated operations layer.' } },
    { '@type': 'Question', name: 'Who is Buildwise Media for?', acceptedAnswer: { '@type': 'Answer', text: 'Service-business owners who want to run marketing the way they run their business — measurable, accountable, instrumented. Owners looking for a savior or hoping for comfort tend to bounce off our process.' } },
    { '@type': 'Question', name: 'How fast does the system go live?', acceptedAnswer: { '@type': 'Answer', text: 'Inside 30 days the website is live, ad accounts are wired, the CRM is instrumented, and first leads start to flow. Full-system instrumentation completes in the same window.' } },
    { '@type': 'Question', name: 'Is there a long-term contract?', acceptedAnswer: { '@type': 'Answer', text: 'No. The engagement runs month-to-month, no long-term lock-in. The build-right guarantee covers install milestones; if we miss them we keep working.' } },
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[proService, service, breadcrumb, faqSchema]}
>
  <Hero />
  <TrustBar />
  <PoorFour />
  <SolutionBridge />
  <AIStorySection />
  <SocialProof />
  <FAQ />
  <FinalCta />
</BaseLayout>
