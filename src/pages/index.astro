---
// buildwisemedia.com homepage — Triangulation, fresh architecture 2026-05-21
// Replaces rejected homepage-redesign-2026-05-20 work (R020 + geo-broadcast failures)
// 12 sections, every section visual drives R020 action (F1/F2/F3/F4 only)
// No transitional scene-photos, no radial diagrams, no geo-hardcoding
// Pricing-public RATIFIED 2026-05-20 (canonical.json source of truth)

// SSR opt-in: L8 reads Astro.locals.metro (populated by middleware from cf-ipcity).
// Unknown / missing → generic copy; known metro → personalized H2 + first mechanism.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import canonical from '../data/canonical.json';

import PoorFour from '../components/PoorFour.astro';
import EightLayerSystem from '../components/EightLayerSystem.astro';
import Sovereignty from '../components/Sovereignty.astro';
import ProductComparison from '../components/ProductComparison.astro';
import EarnBackCalculator from '../components/EarnBackCalculator.astro';
import AIStorySection from '../components/AIStorySection.astro';
import FAQ from '../components/FAQ.astro';

const title = "Ascend — Most-Chosen in Your Market | Buildwise Media";
const description = "Buildwise installs and runs Ascend: an 8-layer revenue operating system for service businesses. You own it. We run it. The math is verified weekly.";

// L8 — Category-of-one mechanism set
// Geo-personalization gate: Astro.locals.metro.known === true → metro-specific copy;
// otherwise → generic "your market" copy. Strict-match gate naturally routes crawlers
// (no cf-ipcity on most bots) to the SEO-canonical generic variant.
const metro = Astro.locals.metro ?? { known: false, name: null, slug: null };

const dominanceMechanisms = [
  {
    name: metro.known && metro.name
      ? `AI-search citation rank in ${metro.name}`
      : 'AI-search citation rank',
    body: metro.known && metro.name
      ? `When buyers ask AI assistants who the best in your category is in ${metro.name}, the answer points at you. We train the underlying signals — schema, citations, structured proof — so the AI tools cite your business with confidence.`
      : 'When buyers ask AI assistants who the best in your category is near them, the answer points at you. We train the underlying signals — schema, citations, structured proof — so the AI tools cite your business with confidence.',
  },
  {
    name: 'Local-search dominance',
    body: 'Service pages, citations, and business profile signals aligned around the exact search terms your buyers use. Not generic SEO — the specific phrases that lead to a booked job.',
  },
  {
    name: 'Review velocity',
    body: 'Happy clients turn into proof that compounds month over month — no manual asking, no scripts taped to dashboards. The system handles the request at the moment the work just landed.',
  },
  {
    name: 'Neighborhood presence',
    body: 'The signals that tell algorithms (and buyers) you are the default answer for this category in this market. The compound effect of everything above, measured weekly.',
  },
];

// L9 — Proof tiles + headline
const proofTiles = [
  { label: 'Qualified-lead share lift · Measured', num: '3.2×' },
  { label: 'Speed-to-lead · Attributed', num: '<5', unit: 'min' },
  { label: 'Day-90 attribution · Modeled', num: 'Live' },
];

const commandMetrics = [
  { label: 'AI-search visibility', value: '68%', trend: '+12 pts', tone: 'cyan' },
  { label: 'Lead response', value: '<5m', trend: 'routing live', tone: 'green' },
  { label: 'Review velocity', value: '2.4×', trend: 'compounding', tone: 'yellow' },
  { label: 'Owner dependency', value: '↓', trend: 'load removed', tone: 'orange' },
];

const leakRadar = [
  { label: 'Invisible Market', status: 'signal low', tone: 'cyan' },
  { label: 'Leaky Revenue', status: 'money escaping', tone: 'red' },
  { label: 'Owner Bottleneck', status: 'handoff risk', tone: 'orange' },
  { label: 'Reactive Growth', status: 'late data', tone: 'yellow' },
];

const weeklyProofRail = [
  { label: 'Baseline', value: 'captured', tone: 'cyan' },
  { label: 'Routes', value: 'wired', tone: 'green' },
  { label: 'Spend', value: 'visible', tone: 'yellow' },
  { label: 'Next move', value: 'queued', tone: 'orange' },
];

const signalQueue = [
  { label: 'Search intent', value: 'mapped to service pages', tone: 'cyan' },
  { label: 'Proof graph', value: 'reviews + jobs stitched', tone: 'green' },
  { label: 'Lead route', value: 'form, call, booking armed', tone: 'yellow' },
];

const operatingTruths = [
  {
    label: 'Not an agency',
    title: 'Agencies sell activity. Ascend installs an operating layer.',
    body: 'The difference is simple: the system lives in your business, not in our pitch deck. You can see the baseline, the routes, the account ownership, and the weekly proof.',
    tone: 'cyan',
  },
  {
    label: 'Owner bottleneck',
    title: 'The quiet tax is the owner acting as the marketing router.',
    body: 'When every lead question, campaign decision, review request, and reporting answer routes through you, growth gets capped by your attention before the market ever gets a vote.',
    tone: 'orange',
  },
  {
    label: 'Compounding asset',
    title: 'Every improvement becomes infrastructure you keep.',
    body: 'The visibility layer teaches search. The conversion layer teaches paid media. The CRM layer teaches follow-up. The weekly operating rhythm makes the whole system harder to copy.',
    tone: 'green',
  },
];

const installSteps = [
  {
    day: 'Day 0',
    label: 'Audit',
    body: 'Capture the baseline, map the lead path, and name which Poor Four gaps are costing the most.',
  },
  {
    day: 'Day 14',
    label: 'Install',
    body: 'Wire visibility, conversion, speed-to-lead, reporting, and follow-up into one operating layer.',
  },
  {
    day: 'Day 30',
    label: 'System live',
    body: 'Start the weekly operating rhythm: what spent, what booked, what needs to move next.',
  },
];

const objections = [
  {
    q: 'We were burned by an agency before.',
    a: 'Ascend is built on your domain, your accounts, and your data. No proprietary trap. No mystery reporting.',
  },
  {
    q: "I don't have time to manage another vendor.",
    a: 'The system surfaces decisions, not chores. The weekly rhythm shows what matters and what we already handled.',
  },
  {
    q: 'AI sounds risky in a real business.',
    a: 'Every autonomous deploy passes human signoff. AI does the work; operators clear the gates.',
  },
  {
    q: 'The math has to make sense.',
    a: 'Pricing is public, the ROI floor is written into the engagement, and the baseline is captured before claims begin.',
  },
];

// L10 — Playbook teaser (8 items, expanded from rejected branch)
const playbookItems = [
  { title: 'The AI marketing department', sub: 'What a run-for-you marketing operation looks like.', href: '/playbook/ai-marketing-department' },
  { title: 'Category-of-one marketing', sub: 'Becoming the most-chosen name in your market.', href: '/playbook/category-of-one-marketing' },
  { title: 'Captured baseline', sub: 'Measuring the floor before the system turns on.', href: '/playbook/captured-baseline' },
  { title: 'The Poor Four', sub: 'The four operating gaps that cap service-business growth.', href: '/playbook/poor-four' },
  { title: 'Fractional CMO alternative', sub: 'Strategy without execution leaves the gap open.', href: '/playbook/fractional-cmo-alternative' },
  { title: 'Capability inheritance guarantee', sub: 'Why your system gets better without renegotiation.', href: '/playbook/capability-inheritance' },
  { title: 'Hyper-personalized SEO', sub: 'Five axes that separate your audit from a templated one.', href: '/playbook/hyper-personalized-seo' },
  { title: 'Capability overhang + harness', sub: 'Why frontier AI in a service-business harness compounds.', href: '/playbook/capability-overhang' },
];

// L11 — FAQ (8 questions; "Where do you operate?" replaces "Why Atlanta?" for national broadcast)
const faqs = [
  {
    q: 'What does Buildwise Media actually do?',
    a: 'We install and run an 8-layer revenue operating system for your service business — visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy operated as one engine. The website is the visible layer. Behind it, our AI system runs the marketing operation 24/7 with human signoff at the gates. We treat marketing as operations: investment in, qualified revenue out, verified weekly.',
  },
  {
    q: 'Who is Buildwise Media for?',
    a: 'Service-business owners who are already generating real revenue and want to stop running their marketing on hope. Owners who want a system that runs whether they watch it or not tend to thrive. Owners looking for a savior, or hoping for comfort, tend to bounce off our process — and that is the right outcome for both of us.',
  },
  {
    q: 'How fast does the system go live?',
    a: 'Inside 30 days the website is live, ad accounts are wired, the CRM is instrumented, and the first qualified leads start to flow. Full-system instrumentation completes in the same window.',
  },
  {
    q: 'How do you measure success?',
    a: 'Every commitment carries a confidence percentage, an evidence class, and a captured baseline. Headline floor: 5× attributable ROI inside 24 months, measured against the baseline we capture on Day 0.',
  },
  {
    q: "What if the system doesn't hit 5×?",
    a: 'We keep building until it does. That is contractual — written into the MSA as a locked clause, not aspirational marketing copy. The 5× ROI floor is the floor we hold ourselves to. If your business is at 4× at Month 24, we are still working. That is what the floor means.',
  },
  {
    q: 'Is there a long-term contract?',
    a: 'No long-term lock-in. The paid Pilot runs 45 days. The 90-day initial operating period starts on the Ascend handoff. After Day 90, the engagement is true month-to-month with no penalty, no clawback, no exit fee. We earn the retainer every month or we don’t.',
  },
  {
    q: 'Where do you operate?',
    a: 'We serve service businesses across the United States. The system installs the same way regardless of metro — local-search depth gets tuned to your specific market during install. Our team is based in Atlanta and we travel to clients on the install when on-site work moves the build forward faster.',
  },
  {
    q: 'How do I own my data?',
    a: 'Everything we build, you own. The code lives in your repository. The customer list lives in your CRM. The ad accounts are in your business. The custom AI agents are configured against your workflows. If you leave, you take the whole system. We walk empty-handed. That sovereignty is in the MSA as a locked clause.',
  },
];

// Anchor for "See the System" secondary CTA → L3 EightLayerSystem
const SYSTEM_ANCHOR = '#system';

// JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/#service-ascend',
  name: 'Ascend',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Ascend installs an 8-layer revenue operating system inside the business — qualified leads, review velocity, local search strength, and AI-search presence operated as one system. Client owns the code, data, ad accounts, and customer list.',
  url: 'https://buildwisemedia.com/services/ascend',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Ascend tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: canonical.products.pilot.name,
        price: canonical.products.pilot.price.oneshot,
        priceCurrency: 'USD',
        description: 'Ascend Pilot — 45-day proof sprint. One-time investment. Converts to Ascend with install fee waived.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend.name,
        price: canonical.products.ascend.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend — full 8-layer revenue operating system installed and operated. Month-to-month after day 90.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend_pro.name,
        price: canonical.products.ascend_pro.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend Pro — multi-location operator build with custom AI agents, RevOps, and territorial cap.',
      },
    ],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/#faq-home',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[serviceSchema, breadcrumb, faqSchema]}
>

  <!-- ============================================ -->
  <!-- L1 · Hero                                    -->
  <!-- ============================================ -->
  <section class="home-hero" aria-labelledby="home-hero-title">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Verifiable autonomous marketing systems for service businesses</p>
        <h1 id="home-hero-title" class="h-hero">You run the business. Ascend makes you the <em>most-chosen</em> name in your market.</h1>
        <p class="hero-sub">
          Buildwise installs and operates Ascend on your domain: visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy. You own the asset. We run the cadence. The math is verified weekly.
        </p>
        <div class="hero-actions" role="group" aria-label="Primary actions">
          <a href="/book" class="cta" data-cta-source="home-hero">See If We're a Fit<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
          <a href={SYSTEM_ANCHOR} class="cta-ghost" data-cta-source="home-hero-system">See the System</a>
        </div>
        <ul class="hero-proof-strip" aria-label="Ascend proof points">
          <li><strong>30 days</strong><span>system live</span></li>
          <li><strong>5×</strong><span>24-month ROI floor</span></li>
          <li><strong>HITL</strong><span>human signoff</span></li>
        </ul>
      </div>
      <aside class="command-center ops-panel" aria-label="Ascend command center preview">
        <div class="command-topline">
          <span class="dot green"></span>
          <span class="mono">ASCEND OPERATING CONSOLE · LIVE</span>
          <span class="console-lock mono">CLIENT-OWNED</span>
        </div>

        <div class="console-shell">
          <div class="signal-map-panel">
            <div class="panel-head">
              <p class="ops-kicker">Market signal map</p>
              <span class="ops-chip"><span class="dot cyan" aria-hidden="true"></span>AI search / local / proof</span>
            </div>
            <svg class="market-signal-svg" viewBox="0 0 520 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ascend routes search, reviews, ads, follow-up, and attribution into one operating center.">
              <defs>
                <linearGradient id="sig-cyan" x1="0" x2="1">
                  <stop stop-color="var(--signal-cyan)" stop-opacity="0.9" />
                  <stop offset="1" stop-color="var(--y2)" stop-opacity="0.9" />
                </linearGradient>
                <linearGradient id="sig-green" x1="0" x2="1">
                  <stop stop-color="var(--signal-green)" stop-opacity="0.9" />
                  <stop offset="1" stop-color="var(--y1)" stop-opacity="0.9" />
                </linearGradient>
              </defs>
              <rect x="16" y="18" width="488" height="284" rx="6" fill="rgba(255,255,255,0.015)" stroke="var(--rule)" />
              <path class="signal-path path-a" d="M78 84 C158 42 236 64 260 152 C286 248 396 226 452 116" fill="none" stroke="url(#sig-cyan)" stroke-width="2" stroke-linecap="round" />
              <path class="signal-path path-b" d="M70 236 C164 228 182 134 258 154 C354 180 374 86 448 72" fill="none" stroke="url(#sig-green)" stroke-width="2" stroke-linecap="round" />
              <path class="signal-path path-c" d="M86 160 C162 122 206 252 274 192 C338 138 398 158 452 238" fill="none" stroke="var(--signal-orange)" stroke-width="1.5" stroke-linecap="round" opacity="0.78" />
              <g class="map-node core">
                <circle cx="260" cy="160" r="42" fill="rgba(240,255,0,0.08)" stroke="var(--y2)" />
                <circle cx="260" cy="160" r="7" fill="var(--y2)" />
                <text x="260" y="146" text-anchor="middle" font-family="var(--mono)" font-size="10" fill="var(--ink)" letter-spacing="1.8">ASCEND</text>
                <text x="260" y="180" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-faint)" letter-spacing="1.6">CONTROL PLANE</text>
              </g>
              <g class="map-node"><circle cx="78" cy="84" r="9" fill="var(--signal-cyan)" /><text x="78" y="62" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">AI SEARCH</text></g>
              <g class="map-node"><circle cx="452" cy="116" r="9" fill="var(--y2)" /><text x="452" y="96" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">REVIEWS</text></g>
              <g class="map-node"><circle cx="70" cy="236" r="9" fill="var(--signal-green)" /><text x="70" y="264" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">CRM</text></g>
              <g class="map-node"><circle cx="448" cy="72" r="9" fill="var(--signal-green)" /><text x="448" y="51" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">BOOKED</text></g>
              <g class="map-node"><circle cx="452" cy="238" r="9" fill="var(--signal-orange)" /><text x="452" y="264" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">NEXT MOVE</text></g>
            </svg>
            <div class="signal-queue" aria-label="Active operating routes">
              {signalQueue.map((item) => (
                <div class={`signal-queue-row tone-${item.tone}`}>
                  <span class="mono">{item.label}</span>
                  <strong>{item.value}</strong>
                </div>
              ))}
            </div>
          </div>

          <div class="leak-radar-panel">
            <div class="panel-head">
              <p class="ops-kicker">Leak radar</p>
              <span class="ops-chip"><span class="dot red" aria-hidden="true"></span>4 active checks</span>
            </div>
            <ul class="radar-list" role="list">
              {leakRadar.map((item) => (
                <li class={`radar-item tone-${item.tone}`}>
                  <span class={`dot ${item.tone === 'yellow' ? 'live' : item.tone}`} aria-hidden="true"></span>
                  <strong>{item.label}</strong>
                  <em>{item.status}</em>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="command-metrics">
          {commandMetrics.map((metric) => (
            <div class={`command-metric tone-${metric.tone}`}>
              <span class="mono">{metric.label}</span>
              <strong>{metric.value}</strong>
              <em>{metric.trend}</em>
            </div>
          ))}
        </div>

        <div class="weekly-proof-rail" aria-label="Weekly operating proof rail">
          {weeklyProofRail.map((item) => (
            <div class={`proof-rail-item tone-${item.tone}`}>
              <span class="mono">{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>

        <div class="evidence-ticker" aria-hidden="true">
          <div class="ticker-track">
            <div class="ticker-items">
              <span>LEADS INGESTED</span>
              <span class="ticker-sep">·</span>
              <span>CRM STITCHED</span>
              <span class="ticker-sep">·</span>
              <span>SPEED-TO-LEAD &lt;5M</span>
              <span class="ticker-sep">·</span>
              <span>SYSTEM ACTIVE</span>
              <span class="ticker-sep">·</span>
              <span>MATH VERIFIED</span>
              <span class="ticker-sep">·</span>
              <span>SOVEREIGN DATA</span>
              <span class="ticker-sep">·</span>
            </div>
            <div class="ticker-items">
              <span>LEADS INGESTED</span>
              <span class="ticker-sep">·</span>
              <span>CRM STITCHED</span>
              <span class="ticker-sep">·</span>
              <span>SPEED-TO-LEAD &lt;5M</span>
              <span class="ticker-sep">·</span>
              <span>SYSTEM ACTIVE</span>
              <span class="ticker-sep">·</span>
              <span>MATH VERIFIED</span>
              <span class="ticker-sep">·</span>
              <span>SOVEREIGN DATA</span>
              <span class="ticker-sep">·</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L1.5 · Operating reframe                     -->
  <!-- ============================================ -->
  <section class="operating-reframe" aria-labelledby="operating-reframe-title">
    <div class="container reframe-grid">
      <header class="reframe-head">
        <p class="section-tag">The reframe</p>
        <h2 id="operating-reframe-title" class="h-section">The problem is not that you need more marketing. The problem is that marketing still needs you.</h2>
      </header>
      <div class="reframe-ledger" role="list">
        {operatingTruths.map((item) => (
          <article class={`reframe-card tone-${item.tone}`} role="listitem">
            <p class="ops-kicker">{item.label}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L2 · Poor Four                                -->
  <!-- ============================================ -->
  <PoorFour />

  <!-- ============================================ -->
  <!-- L3 · 8-Layer Revenue Operating System         -->
  <!-- ============================================ -->
  <EightLayerSystem />

  <!-- ============================================ -->
  <!-- L4 · 30-day operating change                 -->
  <!-- ============================================ -->
  <section class="install-section elev" aria-labelledby="install-title">
    <div class="container install-grid">
      <header class="install-head">
        <p class="section-tag">What changes in 30 days</p>
        <h2 id="install-title" class="h-section">The system goes live before the old excuses do.</h2>
        <p class="lede">
          Ascend starts with the baseline, installs the operating layer, then moves into a weekly rhythm your business can actually read.
        </p>
      </header>
      <ol class="install-steps" role="list">
        {installSteps.map((step) => (
          <li>
            <span class="install-day mono">{step.day}</span>
            <h3>{step.label}</h3>
            <p>{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L5 · Sovereignty                              -->
  <!-- ============================================ -->
  <Sovereignty />

  <!-- ============================================ -->
  <!-- L6 · Product Comparison                       -->
  <!-- ============================================ -->
  <ProductComparison />

  <!-- ============================================ -->
  <!-- L7 · Earn-Back Calculator                     -->
  <!-- ============================================ -->
  <EarnBackCalculator />

  <!-- ============================================ -->
  <!-- L8 · Capability Curve                         -->
  <!-- ============================================ -->
  <AIStorySection />

  <!-- ============================================ -->
  <!-- L9 · Category-of-one                          -->
  <!-- Geo-personalized when Astro.locals.metro.known -->
  <!-- ============================================ -->
  <section class="dominance-section" aria-labelledby="dominance-title">
    <div class="container dominance-grid">
      <header class="dominance-head">
        <p class="section-tag">Category of one</p>
        {metro.known && metro.name ? (
          <h2 id="dominance-title" class="h-section">
            Become the most-chosen name in {metro.name}.
          </h2>
        ) : (
          <h2 id="dominance-title" class="h-section">
            Become the most-chosen name in your market.
          </h2>
        )}
        <p class="lede">
          Local dominance is not won on one channel. It is won when every signal — AI search, local search, reviews, and neighborhood presence — points to the same business.
        </p>
      </header>

      <figure class="dominance-figure">
        <!-- @r020:F2 proof: Node mesh diagram showing AI search rank, reviews and local citations converging on one business -->
        <img
          src="/images/node-mesh-ascending-v1.svg"
          alt="An abstract node-mesh diagram: AI-search citations, local-search rankings, review velocity, and neighborhood-level mentions converging into a single ascending node — the business buyers default to when they look for the category."
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="dominance-cap mono">
          Every signal converging on the same answer · your business as the default.
        </figcaption>
      </figure>

      <ul class="dominance-mechanisms" role="list">
        {dominanceMechanisms.map((m) => (
          <li class="dominance-mech">
            <span class="dot live" aria-hidden="true"></span>
            <div>
              <h3 class="h-sub">{m.name}</h3>
              <p>{m.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L10 · Proof — numeric receipts                -->
  <!-- ============================================ -->
  <section class="proof-section elev" aria-labelledby="proof-title">
    <div class="container">

      <header class="proof-head">
        <p class="section-tag">Proof</p>
