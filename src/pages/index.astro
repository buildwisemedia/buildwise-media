  font-size: clamp(22px, 2.2vw, 30px);
  line-height: 1.15;
  margin-bottom: 12px;
}
.objection-card p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.6;
}

/* ===== L8 Dominance section ===== */
.dominance-section {
  padding-block: var(--section-y);
  background: var(--bg);
}

.dominance-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: clamp(40px, 5vw, 64px);
}

.dominance-head {
  max-width: 820px;
}
.dominance-head .lede {
  margin-top: 22px;
}

.dominance-figure {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}
.default-answer {
  width: 100%;
  max-width: 720px;
  border: 1px solid var(--rule);
  border-radius: 6px;
  background: var(--bg-card);
  padding: clamp(22px, 4vw, 38px);
}
.da-prompt {
  font-family: var(--sans);
  font-size: clamp(17px, 1.9vw, 20px);
  font-weight: 500;
  line-height: 1.4;
  color: var(--ink);
  margin-bottom: 26px;
}
.da-flow {
  display: flex;
  align-items: center;
  gap: clamp(16px, 3vw, 30px);
  flex-wrap: wrap;
}
.da-signals {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 0 0 auto;
}
.da-signals li {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--ink-dim);
  padding: 8px 14px;
  border: 1px solid var(--rule);
  border-radius: 4px;
}
.da-arrow { font-size: 26px; color: var(--y2); flex: 0 0 auto; }
.da-answer {
  flex: 1 1 220px;
  border: 1px solid var(--y2);
  border-radius: 4px;
  padding: 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.da-answer .ops-kicker { color: var(--y2); }
.da-answer strong {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(24px, 3vw, 34px);
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--ink);
}
.da-answer-sub { font-size: 14px; color: var(--ink-dim); }
@media (max-width: 560px) {
  .da-flow { flex-direction: column; align-items: stretch; }
  .da-arrow { transform: rotate(90deg); align-self: center; }
  .da-signals { flex-direction: row; flex-wrap: wrap; }
}
.dominance-cap {
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-faint);
  text-transform: uppercase;
  text-align: center;
}

.dominance-mechanisms {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28px;
  padding: 0;
  margin: 0;
}
.dominance-mech {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  gap: 14px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--rule);
}
.dominance-mech .dot {
  margin-top: 12px;
}
.dominance-mech h3 {
  font-size: clamp(20px, 2.2vw, 26px);
  line-height: 1.15;
  margin-bottom: 8px;
}
.dominance-mech p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.55;
}

@media (max-width: 720px) {
  .dominance-mechanisms { grid-template-columns: 1fr; }
}

/* ===== L9 Proof ===== */
.proof-section { padding-block: var(--section-y); }
.proof-head { margin-bottom: 36px; max-width: 720px; }

.outcome-tiles {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 48px;
}
.outcome-tile {
  background: var(--bg-card);
  padding: 22px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.kpi-label {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  text-transform: uppercase;
}
.outcome-num {
  font-family: var(--mono);
  font-size: clamp(40px, 5vw, 56px);
  font-weight: 400;
  color: var(--y2);
  line-height: 1;
  margin: 0;
}
.outcome-num-unit {
  font-size: 0.45em;
  letter-spacing: 0.12em;
  color: var(--ink-faint);
  margin-left: 6px;
  text-transform: uppercase;
}

.proof-card {
  border: 1px solid var(--rule-bright);
  border-radius: 4px;
  padding: clamp(24px, 4vw, 44px);
  background: var(--bg);
}
.proof-headline {
  max-width: 980px;
  font-size: clamp(32px, 4.5vw, 56px);
  line-height: 1.05;
  margin: 0;
}
.proof-evidence {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  margin-top: 28px;
  padding-top: 22px;
  border-top: 1px solid var(--rule);
}
.proof-evidence li {
  font-size: 14px;
  line-height: 1.5;
  color: var(--ink-dim);
}
.proof-evidence li .tri-tag {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 2px;
  margin-bottom: 6px;
}
.tri-tag-y2 {
  background: var(--y2);
  color: var(--bg);
}
.proof-cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
  margin-top: 32px;
}

@media (max-width: 720px) {
  .outcome-tiles { grid-template-columns: 1fr; }
  .proof-evidence { grid-template-columns: 1fr; }
}

/* ===== Offer Sales Sections ===== */
.offer-equation-section,
.dossier-section,
.contract-proof-section,
.pilot-scope-section,
.entry-paths-section {
  padding-block: var(--section-y);
}

.offer-equation-grid,
.dossier-grid,
.pilot-scope-grid,
.entry-paths-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: clamp(36px, 6vw, 84px);
  align-items: start;
}

.offer-equation-grid header,
.dossier-grid header,
.pilot-scope-grid header,
.entry-paths-grid header {
  position: sticky;
  top: 104px;
}

.offer-equation-grid .lede,
.dossier-grid .lede,
.pilot-scope-grid .lede,
.entry-paths-grid .lede,
.contract-proof-head .lede {
  margin-top: 22px;
}

.offer-equation-cards {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.offer-equation-card {
  min-width: 0;
  position: relative;
  background: var(--bg-card);
  padding: clamp(20px, 2.4vw, 28px);
  border-top: 2px solid currentColor;
  overflow: hidden;
}

.offer-equation-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, currentColor, transparent 42%);
  opacity: 0.07;
  pointer-events: none;
}

.offer-equation-metric {
  display: block;
  margin-top: 22px;
  color: currentColor;
  font-size: clamp(42px, 5.2vw, 72px);
  font-weight: 800;
  font-stretch: 75%;
  line-height: 0.88;
  letter-spacing: 0;
  text-transform: lowercase;
  white-space: nowrap;
}

.offer-equation-card h3 {
  margin-top: 22px;
  color: var(--ink);
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.12;
}

.offer-equation-card p:last-child {
  margin-top: 12px;
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.dossier-preview {
  display: grid;
  gap: 18px;
  padding: clamp(20px, 3vw, 34px);
  background:
    linear-gradient(135deg, rgba(56,216,255,0.055), transparent 44%),
    var(--bg-card);
}

.dossier-preview-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--rule);
}

.dossier-preview-head span,
.dossier-score-row span,
.dossier-first-move span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.dossier-preview-head strong {
  max-width: 320px;
  color: var(--ink);
  font-size: clamp(20px, 2.2vw, 28px);
  line-height: 1.05;
  text-align: right;
}

.dossier-score-stack {
  display: grid;
  gap: 14px;
}

.dossier-score-row {
  display: grid;
  grid-template-columns: minmax(0, 0.85fr) minmax(120px, 0.6fr);
  gap: 18px;
  align-items: center;
}

.dossier-score-row strong {
  display: block;
  margin-top: 6px;
  color: var(--ink);
  font-size: clamp(16px, 1.7vw, 22px);
  line-height: 1.12;
}

.dossier-score-bar {
  height: 10px;
  border: 1px solid rgba(240, 255, 0, 0.32);
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}

.dossier-score-bar span {
  display: block;
  width: var(--score);
  height: 100%;
  background: linear-gradient(90deg, var(--y1), var(--y2));
}

.dossier-leak-map {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.dossier-leak-map article {
  min-width: 0;
  padding: 16px;
  background: rgba(5, 5, 7, 0.78);
}

.dossier-leak-map span {
  display: block;
  color: var(--y2);
  font-family: var(--mono);
  font-size: clamp(22px, 2.5vw, 34px);
  line-height: 1;
}

.dossier-leak-map strong {
  display: block;
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 12px;
  line-height: 1.3;
}

.dossier-first-move {
  display: grid;
  gap: 8px;
  padding: 18px;
  border-left: 3px solid var(--y2);
  background: rgba(240, 255, 0, 0.06);
}

.dossier-first-move strong {
  color: var(--ink);
  font-size: clamp(18px, 2vw, 26px);
  line-height: 1.12;
}

.contract-proof-head {
  max-width: 820px;
  margin-bottom: clamp(30px, 4vw, 44px);
}

.contract-proof-board {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(220px, 0.32fr);
  gap: clamp(18px, 3vw, 30px);
  align-items: stretch;
}

.contract-proof-page {
  border: 1px solid var(--rule);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px),
    linear-gradient(0deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px),
    var(--bg-card);
  background-size: 40px 40px;
  padding: clamp(18px, 3vw, 32px);
}

.contract-proof-page-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--rule);
}

.contract-proof-page-head span,
.contract-clause-group,
.contract-clause-label,
.contract-proof-stamp span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.contract-proof-page-head strong {
  color: var(--ink);
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.05;
}

.contract-proof-clauses {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.contract-proof-clause {
  --clause-accent: var(--y2);
  min-width: 0;
  display: grid;
  grid-template-columns: 84px minmax(0, 1fr);
  gap: 16px;
  padding: 16px 18px;
  border: 1px solid var(--rule);
  border-top: 2px solid var(--clause-accent);
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--clause-accent) 9%, transparent), transparent 46%),
    rgba(5, 5, 7, 0.78);
  transition: border-color 180ms ease, transform 180ms ease, background 180ms ease;
}
.contract-proof-clause.tone-cyan { --clause-accent: var(--signal-cyan); }
.contract-proof-clause.tone-green { --clause-accent: var(--signal-green); }
.contract-proof-clause.tone-yellow { --clause-accent: var(--y2); }
.contract-proof-clause.tone-orange { --clause-accent: var(--signal-orange); }
.contract-proof-clause:hover {
  border-color: color-mix(in srgb, var(--clause-accent) 65%, var(--rule-bright));
  transform: translateY(-2px);
}

.clause-rail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14px;
}

.clause-glyph {
  width: 46px;
  height: 46px;
  margin-top: auto;
  filter: drop-shadow(0 0 10px color-mix(in srgb, var(--clause-accent) 28%, transparent));
}

.contract-clause-group {
  color: var(--clause-accent);
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

.contract-clause-label {
  display: inline-block;
  color: var(--bg);
  background: var(--clause-accent);
  font-weight: 700;
  padding: 5px 8px;
}

.contract-proof-clause h3 {
  color: var(--ink);
  font-size: 18px;
  line-height: 1.2;
  margin-top: 12px;
}

.contract-proof-clause p {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.55;
}

.contract-proof-stamp {
  display: grid;
  align-content: center;
  gap: 16px;
  padding: clamp(22px, 3vw, 32px);
  border: 1px solid var(--y2);
  background:
    radial-gradient(circle at 50% 30%, rgba(240, 255, 0, 0.18), transparent 42%),
    var(--bg);
}

.contract-proof-stamp strong {
  color: var(--y2);
  font-size: clamp(24px, 3vw, 40px);
  line-height: 0.98;
  letter-spacing: 0;
}

.pilot-scope-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.pilot-scope-cards article {
  min-width: 0;
  background: var(--bg-card);
  padding: clamp(18px, 2.2vw, 26px);
  border-top: 2px solid var(--signal-cyan);
}

.pilot-scope-cards article:nth-child(2) { border-top-color: var(--signal-orange); }
.pilot-scope-cards article:nth-child(3) { border-top-color: var(--signal-green); }

.pilot-scope-cards p:last-child {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.entry-path-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.entry-path-card {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: clamp(20px, 2.5vw, 30px);
  background:
    linear-gradient(160deg, rgba(240, 255, 0, 0.035), transparent 60%),
    var(--bg-card);
  color: inherit;
  text-decoration: none;
  border-top: 3px solid currentColor;
}

.entry-path-card h3 {
  font-size: clamp(24px, 2.6vw, 34px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--ink);
}

.entry-path-card strong {
  min-height: 2.4em;
  font-size: clamp(19px, 2vw, 26px);
  line-height: 1.12;
  letter-spacing: -0.04em;
  color: var(--y2);
}

.entry-path-card p {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.entry-path-card:hover h3,
.entry-path-card:focus-visible h3 {
  color: var(--y2);
}

.attribution-honesty {
  margin-top: 36px;
  border: 1px solid var(--rule);
  background: var(--bg-card);
  padding: clamp(24px, 3vw, 36px);
}

.attribution-honesty h3 {
  margin-top: 12px;
  color: var(--ink);
  font-size: clamp(22px, 2.4vw, 32px);
  line-height: 1.12;
}

.attribution-rule-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  margin-top: 22px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.attribution-rule-grid article {
  min-width: 0;
  background: rgba(5, 5, 7, 0.76);
  padding: 18px;
}

.attribution-rule-grid span {
  color: var(--y2);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.attribution-rule-grid p {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.5;
}

/* ===== L10 Playbook teaser ===== */
.playbook-teaser {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
}
.playbook-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  margin-top: 28px;
  border-top: 1px solid var(--rule);
  padding: 0;
}
.playbook-list li { border-bottom: 1px solid var(--rule); }
.playbook-list a {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 6px;
  padding: 22px 0;
  color: var(--ink);
  transition: color 180ms ease, padding-left 220ms ease;
}
.playbook-list a:hover {
  color: var(--y2);
  padding-left: 14px;
}
.playbook-link-title {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(22px, 2.6vw, 30px);
  letter-spacing: -0.015em;
  line-height: 1.15;
}
.playbook-link-sub {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.5;
  color: var(--ink-dim);
}

/* ===== L12 Final CTA ===== */
.final-section { padding-block: var(--section-y); }
.final-inner {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: clamp(28px, 5vw, 72px);
  align-items: end;
}
.final-inner .lede { margin-top: 22px; }
.final-inner .cta { margin-bottom: 8px; }

.final-timeline {
  margin: clamp(40px, 5vw, 64px) 0 0;
  padding-top: clamp(32px, 4vw, 48px);
  border-top: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.final-timeline svg {
  width: 100%;
  height: auto;
  max-height: 90px;
}
.final-timeline-cap {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  text-transform: uppercase;
  text-align: center;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .operating-reframe {
    min-height: auto;
    padding-block: 56px;
  }
  .home-hero {
    min-height: auto;
    padding-bottom: 56px;
  }
  .hero-grid,
  .velocity-stage,
  .offer-equation-grid,
  .dossier-grid,
  .pilot-scope-grid,
  .entry-paths-grid,
  .install-grid,
  .objection-grid,
  .final-inner { grid-template-columns: 1fr; }
  .velocity-head,
  .offer-equation-grid header,
  .dossier-grid header,
  .pilot-scope-grid header,
  .entry-paths-grid header,
  .install-head { position: static; }
  .velocity-head .h-section {
    max-width: 12ch;
    font-size: clamp(38px, 8vw, 64px);
  }
  .final-inner { align-items: start; }
  .contract-proof-board { grid-template-columns: 1fr; }
}

@media (max-width: 520px) {
  .home-hero { padding-top: 82px; }
  .hero-grid { gap: 28px; }
  .hero-copy { gap: 14px; }
  .home-hero .eyebrow {
    max-width: 100%;
    align-items: flex-start;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .hero-copy .h-hero {
    max-width: 100%;
    font-size: 32px;
    line-height: 1.04;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }
  .hero-copy .h-hero em {
    color: var(--y2);
    font-style: normal;
  }
  .hero-copy .hero-sub {
    font-size: 16px;
    line-height: 1.45;
  }
  .command-center { min-height: 0; padding: 18px; gap: 14px; }
  .command-center::before { inset: 10px; }
  .console-shell,
  .command-metrics,
  .weekly-proof-rail,
  .hero-proof-strip,
  .offer-equation-cards,
  .dossier-leak-map,
  .contract-proof-clauses,
  .entry-path-cards,
  .pilot-scope-cards,
  .attribution-rule-grid {
    grid-template-columns: 1fr;
  }
  .velocity-chart { padding: 18px; }
  .velocity-phase-rail {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .velocity-chart-top {
    flex-direction: column;
  }
  .velocity-chip {
    white-space: normal;
  }
  .velocity-svg {
    height: auto;
    min-height: 310px;
  }
  .event-label {
    font-size: 42px;
    letter-spacing: 0.02em;
    stroke-width: 10px;
  }
