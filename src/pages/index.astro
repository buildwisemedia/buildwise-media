  margin-top: 8px;
}
.hero-proof-strip li {
  background: var(--bg-card);
  padding: 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.hero-proof-strip strong {
  font-size: clamp(22px, 2.5vw, 34px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--ink);
}
.hero-proof-strip span {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.command-center {
  position: relative;
  min-width: 0;
  border: 1px solid var(--rule-bright);
  background:
    linear-gradient(180deg, rgba(56, 216, 255, 0.06), transparent 34%),
    linear-gradient(125deg, rgba(240, 255, 0, 0.055), transparent 48%),
    var(--bg-card);
  padding: clamp(18px, 2.4vw, 28px);
  min-height: 520px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
  overflow: hidden;
}
.command-center::before {
  content: "";
  position: absolute;
  inset: 14px;
  border: 1px solid rgba(240, 255, 0, 0.12);
  pointer-events: none;
}
.command-center::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(180deg, transparent 0 47%, rgba(240, 255, 0, 0.08) 48%, transparent 50%),
    radial-gradient(circle at 74% 16%, rgba(101, 255, 142, 0.12), transparent 20%),
    radial-gradient(circle at 22% 82%, rgba(56, 216, 255, 0.1), transparent 18%);
  mix-blend-mode: screen;
  opacity: 0.62;
}
.command-topline {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--y2);
  font-size: 10px;
  letter-spacing: 0.18em;
  position: relative;
  z-index: 1;
}
.console-lock {
  margin-left: auto;
  color: var(--signal-green);
  font-size: 8px;
  letter-spacing: 0.16em;
}

.console-shell {
  display: grid;
  grid-template-columns: minmax(0, 1.18fr) minmax(140px, 0.82fr);
  gap: 12px;
  position: relative;
  z-index: 1;
}
.signal-map-panel,
.leak-radar-panel {
  min-width: 0;
  border: 1px solid var(--rule);
  background: rgba(5, 5, 7, 0.62);
  padding: 12px;
}
.signal-map-panel {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}
.market-signal-svg {
  width: 100%;
  height: auto;
  border: 1px solid rgba(255, 255, 255, 0.03);
}
.signal-queue {
  display: grid;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.signal-queue-row {
  display: grid;
  grid-template-columns: minmax(78px, 0.7fr) minmax(0, 1.3fr);
  gap: 10px;
  align-items: center;
  background: rgba(5, 5, 7, 0.72);
  border-left: 2px solid currentColor;
  padding: 8px 10px;
}
.signal-queue-row span {
  color: var(--ink-faint);
  font-size: 8px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.signal-queue-row strong {
  color: var(--ink);
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.signal-path {
  stroke-dasharray: 15 16;
  animation: signalRoute 8s linear infinite;
}
.path-b { animation-duration: 10s; animation-direction: reverse; }
.path-c { animation-duration: 12s; }
.map-node:not(.core) circle {
  animation: nodeBlink 2.8s ease-in-out infinite;
  transform-origin: center;
}
.leak-radar-panel {
  display: flex;
  flex-direction: column;
}
.radar-list {
  list-style: none;
  display: grid;
  gap: 6px;
  margin: 0;
  padding: 0;
}
.radar-item {
  display: grid;
  grid-template-columns: 10px minmax(0, 1fr);
  gap: 8px 10px;
  align-items: center;
  padding: 8px;
  border: 1px solid var(--rule);
  background: rgba(255, 255, 255, 0.015);
}
.radar-item .dot { margin: 0; }
.radar-item strong {
  color: var(--ink);
  font-size: 12px;
  line-height: 1.2;
}
.radar-item em {
  grid-column: 2;
  font-family: var(--mono);
  font-style: normal;
  font-size: 8px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: currentColor;
}
.command-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  align-self: stretch;
  position: relative;
  z-index: 1;
}
.command-metric {
  background: var(--bg);
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-top: 2px solid currentColor;
}
.command-metric span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.18em;
}
.command-metric strong {
  font-size: clamp(28px, 3vw, 44px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--ink);
}
.command-metric em {
  font-family: var(--mono);
  font-style: normal;
  text-transform: uppercase;
  font-size: 9px;
  letter-spacing: 0.18em;
  color: currentColor;
}

.weekly-proof-rail {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  position: relative;
  z-index: 1;
}
.proof-rail-item {
  background: rgba(5, 5, 7, 0.72);
  padding: 10px 10px;
  border-top: 2px solid currentColor;
}
.proof-rail-item span {
  display: block;
  font-size: 8px;
  letter-spacing: 0.14em;
  color: var(--ink-faint);
}
.proof-rail-item strong {
  display: block;
  margin-top: 6px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: currentColor;
}

@media (min-width: 901px) and (max-height: 900px) {
  .home-hero {
    min-height: 100svh;
    padding-top: clamp(72px, 8svh, 92px);
    padding-bottom: clamp(28px, 4svh, 44px);
  }
  .hero-grid {
    grid-template-columns: minmax(0, 1.08fr) minmax(270px, 0.92fr);
    gap: clamp(24px, 4vw, 52px);
  }
  .hero-copy { gap: 14px; }
  .hero-copy .h-hero {
    max-width: 700px;
    font-size: clamp(40px, 4.75vw, 64px);
    line-height: 0.94;
  }
  .hero-copy .hero-sub {
    max-width: 580px;
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.42;
  }
  .hero-actions {
    gap: 12px;
    margin-top: 0;
  }
  .hero-proof-strip {
    max-width: 620px;
    margin-top: 4px;
  }
  .hero-proof-strip li {
    padding: 11px 12px;
    gap: 4px;
  }
  .hero-proof-strip strong {
    font-size: clamp(21px, 2.2vw, 30px);
  }
  .command-center {
    min-height: 0;
    padding: 18px;
    gap: 12px;
  }
  .command-center::before { inset: 10px; }
  .console-shell {
    grid-template-columns: minmax(0, 1.1fr) minmax(126px, 0.9fr);
    gap: 10px;
  }
  .signal-map-panel,
  .leak-radar-panel {
    padding: 10px;
  }
  .panel-head {
    margin-bottom: 8px;
  }
  .market-signal-svg {
    max-height: 144px;
  }
  .signal-map-panel {
    gap: 8px;
  }
  .signal-queue-row {
    grid-template-columns: minmax(68px, 0.64fr) minmax(0, 1.36fr);
    gap: 8px;
    padding: 6px 8px;
  }
  .radar-list { gap: 5px; }
  .radar-item {
    gap: 6px 8px;
    padding: 6px;
  }
  .radar-item strong {
    font-size: 11px;
  }
  .command-metric {
    padding: 10px 12px;
    gap: 6px;
  }
  .command-metric strong {
    font-size: clamp(26px, 2.5vw, 36px);
  }
  .command-metric em {
    font-size: 8px;
  }
  .proof-rail-item {
    padding: 8px;
  }
  .proof-rail-item span {
    font-size: 7px;
  }
  .proof-rail-item strong {
    margin-top: 5px;
    font-size: 9px;
  }
  .evidence-ticker {
    padding-top: 8px;
  }
}

@keyframes signalRoute {
  to { stroke-dashoffset: -180; }
}
@keyframes nodeBlink {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

.evidence-ticker {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-top: 1px solid var(--rule);
  padding-top: 12px;
  margin-top: auto;
  mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  position: relative;
  z-index: 1;
}

/* ===== L1.5 Operating reframe ===== */
.operating-reframe {
  min-height: calc(100svh - 96px);
  padding-block: clamp(28px, 4vh, 48px);
  border-block: 1px solid var(--rule);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent),
    var(--bg-elev);
  display: grid;
  align-items: center;
}
.velocity-stage {
  display: grid;
  grid-template-columns: minmax(310px, 0.72fr) minmax(0, 1.28fr);
  gap: clamp(28px, 4vw, 58px);
  align-items: center;
}
.velocity-head {
  min-width: 0;
}
.velocity-head .h-section {
  max-width: 10.8ch;
  font-size: clamp(42px, 4.6vw, 72px);
  line-height: 0.93;
  text-wrap: balance;
}
.velocity-head .lede {
  margin-top: clamp(18px, 2.6vh, 26px);
  max-width: 590px;
  font-size: clamp(17px, 1.6vw, 22px);
  line-height: 1.42;
}
.velocity-phase-rail {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  margin-top: clamp(18px, 2.6vh, 28px);
  background: var(--rule);
  border: 1px solid var(--rule);
}
.velocity-phase-rail span {
  min-height: 38px;
  display: grid;
  place-items: center;
  padding: 10px 12px;
  background: var(--bg-card);
  color: var(--y2);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-align: center;
}
.velocity-urgent {
  margin-top: clamp(18px, 2.6vh, 28px);
  padding: 13px 16px;
  border-left: 2px solid var(--y2);
  background: rgba(240, 255, 0, 0.045);
  color: var(--ink);
  font-size: clamp(16px, 1.4vw, 19px);
  line-height: 1.45;
}
.velocity-chart {
  min-width: 0;
  margin: 0;
  padding: clamp(18px, 2.4vw, 28px);
  border: 1px solid var(--rule);
  background:
    radial-gradient(circle at 78% 18%, rgba(240, 255, 0, 0.16), transparent 28%),
    linear-gradient(135deg, rgba(56, 216, 255, 0.07), transparent 42%),
    var(--bg-card);
}
.velocity-chart-top {
  display: flex;
  justify-content: space-between;
  align-items: start;
  gap: 18px;
  margin-bottom: 12px;
}
.velocity-chart-top h3 {
  max-width: 560px;
  margin-top: 8px;
  font-size: clamp(28px, 3.1vw, 44px);
  line-height: 0.96;
  text-wrap: balance;
}
.velocity-chip {
  border: 1px solid rgba(240, 255, 0, 0.42);
  color: var(--y2);
  padding: 10px 12px;
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  white-space: nowrap;
}
.velocity-svg {
  display: block;
  width: 100%;
  height: min(58svh, 580px);
  min-height: 420px;
}
.velocity-event circle {
  fill: var(--bg);
  stroke: var(--y2);
  stroke-width: 4;
  filter: drop-shadow(0 0 14px rgba(240, 255, 0, 0.34));
}
.velocity-event text {
  font-family: var(--mono);
  text-transform: uppercase;
}
.event-date {
  fill: var(--ink-faint);
  font-size: 17px;
  letter-spacing: 0.12em;
}
.event-label {
  fill: var(--ink);
  font-size: 27px;
  font-weight: 700;
  letter-spacing: 0.025em;
  paint-order: stroke;
  stroke: rgba(7, 7, 9, 0.88);
  stroke-linejoin: round;
  stroke-width: 9px;
}
.event-detail {
  display: none;
  fill: var(--ink-dim);
  font-size: 15px;
  letter-spacing: 0.06em;
}
.velocity-event.forecast circle {
  fill: var(--y2);
  stroke: var(--bg);
}
.velocity-event.terminal circle {
  stroke-width: 5;
}
.next-curve circle {
  fill: var(--signal-cyan);
  stroke: var(--signal-cyan);
}
.next-curve .event-label {
  fill: var(--signal-cyan);
  font-size: 21px;
}
.velocity-now .event-label {
  fill: var(--y2);
}
.velocity-caption {
  margin-top: 12px;
  padding-top: 14px;
  border-top: 1px solid var(--rule);
  color: var(--ink-dim);
  font-size: clamp(15px, 1.25vw, 18px);
  line-height: 1.42;
  max-width: 1020px;
}
.velocity-caption strong {
  color: var(--ink);
}
.ticker-track {
  display: flex;
  width: max-content;
  animation: tickerMove 25s linear infinite;
}
.ticker-items {
  display: flex;
  align-items: center;
  gap: 20px;
  padding-right: 20px;
  white-space: nowrap;
  font-family: var(--mono);
  font-size: 8px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-faint);
}
.ticker-sep {
  color: var(--y2);
  font-weight: bold;
}

/* ===== Comparative Progress Bars ===== */
.bar-comparison {
  margin-top: 32px;
  padding: 28px;
  background: var(--bg-card);
  border: 1px solid var(--rule);
  border-radius: 4px;
}
.comparison-title {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  margin-bottom: 24px;
  text-transform: uppercase;
}
.comparison-bars {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.comparison-bar {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.bar-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.bar-label {
  color: var(--ink-dim);
}
.bar-value {
  color: var(--ink);
}
.legacy .bar-value {
  color: var(--ink-faint);
}
.ascend .bar-value {
  color: var(--y2);
  font-weight: bold;
}
.bar-track {
  width: 100%;
  height: 8px;
  background: var(--bg);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 2px;
  clip-path: inset(0 100% 0 0);
  transition: clip-path 1.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.legacy-fill {
  width: 12%;
  background: var(--ink-faint);
  opacity: 0.5;
}
.ascend-fill {
  width: 100%;
  background: linear-gradient(90deg, var(--y1), var(--y2));
  box-shadow: 0 0 12px rgba(240, 255, 0, 0.3);
}
.bar-fill.is-visible {
  clip-path: inset(0 0 0 0);
}

/* ===== L4 Install section ===== */
.install-section { padding-block: var(--section-y); }
.install-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}
.install-head { position: sticky; top: 104px; }
.install-head .lede { margin-top: 22px; }
.install-console {
  position: relative;
  border: 1px solid var(--rule);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
    linear-gradient(0deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    var(--bg-card);
  background-size: 44px 44px;
  padding: clamp(18px, 3vw, 32px);
  overflow: hidden;
}
.install-console::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 78% 18%, rgba(240, 255, 0, 0.13), transparent 34%);
  pointer-events: none;
}
.install-pulse {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-bottom: 18px;
}
.install-pulse span {
  height: 42px;
  border: 1px solid var(--rule);
  background:
    linear-gradient(90deg, rgba(240, 255, 0, 0.16), transparent 58%),
    rgba(5, 5, 7, 0.72);
}
.install-pulse span:nth-child(2) {
  background:
    linear-gradient(90deg, rgba(240, 255, 0, 0.32), transparent 70%),
    rgba(5, 5, 7, 0.72);
}
.install-pulse span:nth-child(3) {
  background:
    linear-gradient(90deg, var(--y2), rgba(240, 255, 0, 0.1)),
    rgba(5, 5, 7, 0.72);
  box-shadow: 0 0 28px rgba(240, 255, 0, 0.12);
}
.install-steps {
  position: relative;
  z-index: 1;
  list-style: none;
  display: grid;
  gap: 14px;
  margin: 0;
  padding: 0;
}
.install-steps li {
  display: grid;
  gap: 14px;
  background: rgba(5, 5, 7, 0.82);
  border: 1px solid var(--rule);
  padding: clamp(22px, 3vw, 32px);
}
.install-step-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.install-day {
  color: var(--y2);
  font-size: 10px;
  letter-spacing: 0.2em;
}
.install-metric {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-align: right;
}
.install-meter {
  height: 8px;
  border: 1px solid rgba(240, 255, 0, 0.28);
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}
.install-meter span {
  display: block;
  width: var(--fill);
  height: 100%;
  background: linear-gradient(90deg, var(--y1), var(--y2));
  box-shadow: 0 0 18px rgba(240, 255, 0, 0.24);
}
.install-steps h3 {
  font-size: clamp(24px, 2.8vw, 38px);
  line-height: 1;
  margin: 0;
}
.install-steps p {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
  max-width: 620px;
  margin: 0;
}

/* ===== Objection section ===== */
.objection-section { padding-block: var(--section-y); }
.objection-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
}
.objection-head .lede { margin-top: 22px; }
.objection-list {
  display: grid;
  gap: 14px;
}
.objection-card {
  --obj-accent: var(--y2);
  display: grid;
  gap: 14px;
  padding: clamp(22px, 2.6vw, 30px);
  border: 1px solid var(--rule);
  border-left: 3px solid var(--obj-accent);
  background:
    linear-gradient(90deg, color-mix(in srgb, var(--obj-accent) 7%, transparent), transparent 62%),
    var(--bg-card);
}
.objection-card.tone-cyan { --obj-accent: var(--signal-cyan); }
.objection-card.tone-green { --obj-accent: var(--signal-green); }
.objection-card.tone-orange { --obj-accent: var(--signal-orange); }
.objection-card.tone-yellow { --obj-accent: var(--y2); }
.objection-quote {
  position: relative;
  font-family: var(--sans);
  font-weight: 700;
  font-size: clamp(19px, 2vw, 26px);
  line-height: 1.18;
  color: var(--ink);
  padding-left: 28px;
  margin: 0;
}
.objection-qmark {
  position: absolute;
  left: 0;
  top: -4px;
  color: var(--obj-accent);
  font-size: 34px;
  line-height: 1;
  font-weight: 800;
}
.objection-answer {
  display: grid;
  gap: 6px;
}
.objection-answer-label {
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--obj-accent);
}
.objection-answer p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.6;
  margin: 0;
}

/* ===== L8 Dominance section ===== */
.dominance-section {
  padding-block: var(--section-y);
  background: var(--bg);
}

.dominance-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: clamp(40px, 5vw, 64px);
}

.dominance-head {
  max-width: 820px;
}
.dominance-head .lede {
  margin-top: 22px;
}

.dominance-figure {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}
.default-answer {
  width: 100%;
  max-width: 720px;
  border: 1px solid var(--rule);
  border-radius: 6px;
  background: var(--bg-card);
  padding: clamp(22px, 4vw, 38px);
}
.da-prompt {
  font-family: var(--sans);
  font-size: clamp(17px, 1.9vw, 20px);
  font-weight: 500;
  line-height: 1.4;
  color: var(--ink);
  margin-bottom: 26px;
}
.da-flow {
  display: grid;
  grid-template-columns: minmax(0, auto) minmax(0, 1.05fr);
  align-items: center;
  gap: clamp(18px, 3.4vw, 40px);
}
.da-signals {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0;
  margin: 0;
}
.da-signal {
  --sig-accent: var(--y2);
  display: grid;
  grid-template-columns: 20px minmax(0, 1fr) 16px;
  align-items: center;
  gap: 12px;
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.06em;
  color: var(--ink);
  padding: 11px 14px;
  border: 1px solid var(--rule);
  border-left: 3px solid var(--sig-accent);
  border-radius: 4px;
  background: linear-gradient(90deg, color-mix(in srgb, var(--sig-accent) 9%, transparent), transparent 70%);
}
.da-signal.tone-cyan { --sig-accent: var(--signal-cyan); }
.da-signal.tone-green { --sig-accent: var(--signal-green); }
.da-signal.tone-orange { --sig-accent: var(--signal-orange); }
.da-signal.tone-yellow { --sig-accent: var(--y2); }
.da-signal-glyph { width: 20px; height: 20px; }
.da-signal-arrow {
  color: var(--sig-accent);
  font-size: 18px;
  font-weight: 700;
  justify-self: end;
}
.da-answer {
  position: relative;
  border: 1.5px solid var(--y2);
  border-radius: 6px;
  padding: clamp(24px, 3vw, 38px);
  display: flex;
  flex-direction: column;
  gap: 8px;
  background:
    radial-gradient(120% 140% at 0% 50%, rgba(240, 255, 0, 0.14), transparent 58%),
    var(--bg-card);
  box-shadow: 0 0 54px rgba(240, 255, 0, 0.12), inset 0 0 0 1px rgba(240, 255, 0, 0.08);
}
.da-answer .ops-kicker { color: var(--y2); }
.da-answer strong {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(30px, 4vw, 46px);
  line-height: 0.98;
  letter-spacing: -0.02em;
  color: var(--ink);
}
.da-answer-sub { font-size: 15px; color: var(--ink-dim); }
@media (max-width: 620px) {
  .da-flow { grid-template-columns: 1fr; }
}
.dominance-cap {
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-faint);
  text-transform: uppercase;
  text-align: center;
}

.dominance-mechanisms {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28px;
  padding: 0;
  margin: 0;
}
.dominance-mech {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  gap: 14px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--rule);
}
.dominance-mech .dot {
  margin-top: 12px;
}
.dominance-mech h3 {
  font-size: clamp(20px, 2.2vw, 26px);
  line-height: 1.15;
  margin-bottom: 8px;
}
.dominance-mech p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.55;
}

@media (max-width: 720px) {
  .dominance-mechanisms { grid-template-columns: 1fr; }
}

/* ===== L9 Proof ===== */
.proof-section { padding-block: var(--section-y); }
.proof-head { margin-bottom: 36px; max-width: 720px; }

.outcome-tiles {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 48px;
}
.outcome-tile {
  background: var(--bg-card);
  padding: 22px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.kpi-label {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  text-transform: uppercase;
}
.outcome-num {
  font-family: var(--mono);
  font-size: clamp(40px, 5vw, 56px);
  font-weight: 400;
  color: var(--y2);
  line-height: 1;
  margin: 0;
}
.outcome-num-unit {
  font-size: 0.45em;
  letter-spacing: 0.12em;
  color: var(--ink-faint);
  margin-left: 6px;
  text-transform: uppercase;
}

.proof-card {
  border: 1px solid var(--rule-bright);
  border-radius: 4px;
  padding: clamp(24px, 4vw, 44px);
  background: var(--bg);
}
.proof-headline {
  max-width: 980px;
  font-size: clamp(32px, 4.5vw, 56px);
  line-height: 1.05;
  margin: 0;
}
.proof-evidence {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  margin-top: 28px;
  padding-top: 22px;
  border-top: 1px solid var(--rule);
}
.proof-evidence li {
  font-size: 14px;
  line-height: 1.5;
  color: var(--ink-dim);
}
.proof-evidence li .tri-tag {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 2px;
  margin-bottom: 6px;
}
.tri-tag-y2 {
  background: var(--y2);
  color: var(--bg);
}
.proof-cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
  margin-top: 32px;
}

@media (max-width: 720px) {
  .outcome-tiles { grid-template-columns: 1fr; }
  .proof-evidence { grid-template-columns: 1fr; }
}

/* ===== Offer Sales Sections ===== */
.offer-equation-section,
.dossier-section,
.contract-proof-section,
.pilot-scope-section,
.entry-paths-section {
  padding-block: var(--section-y);
}

.offer-equation-grid,
.dossier-grid,
.pilot-scope-grid,
.entry-paths-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: clamp(36px, 6vw, 84px);
  align-items: start;
}

.offer-equation-grid header,
.dossier-grid header,
.pilot-scope-grid header,
.entry-paths-grid header {
  position: sticky;
  top: 104px;
}

.offer-equation-grid .lede,
.dossier-grid .lede,
.pilot-scope-grid .lede,
.entry-paths-grid .lede,
.contract-proof-head .lede {
  margin-top: 22px;
}

.offer-equation-cards {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.offer-equation-card {
  min-width: 0;
  position: relative;
  background: var(--bg-card);
  padding: clamp(20px, 2.4vw, 28px);
  border-top: 2px solid currentColor;
  overflow: hidden;
}

.offer-equation-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, currentColor, transparent 42%);
  opacity: 0.07;
  pointer-events: none;
}

.offer-equation-metric {
  display: block;
  margin-top: 22px;
  color: currentColor;
  font-size: clamp(42px, 5.2vw, 72px);
  font-weight: 800;
  font-stretch: 75%;
  line-height: 0.88;
  letter-spacing: 0;
  text-transform: lowercase;
  white-space: nowrap;
}

.offer-equation-card h3 {
  margin-top: 22px;
  color: var(--ink);
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.12;
}

.offer-equation-card p:last-child {
  margin-top: 12px;
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.dossier-preview {
  display: grid;
  gap: 18px;
  padding: clamp(20px, 3vw, 34px);
  background:
    linear-gradient(135deg, rgba(56,216,255,0.055), transparent 44%),
    var(--bg-card);
}

.dossier-preview-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--rule);
}

.dossier-preview-head span,
.dossier-score-row span,
.dossier-first-move span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.dossier-preview-head strong {
  max-width: 320px;
  color: var(--ink);
  font-size: clamp(20px, 2.2vw, 28px);
  line-height: 1.05;
  text-align: right;
}

.dossier-score-stack {
  display: grid;
  gap: 14px;
}

.dossier-score-row {
  display: grid;
  grid-template-columns: minmax(0, 0.85fr) minmax(120px, 0.6fr);
  gap: 18px;
  align-items: center;
}

.dossier-score-row strong {
  display: block;
  margin-top: 6px;
  color: var(--ink);
  font-size: clamp(16px, 1.7vw, 22px);
  line-height: 1.12;
}

.dossier-score-bar {
  height: 10px;
  border: 1px solid rgba(240, 255, 0, 0.32);
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}

.dossier-score-bar span {
  display: block;
  width: var(--score);
  height: 100%;
  background: linear-gradient(90deg, var(--y1), var(--y2));
}

.dossier-leak-map {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.dossier-leak-map article {
  min-width: 0;
  padding: 16px;
  background: rgba(5, 5, 7, 0.78);
}

.dossier-leak-map span {
  display: block;
  color: var(--y2);
  font-family: var(--mono);
  font-size: clamp(22px, 2.5vw, 34px);
  line-height: 1;
}

.dossier-leak-map strong {
  display: block;
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 12px;
  line-height: 1.3;
}

.dossier-first-move {
  display: grid;
  gap: 8px;
  padding: 18px;
  border-left: 3px solid var(--y2);
  background: rgba(240, 255, 0, 0.06);
}

.dossier-first-move strong {
  color: var(--ink);
  font-size: clamp(18px, 2vw, 26px);
  line-height: 1.12;
}

.dossier-sample-note {
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin: -6px 0 0;
}

.dossier-cta {
  margin-top: clamp(28px, 4vw, 44px);
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  gap: clamp(24px, 4vw, 56px);
  align-items: center;
  padding: clamp(26px, 3.4vw, 40px);
  border: 1px solid var(--rule);
  border-top: 2px solid var(--y2);
  background:
    radial-gradient(120% 160% at 100% 50%, rgba(240, 255, 0, 0.1), transparent 60%),
    var(--bg-card);
}

.dossier-cta-kicker {
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--y2);
  margin: 0 0 14px;
}

.dossier-cta-list {
  list-style: none;
  display: grid;
  gap: 10px;
  padding: 0;
  margin: 0;
}

.dossier-cta-list li {
  position: relative;
  padding-left: 26px;
  color: var(--ink);
  font-size: clamp(15px, 1.6vw, 17px);
  line-height: 1.4;
}

.dossier-cta-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.45em;
  width: 11px;
  height: 6px;
  border-left: 2px solid var(--y2);
  border-bottom: 2px solid var(--y2);
  transform: rotate(-45deg);
}

.dossier-cta-action {
  display: grid;
  justify-items: start;
  gap: 14px;
}

.dossier-cta-risk {
  font-size: 14px;
  line-height: 1.5;
  color: var(--ink-dim);
  margin: 0;
}

@media (max-width: 720px) {
  .dossier-cta { grid-template-columns: 1fr; }
}

.contract-proof-head {
  max-width: 820px;
  margin-bottom: clamp(30px, 4vw, 44px);
}

.contract-proof-board {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(220px, 0.32fr);
  gap: clamp(18px, 3vw, 30px);
  align-items: stretch;
}

.contract-proof-page {
  border: 1px solid var(--rule);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px),
    linear-gradient(0deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px),
    var(--bg-card);
  background-size: 40px 40px;
  padding: clamp(18px, 3vw, 32px);
}

.contract-proof-page-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--rule);
}

.contract-proof-page-head span,
.contract-clause-group,
.contract-clause-label,
.contract-proof-stamp span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.contract-proof-page-head strong {
  color: var(--ink);
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.05;
}

.contract-proof-clauses {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.contract-proof-clause {
  --clause-accent: var(--y2);
  min-width: 0;
  display: grid;
  grid-template-columns: 84px minmax(0, 1fr);
  gap: 16px;
  padding: 16px 18px;
  border: 1px solid var(--rule);
  border-top: 2px solid var(--clause-accent);
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--clause-accent) 9%, transparent), transparent 46%),
    rgba(5, 5, 7, 0.78);
  transition: border-color 180ms ease, transform 180ms ease, background 180ms ease;
}
.contract-proof-clause.tone-cyan { --clause-accent: var(--signal-cyan); }
.contract-proof-clause.tone-green { --clause-accent: var(--signal-green); }
.contract-proof-clause.tone-yellow { --clause-accent: var(--y2); }
.contract-proof-clause.tone-orange { --clause-accent: var(--signal-orange); }
.contract-proof-clause:hover {
  border-color: color-mix(in srgb, var(--clause-accent) 65%, var(--rule-bright));
  transform: translateY(-2px);
}

.clause-rail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14px;
}

.clause-glyph {
  width: 46px;
  height: 46px;
  margin-top: auto;
  filter: drop-shadow(0 0 10px color-mix(in srgb, var(--clause-accent) 28%, transparent));
}

.contract-clause-group {
  color: var(--clause-accent);
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

.contract-clause-label {
  display: inline-block;
  color: var(--bg);
  background: var(--clause-accent);
  font-weight: 700;
  padding: 5px 8px;
}

.contract-proof-clause h3 {
  color: var(--ink);
  font-size: 18px;
  line-height: 1.2;
  margin-top: 12px;
}

.contract-proof-clause p {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.55;
}

.contract-proof-stamp {
  display: grid;
  align-content: center;
  gap: 16px;
  padding: clamp(22px, 3vw, 32px);
  border: 1px solid var(--y2);
  background:
    radial-gradient(circle at 50% 30%, rgba(240, 255, 0, 0.18), transparent 42%),
    var(--bg);
}

.contract-proof-stamp strong {
  color: var(--y2);
  font-size: clamp(24px, 3vw, 40px);
  line-height: 0.98;
  letter-spacing: 0;
}

.pilot-scope-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.pilot-scope-cards article {
  min-width: 0;
  background: var(--bg-card);
  padding: clamp(18px, 2.2vw, 26px);
  border-top: 2px solid var(--signal-cyan);
}

.pilot-scope-cards article:nth-child(2) { border-top-color: var(--signal-orange); }
.pilot-scope-cards article:nth-child(3) { border-top-color: var(--signal-green); }

.pilot-scope-cards p:last-child {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.entry-path-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.entry-path-card {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: clamp(20px, 2.5vw, 30px);
  background:
    linear-gradient(160deg, rgba(240, 255, 0, 0.035), transparent 60%),
    var(--bg-card);
  color: inherit;
  text-decoration: none;
  border-top: 3px solid currentColor;
}

.entry-path-card h3 {
  font-size: clamp(24px, 2.6vw, 34px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--ink);
}

.entry-path-card strong {
  min-height: 2.4em;
  font-size: clamp(19px, 2vw, 26px);
  line-height: 1.12;
  letter-spacing: -0.04em;
  color: var(--y2);
}

.entry-path-card p {
  color: var(--ink-dim);
  font-size: 15px;
  line-height: 1.55;
}

.entry-path-card:hover h3,
.entry-path-card:focus-visible h3 {
  color: var(--y2);
}

.attribution-honesty {
  margin-top: 36px;
  border: 1px solid var(--rule);
  background: var(--bg-card);
  padding: clamp(24px, 3vw, 36px);
}

.attribution-honesty h3 {
  margin-top: 12px;
  color: var(--ink);
  font-size: clamp(22px, 2.4vw, 32px);
  line-height: 1.12;
}

.attribution-rule-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  margin-top: 22px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.attribution-rule-grid article {
  min-width: 0;
  background: rgba(5, 5, 7, 0.76);
  padding: 18px;
}

.attribution-rule-grid span {
  color: var(--y2);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.attribution-rule-grid p {
  margin-top: 10px;
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.5;
}

/* ===== L10 Playbook teaser ===== */
.playbook-teaser {
  padding-block: var(--section-y);
  border-top: 1px solid var(--rule);
}
.playbook-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  margin-top: 28px;
  border-top: 1px solid var(--rule);
  padding: 0;
}
.playbook-list li { border-bottom: 1px solid var(--rule); }
.playbook-list a {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 6px;
  padding: 22px 0;
  color: var(--ink);
  transition: color 180ms ease, padding-left 220ms ease;
}
.playbook-list a:hover {
  color: var(--y2);
  padding-left: 14px;
}
.playbook-link-title {
  font-family: var(--sans);
  font-weight: 800;
  font-stretch: 75%;
  font-size: clamp(22px, 2.6vw, 30px);
  letter-spacing: -0.015em;
  line-height: 1.15;
}
.playbook-link-sub {
  font-family: var(--sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.5;
  color: var(--ink-dim);
}

/* ===== L12 Final CTA ===== */
.final-section { padding-block: var(--section-y); }
.final-inner {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: clamp(28px, 5vw, 72px);
  align-items: end;
}
.final-inner .lede { margin-top: 22px; }
.final-inner .cta { margin-bottom: 8px; }

.final-timeline {
  margin: clamp(40px, 5vw, 64px) 0 0;
  padding-top: clamp(32px, 4vw, 48px);
  border-top: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.final-timeline svg {
  width: 100%;
  height: auto;
  max-height: 90px;
}
.final-timeline-cap {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  text-transform: uppercase;
  text-align: center;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .operating-reframe {
    min-height: auto;
    padding-block: 56px;
  }
  .home-hero {
    min-height: auto;
    padding-bottom: 56px;
  }
  .hero-grid,
  .velocity-stage,
  .offer-equation-grid,
  .dossier-grid,
  .pilot-scope-grid,
  .entry-paths-grid,
  .install-grid,
  .objection-grid,
  .final-inner { grid-template-columns: 1fr; }
  .velocity-head,
  .offer-equation-grid header,
  .dossier-grid header,
  .pilot-scope-grid header,
  .entry-paths-grid header,
  .install-head { position: static; }
  .velocity-head .h-section {
