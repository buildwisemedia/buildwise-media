---
// buildwisemedia.com homepage — Triangulation, fresh architecture 2026-05-21
// Replaces rejected homepage-redesign-2026-05-20 work (R020 + geo-broadcast failures)
// Installed Advantage pass: the homepage sells the owned AI growth system first.
// No transitional scene-photos, no radial diagrams, no geo-hardcoding
// Pricing-public RATIFIED 2026-05-20 (canonical.json source of truth)

// SSR opt-in: L8 reads Astro.locals.metro (populated by middleware from cf-ipcity).
// Unknown / missing → generic copy; known metro → personalized H2 + first mechanism.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import canonical from '../data/canonical.json';

import PoorFour from '../components/PoorFour.astro';
import EightLayerSystem from '../components/EightLayerSystem.astro';
import Sovereignty from '../components/Sovereignty.astro';
import EarnBackCalculator from '../components/EarnBackCalculator.astro';
import AIStorySection from '../components/AIStorySection.astro';
import CostOfAssembly from '../components/CostOfAssembly.astro';
import FAQ from '../components/FAQ.astro';

const title = "Ascend — Installed AI Growth System You Own | Buildwise Media";
const description = "Buildwise installs and operates Ascend, a fast-improving AI growth system for owner-led service businesses. It runs on your domain, uses your data, and stays yours.";

// L8 — Category-of-one mechanism set
// Geo-personalization gate: Astro.locals.metro.known === true → metro-specific copy;
// otherwise → generic "your market" copy. Strict-match gate naturally routes crawlers
// (no cf-ipcity on most bots) to the SEO-canonical generic variant.
const metro = Astro.locals.metro ?? { known: false, name: null, slug: null };

const dominanceMechanisms = [
  {
    name: metro.known && metro.name
      ? `AI-search citation rank in ${metro.name}`
      : 'AI-search citation rank',
    body: metro.known && metro.name
      ? `When buyers ask AI assistants who the best in your category is in ${metro.name}, the answer points at you. We train the underlying signals — schema, citations, structured proof — so the AI tools cite your business with confidence.`
      : 'When buyers ask AI assistants who the best in your category is near them, the answer points at you. We train the underlying signals — schema, citations, structured proof — so the AI tools cite your business with confidence.',
  },
  {
    name: 'Local-search dominance',
    body: 'Service pages, citations, and business profile signals aligned around the exact search terms your buyers use. Not generic SEO — the specific phrases that lead to a booked job.',
  },
  {
    name: 'Review velocity',
    body: 'Happy clients turn into proof that compounds month over month — no manual asking, no scripts taped to dashboards. The system handles the request at the moment the work just landed.',
  },
  {
    name: 'Neighborhood presence',
    body: 'The signals that tell algorithms (and buyers) you are the default answer for this category in this market. The compound effect of everything above, measured weekly.',
  },
];

// L9 — Proof tiles + headline
const proofTiles = [
  { label: 'Qualified-lead share lift · Measured', num: '3.2×' },
  { label: 'Speed-to-lead · Attributed', num: '<5', unit: 'min' },
  { label: 'Day-90 attribution · Modeled', num: 'Live' },
];

const commandMetrics = [
  { label: 'Install window', value: '30d', trend: 'system live', tone: 'cyan' },
  { label: 'Ownership', value: '100%', trend: 'client-held', tone: 'green' },
  { label: 'Upgrade path', value: 'auto', trend: 'no rebuilds', tone: 'yellow' },
  { label: 'Owner load', value: '↓', trend: 'less chase', tone: 'orange' },
];

const leakRadar = [
  { label: 'Your site', status: 'working for you', tone: 'cyan' },
  { label: 'Calls + jobs', status: 'every lead tracked', tone: 'green' },
  { label: 'New AI', status: 'growth system uses it', tone: 'yellow' },
  { label: 'Weekly proof', status: 'what moved', tone: 'orange' },
];

const weeklyProofRail = [
  { label: 'Installed', value: '30d', tone: 'cyan' },
  { label: 'Operated', value: 'weekly', tone: 'green' },
  { label: 'Upgraded', value: 'no rebuild', tone: 'yellow' },
  { label: 'Owned', value: 'by you', tone: 'orange' },
];

const signalQueue = [
  { label: 'Your domain', value: 'website + tracking live', tone: 'cyan' },
  { label: 'Your data', value: 'CRM + calls stitched', tone: 'green' },
  { label: 'New AI', value: 'growth work upgraded', tone: 'yellow' },
];

const installSteps = [
  {
    day: 'Day 0',
    label: 'Baseline',
    metric: 'Current leak map',
    fill: '18%',
    body: 'Capture the current state, agree on the starting point, and initialize the client-owned system environment.',
  },
  {
    day: 'Day 7',
    label: 'Install map',
    metric: 'First layer wired',
    fill: '54%',
    body: 'Name the first layer to move, wire the core routes, and point the system at the highest-value growth constraint.',
  },
  {
    day: 'Day 30',
    label: 'Live',
    metric: 'Weekly rhythm running',
    fill: '100%',
    body: 'The system is running, the dashboard is filling, and the weekly operating rhythm begins.',
  },
];

const valueEquation = [
  {
    label: 'Installed',
    metric: '30d',
    title: 'The system goes into your business.',
    body: 'Domain, data, accounts, and workflows wired into one owned operating layer.',
    tone: 'green',
  },
  {
    label: 'Operated',
    metric: 'weekly',
    title: 'Buildwise runs the week.',
    body: 'Signals watched, gates cleared, underperformers adjusted before the month drifts.',
    tone: 'cyan',
  },
  {
    label: 'Owned',
    metric: '100%',
    title: 'The asset stays with you.',
    body: 'Code, data, ad accounts, customer list, and workflows remain client-owned.',
    tone: 'yellow',
  },
  {
    label: 'Improving',
    metric: 'auto',
    title: 'It inherits the frontier.',
    body: 'Useful AI upgrades route into the system without a platform reset.',
    tone: 'orange',
  },
];

const dossierSignals = [
  { label: 'Market rank', value: 'search + AI answer visibility', score: 62, cue: 'who appears before you' },
  { label: 'Revenue leaks', value: 'calls, forms, quotes, follow-up', score: 78, cue: 'where buyers stall' },
  { label: 'Proof gaps', value: 'reviews, reputation, citations', score: 44, cue: 'where trust thins out' },
  { label: 'First move', value: 'highest-leverage layer', score: 91, cue: 'what should move first' },
];

const contractProofs = [
  { group: 'Capability', clause: 'Inheritance', title: 'Capability inheritance', body: 'When better AI ships, your system can use it without a new platform fee or rebuild.', tone: 'cyan', visual: 'inheritance' },
  { group: 'Control', clause: 'Human gate', title: 'Human signoff', body: 'Nothing autonomous goes live to buyers without a human gate.', tone: 'green', visual: 'gate' },
  { group: 'Ownership', clause: 'Client assets', title: 'Sovereignty', body: 'You own code, data, ad accounts, customer list, and built assets.', tone: 'yellow', visual: 'sovereignty' },
  { group: 'Economics', clause: 'ROI floor', title: 'ROI floor', body: '5x attributable ROI within 24 months, or Buildwise keeps building.', tone: 'orange', visual: 'roi' },
  { group: 'Portability', clause: 'No lock-in', title: 'No vendor lock-in', body: 'The system is portable across models, tools, and channels.', tone: 'cyan', visual: 'portability' },
  { group: 'Exit rights', clause: 'After Day 90', title: 'True m-t-m after Day 90', body: 'No clawback. No exit fee. No long-term penalty.', tone: 'green', visual: 'exit' },
];

const attributionRules = [
  { label: 'Counts', body: 'Booked work tied to an audited touchpoint in the dashboard.' },
  { label: 'Does not count', body: 'Existing referrals, old SEO, or outside channels we cannot trace.' },
  { label: 'Why it matters', body: 'The math stays conservative so trust does not depend on our storytelling.' },
];

const entryPaths = [
  {
    name: 'Ascend Pilot',
    price: canonical.products.pilot.price.oneshot_display,
    label: 'Proof sprint',
    body: 'A 45-day paid sprint that proves the highest-leverage layer before a full operating relationship.',
    href: '/pricing#pilot',
    tone: 'cyan',
  },
  {
    name: 'Ascend',
    price: `${canonical.products.ascend.price.oneshot_display} + ${canonical.products.ascend.price.recurring_display}`,
    label: 'Main system',
    body: 'The owned AI growth system installed in your environment and operated weekly by Buildwise.',
    href: '/pricing#ascend',
    tone: 'yellow',
  },
  {
    name: 'Ascend Pro',
    price: `${canonical.products.ascend_pro.price.oneshot_display} + ${canonical.products.ascend_pro.price.recurring_display}`,
    label: 'Expansion system',
    body: 'For multi-location operators and category leaders who need deeper AI agents, RevOps, and territory strategy.',
    href: '/pricing#pro',
    tone: 'green',
  },
];

const objections = [
  {
    q: 'We were burned by an agency before.',
    a: 'Ascend is built on your domain, your accounts, and your data. You keep the asset. You see the work. There is no mystery dashboard.',
  },
  {
    q: "I don't have time to manage another vendor.",
    a: 'That is the point. You approve the important gates. Buildwise runs the weekly work.',
  },
  {
    q: 'AI sounds risky in a real business.',
    a: 'Every autonomous deploy passes human signoff. AI does the work; operators clear the gates.',
  },
  {
    q: 'The math has to make sense.',
    a: 'Pricing is public, the ROI floor is written into the engagement, and the baseline is captured before claims begin.',
  },
];

// L11 — FAQ (8 questions; "Where do you operate?" replaces "Why Atlanta?" for national broadcast)
const faqs = [
  {
    q: 'What does Buildwise Media actually do?',
    a: 'We install and run an 8-layer revenue operating system for your service business — visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy operated as one engine. The website is the visible layer. Behind it, our AI system runs the marketing operation 24/7 with human signoff at the gates. We treat marketing as operations: investment in, qualified revenue out, verified weekly.',
  },
  {
    q: 'Who is Buildwise Media for?',
    a: 'Service-business owners who are already generating real revenue and want to stop running their marketing on hope. Owners who want a system that runs whether they watch it or not tend to thrive. Owners looking for a savior, or hoping for comfort, tend to bounce off our process — and that is the right outcome for both of us.',
  },
  {
    q: 'How fast does the system go live?',
    a: 'Inside 30 days the system is live, the dashboard is open, and the first proof sprint is aimed at the leak with the fastest path to cash. The full install runs through the 45-day proof window.',
  },
  {
    q: 'How do you measure success?',
    a: 'We start with a written baseline. From there, the dashboard tracks spend, source, follow-up, booked work, and the next move. The headline floor is 5x attributable ROI inside 24 months.',
  },
  {
    q: "What if the system doesn't hit 5×?",
    a: 'We keep building until it does. That is contractual — written into the MSA as a locked clause, not aspirational marketing copy. The 5× ROI floor is the floor we hold ourselves to. If your business is at 4× at Month 24, we are still working. That is what the floor means.',
  },
  {
    q: 'Is there a long-term contract?',
    a: 'No long-term lock-in. The paid Pilot runs 45 days. The 90-day initial operating period starts on the Ascend handoff. After Day 90, the engagement is true month-to-month with no penalty, no clawback, no exit fee. We earn the retainer every month or we don’t.',
  },
  {
    q: 'Where do you operate?',
    a: 'We serve service businesses across the United States. The system installs the same way regardless of metro — local-search depth gets tuned to your specific market during install. Our team is based in Atlanta and we travel to clients on the install when on-site work moves the build forward faster.',
  },
  {
    q: 'How do I own my data?',
    a: 'Everything we build, you own. The code lives in your repository. The customer list lives in your CRM. The ad accounts are in your business. The custom AI agents are configured against your workflows. If you leave, you take the whole system. We walk empty-handed. That sovereignty is in the MSA as a locked clause.',
  },
];

// Anchor for "See the System" secondary CTA → L3 EightLayerSystem
const SYSTEM_ANCHOR = '#system';

// JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/#service-ascend',
  name: 'Ascend',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Ascend installs a revenue AI system inside owner-led service businesses. Buildwise operates the system, the client owns the code, data, ad accounts, and customer list, and the math is visible from Day 1.',
  url: 'https://buildwisemedia.com/services/ascend',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Ascend tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: canonical.products.pilot.name,
        price: canonical.products.pilot.price.oneshot,
        priceCurrency: 'USD',
        description: 'Ascend Pilot — 45-day proof sprint. One-time investment. Converts to Ascend with install fee waived.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend.name,
        price: canonical.products.ascend.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend — full 8-layer revenue operating system installed and operated. Month-to-month after day 90.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend_pro.name,
        price: canonical.products.ascend_pro.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend Pro — multi-location operator build with custom AI agents, RevOps, and territorial cap.',
      },
    ],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/#faq-home',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[serviceSchema, breadcrumb, faqSchema]}
>

  <!-- ============================================ -->
  <!-- L1 · Hero                                    -->
  <!-- ============================================ -->
  <section class="home-hero" aria-labelledby="home-hero-title">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI growth system for owner-led service businesses</p>
        <h1 id="home-hero-title" class="h-hero">Own the AI growth system your competitors wish they had.</h1>
        <p class="hero-sub">
          Buildwise installs Ascend on your domain and runs it every week. It handles visibility, follow-up, reputation, attribution, and AI upgrades while the system stays yours.
        </p>
        <div class="hero-actions" role="group" aria-label="Primary actions">
          <a href="/book" class="cta" data-cta-source="home-hero">See If We're a Fit<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
          <a href={SYSTEM_ANCHOR} class="cta-ghost" data-cta-source="home-hero-system">See the System</a>
        </div>
        <ul class="hero-proof-strip" aria-label="Ascend proof points">
          <li><strong>30 days</strong><span>installed</span></li>
          <li><strong>Yours</strong><span>domain · data · accounts</span></li>
          <li><strong>Auto</strong><span>upgrades without rebuilds</span></li>
        </ul>
      </div>
      <aside class="command-center ops-panel" aria-label="Ascend installed system preview">
        <div class="command-topline">
          <span class="dot green"></span>
          <span class="mono">ASCEND INSTALLATION · LIVE</span>
          <span class="console-lock mono">CLIENT-OWNED</span>
        </div>

        <div class="console-shell">
          <div class="signal-map-panel">
            <div class="panel-head">
              <p class="ops-kicker">Where buyers find you</p>
              <span class="ops-chip"><span class="dot cyan" aria-hidden="true"></span>AI search · local · reviews</span>
            </div>
            <!-- @r020:F4 curiosity: hero signal-map diagram — scattered demand signals (search, reviews, ads, follow-up, attribution) routing into one operating center; opens the "what is this one system?" loop that the page resolves. -->
            <svg class="market-signal-svg" viewBox="0 0 520 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ascend routes search, reviews, ads, follow-up, and attribution into one operating center.">
              <defs>
                <linearGradient id="sig-cyan" x1="0" x2="1">
                  <stop stop-color="var(--signal-cyan)" stop-opacity="0.9" />
                  <stop offset="1" stop-color="var(--y2)" stop-opacity="0.9" />
                </linearGradient>
                <linearGradient id="sig-green" x1="0" x2="1">
                  <stop stop-color="var(--signal-green)" stop-opacity="0.9" />
                  <stop offset="1" stop-color="var(--y1)" stop-opacity="0.9" />
                </linearGradient>
              </defs>
              <rect x="16" y="18" width="488" height="284" rx="6" fill="rgba(255,255,255,0.015)" stroke="var(--rule)" />
              <path class="signal-path path-a" d="M78 84 C158 42 236 64 260 152 C286 248 396 226 452 116" fill="none" stroke="url(#sig-cyan)" stroke-width="2" stroke-linecap="round" />
              <path class="signal-path path-b" d="M70 236 C164 228 182 134 258 154 C354 180 374 86 448 72" fill="none" stroke="url(#sig-green)" stroke-width="2" stroke-linecap="round" />
              <path class="signal-path path-c" d="M86 160 C162 122 206 252 274 192 C338 138 398 158 452 238" fill="none" stroke="var(--signal-orange)" stroke-width="1.5" stroke-linecap="round" opacity="0.78" />
              <g class="map-node core">
                <circle cx="260" cy="160" r="42" fill="rgba(240,255,0,0.08)" stroke="var(--y2)" />
                <circle cx="260" cy="160" r="7" fill="var(--y2)" />
                <text x="260" y="146" text-anchor="middle" font-family="var(--mono)" font-size="10" fill="var(--ink)" letter-spacing="1.8">ASCEND</text>
                <text x="260" y="180" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-faint)" letter-spacing="1.6">INSTALLED LAYER</text>
              </g>
              <g class="map-node"><circle cx="78" cy="84" r="9" fill="var(--signal-cyan)" /><text x="78" y="62" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">DOMAIN</text></g>
              <g class="map-node"><circle cx="452" cy="116" r="9" fill="var(--y2)" /><text x="452" y="96" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">SYSTEM</text></g>
              <g class="map-node"><circle cx="70" cy="236" r="9" fill="var(--signal-green)" /><text x="70" y="264" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">CRM</text></g>
              <g class="map-node"><circle cx="448" cy="72" r="9" fill="var(--signal-green)" /><text x="448" y="51" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">PROOF</text></g>
              <g class="map-node"><circle cx="452" cy="238" r="9" fill="var(--signal-orange)" /><text x="452" y="264" text-anchor="middle" font-family="var(--mono)" font-size="8" fill="var(--ink-dim)" letter-spacing="1.4">WEEKLY OPS</text></g>
            </svg>
            <div class="signal-queue" aria-label="Active operating routes">
              {signalQueue.map((item) => (
                <div class={`signal-queue-row tone-${item.tone}`}>
                  <span class="mono">{item.label}</span>
                  <strong>{item.value}</strong>
                </div>
              ))}
            </div>
          </div>

          <div class="leak-radar-panel">
            <div class="panel-head">
              <p class="ops-kicker">Where money leaks</p>
              <span class="ops-chip"><span class="dot red" aria-hidden="true"></span>4 leaks watched</span>
            </div>
            <ul class="radar-list" role="list">
              {leakRadar.map((item) => (
                <li class={`radar-item tone-${item.tone}`}>
                  <span class={`dot ${item.tone === 'yellow' ? 'live' : item.tone}`} aria-hidden="true"></span>
                  <strong>{item.label}</strong>
                  <em>{item.status}</em>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="command-metrics">
          {commandMetrics.map((metric) => (
            <div class={`command-metric tone-${metric.tone}`}>
              <span class="mono">{metric.label}</span>
              <strong>{metric.value}</strong>
              <em>{metric.trend}</em>
            </div>
          ))}
        </div>

        <div class="weekly-proof-rail" aria-label="Weekly operating proof rail">
          {weeklyProofRail.map((item) => (
            <div class={`proof-rail-item tone-${item.tone}`}>
              <span class="mono">{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>

        <div class="evidence-ticker" aria-hidden="true">
          <div class="ticker-track">
            <div class="ticker-items">
              <span>DOMAIN OWNED</span>
              <span class="ticker-sep">·</span>
              <span>DATA OWNED</span>
              <span class="ticker-sep">·</span>
              <span>NEW AI USED</span>
              <span class="ticker-sep">·</span>
              <span>HUMAN GATES</span>
              <span class="ticker-sep">·</span>
              <span>WEEKLY OPERATED</span>
              <span class="ticker-sep">·</span>
              <span>CAPABILITY INHERITED</span>
              <span class="ticker-sep">·</span>
            </div>
            <div class="ticker-items">
              <span>DOMAIN OWNED</span>
              <span class="ticker-sep">·</span>
              <span>DATA OWNED</span>
              <span class="ticker-sep">·</span>
              <span>NEW AI USED</span>
              <span class="ticker-sep">·</span>
              <span>HUMAN GATES</span>
              <span class="ticker-sep">·</span>
              <span>WEEKLY OPERATED</span>
              <span class="ticker-sep">·</span>
              <span>CAPABILITY INHERITED</span>
              <span class="ticker-sep">·</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L1.5 · Operating reframe                     -->
  <!-- ============================================ -->
  <section class="operating-reframe" aria-labelledby="operating-reframe-title">
    <div class="container velocity-stage">
      <header class="velocity-head">
        <p class="section-tag">Why now</p>
        <h2 id="operating-reframe-title" class="h-section">
          AI is outrunning manual marketing.
        </h2>
        <p class="lede">
          Since ChatGPT launched in November 2022, AI has moved from chat to reasoning to agents. The next phase is AI improving AI itself. Waiting a month is not neutral.
        </p>
        <div class="velocity-phase-rail" aria-label="AI acceleration phases">
          <span class="mono">Chat</span>
          <span class="mono">Reasoning</span>
          <span class="mono">Agents</span>
          <span class="mono">AI improves AI</span>
        </div>
        <p class="velocity-urgent">
          The owner who installs the operating layer first gets the next capability first.
        </p>
      </header>
      <figure class="velocity-chart" aria-labelledby="velocity-chart-title">
        <div class="velocity-chart-top">
          <div>
            <p class="ops-kicker">AI acceleration · Nov 2022 to Dec 2028</p>
            <h3 id="velocity-chart-title">The curve is exponential.</h3>
          </div>
          <span class="velocity-chip mono">2029 / 2030: next curve starts</span>
        </div>
        <!-- @r020:F2 proof: AI capability acceleration curve from ChatGPT release through 2029/2030 vs the owner-learning curve below it; visually proves the "waiting a month is not neutral" urgency that drives the Book CTA below. -->
        <svg class="velocity-svg" viewBox="0 0 1320 600" role="img" aria-label="Exponential AI capability curve from the ChatGPT release in November 2022 through forecast milestones — AI plans the work in 2027, AI improves itself in 2028, and Artificial General Intelligence in 2029 to 2030.">
          <defs>
            <linearGradient id="velocityFill" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="var(--y2)" stop-opacity="0.34" />
              <stop offset="100%" stop-color="var(--y2)" stop-opacity="0" />
            </linearGradient>
            <linearGradient id="velocityStroke" x1="0" x2="1" y1="0" y2="0">
              <stop stop-color="var(--signal-cyan)" />
              <stop offset="0.38" stop-color="var(--signal-green)" />
              <stop offset="0.68" stop-color="var(--y1)" />
              <stop offset="1" stop-color="var(--y2)" />
