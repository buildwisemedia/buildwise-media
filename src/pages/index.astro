    // Animate comparative progress bars when the proof section enters view.
    const bands = document.querySelectorAll('.figure-band');
    const checkReveal = () => {
      bands.forEach((b) => {
        const rect = b.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.9) {
          b.classList.add('is-visible');
        }
      });
