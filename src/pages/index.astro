---
// buildwisemedia.com homepage — Triangulation, fresh architecture 2026-05-21
// Replaces rejected homepage-redesign-2026-05-20 work (R020 + geo-broadcast failures)
// 12 sections, every section visual drives R020 action (F1/F2/F3/F4 only)
// No transitional scene-photos, no radial diagrams, no geo-hardcoding
// Pricing-visible RATIFIED 2026-05-20 (canonical.json source of truth)

import BaseLayout from '../layouts/BaseLayout.astro';
import canonical from '../data/canonical.json';

import PoorFour from '../components/PoorFour.astro';
import EightLayerSystem from '../components/EightLayerSystem.astro';
import Sovereignty from '../components/Sovereignty.astro';
import ProductComparison from '../components/ProductComparison.astro';
import EarnBackCalculator from '../components/EarnBackCalculator.astro';
import AIStorySection from '../components/AIStorySection.astro';
import FAQ from '../components/FAQ.astro';

// L1 — 4-arm A/B preserved (proven harness, D default)
const heroVariants = {
  A: {
    question: "Do you want to be the #1 service business in your market?",
    subhead: "Most #1 shops aren't the best — they're the most-found. The free AI Marketing Audit takes 5 minutes.",
  },
  B: {
    question: "Do you want 3-6 new clients every 90 days?",
    subhead: "Stop running the same playbook and hoping for more leads. The free AI Marketing Audit takes 5 minutes.",
  },
  C: {
    question: "Do you want to add $1M+ to your service business?",
    subhead: "Stop leaving the next $1M on the table. The free AI Marketing Audit takes 5 minutes.",
  },
  D: {
    question: "Do you want to end the feast or famine?",
    subhead: "Stop guessing where your next clients come from. The free AI Marketing Audit takes 5 minutes.",
  },
} as const;

type HeroArm = keyof typeof heroVariants;
const isHeroArm = (v: string | null): v is HeroArm => v === 'A' || v === 'B' || v === 'C' || v === 'D';
const requestedArm = Astro.url.searchParams.get('arm')?.toUpperCase() ?? null;
const arm = isHeroArm(requestedArm) ? requestedArm : 'D';
const heroVariant = heroVariants[arm];

const title = `${heroVariant.subhead} | Buildwise Media`;
const description = heroVariant.subhead;

// L8 — Category-of-one mechanism set (replaces rejected Atlanta-specific section)
// No geo-hardcoding: copy speaks to "your market" universally
const dominanceMechanisms = [
  {
    name: 'AI-search citation rank',
    body: 'When buyers ask AI assistants who the best in your category is near them, the answer points at you. We train the underlying signals — schema, citations, structured proof — so the AI tools cite your business with confidence.',
  },
  {
    name: 'Local-search dominance',
    body: 'Service pages, citations, and Google Business Profile aligned around the exact search terms your buyers use. Not generic SEO — the specific phrases that lead to a booked job.',
  },
  {
    name: 'Review velocity',
    body: 'Happy clients turn into proof that compounds month over month — no manual asking, no scripts taped to dashboards. The system handles the request at the moment the work just landed.',
  },
  {
    name: 'Neighborhood presence',
    body: 'The signals that tell algorithms (and buyers) you are the default answer for this category in this market. The compound effect of everything above, measured weekly.',
  },
];

// L9 — Proof tiles + headline
const proofTiles = [
  { label: 'Qualified-lead share lift · Measured', num: '3.2×' },
  { label: 'Speed-to-lead · Attributed', num: '<5', unit: 'min' },
  { label: 'Day-90 attribution · Modeled', num: 'Live' },
];

// L10 — Playbook teaser (8 items, expanded from rejected branch)
const playbookItems = [
  { title: 'The AI marketing department', sub: 'What a run-for-you marketing operation looks like.', href: '/playbook/ai-marketing-department' },
  { title: 'Category-of-one marketing', sub: 'Becoming the most-chosen name in your market.', href: '/playbook/category-of-one-marketing' },
  { title: 'Captured baseline', sub: 'Measuring the floor before the system turns on.', href: '/playbook/captured-baseline' },
  { title: 'The Poor Four', sub: 'The four operating gaps that cap service-business growth.', href: '/playbook/poor-four' },
  { title: 'Fractional CMO alternative', sub: 'Strategy without execution leaves the gap open.', href: '/playbook/fractional-cmo-alternative' },
  { title: 'Capability inheritance guarantee', sub: 'Why your system gets better without renegotiation.', href: '/playbook/capability-inheritance' },
  { title: 'Hyper-personalized SEO', sub: 'Five axes that separate your audit from a templated one.', href: '/playbook/hyper-personalized-seo' },
  { title: 'Capability overhang + harness', sub: 'Why frontier AI in a service-business harness compounds.', href: '/playbook/capability-overhang' },
];

// L11 — FAQ (8 questions; "Where do you operate?" replaces "Why Atlanta?" for national broadcast)
const faqs = [
  {
    q: 'What does Buildwise Media actually do?',
    a: 'We install and run an 8-layer revenue operating system for your service business — visibility, conversion, speed-to-lead, sales ops, reputation, paid media, reporting, and strategy operated as one engine. The website is the visible layer. Behind it, our AI system runs the marketing operation 24/7 with human signoff at the gates. We treat marketing as operations: investment in, qualified revenue out, verified weekly.',
  },
  {
    q: 'Who is Buildwise Media for?',
    a: 'Service-business owners who are already generating real revenue and want to stop running their marketing on hope. Owners who want a system that runs whether they watch it or not tend to thrive. Owners looking for a savior, or hoping for comfort, tend to bounce off our process — and that is the right outcome for both of us.',
  },
  {
    q: 'How fast does the system go live?',
    a: 'Inside 30 days the website is live, ad accounts are wired, the CRM is instrumented, and the first qualified leads start to flow. Full-system instrumentation completes in the same window. We do not run a 90-day waiting period before anything is observable.',
  },
  {
    q: 'How do you measure success?',
    a: 'Every commitment carries a confidence percentage (75% floor), an evidence class (Measured / Attributed / Modeled / Benchmark), and a captured baseline. The Outcomes Commitment Card is the contract. Headline floor: 5× attributable ROI inside 24 months, measured against the baseline we capture on Day 0.',
  },
  {
    q: "What if the system doesn't hit 5×?",
    a: 'We keep building until it does. That is contractual — written into the MSA as a locked clause, not aspirational marketing copy. The 5× ROI floor is the floor we hold ourselves to. If your business is at 4× at Month 24, we are still working. That is what the floor means.',
  },
  {
    q: 'Is there a long-term contract?',
    a: 'No long-term lock-in. The paid Pilot runs 45 days. The 90-day initial operating period starts on the Ascend handoff. After Day 90, the engagement is true month-to-month with no penalty, no clawback, no exit fee. We earn the retainer every month or we don’t.',
  },
  {
    q: 'Where do you operate?',
    a: 'We serve service businesses across the United States. The system installs the same way regardless of metro — local-search depth gets tuned to your specific market during install. Our team is based in Atlanta and we travel to clients on the install when on-site work moves the build forward faster.',
  },
  {
    q: 'How do I own my data?',
    a: 'Everything we build, you own. The code lives in your repository. The customer list lives in your CRM. The ad accounts are in your business. The custom AI agents are configured against your workflows. If you leave, you take the whole system. We walk empty-handed. That sovereignty is in the MSA as a locked clause.',
  },
];

// Anchor for "See the System" secondary CTA → L3 EightLayerSystem
const SYSTEM_ANCHOR = '#system';

// JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/#service-ascend',
  name: 'Ascend',
  serviceType: 'AI marketing department for service businesses',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  description:
    'Ascend installs an 8-layer revenue operating system inside the business — qualified leads, review velocity, local search strength, and AI-search presence operated as one system. Client owns the code, data, ad accounts, and customer list.',
  url: 'https://buildwisemedia.com/services/ascend',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Ascend tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: canonical.products.pilot.name,
        price: canonical.products.pilot.price.oneshot,
        priceCurrency: 'USD',
        description: 'Ascend Pilot — 45-day proof sprint. One-time investment. Converts to Ascend with install fee waived.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend.name,
        price: canonical.products.ascend.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend — full 8-layer revenue operating system installed and operated. Month-to-month after day 90.',
      },
      {
        '@type': 'Offer',
        name: canonical.products.ascend_pro.name,
        price: canonical.products.ascend_pro.price.recurring,
        priceCurrency: 'USD',
        description: 'Ascend Pro — multi-location operator build with custom AI agents, RevOps, and territorial cap.',
      },
    ],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/#faq-home',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[serviceSchema, breadcrumb, faqSchema]}
  preloadImage="/images/bwm-hero-atmospheric-v1.webp"
>

  <!-- ============================================ -->
  <!-- L1 · Hero (4-arm A/B preserved)              -->
  <!-- ============================================ -->
  <section class="home-hero" aria-labelledby="home-hero-title" data-arm={arm} data-hero-arm-root>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The AI Marketing Audit</p>
        <h1 id="home-hero-title" class="h-hero">{heroVariant.question}</h1>
        <p class="hero-sub" data-hero-subhead>{heroVariant.subhead}</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a href="/book" class="cta" data-cta-source="home-hero">See If We're a Fit<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
          <a href={SYSTEM_ANCHOR} class="cta-ghost" data-cta-source="home-hero-system">See the System</a>
        </div>
      </div>
      <figure class="hero-photo">
        <img
          src="/images/bwm-hero-atmospheric-v1.webp"
          alt="A leather chair pulled back from a clean desk in a small-business owner's office at first light, a monitor glowing dim with a soft accent of light on the screen — the moment before the workday starts, with the system already running."
          width="1920"
          height="1080"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <figcaption class="hero-photo-cap mono">
          The morning before the work begins · your seat empty because the system is already running.
        </figcaption>
      </figure>
    </div>
  </section>

  <script is:inline>
    (function () {
      var cQuestionAmount = String.fromCharCode(36) + '1M+';
      var cSubheadAmount = String.fromCharCode(36) + '1M';
      var variants = {
        A: {
          question: "Do you want to be the #1 service business in your market?",
          subhead: "Most #1 shops aren't the best — they're the most-found. The free AI Marketing Audit takes 5 minutes.",
        },
        B: {
          question: "Do you want 3-6 new clients every 90 days?",
          subhead: "Stop running the same playbook and hoping for more leads. The free AI Marketing Audit takes 5 minutes.",
        },
        C: {
          question: "Do you want to add " + cQuestionAmount + " to your service business?",
          subhead: "Stop leaving the next " + cSubheadAmount + " on the table. The free AI Marketing Audit takes 5 minutes.",
        },
        D: {
          question: "Do you want to end the feast or famine?",
          subhead: "Stop guessing where your next clients come from. The free AI Marketing Audit takes 5 minutes.",
        },
      };

      var arm = new URL(window.location.href).searchParams.get('arm');
      arm = arm ? arm.toUpperCase() : 'D';
      if (!Object.prototype.hasOwnProperty.call(variants, arm)) arm = 'D';

      var variant = variants[arm];
      var heroRoot = document.querySelector('[data-hero-arm-root]');
      var heroTitle = document.getElementById('home-hero-title');
      var heroSubhead = document.querySelector('[data-hero-subhead]');
      var metaDescription = document.querySelector('meta[name="description"]');
      var ogDescription = document.querySelector('meta[property="og:description"]');

      if (heroRoot) heroRoot.setAttribute('data-arm', arm);
      if (heroTitle) heroTitle.textContent = variant.question;
      if (heroSubhead) heroSubhead.textContent = variant.subhead;
      document.title = variant.subhead + ' | Buildwise Media';
      if (metaDescription) metaDescription.setAttribute('content', variant.subhead);
      if (ogDescription) ogDescription.setAttribute('content', variant.subhead);
      window.__bwmHeroArm = arm;
    })();
  </script>

  <!-- ============================================ -->
  <!-- L2 · Poor Four                                -->
  <!-- ============================================ -->
  <PoorFour />

  <!-- ============================================ -->
  <!-- L3 · 8-Layer Revenue Operating System         -->
  <!-- ============================================ -->
  <EightLayerSystem />

  <!-- ============================================ -->
  <!-- L4 · Sovereignty                              -->
  <!-- ============================================ -->
  <Sovereignty />

  <!-- ============================================ -->
  <!-- L5 · Product Comparison                       -->
  <!-- ============================================ -->
  <ProductComparison />

  <!-- ============================================ -->
  <!-- L6 · Earn-Back Calculator                     -->
  <!-- ============================================ -->
  <EarnBackCalculator />

  <!-- ============================================ -->
  <!-- L7 · Capability Curve                         -->
  <!-- ============================================ -->
  <AIStorySection />

  <!-- ============================================ -->
  <!-- L8 · Category-of-one (generic, non-geo)       -->
  <!-- Replaces rejected AtlantaMap geo-broadcast    -->
  <!-- ============================================ -->
  <section class="dominance-section" aria-labelledby="dominance-title">
    <div class="container dominance-grid">
      <header class="dominance-head">
        <p class="section-tag">Category of one</p>
        <h2 id="dominance-title" class="h-section">
          Become the most-chosen name in your market.
        </h2>
        <p class="lede">
          Local dominance is not won on one channel. It is won when every signal — AI search, local search, reviews, and neighborhood presence — points to the same business.
        </p>
      </header>

      <figure class="dominance-figure">
        <img
          src="/images/node-mesh-ascending-v1.svg"
          alt="An abstract node-mesh diagram: AI-search citations, local-search rankings, review velocity, and neighborhood-level mentions converging into a single ascending node — the business buyers default to when they look for the category."
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="dominance-cap mono">
          Every signal converging on the same answer · your business as the default.
        </figcaption>
      </figure>

      <ul class="dominance-mechanisms" role="list">
        {dominanceMechanisms.map((m) => (
          <li class="dominance-mech">
            <span class="dot live" aria-hidden="true"></span>
            <div>
              <h3 class="h-sub">{m.name}</h3>
              <p>{m.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L9 · Proof — numeric receipts                 -->
  <!-- ============================================ -->
  <section class="proof-section elev" aria-labelledby="proof-title">
    <div class="container">

      <header class="proof-head">
        <p class="section-tag">Proof</p>
        <h2 id="proof-title" class="h-section">Real numbers. <em>Real receipts.</em></h2>
      </header>

      <ul class="outcome-tiles" role="list">
        {proofTiles.map((tile) => (
          <li class="outcome-tile">
            <span class="kpi-label mono">{tile.label}</span>
            <p class="outcome-num">
              {tile.num}{tile.unit && <span class="outcome-num-unit">{tile.unit}</span>}
            </p>
          </li>
        ))}
      </ul>

      <article class="proof-card">
        <p class="proof-headline">
          One service business went from $300K to $10M in 12 months.<br/>
          Same owner. Same hours. <em>Different system.</em>
        </p>
        <ul class="proof-evidence" role="list">
          <li>
            <span class="tri-tag tri-tag-y2">Measured</span>
            3.2× lift in qualified-lead share at Day-90.
          </li>
          <li>
            <span class="tri-tag tri-tag-y2">Attributed</span>
            Booked-job stitching via UTM + first-touch / last-touch attribution.
          </li>
          <li>
            <span class="tri-tag tri-tag-y2">Modeled</span>
            Review velocity, local search, and AI-search citation moved as one system.
          </li>
        </ul>
        <div class="proof-cta-row">
          <a href="/book" class="cta" data-cta-source="proof-cta">See If We're a Fit<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
          <a href="/results" class="cta-ghost" data-cta-source="proof-results">See more receipts</a>
        </div>
      </article>

    </div>
  </section>

  <!-- ============================================ -->
  <!-- L10 · Playbook teaser (8 items)               -->
  <!-- ============================================ -->
  <section class="playbook-teaser" aria-labelledby="playbook-teaser-title">
    <div class="container">
      <p class="section-tag">The Playbook</p>
      <h2 id="playbook-teaser-title" class="h-section">What we believe.</h2>
      <ul class="playbook-list" role="list">
        {playbookItems.map((item) => (
          <li>
            <a href={item.href}>
              <span class="playbook-link-title">{item.title}</span>
              <span class="playbook-link-sub">{item.sub}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- L11 · FAQ                                     -->
  <!-- ============================================ -->
  <FAQ faqs={faqs} />

  <!-- ============================================ -->
  <!-- L12 · Final CTA                               -->
  <!-- ============================================ -->
  <section class="final-section" aria-labelledby="final-title">
    <div class="container">
      <div class="final-inner">
        <div>
          <p class="section-tag">Start with the audit</p>
          <h2 id="final-title" class="h-closer">Stop guessing where the next client <em>comes from.</em></h2>
          <p class="lede">The free AI Marketing Audit takes 5 minutes. The answer tells us whether Ascend should be installed next.</p>
        </div>
        <a href="/book" class="cta" data-cta-source="home-final">See If We're a Fit<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
      </div>
      <!-- 30-day install timeline · F3 CTA-pull + F2 proof (3 named milestones) -->
      <figure class="final-timeline" aria-labelledby="timeline-cap">
        <svg viewBox="0 0 1000 90" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="From audit to system-live in 30 days: three milestones across one month">
          <line x1="60" y1="50" x2="940" y2="50" stroke="var(--rule)" stroke-width="1"/>
          <line x1="60" y1="50" x2="940" y2="50" stroke="var(--y2)" stroke-width="1.5" stroke-dasharray="2 6"/>
          <circle cx="60" cy="50" r="5" fill="var(--y2)"/>
          <circle cx="500" cy="50" r="5" fill="var(--y2)"/>
          <circle cx="940" cy="50" r="5" fill="var(--y2)"/>
          <text x="60" y="32" text-anchor="start" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">DAY 0</text>
          <text x="60" y="78" text-anchor="start" fill="var(--ink-dim)" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">AUDIT</text>
          <text x="500" y="32" text-anchor="middle" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">DAY 14</text>
          <text x="500" y="78" text-anchor="middle" fill="var(--ink-dim)" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">INSTALL</text>
          <text x="940" y="32" text-anchor="end" fill="var(--y2)" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="2">DAY 30</text>
          <text x="940" y="78" text-anchor="end" fill="var(--ink-dim)" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2">SYSTEM LIVE</text>
        </svg>
        <figcaption id="timeline-cap" class="final-timeline-cap mono">
          Audit to system-live · 30 days · no 90-day waiting period.
        </figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>

<style>
/* ===== L1 Hero ===== */
.home-hero {
  min-height: 100svh;
  display: flex;
  align-items: center;
  padding-top: clamp(104px, 12vw, 168px);
  padding-bottom: clamp(56px, 8vw, 104px);
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.12fr) minmax(240px, 0.88fr);
  gap: clamp(36px, 7vw, 96px);
  align-items: center;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.hero-copy .h-hero { max-width: 880px; }
.hero-copy .hero-sub {
  max-width: 680px;
  font-size: clamp(21px, 2.1vw, 24px);
  font-weight: 500;
  color: var(--ink);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
}

.hero-photo {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.hero-photo img {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 11;
  object-fit: cover;
  display: block;
  border-radius: 6px;
  border: 1px solid var(--rule);
}
.hero-photo-cap {
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-faint);
  text-transform: uppercase;
  line-height: 1.5;
}

/* ===== L8 Dominance section ===== */
.dominance-section {
  padding-block: var(--section-y);
  background: var(--bg);
}

.dominance-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: clamp(40px, 5vw, 64px);
}

.dominance-head {
  max-width: 820px;
}
.dominance-head .lede {
  margin-top: 22px;
}

.dominance-figure {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
}
.dominance-figure img {
  width: 100%;
  max-width: 640px;
  height: auto;
  display: block;
}
.dominance-cap {
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-faint);
  text-transform: uppercase;
  text-align: center;
}

.dominance-mechanisms {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28px;
  padding: 0;
  margin: 0;
}
.dominance-mech {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  gap: 14px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--rule);
}
.dominance-mech .dot {
  margin-top: 12px;
}
.dominance-mech h3 {
  font-size: clamp(20px, 2.2vw, 26px);
  line-height: 1.15;
  margin-bottom: 8px;
}
.dominance-mech p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.55;
}

@media (max-width: 720px) {
  .dominance-mechanisms { grid-template-columns: 1fr; }
}

/* ===== L9 Proof ===== */
.proof-section { padding-block: var(--section-y); }
.proof-head { margin-bottom: 36px; max-width: 720px; }

.outcome-tiles {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 48px;
}
.outcome-tile {
  background: var(--bg-card);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.kpi-label {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
  text-transform: uppercase;
}
.outcome-num {
  font-family: var(--mono);
  font-size: clamp(40px, 5vw, 56px);
  font-weight: 400;
  color: var(--y2);
  line-height: 1;
  margin: 0;
