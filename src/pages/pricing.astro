---
// /pricing — Pricing route
// Plan ref: based-on-all-nifty-karp.md §3.8 + §L5 + §6 Phase 3
// Pricing-public lock: RATIFIED 2026-05-20
// JSON-LD: Service schema with hasOfferCatalog (3 Offer items sourced from canonical)
// Voice: team voice — no "I", no Robert, no vendors named
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductComparison from '../components/ProductComparison.astro';
import FAQ from '../components/FAQ.astro';
import canonical from '../data/canonical.json';

const pilot  = canonical.products.pilot;
const ascend = canonical.products.ascend;
const pro    = canonical.products.ascend_pro;
const layers = canonical.products.ascend.eight_layers;
const msa    = canonical.contract.msa_locked_clauses;
const title = "Pricing — Commercial Marketing System for Multi-Location Service Businesses";
const description = "Buildwise Media pricing: Ascend Pilot $15K one-time, Ascend $7K/mo, Ascend Pro $15K/mo for multi-location service businesses. Transparent pricing, true month-to-month after Day 90.";
const pricingSignals = [
  { label: 'Entry sprint', name: pilot.name, price: pilot.price.oneshot_display, tone: 'cyan' },
  { label: 'Main system', name: ascend.name, price: ascend.price.recurring_display, tone: 'yellow' },
  { label: 'Market lock', name: pro.name, price: pro.price.recurring_display, tone: 'green' },
];
const valueMath = [
  { label: 'Year-one system cost', value: '$78K', body: 'Pilot plus nine operating months after conversion.' },
  { label: 'Pilot graduates', value: '$0', body: 'No second install fee after the $15K Pilot.' },
  { label: 'Distribution budget', value: '1:1', body: 'You pay ad platforms direct. Buildwise never touches ad dollars.' },
];
const roiChecks = [
  { label: 'What must be true', body: 'A few closed jobs must repay the install and operating cost. If your average job cannot support that, the diagnostic should stop us early.', tone: 'cyan' },
  { label: 'Why public pricing', body: 'Qualified owners should know the economic class before sharing company numbers. No price-discovery call required.', tone: 'green' },
  { label: 'Why it earns back', body: 'Ascend attacks leaks closest to cash first: slow response, quote follow-up, booked-job tracking, and channels already showing signal.', tone: 'orange' },
];
const pricingLinks = [
  { href: '/services/ascend', label: 'Ascend system' },
  { href: '/services/ascend-pilot', label: 'Ascend Pilot' },
  { href: '/system', label: '8-layer system' },
  { href: '/audit', label: 'Revenue Leak Map' },
];
const ownerLayerBodies: Record<string, string> = {
  Visibility: 'Show up when buyers search, ask AI, or compare local providers.',
  Conversion: 'Make calls, forms, pages, and quote paths easier to act on.',
  'Speed-to-Lead': 'Reply before the lead cools off or calls a competitor.',
  'Sales Ops': 'Keep quotes, pipeline stages, and past leads moving.',
  Reputation: 'Turn finished work into reviews and proof.',
  'Paid Media': 'Watch spend, test creative, and move budget toward better leads.',
  Reporting: 'Show spend, source, calls, leads, booked work, and next moves.',
  Strategy: 'Use a weekly scoreboard instead of a late-month guess.',
};

// JSON-LD: Service schema with 3-tier offer catalog (canonical-sourced)
const pricingJsonLd = {
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/pricing#service',
  name: 'Buildwise Media — Installed AI Growth System',
  description:
    'Owned AI growth system for service businesses. Three commitment shapes: Ascend Pilot, Ascend, and Ascend Pro. Same 5x return on investment floor.',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Buildwise Media Tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: pilot.name,
        description:
          'A 45-day proof sprint. The $15,000 Pilot fee covers the Ascend install scope — Pilot graduates begin Ascend at no additional install fee.',
        price: String(pilot.price.oneshot),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(pilot.price.oneshot),
          priceCurrency: 'USD',
          description: 'One-time fee, covers install scope',
        },
        eligibleDuration: {
          '@type': 'QuantitativeValue',
          value: 45,
          unitCode: 'DAY',
        },
      },
      {
        '@type': 'Offer',
        name: ascend.name,
        description:
          'The main product. Full 8-layer revenue operating system installed in your environment, operated weekly, owned by you. Month-to-month after Day 90.',
        price: String(ascend.price.recurring),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(ascend.price.recurring),
          priceCurrency: 'USD',
          billingDuration: {
            '@type': 'QuantitativeValue',
            value: 1,
            unitCode: 'MON',
          },
          description: 'Monthly recurring + $15,000 one-time install',
        },
      },
      {
        '@type': 'Offer',
        name: pro.name,
        description:
          'For multi-location service businesses building market depth. Adds custom AI agents, operating infrastructure, brand spine, and territory strategy. Month-to-month after Day 90.',
        price: String(pro.price.recurring),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(pro.price.recurring),
          priceCurrency: 'USD',
          billingDuration: {
            '@type': 'QuantitativeValue',
            value: 1,
            unitCode: 'MON',
          },
          description: 'Monthly recurring + $25,000 one-time install',
        },
      },
    ],
  },
};

// JSON-LD: BreadcrumbList — Home › Pricing (leaf matches the trailing-slash canonical)
const pricingBreadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://buildwisemedia.com/pricing/' },
  ],
};

// FAQ — voice-search phrased, mined from the on-page pricing facts above. The
// FAQPage schema is emitted alongside the rendered <FAQ> section so answer engines
// see matching question/answer content. Prices inherit from canonical (The Book).
const faqs = [
  {
    q: 'How much does Buildwise Media cost?',
    a: `Pricing is public. Ascend Pilot is ${pilot.price.oneshot_display} one-time — a 45-day proof sprint that covers your install. Ascend is ${ascend.price.recurring_display} plus a ${ascend.price.oneshot_display} install, waived for Pilot graduates. Ascend Pro is ${pro.price.recurring_display} plus a ${pro.price.oneshot_display} install for multi-location operators.`,
  },
  {
    q: 'Is the install fee one-time, and do Pilot graduates pay it twice?',
    a: `The install fee is one-time. The ${pilot.price.oneshot_display} Pilot already covers the Ascend install scope, so graduates start Ascend with no second install fee. There is no exit fee and no clawback.`,
  },
  {
    q: 'Is there a long-term contract?',
    a: 'No long-term lock-in. You pay the Pilot up front, then a 90-day initial operating period starts when Ascend goes live. After Day 90 the system is true month-to-month — no penalty, no exit fee. We earn the operating fee every month or we do not.',
  },
  {
    q: 'What is the return floor, and what if the system does not hit it?',
    a: 'Every tier holds the same floor: 5x attributable return on investment inside 24 months. It is written into the agreement and measured against the baseline we capture on Day 0. If you are below it at Month 24, we keep building until you reach it.',
  },
  {
    q: 'Do you mark up or manage my ad budget?',
    a: 'No. Ad spend is 1:1 and paid straight to the platforms from your own accounts. We never touch your ad dollars and never mark them up. You pay us to run the system; you pay the platforms direct.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/pricing#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[pricingJsonLd, pricingBreadcrumb, faqSchema]}
>

  <!-- Pricing hero -->
  <section class="pricing-hero">
    <div class="container pricing-hero-inner">
      <div>
        <p class="eyebrow">PRICING</p>
        <h1 class="h-hero pricing-h1">One Commercial Marketing System. Three Entry Points. All Yours.</h1>
        <h2 class="pricing-keyword-subhead">Commercial marketing system for multi-location service businesses — three entry points.</h2>
        <p class="lede pricing-lede">
          Three commitment shapes. Same commercial marketing system. Same 5x return on investment floor. The fit question is whether your market opportunity is large enough for Ascend to be obvious.
        </p>
        <div class="pricing-hero-actions">
          <a href="/book" class="cta" data-cta-source="pricing-hero">Get My Free Revenue Leak Map<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href="/book" class="cta-ghost" data-cta-source="pricing-fit">See If We're a Fit</a>
        </div>
        <dl class="pricing-math-strip" aria-label="Pricing value math">
          {valueMath.map((item) => (
            <div>
              <dt class="mono">{item.label}</dt>
              <dd>
                <strong>{item.value}</strong>
                <span>{item.body}</span>
              </dd>
            </div>
          ))}
        </dl>
      </div>
      <aside class="pricing-console ops-panel" aria-label="Pricing architecture console">
        <div class="pricing-console-head">
          <p class="ops-kicker">Price architecture</p>
          <span class="ops-chip"><span class="dot green" aria-hidden="true"></span>public</span>
        </div>
        <div class="pricing-console-grid">
          {pricingSignals.map((item) => (
            <article class={`pricing-signal tone-${item.tone}`}>
              <span class="mono">{item.label}</span>
              <strong>{item.price}</strong>
              <em>{item.name}</em>
            </article>
          ))}
        </div>
        <p class="pricing-console-note">The diagnostic checks whether your market opportunity can support the operating cost before we ask for a booking.</p>
        <nav class="pricing-related-links" aria-label="Related pricing pages">
          {pricingLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </aside>
    </div>
  </section>

  <!-- Product comparison (built by parallel agent — L5) -->
  <section id="price-architecture" class="pricing-comparison-section">
    <div class="container">
      <ProductComparison />
    </div>
  </section>

  <section class="pricing-roi-section elev" aria-labelledby="pricing-roi-title">
    <div class="container pricing-roi-grid">
      <header>
        <p class="section-tag">Why this pencils</p>
        <h2 id="pricing-roi-title" class="h-section">Premium pricing only works when the math is visible.</h2>
        <p class="lede">Ascend is not priced for hobby marketing. It is priced for service businesses where an owned, improving system can change the year.</p>
      </header>
      <div class="roi-check-grid">
        {roiChecks.map((item) => (
          <article class={`roi-check tone-${item.tone}`}>
            <p class="ops-kicker">{item.label}</p>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- What you get: 8 layers -->
  <section class="pricing-layers-section">
    <div class="container">

      <header class="pricing-layers-header">
        <p class="section-tag">WHAT YOU GET</p>
        <h2 class="h-section pricing-layers-h2">
          The 8 layers that run your growth.
        </h2>
        <p class="lede">
          Every tier runs on the same operating system. The layers connect so improving one helps the rest.
        </p>
      </header>

      <div class="pricing-layers-grid">
        {layers.map((raw: string, i: number) => {
          const dashIdx = raw.indexOf('—');
          const dotIdx  = raw.indexOf('·');
          const name    = dashIdx > 0
            ? raw.slice(dotIdx + 1, dashIdx).trim()
            : raw.slice(dotIdx + 1).trim();
          const body    = ownerLayerBodies[name] ?? '';
          const num     = String(i + 1).padStart(2, '0');
          return (
            <article class="pricing-layer-card card">
              <p class="pricing-layer-num mono">{num}</p>
              <h3 class="h-sub pricing-layer-name">{name}</h3>
              <p class="pricing-layer-body card-body">{body}</p>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- Contract: MSA locked clauses -->
  <section class="pricing-contract-section">
    <div class="container">

      <header class="pricing-contract-header">
        <p class="section-tag">THE CONTRACT</p>
        <h2 class="h-section">
          What the agreement actually says.
        </h2>
        <p class="lede">
          Every client signs the same universal contract. No surprise conditions.
        </p>
      </header>

      <div class="pricing-contract-grid">
        {msa.map((clause: string) => (
          <div class="pricing-contract-card card">
            <span class="dot live"></span>
            <p class="pricing-contract-text">{clause}</p>
          </div>
        ))}
      </div>

      <!-- Key contract highlight -->
      <div class="pricing-contract-highlight card">
        <p class="eyebrow">UNIVERSAL CONTRACT SHAPE</p>
        <p class="pricing-contract-highlight-text">
          Paid Pilot ${pilot.price.oneshot.toLocaleString()} up-front · 1:1 ad spend paid direct to platforms · 90-day initial operating period · true month-to-month after Day 90.
        </p>
        <p class="pricing-contract-note mono">
          Pilot graduates do not pay a second install fee. No exit fee. No clawback.
        </p>
      </div>

    </div>
  </section>

  <!-- FAQ — answer-engine extractable Q&A, matches FAQPage schema -->
  <FAQ faqs={faqs} />

  <section class="pricing-final-cta elev" aria-labelledby="pricing-final-title">
    <div class="container pricing-final-row">
      <div>
        <p class="section-tag">Start with the map</p>
        <h2 id="pricing-final-title" class="h-closer">Know the leak before you choose the entry point.</h2>
        <p class="lede">The free Revenue Leak Map shows whether Pilot, Ascend, or Pro has a clear first move. We build it from your business and walk it with you on the call.</p>
      </div>
      <div class="pricing-final-actions">
        <a href="/book" class="cta" data-cta-source="pricing-final-primary">Get My Free Revenue Leak Map<span class="cta-arrow" aria-hidden="true">→</span></a>
        <a href="/book" class="cta-ghost" data-cta-source="pricing-final-secondary">See If We're a Fit</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ============ Hero ============ */
.pricing-hero {
  padding-block: clamp(96px, 9vw, 128px) clamp(56px, 7vw, 88px);
  background: var(--bg);
}
.pricing-hero-inner {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(300px, 0.78fr);
  gap: clamp(32px, 5vw, 64px);
  align-items: center;
}
.pricing-h1 {
  color: var(--ink);
  margin-bottom: 14px;
}
.pricing-keyword-subhead {
  max-width: 720px;
  margin: 0 0 24px;
  color: var(--ink);
  font-size: clamp(22px, 3vw, 34px);
  line-height: 1.15;
  font-weight: 500;
}
.pricing-lede { max-width: 680px; }
.pricing-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 24px;
}
.pricing-math-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  margin-top: 22px;
  max-width: 720px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.pricing-math-strip div {
  min-width: 0;
  background: rgba(15, 15, 20, 0.72);
  padding: 16px;
  border-top: 2px solid var(--y2);
}
.pricing-math-strip dt {
  color: var(--ink-faint);
  font-size: 8px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.pricing-math-strip dd {
  margin: 8px 0 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.pricing-math-strip strong {
  color: var(--ink);
  font-size: 28px;
  line-height: 1;
}
.pricing-math-strip span {
  color: var(--ink-dim);
  font-size: 12px;
  line-height: 1.35;
}
.pricing-console {
  padding: clamp(20px, 2.5vw, 28px);
}
.pricing-console > * {
  position: relative;
  z-index: 1;
}
.pricing-console-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14px;
  margin-bottom: 16px;
}
.pricing-console-grid {
  display: grid;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.pricing-signal {
  background: var(--bg);
  border-left: 3px solid currentColor;
  padding: 18px;
}
.pricing-signal span {
  color: var(--ink-faint);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}
.pricing-signal strong {
  display: block;
  margin-block: 10px 6px;
  font-size: clamp(28px, 3.4vw, 46px);
  line-height: 1;
  letter-spacing: -0.05em;
  color: var(--ink);
}
.pricing-signal em {
  font-family: var(--mono);
  font-style: normal;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: currentColor;
}
.pricing-console-note {
  margin-top: 18px;
  color: var(--ink-dim);
  font-size: 14px;
  line-height: 1.55;
}
.pricing-related-links {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 18px;
}
.pricing-related-links a {
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.13em;
  line-height: 1.2;
  padding: 8px 9px;
  text-transform: uppercase;
  transition: border-color 180ms ease, color 180ms ease;
}
.pricing-related-links a:hover {
  border-color: var(--y2);
  color: var(--ink);
}

/* ============ Comparison section ============ */
.pricing-comparison-section {
  padding-block: 0 clamp(56px, 7vw, 88px);
  background: var(--bg);
}

.pricing-roi-section { padding-block: clamp(56px, 7vw, 88px); }
.pricing-roi-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
  gap: clamp(32px, 5vw, 64px);
  align-items: start;
}
.pricing-roi-grid header {
  position: sticky;
  top: 104px;
}
.pricing-roi-grid .lede { margin-top: 22px; }
.roi-check-grid {
  display: grid;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}
.roi-check {
  background: var(--bg-card);
  border-left: 3px solid currentColor;
  padding: clamp(20px, 2.5vw, 28px);
}
.roi-check p:last-child {
  margin-top: 12px;
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.6;
}

/* ============ 8-layer section ============ */
.pricing-layers-section {
  padding-block: clamp(56px, 7vw, 88px);
  background: var(--bg-elev);
}
.pricing-layers-header {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 36px;
  max-width: 760px;
}
.pricing-layers-h2 { color: var(--ink); }

.pricing-layers-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
}
@media (max-width: 960px) {
  .pricing-layers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 520px) {
  .pricing-layers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .pricing-layer-card { padding: 18px 16px; }
  .pricing-layer-name { font-size: 17px; }
  .pricing-layer-body { display: none; }
}

.pricing-layer-card {
  background: var(--bg-card);
  border: none;
  border-radius: 0;
  padding: 22px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: background 180ms ease;
}
.pricing-layer-card:hover { background: var(--bg-elev); }

.pricing-layer-num {
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--y2);
}
.pricing-layer-name {
  font-size: clamp(18px, 2vw, 24px);
  color: var(--ink);
}
.pricing-layer-body {
  font-size: 13px;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* ============ Contract section ============ */
.pricing-contract-section {
  padding-block: clamp(56px, 7vw, 88px);
  background: var(--bg);
}
.pricing-contract-header {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 36px;
  max-width: 760px;
}

.pricing-contract-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}
@media (max-width: 640px) {
  .pricing-contract-grid { grid-template-columns: 1fr; }
}

@media (max-width: 900px) {
  .pricing-hero-inner,
  .pricing-roi-grid { grid-template-columns: 1fr; }
  .pricing-roi-grid header { position: static; }
}

@media (max-width: 560px) {
  .pricing-hero {
    padding-top: 92px;
    padding-bottom: 48px;
  }

  .pricing-h1 {
    font-size: 34px;
    line-height: 1.03;
    letter-spacing: 0;
  }

  .pricing-lede {
    font-size: 16px;
    line-height: 1.5;
  }
  .pricing-console { padding: 18px; }
  .pricing-signal { padding: 14px; }
  .pricing-signal strong { font-size: 32px; }

  .pricing-math-strip {
    grid-template-columns: 1fr;
  }

  .pricing-hero-actions .cta,
  .pricing-hero-actions .cta-ghost {
    width: 100%;
    justify-content: center;
  }
}

.pricing-contract-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 24px;
}
.pricing-contract-card .dot {
  flex-shrink: 0;
  margin-top: 4px;
}
.pricing-contract-text {
  font-size: 15px;
  font-weight: 400;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* Contract highlight card */
.pricing-contract-highlight {
  border-left: 2px solid var(--y2);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.pricing-contract-highlight .eyebrow::before { display: none; }
.pricing-contract-highlight-text {
  font-family: var(--sans);
  font-size: clamp(20px, 2.5vw, 28px);
  font-weight: 700;
  font-stretch: 75%;
  letter-spacing: -0.02em;
  line-height: 1.3;
  color: var(--ink);
}
.pricing-contract-note {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
}
.pricing-final-cta { padding-block: clamp(56px, 7vw, 88px); }
.pricing-final-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: clamp(28px, 4vw, 52px);
