---
// /pricing — Pricing route
// Plan ref: based-on-all-nifty-karp.md §3.8 + §L5 + §6 Phase 3
// Pricing-visible lock: RATIFIED 2026-05-20 (flip from pricing-hidden-from-humans)
// JSON-LD: Service schema with hasOfferCatalog (3 Offer items sourced from canonical)
// Voice: team voice — no "I", no Robert, no vendors named
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductComparison from '../components/ProductComparison.astro';
import FinalCta from '../components/FinalCta.astro';
import canonical from '../data/canonical.json';

const pilot  = canonical.products.pilot;
const ascend = canonical.products.ascend;
const pro    = canonical.products.ascend_pro;
const layers = canonical.products.ascend.eight_layers;
const msa    = canonical.contract.msa_locked_clauses;
const publicLayerBody = (body: string) => body
  .replace(/\s*\([^)]*\)/g, '')
  .replace(/GBP \+ AEO \+ local SEO \+ schema \+ citations \+ AI-search readiness/g, 'local search, AEO, schema, citations, and AI-search readiness')
  .replace(/Instant SMS\/email\/call follow-up · automated qualification · appointment routing · .* integration/g, 'instant follow-up, automated qualification, appointment routing, and operations integration')
  .replace(/Campaign monitoring · creative testing · budget alerts · lead-quality feedback · .*/g, 'Campaign monitoring, creative testing, budget alerts, and lead-quality feedback')
  .replace(/\s+/g, ' ')
  .trim();

// JSON-LD: Service schema with 3-tier offer catalog (canonical-sourced)
const pricingJsonLd = {
  '@type': 'Service',
  '@id': 'https://buildwisemedia.com/pricing#service',
  name: 'Buildwise Media — 8-Layer Revenue Operating System',
  description:
    'AI-operated marketing system for service businesses. Three commitment shapes: Ascend Pilot, Ascend, and Ascend Pro. Same 8-layer revenue operating system. Same 5× ROI floor.',
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: {
    '@type': 'Place',
    name: 'Atlanta, GA (metro) and surrounding markets',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Buildwise Media Tiers',
    itemListElement: [
      {
        '@type': 'Offer',
        name: pilot.name,
        description:
          'A 45-day proof sprint. The $15,000 Pilot fee covers the Ascend install scope — Pilot graduates begin Ascend at no additional install fee.',
        price: String(pilot.price.oneshot),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(pilot.price.oneshot),
          priceCurrency: 'USD',
          description: 'One-time fee, covers install scope',
        },
        eligibleDuration: {
          '@type': 'QuantitativeValue',
          value: 45,
          unitCode: 'DAY',
        },
      },
      {
        '@type': 'Offer',
        name: ascend.name,
        description:
          'The main product. Full 8-layer revenue operating system installed in your environment, operated weekly, owned by you. Month-to-month after Day 90.',
        price: String(ascend.price.recurring),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(ascend.price.recurring),
          priceCurrency: 'USD',
          billingDuration: {
            '@type': 'QuantitativeValue',
            value: 1,
            unitCode: 'MON',
          },
          description: 'Monthly recurring + $15,000 one-time install',
        },
      },
      {
        '@type': 'Offer',
        name: pro.name,
        description:
          'For owners building market dominance. Multi-location, outbound infrastructure, custom AI agents, RevOps, brand spine, vertical-SaaS integrations. Month-to-month after Day 90.',
        price: String(pro.price.recurring),
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: String(pro.price.recurring),
          priceCurrency: 'USD',
          billingDuration: {
            '@type': 'QuantitativeValue',
            value: 1,
            unitCode: 'MON',
          },
          description: 'Monthly recurring + $25,000 one-time install',
        },
      },
    ],
  },
};
---

<BaseLayout
  title="Pricing — Buildwise Media"
  description={`Three commitment shapes. Same 8-layer revenue operating system. Pilot $${pilot.price.oneshot.toLocaleString()} one-time · Ascend $${ascend.price.recurring.toLocaleString()}/mo + $${ascend.price.oneshot.toLocaleString()} install · Pro $${pro.price.recurring.toLocaleString()}/mo + $${pro.price.oneshot.toLocaleString()} install. Month-to-month after day 90.`}
  jsonLd={pricingJsonLd}
>

  <!-- Pricing hero -->
  <section class="pricing-hero">
    <div class="container pricing-hero-inner">
      <p class="eyebrow">PRICING</p>
      <h1 class="h-hero pricing-h1">Pricing.</h1>
      <p class="lede pricing-lede">
        Three commitment shapes. Same 8-layer revenue operating system. Same 5× ROI floor. Choose the one that fits how you want to enter.
      </p>
    </div>
  </section>

  <!-- Product comparison (built by parallel agent — L5) -->
  <section class="pricing-comparison-section">
    <div class="container">
      <ProductComparison />
    </div>
  </section>

  <!-- What you get: 8 layers -->
  <section class="pricing-layers-section">
    <div class="container">

      <header class="pricing-layers-header">
        <p class="section-tag">WHAT YOU GET</p>
        <h2 class="h-section pricing-layers-h2">
          The 8 layers that run your growth.
        </h2>
        <p class="lede">
          Every tier runs on the same 8-layer operating system. The layers connect — so improving one tightens the others automatically.
        </p>
      </header>

      <div class="pricing-layers-grid">
        {layers.map((raw: string, i: number) => {
          const dashIdx = raw.indexOf('—');
          const dotIdx  = raw.indexOf('·');
          const name    = dashIdx > 0
            ? raw.slice(dotIdx + 1, dashIdx).trim()
            : raw.slice(dotIdx + 1).trim();
          const body    = dashIdx > 0 ? publicLayerBody(raw.slice(dashIdx + 1).trim()) : '';
          const num     = String(i + 1).padStart(2, '0');
          return (
            <article class="pricing-layer-card card">
              <p class="pricing-layer-num mono">{num}</p>
              <h3 class="h-sub pricing-layer-name">{name}</h3>
              <p class="pricing-layer-body card-body">{body}</p>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- Contract: MSA locked clauses -->
  <section class="pricing-contract-section">
    <div class="container">

      <header class="pricing-contract-header">
        <p class="section-tag">THE CONTRACT</p>
        <h2 class="h-section">
          What the agreement actually says.
        </h2>
        <p class="lede">
          Every client signs the same universal contract. No hidden conditions.
        </p>
      </header>

      <div class="pricing-contract-grid">
        {msa.map((clause: string) => (
          <div class="pricing-contract-card card">
            <span class="dot live"></span>
            <p class="pricing-contract-text">{clause}</p>
          </div>
        ))}
      </div>

      <!-- Key contract highlight -->
      <div class="pricing-contract-highlight card">
        <p class="eyebrow">UNIVERSAL CONTRACT SHAPE</p>
        <p class="pricing-contract-highlight-text">
          Paid Pilot ${pilot.price.oneshot.toLocaleString()} up-front · 90-day initial operating period · true month-to-month, no penalty, after Day 90.
        </p>
        <p class="pricing-contract-note mono">
          No exit fee. No clawback. No long-term lock-in.
        </p>
      </div>

    </div>
  </section>

  <!-- Final CTA -->
  <FinalCta />

</BaseLayout>

<style>
/* ============ Hero ============ */
.pricing-hero {
  padding-block: var(--section-y);
  background: var(--bg);
}
.pricing-hero-inner {
  display: flex;
  flex-direction: column;
  gap: 24px;
  max-width: 900px;
}
.pricing-h1 { color: var(--ink); }
.pricing-lede { max-width: 680px; }

/* ============ Comparison section ============ */
.pricing-comparison-section {
  padding-block: 0 var(--section-y);
  background: var(--bg);
}

/* ============ 8-layer section ============ */
.pricing-layers-section {
  padding-block: var(--section-y);
  background: var(--bg-elev);
}
.pricing-layers-header {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 48px;
  max-width: 760px;
}
.pricing-layers-h2 { color: var(--ink); }

.pricing-layers-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
}
@media (max-width: 960px) {
  .pricing-layers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 520px) {
  .pricing-layers-grid { grid-template-columns: 1fr; }
}

.pricing-layer-card {
  background: var(--bg-card);
  border: none;
  border-radius: 0;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: background 180ms ease;
}
.pricing-layer-card:hover { background: var(--bg-elev); }

.pricing-layer-num {
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--y2);
}
.pricing-layer-name {
  font-size: clamp(18px, 2vw, 24px);
  color: var(--ink);
}
.pricing-layer-body {
  font-size: 13px;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* ============ Contract section ============ */
.pricing-contract-section {
  padding-block: var(--section-y);
  background: var(--bg);
}
.pricing-contract-header {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 48px;
  max-width: 760px;
}

.pricing-contract-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}
@media (max-width: 640px) {
  .pricing-contract-grid { grid-template-columns: 1fr; }
}

.pricing-contract-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 24px;
}
.pricing-contract-card .dot {
  flex-shrink: 0;
  margin-top: 4px;
}
.pricing-contract-text {
  font-size: 15px;
  font-weight: 400;
  line-height: 1.55;
  color: var(--ink-dim);
}

/* Contract highlight card */
.pricing-contract-highlight {
  border-left: 2px solid var(--y2);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.pricing-contract-highlight .eyebrow::before { display: none; }
.pricing-contract-highlight-text {
  font-family: var(--sans);
  font-size: clamp(20px, 2.5vw, 28px);
  font-weight: 700;
  font-stretch: 75%;
  letter-spacing: -0.02em;
  line-height: 1.3;
  color: var(--ink);
}
.pricing-contract-note {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-faint);
}
</style>
