---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = "About — Buildwise Media";
const description = "Buildwise Media installs and runs Ascend, a custom AI system built for home service businesses. You run the business. We run the marketing, with proof every week.";

const workSteps = [
  {
    name: "Audit",
    body: "Ascend starts by finding where qualified leads come from now, where they leak, and what proof buyers see before they call.",
  },
  {
    name: "Install",
    body: "The system is placed inside the business: lead paths, review flow, local search, AI search presence, and follow-up.",
  },
  {
    name: "Run",
    body: "The Buildwise team and our AI system keep the operating layer moving so the owner can stay focused on the business.",
  },
];

// Organization schema is emitted site-wide via BaseLayout siteSchemas
// (see src/layouts/BaseLayout.astro) — no need to redeclare here.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://buildwisemedia.com/about' },
  ],
};

const aboutPage = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://buildwisemedia.com/about#aboutpage',
  name: title,
  description,
  url: 'https://buildwisemedia.com/about',
  about: { '@id': 'https://buildwisemedia.com/#org' },
};

// FAQ — voice-search phrased, mined from on-page copy. FAQPage schema emitted
// alongside the rendered <FAQ> section so answer engines see matching content.
const faqs = [
  {
    q: 'What is Buildwise Media?',
    a: 'We install Ascend — an owned AI growth system — inside owner-led service businesses, and the Buildwise team runs it with our AI operating layer. The marketing work that usually gets pushed onto the owner after hours becomes a system the business owns.',
  },
  {
    q: 'Where is Buildwise Media based, and where do you work?',
    a: 'Our team is based in Atlanta, and we serve service businesses across the United States. The system installs the same way regardless of metro — local depth gets tuned to your market during install.',
  },
  {
    q: 'What is the goal for a client?',
    a: 'To become the most-chosen name in your market within 12 months — the category of one in your service area. We map the lead path, tighten follow-up, grow reviews, and strengthen local and AI search until your presence keeps compounding.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/about#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[aboutPage, breadcrumb, faqSchema]}
  preloadImage="/images/bwm-about-atmospheric-v1.webp"
>
  <section class="about-hero" aria-labelledby="about-title">
    <div class="container about-hero-inner">
      <p class="eyebrow">About Buildwise Media</p>
      <h1 id="about-title" class="h-hero">
        You run the business. Ascend makes you the most-chosen name in your market within 12 months.
      </h1>
      <figure class="section-photo section-photo--about-hero">
        <!-- @r020:F1 emotion: first-light operations floor — the team and its AI system already at work, the aspirational "run by people who run a real system" pull toward the fit CTA -->
        <img src="/images/bwm-about-atmospheric-v1.webp" alt="First-light operations floor: workbench, monitor, paper plans, and a single visible desk lamp. The team and its AI system at work before the world wakes up." width="1920" height="1080" loading="eager" decoding="async" fetchpriority="high" />
      </figure>
    </div>
  </section>

  <section class="mission-section elev" aria-labelledby="mission-title">
    <div class="container mission-grid">
      <div>
        <p class="section-tag">Mission</p>
        <h2 id="mission-title" class="h-section">
          We democratize AI capabilities for American small business owners by installing Ascend in their business.
        </h2>
      </div>
      <div class="prose mission-copy">
        <p class="lead">
          Installing Ascend means the system does the work that usually gets pushed onto the owner after hours.
        </p>
        <p>
          It maps the lead path, tightens follow-up, grows review velocity, strengthens local search, and makes the business easier for AI search to understand.
        </p>
        <p>
          The Buildwise team runs the system with our AI operating layer. The owner gets fewer loose ends, clearer demand signals, and <a href="/playbook/category-of-one-marketing">a market presence that keeps compounding</a>.
        </p>
      </div>
      <figure class="section-photo section-photo--mission">
        <!-- @r020:F2 proof: measurement still-life — printed graph, pen, magnifying glass — the conservative-proof posture behind the baseline-first claim -->
        <img src="/images/bwm-proof-still-life-v1.webp" alt="Macro still-life: an illegible printed graph on aged paper beside a fountain pen and a magnifying glass." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="work-section" aria-labelledby="work-title">
    <div class="container">
      <div class="work-head">
        <p class="section-tag">How we work</p>
        <h2 id="work-title" class="h-section">Audit, install, run.</h2>
      </div>
      <figure class="section-photo section-photo--work">
        <!-- @r020:F1 emotion: human-and-machine collaboration — a hand annotating beside live code — grounds "the team runs it with our AI layer" in real work -->
        <img src="/images/bwm-about-environmental-cinematic-v1.webp" alt="A hand mid-annotation in a notebook beside a monitor showing blurred code. Human and machine collaborating quietly." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
      <div class="work-grid">
        {workSteps.map((step, index) => (
          <article class="work-card">
            <p class="work-num mono">{String(index + 1).padStart(2, '0')}</p>
            <h3>{step.name}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
      <figure class="section-photo section-photo--team">
        <!-- @r020:F1 emotion: a real team running the system in parallel focus — the credibility proof that a human team stands behind the AI before the fit CTA -->
        <img src="/images/bwm-team-editorial-v1.webp" alt="Two operators side-by-side at a long desk, both heads-down on laptops in cool morning light — the team running the system in parallel focus." width="1920" height="1080" loading="lazy" decoding="async" />
      </figure>
      <p class="trust-line">It actually works.</p>
    </div>
  </section>

  <!-- FAQ — answer-engine extractable Q&A, matches FAQPage schema -->
  <FAQ faqs={faqs} />

  <section class="about-cta elev" aria-labelledby="about-cta-title">
    <div class="container about-cta-row">
      <div>
        <p class="section-tag">Next step</p>
        <h2 id="about-cta-title" class="h-closer">See whether Ascend fits the business.</h2>
      </div>
      <a href="/book" class="cta" data-cta-source="about-final">See If We're a Fit<span class="cta-arrow" aria-hidden="true">-&gt;</span></a>
    </div>
  </section>
</BaseLayout>

<style>
.about-hero {
  padding-top: clamp(132px, 14vw, 196px);
  padding-bottom: clamp(72px, 9vw, 128px);
}

.section-photo {
  margin: clamp(40px, 6vw, 72px) 0 0;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--rule);
  aspect-ratio: 21 / 9;
  width: 100%;
}

.section-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.section-photo--about-hero {
  aspect-ratio: 21 / 9;
  margin-top: clamp(32px, 4vw, 48px);
}

.section-photo--mission {
  aspect-ratio: 16 / 10;
  margin-top: clamp(28px, 4vw, 40px);
}

.section-photo--work {
  aspect-ratio: 21 / 9;
  margin-top: clamp(28px, 4vw, 40px);
  margin-bottom: clamp(40px, 6vw, 72px);
}

.section-photo--team {
  aspect-ratio: 21 / 9;
  margin-top: clamp(28px, 4vw, 40px);
  margin-bottom: clamp(28px, 4vw, 40px);
}

@media (max-width: 880px) {
  .section-photo, .section-photo--about-hero, .section-photo--mission, .section-photo--work, .section-photo--team {
    aspect-ratio: 16 / 10;
  }
}

.about-hero-inner {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.about-hero .h-hero {
  max-width: 1080px;
}

.mission-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  gap: clamp(44px, 7vw, 96px);
  align-items: start;
}

.mission-copy {
  border-left: 1px solid var(--rule-bright);
  padding-left: clamp(24px, 4vw, 48px);
}

.work-head {
  max-width: 720px;
  margin-bottom: 42px;
}

.work-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.work-card {
  border: 1px solid var(--rule);
  border-radius: 4px;
  background: var(--bg-card);
  padding: clamp(24px, 4vw, 34px);
  min-height: 280px;
}

.work-num {
  color: var(--y2);
  font-size: 11px;
  letter-spacing: 0.16em;
  margin-bottom: 32px;
}

.work-card h3 {
  font-size: clamp(25px, 3vw, 34px);
  line-height: 1;
  margin-bottom: 14px;
}

.work-card p {
  color: var(--ink-dim);
  font-size: 16px;
  line-height: 1.6;
}

.trust-line {
  margin-top: 38px;
  padding-top: 26px;
  border-top: 1px solid var(--rule);
  color: var(--ink);
  font-size: clamp(24px, 3vw, 34px);
  font-weight: 800;
  line-height: 1.1;
}

.about-cta-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: clamp(28px, 5vw, 72px);
  align-items: end;
}

.about-cta-row .cta {
  margin-bottom: 8px;
}

@media (max-width: 900px) {
  .mission-grid,
  .work-grid,
  .about-cta-row {
    grid-template-columns: 1fr;
  }

  .mission-copy {
    border-left: 0;
    border-top: 1px solid var(--rule-bright);
    padding-left: 0;
    padding-top: 28px;
  }
}

@media (max-width: 520px) {
  .about-hero {
    padding-top: 112px;
  }

  .about-cta-row .cta {
    width: 100%;
    justify-content: center;
  }
}
</style>
