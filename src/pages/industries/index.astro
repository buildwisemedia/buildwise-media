---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Custom AI for Service Businesses — Buildwise Media";
const description = "Custom AI for owner-led service businesses, installed and run by Buildwise Media — visibility, speed-to-lead, reviews, follow-up, and attribution.";

const industryLinks = [
  { "href": "/industries/hvac", "label": "HVAC", "accent": "--signal-cyan",
    "body": "Seasonal demand, quote paths, urgent calls, and review proof." },
  { "href": "/industries/plumbing", "label": "Plumbing", "accent": "--signal-green",
    "body": "Emergency calls, drain and sewer work, water heaters, and source truth." },
  { "href": "/industries/roofing", "label": "Roofing", "accent": "--y2",
    "body": "Storm spikes, inspections, proof, and booked roofing work." },
  { "href": "/industries/restoration", "label": "Restoration", "accent": "--signal-orange",
    "body": "Water, fire, and mold emergencies with claim-aware follow-up." },
  { "href": "/industries/foundation", "label": "Foundation Repair", "accent": "--y1",
    "body": "Foundation, waterproofing, and crawl space inspections." },
  { "href": "/industries/pest", "label": "Pest Control", "accent": "--signal-cyan",
    "body": "Urgent infestations, recurring plans, reviews, and seasonal demand." },
  { "href": "/industries/electrical", "label": "Electrical", "accent": "--signal-green",
    "body": "Service calls, generators, panel upgrades, and estimate follow-up." },
  { "href": "/industries/garage-door", "label": "Garage Door", "accent": "--y2",
    "body": "Same-day repair windows, quotes, installs, and reviews." }
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://buildwisemedia.com/industries' },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://buildwisemedia.com/industries#collection',
  name: 'Custom AI for service businesses',
  description,
  url: 'https://buildwisemedia.com/industries',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: industryLinks.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      url: 'https://buildwisemedia.com' + item.href,
    })),
  },
};
---
<BaseLayout title={title} description={description} jsonLd={[breadcrumb, collectionSchema]}>

  <section class="industry-hero">
    <div class="container industry-hero-grid">
      <div>
        <p class="eyebrow"><a href="/services/ascend" class="back-link">← Ascend</a> · Industries</p>
        <h1 class="h-hero">Custom AI for Service Businesses</h1>
        <p class="hero-sub">
          Buildwise Media installs and runs custom AI for owner-led service businesses. It connects visibility, fast response, reviews, follow-up, source truth, and weekly strategy so you can see where revenue leaks before the month is over.
        </p>
        <div class="industry-ctas">
          <a href="/book" class="cta" data-cta-source="industries-hero-primary">Get My Free Revenue Leak Map<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href="/book" class="cta-ghost" data-cta-source="industries-hero-secondary">See If We're a Fit</a>
        </div>
      </div>
      <aside class="industry-panel ops-panel" aria-label="Service business operating system">
        <div class="industry-panel-head">
          <p class="panel-label mono">service revenue system</p>
          <span class="ops-chip"><span class="dot green" aria-hidden="true"></span>baseline first</span>
        </div>
        <div class="plumbing-loop" aria-hidden="true">
          <span>Search</span>
          <span>Answer</span>
          <span>Book</span>
          <span>Review</span>
          <span>Prove</span>
        </div>
        <p class="panel-copy">The system connects the first search to the booked job, then feeds proof back into the next buyer's choice.</p>
      </aside>
    </div>
  </section>

  <section class="industry-section elev">
    <div class="container">
      <p class="section-tag">Flagship industries</p>
      <h2 class="h-section">Built around how service work gets chosen.</h2>
      <p class="prose">Every trade has its own pressure. The system stays the same: capture the baseline, answer fast, prove the source, and run the next week from facts.</p>
      <div class="layers-grid">
        {industryLinks.map((item) => (
          <a class="industry-card" href={item.href} style={`--accent: var(${item.accent});`}>
            <h3>{item.label} <span class="industry-card-arrow" aria-hidden="true">→</span></h3>
            <p>{item.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="industry-cta elev">
    <div class="container">
      <p class="section-tag">Other service businesses</p>
      <h2 class="h-closer">Don't see your trade?</h2>
      <p class="lede">If you run an owner-led service company with real demand, a defined service area, and revenue leaks you can feel but cannot trace, the same custom AI system may fit your shop.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="industries-final-primary">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="industries-final-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.industry-hero { padding-block: clamp(80px, 12vw, 144px); }
.industry-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.industry-ctas { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

.industry-panel { padding: 28px; }
.industry-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
.plumbing-loop { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 32px; }
.plumbing-loop span {
  min-height: 64px;
  display: grid;
  place-items: center;
  border: 1px solid var(--rule);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}
.plumbing-loop span:nth-child(2), .plumbing-loop span:nth-child(5) { border-color: rgba(240,255,0,0.45); color: var(--y2); }
.panel-copy { margin-top: 24px; color: var(--ink-dim); line-height: 1.6; }

.industry-proof, .industry-section, .industry-related, .industry-cta, .industry-faq { padding-block: clamp(56px, 8vw, 96px); }
.proof-grid { display: grid; gap: 32px; }
.proof-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
.proof-card, .fit-panel {
  border: 1px solid var(--rule);
  background: rgba(255,255,255,0.025);
  padding: 24px;
  border-radius: 4px;
}
.proof-card strong { display: block; margin-top: 8px; font-size: clamp(30px, 5vw, 56px); line-height: 1; color: var(--y2); font-weight: 600; }
.proof-card p:last-child, .proof-note { color: var(--ink-dim); line-height: 1.6; }
.proof-note { max-width: 760px; }

.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; margin-top: 24px; }
.prose a, .related-list a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.prose a:hover, .related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }
.layers-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-block: 40px; }
.spec-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-top: 32px; }
.layer-card { border: 1px solid var(--rule); padding: 20px; border-radius: 4px; background: rgba(255,255,255,0.02); }
.layer-card h3 { margin-top: 16px; font-size: 18px; color: var(--ink); }
.layer-card p:last-child { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }
.layer-num { color: var(--y2); }
.article-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: start; }
.article-photo { margin: 0; border: 1px solid var(--rule); border-radius: 4px; overflow: hidden; }
.article-photo img { display: block; width: 100%; height: auto; }
.layer-photo { max-width: 760px; margin: 0 0 32px; background: transparent; }
.fit-panel h3 { font-size: 24px; line-height: 1.25; color: var(--ink); font-weight: 500; }
.fit-panel ul { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
.fit-panel li { color: var(--ink-dim); line-height: 1.55; padding-left: 20px; position: relative; }
.fit-panel li::before { content: ""; position: absolute; left: 0; top: 0.72em; width: 7px; height: 7px; border-radius: 50%; background: var(--y2); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
.industry-faq { padding-top: 0; }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

@media (max-width: 860px) {
  .industry-hero-grid, .article-grid { grid-template-columns: 1fr; }
  .proof-cards, .layers-grid, .spec-grid { grid-template-columns: 1fr; }
  .plumbing-loop { grid-template-columns: 1fr; }
}
.layer-card a { color: var(--ink); text-decoration: none; }
.layer-card a:hover { color: var(--y2); }

/* Industry hub cards — whole card clickable + per-trade color wayfinding (V-016) */
.industry-card {
  display: block;
  border: 1px solid var(--rule);
  border-left: 3px solid var(--accent, var(--rule-bright));
  background: rgba(255,255,255,0.02);
  padding: 24px;
  border-radius: 4px;
  text-decoration: none;
  color: var(--ink);
  transition: border-color 180ms ease, background 180ms ease;
}
.industry-card h3 {
  font-size: 18px;
  color: var(--accent, var(--ink));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.industry-card p { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }
.industry-card-arrow {
  color: var(--accent, var(--y2));
  font-family: var(--mono);
  opacity: 0;
  transition: opacity 180ms ease;
}
.industry-card:hover {
  border-color: var(--accent, var(--y2));
  background: rgba(255,255,255,0.06);
}
.industry-card:hover .industry-card-arrow { opacity: 1; }
.industry-card:focus-visible { outline: 2px solid var(--accent, var(--y2)); outline-offset: 3px; }
</style>
