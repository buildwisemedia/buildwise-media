---
import BaseLayout from '../../layouts/BaseLayout.astro';
import canonical from '../../data/canonical.json';

const title = "Custom AI for Restoration Companies — Buildwise Media";
const description = "Custom AI for restoration companies, installed and run by Buildwise Media — emergency response, reviews, claim-aware follow-up, and attribution for booked work.";

const layerBodies: Record<string, string> = {
  "Visibility": "Show up when local buyers search, ask AI, or compare restoration companies in an emergency.",
  "Conversion": "Turn visits, calls, forms, and inspection paths into clear next steps.",
  "Speed-to-Lead": "Answer emergency restoration leads before the homeowner calls the next company.",
  "Sales Ops": "Keep inspections, claim-aware reminders, and past leads moving.",
  "Reputation": "Ask for reviews, reply with care, and turn finished jobs into proof.",
  "Paid Media": "Watch spend and move budget toward calls that can become booked work.",
  "Reporting": "Show source, spend, calls, inspections, booked jobs, and the next move.",
  "Strategy": "Run the week from a scoreboard, not a late-month guess."
};

const layers = canonical.products.ascend.eight_layers.map((raw: string, index: number) => {
  const dashIndex = raw.indexOf('—');
  const dotIndex = raw.indexOf('·');
  const name = dashIndex > 0 ? raw.slice(dotIndex + 1, dashIndex).trim() : raw.slice(dotIndex + 1).trim();
  return {
    n: String(index + 1).padStart(2, '0'),
    name,
    body: layerBodies[name] ?? '',
    tone: ['cyan', 'green', 'yellow', 'orange', 'green', 'cyan', 'yellow', 'green'][index],
  };
});

const proofStats = [
  {
    "label": "system install",
    "value": "30 days",
    "body": "Baseline, lead path, and first operating rhythm live."
  },
  {
    "label": "connected layers",
    "value": "8",
    "body": "Visibility, speed, reputation, source truth, and weekly strategy."
  },
  {
    "label": "proof rule",
    "value": "Day 1",
    "body": "The baseline is captured before any claim gets made."
  }
];

const fitSignals = [
  "Owner-led restoration company with emergency demand but unclear source truth.",
  "Enough real volume for missed calls and slow follow-up to cost serious money.",
  "Service area with enough density for search visibility, reviews, and paid demand.",
  "Owner wants the Buildwise team and our AI system to run the rhythm each week."
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://buildwisemedia.com/industries' },
    { '@type': 'ListItem', position: 3, name: "Restoration", item: "https://buildwisemedia.com/industries/restoration" },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': "https://buildwisemedia.com/industries/restoration#service",
  name: "Custom AI for restoration companies",
  serviceType: "Custom AI system installed and run for restoration companies",
  provider: { '@id': 'https://buildwisemedia.com/#org' },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: "Owner-led water, fire, and mold restoration companies",
  },
  description,
  url: "https://buildwisemedia.com/industries/restoration",
};

const faqs = [
  {
    "q": "What does Buildwise Media install for a restoration company?",
    "a": "The Buildwise team and our AI system install custom AI for emergency visibility, inspection paths, speed-to-lead, reviews, spend, reporting, and weekly strategy. It is built around booked restoration work."
  },
  {
    "q": "How fast can the restoration system go live?",
    "a": "The install path is 30 days. The first window captures the baseline, wires the lead path, improves follow-up, and starts the weekly operating rhythm."
  },
  {
    "q": "Do you handle water, fire, and mold restoration?",
    "a": "Yes. The same system can support water damage, fire and smoke, and mold remediation. The lead path and proof are tuned to the way each job books."
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': "https://buildwisemedia.com/industries/restoration#faq",
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[serviceSchema, breadcrumb, faqSchema]}>

  <section class="industry-hero">
    <div class="container industry-hero-grid">
      <div>
        <p class="eyebrow"><a href="/services/ascend" class="back-link">← Ascend</a> · Restoration</p>
        <h1 class="h-hero">Custom AI, Built for Restoration Companies</h1>
        <p class="hero-sub">
          Restoration buyers are often in crisis. Water spreads. Smoke damage sits. Mold fear grows. The homeowner calls whoever answers first and sounds organized. If your visibility, follow-up system, reviews, and source tracking live in separate places, the best emergencies leak before the inspection is booked.
        </p>
        <div class="industry-ctas">
          <a href="/book" class="cta" data-cta-source="restoration-hero-primary">Get My Free Revenue Leak Map<span class="cta-arrow" aria-hidden="true">→</span></a>
          <a href="/book" class="cta-ghost" data-cta-source="restoration-hero-secondary">See If We're a Fit</a>
        </div>
      </div>
      <aside class="industry-panel ops-panel" aria-label="Restoration operating system">
        <div class="industry-panel-head">
          <p class="panel-label mono">restoration revenue system</p>
          <span class="ops-chip"><span class="dot green" aria-hidden="true"></span>baseline first</span>
        </div>
        <div class="plumbing-loop" aria-hidden="true">
          <span>Search</span>
          <span>Answer</span>
          <span>Inspect</span>
          <span>Claim</span>
          <span>Prove</span>
        </div>
        <p class="panel-copy">The system connects the first search to the booked inspection, then keeps claim-aware follow-up and proof moving.</p>
      </aside>
    </div>
  </section>

  <section class="industry-proof elev" aria-labelledby="proof-title">
    <div class="container proof-grid">
      <header class="section-head">
        <p class="section-tag">Restoration proof path</p>
        <h2 id="proof-title" class="h-section">Emergency demand breaks when the answer is slow.</h2>
        <p class="lede">A restoration company can be ready 24/7 and still lose work if the first response is slow. The owner needs to see which source brought the job, which call got missed, and which finished project should become proof.</p>
      </header>
      <div class="proof-cards">
        {proofStats.map((stat) => (
          <article class="proof-card">
            <p class="ops-kicker">{stat.label}</p>
            <strong>{stat.value}</strong>
            <p>{stat.body}</p>
          </article>
        ))}
      </div>
      <p class="proof-note">We do not invent a restoration-only proof stat. The system starts by capturing your baseline, then measures booked work from the same market over time.</p>
    </div>
  </section>

  <section class="industry-section">
    <div class="container">
      <p class="section-tag">Restoration specialties</p>
      <h2 class="h-section">Built for how your shop actually runs.</h2>
      <p class="prose">Water, fire, and mold calls carry different fears. The system keeps the lead path fast while tuning the proof to the damage type.</p>
      <div class="spec-grid">
        <article class="layer-card">
          <h3>Water Damage</h3>
          <p>Urgent leaks, floods, and dry-out calls where damage spreads by the hour.</p>
        </article>
        <article class="layer-card">
          <h3>Fire & Smoke</h3>
          <p>High-stress recovery work that needs trust, clear steps, and careful follow-up.</p>
        </article>
        <article class="layer-card">
          <h3>Mold Remediation</h3>
          <p>Fear-driven calls where proof, reviews, and plain answers help the owner choose.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="industry-section">
    <div class="container">
      <p class="section-tag">The installed system</p>
      <h2 class="h-section">Eight layers built around booked restoration work.</h2>
      <p class="prose">
        A restoration company does not need scattered tactics. It needs one revenue operating system. The Buildwise team installs the same eight Ascend layers across the business, then runs them as one weekly rhythm.
      </p>
      <div class="layers-grid">
        {layers.map((layer) => (
          <article class={`layer-card tone-${layer.tone}`}>
            <p class="layer-num mono">{layer.n}</p>
            <h3>{layer.name}</h3>
            <p>{layer.body}</p>
          </article>
        ))}
      </div>
      <!-- @r020:F2 proof: node-mesh visual shows the eight restoration layers acting as one connected operating system -->
      <figure class="article-photo layer-photo">
        <img src="/images/node-mesh-ascending-v1.svg" alt="Isometric ascending node mesh showing connected layers wired as one operating system." width="1200" height="900" loading="lazy" decoding="async" />
      </figure>
      <p class="prose">
        The layers matter most when they talk to each other. Visibility brings the homeowner in. Conversion gives them a clear help path. Speed-to-Lead answers while damage is spreading. Sales Ops keeps inspections and claim-aware reminders moving. Reputation turns finished work into proof. Paid Media gets judged by job quality. Reporting shows what happened. Strategy sets the next week.
      </p>
    </div>
  </section>

  <section class="industry-section">
    <div class="container">
      <p class="section-tag">Speed-to-Lead</p>
      <h2 class="h-section">When damage spreads by the hour, slow follow-up loses the job.</h2>
      <p class="prose">
        A restoration lead can go cold in minutes. The homeowner has water in the house or smoke damage to solve. If no one answers quickly, they keep calling. Speed-to-Lead routes each new call, form, and booking request into a fast next step.
      </p>
      <p class="prose">
        That speed also protects attribution. A strong source can look weak if the answer time is slow. A weak source can look strong if one job closes by luck. We separate those signals so the owner can make a better call.
      </p>
      <!-- @r020:F2 proof: the response window — answer inside it and the job is yours; miss it and the restoration lead calls the next shop — encodes the speed-to-lead claim above -->
      <figure class="scene-fig" style="max-width: 520px;">
        <svg viewBox="0 0 520 120" role="img" aria-label="Diagram: a restoration lead's response window — the system answers fast inside the first five minutes; past the window the lead calls the next shop.">
          <line class="fx-hair" x1="24" y1="60" x2="300" y2="60" />
          <rect class="fx-vertex" x="20" y="56" width="8" height="8" />
          <text class="fx-label" x="18" y="86" text-anchor="start">NEW LEAD</text>
          <rect class="fx-vertex-filled" x="126" y="56" width="8" height="8" />
          <text class="fx-label-y2" x="130" y="44" text-anchor="middle">SYSTEM ANSWERS</text>
          <line class="fx-hair" x1="300" y1="52" x2="300" y2="68" />
          <text class="fx-label" x="300" y="86" text-anchor="middle">5 MIN</text>
          <line class="fx-hair" x1="300" y1="60" x2="470" y2="60" stroke-dasharray="3 4" />
          <polyline class="fx-hair" points="464,56 470,60 464,64" fill="none" />
          <text class="fx-caption" x="385" y="50" text-anchor="middle">RESTORE LEAD CALLS NEXT SHOP</text>
          <text class="fx-caption" x="24" y="110">ANSWER INSIDE THE WINDOW — BOOK THE JOB</text>
        </svg>
      </figure>
    </div>
  </section>

  <section class="industry-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Visibility and AI search</p>
        <h2 class="h-section">Show up when the homeowner asks who can help now.</h2>
        <p class="prose">
          Restoration buyers often search under stress. They ask search, maps, and AI tools who handles water, fire, or mold near them. The companies that get named tend to have clear service pages, strong local proof, steady data, and fresh reviews.
        </p>
        <p class="prose">
          Ascend connects those signals. Service pages explain the work. Reviews make the proof visible. Reputation replies pass through a human gate. The owner sees whether the work is making the company easier to find and easier to choose.
        </p>
      </div>
      <!-- @r020:F2 proof: receipt-style image reinforces that restoration attribution is measured from source to booked work -->
      <figure class="article-photo">
        <img src="/images/bwm-receipts-still-life-v1.webp" alt="Printed proof packet and measurement notes on a dark desk." width="720" height="480" loading="lazy" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="industry-section elev">
    <div class="container article-grid">
      <div>
        <p class="section-tag">Attribution</p>
        <h2 class="h-section">Know which source, call, inspection, and claim path became work.</h2>
        <p class="prose">
          A restoration owner should not have to guess where booked work came from. The system ties source, page, form, call, inspection, and booked job into one view. Claim-aware notes keep the path clearer without turning it into a black box.
        </p>
        <p class="prose">
          After 30 days, the owner should see the baseline, the lead path, and the first proof rhythm. The next question becomes clear: which source brought booked work, which step slowed it down, and which first move deserves more time or budget.
        </p>
        <!-- @r020:F2 proof: dollar→source→page→call→inspection→booked-job attribution chain — encodes the one-view traceability the prose claims -->
        <figure class="scene-fig">
          <svg viewBox="0 0 520 120" role="img" aria-label="Diagram: an attribution chain tying dollar, source, page, call, and inspection to the booked restoration job in one view.">
            <line class="fx-hair" x1="34" y1="52" x2="451" y2="52" />
            <rect class="fx-vertex" x="30" y="48" width="8" height="8" />
            <rect class="fx-vertex" x="110" y="48" width="8" height="8" />
            <rect class="fx-vertex" x="190" y="48" width="8" height="8" />
            <rect class="fx-vertex" x="270" y="48" width="8" height="8" />
            <rect class="fx-vertex" x="350" y="48" width="8" height="8" />
            <rect class="fx-vertex-filled" x="447" y="48" width="8" height="8" />
            <text class="fx-label" x="34" y="76" text-anchor="middle">DOLLAR</text>
            <text class="fx-label" x="114" y="76" text-anchor="middle">SOURCE</text>
            <text class="fx-label" x="194" y="76" text-anchor="middle">PAGE</text>
            <text class="fx-label" x="274" y="76" text-anchor="middle">CALL</text>
            <text class="fx-label" x="354" y="76" text-anchor="middle">INSPECTION</text>
            <text class="fx-label-y2" x="451" y="76" text-anchor="middle">BOOKED JOB</text>
            <line class="fx-hair" x1="24" y1="92" x2="496" y2="92" />
            <line class="fx-hair" x1="24" y1="88" x2="24" y2="92" />
            <line class="fx-hair" x1="496" y1="88" x2="496" y2="92" />
            <text class="fx-caption" x="24" y="110">ONE VIEW — EVERY BOOKED JOB TRACES TO ITS DOLLAR</text>
          </svg>
        </figure>
      </div>
      <div class="fit-panel">
        <p class="section-tag">Fit check</p>
        <h3>Ascend is built for restoration operators who are ready to be run by proof.</h3>
        <ul role="list">
          {fitSignals.map((signal) => <li>{signal}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="industry-related">
    <div class="container">
      <p class="section-tag">Next reading</p>
      <h2 class="h-section">See how the system connects.</h2>
      <ul class="related-list">
        <li><a href="/system">The System</a> — the full eight-layer operating model</li>
        <li><a href="/services/ascend">Ascend</a> — what gets installed and run each week</li>
        <li><a href="/industries/plumbing">Plumbing</a> — urgent water calls and fast response paths</li>
        <li><a href="/industries/roofing">Roofing</a> — storm-driven demand and inspection-led work</li>
        <li><a href="/industries/foundation">Foundation Repair</a> — waterproofing and inspection-heavy sales</li>
        <li><a href="/audit">Revenue Leak Map</a> — the diagnostic that shows the first gap</li>
      </ul>
    </div>
  </section>

  <section class="industry-faq">
    <div class="container">
      <p class="section-tag">FAQ</p>
      <h2 class="h-section">Common questions.</h2>
      <!-- @r020:F2 proof: question checked against the live operating record (baseline · tracked source · booked outcome) → verified answer — encodes that these answers come from the running system, not sales copy -->
      <figure class="scene-fig" style="margin: 24px 0 40px; max-width: 460px;">
        <svg viewBox="0 0 500 132" role="img" aria-label="Diagram: a question is checked against the live operating record — baseline, tracked source, and booked outcome — and returns a verified answer.">
          <rect class="fx-vertex" x="40" y="54" width="8" height="8" />
          <text class="fx-label" x="44" y="80" text-anchor="middle">QUESTION</text>
          <line class="fx-hair" x1="48" y1="58" x2="150" y2="58" />
          <rect class="fx-block" x="150" y="22" width="156" height="72" />
          <text class="fx-caption" x="162" y="38">OPERATING RECORD</text>
          <rect class="fx-vertex" x="162" y="49" width="5" height="5" />
          <text class="fx-label" x="176" y="54">BASELINE</text>
          <rect class="fx-vertex" x="162" y="65" width="5" height="5" />
          <text class="fx-label" x="176" y="70">TRACKED SOURCE</text>
          <rect class="fx-vertex" x="162" y="81" width="5" height="5" />
          <text class="fx-label" x="176" y="86">BOOKED OUTCOME</text>
          <line class="fx-hair" x1="306" y1="58" x2="410" y2="58" />
          <polyline class="fx-hair" points="404,54 410,58 404,62" fill="none" />
          <rect class="fx-vertex-filled" x="415" y="54" width="8" height="8" />
          <text class="fx-label-y2" x="419" y="44" text-anchor="middle">VERIFIED ANSWER</text>
          <text class="fx-caption" x="20" y="122">GROUNDED IN YOUR OPERATING RECORD — NOT SALES COPY</text>
        </svg>
      </figure>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="industry-cta elev">
    <div class="container">
      <h2 class="h-closer">Ready to see the restoration leaks in your market?</h2>
      <p class="lede">The free Revenue Leak Map shows where visibility, speed, follow-up, and attribution are holding back booked work.</p>
      <p class="cta-row">
        <a class="cta-primary" href="/book" data-cta-source="restoration-final-primary">Get My Free Revenue Leak Map <span class="cta-arrow">→</span></a>
        <a class="cta-ghost" href="/book" data-cta-source="restoration-final-secondary">See If We're a Fit</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.industry-hero { padding-block: clamp(80px, 12vw, 144px); }
.industry-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: center; }
.back-link { color: var(--ink-faint); transition: color 180ms ease; }
.back-link:hover { color: var(--y2); }
.industry-ctas { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }

.industry-panel { padding: 28px; }
.industry-panel-head { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
.plumbing-loop { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 32px; }
.plumbing-loop span {
  min-height: 64px;
  display: grid;
  place-items: center;
  border: 1px solid var(--rule);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}
.plumbing-loop span:nth-child(2), .plumbing-loop span:nth-child(5) { border-color: rgba(240,255,0,0.45); color: var(--y2); }
.panel-copy { margin-top: 24px; color: var(--ink-dim); line-height: 1.6; }

.industry-proof, .industry-section, .industry-related, .industry-cta, .industry-faq { padding-block: clamp(56px, 8vw, 96px); }
.proof-grid { display: grid; gap: 32px; }
.proof-cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
.proof-card, .fit-panel {
  border: 1px solid var(--rule);
  background: rgba(255,255,255,0.025);
  padding: 24px;
  border-radius: 4px;
}
.proof-card strong { display: block; margin-top: 8px; font-size: clamp(30px, 5vw, 56px); line-height: 1; color: var(--y2); font-weight: 600; }
.proof-card p:last-child, .proof-note { color: var(--ink-dim); line-height: 1.6; }
.proof-note { max-width: 760px; }

.prose { font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 760px; margin-top: 24px; }
.prose a, .related-list a { color: var(--ink); text-decoration: none; border-bottom: 1px solid rgba(240,255,0,0.45); }
.prose a:hover, .related-list a:hover { color: var(--y2); border-bottom-color: var(--y2); }
.layers-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-block: 40px; }
.spec-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-top: 32px; }
.layer-card { border: 1px solid var(--rule); padding: 20px; border-radius: 4px; background: rgba(255,255,255,0.02); }
.layer-card h3 { margin-top: 16px; font-size: 18px; color: var(--ink); }
.layer-card p:last-child { margin-top: 12px; color: var(--ink-dim); line-height: 1.55; }
.layer-num { color: var(--y2); }
.article-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: clamp(32px, 6vw, 72px); align-items: start; }
.article-photo { margin: 0; border: 1px solid var(--rule); border-radius: 4px; overflow: hidden; }
.article-photo img { display: block; width: 100%; height: auto; }
.layer-photo { max-width: 760px; margin: 0 0 32px; background: transparent; }
.fit-panel h3 { font-size: 24px; line-height: 1.25; color: var(--ink); font-weight: 500; }
.fit-panel ul { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
.fit-panel li { color: var(--ink-dim); line-height: 1.55; padding-left: 20px; position: relative; }
.fit-panel li::before { content: ""; position: absolute; left: 0; top: 0.72em; width: 7px; height: 7px; border-radius: 50%; background: var(--y2); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 32px; max-width: 880px; }
.cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
.industry-faq { padding-top: 0; }
.faq-list { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; max-width: 880px; }
.faq-item { border-top: 1px solid var(--rule); padding-block: 20px; }
.faq-item[open] summary { color: var(--y2); }
.faq-q { font-size: 17px; font-weight: 500; color: var(--ink); cursor: pointer; line-height: 1.4; list-style: none; }
.faq-q::marker, .faq-q::-webkit-details-marker { display: none; }
.faq-q::after { content: "+"; float: right; font-family: var(--mono); font-size: 18px; color: var(--y2); }
.faq-item[open] .faq-q::after { content: "-"; }
.faq-a { margin-top: 12px; }
.faq-a p { font-size: 16px; line-height: 1.65; color: var(--ink-dim); max-width: 720px; }

@media (max-width: 860px) {
  .industry-hero-grid, .article-grid { grid-template-columns: 1fr; }
  .proof-cards, .layers-grid, .spec-grid { grid-template-columns: 1fr; }
  .plumbing-loop { grid-template-columns: 1fr; }
}
</style>
