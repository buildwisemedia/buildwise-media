---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = "How It Works — Buildwise Media";
const description = "Ascend installs in 30 days. Audit, Install, Run — three phases, one 8-layer revenue operating system.";

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://buildwisemedia.com/' },
    { '@type': 'ListItem', position: 2, name: 'How It Works', item: 'https://buildwisemedia.com/how-it-works' },
  ],
};

const howTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How Ascend installs',
  description: 'Three-phase install of the 8-layer revenue operating system.',
  totalTime: 'P30D',
  step: [
    { '@type': 'HowToStep', name: 'Audit', text: 'Map current pipeline, channels, integrations, and conversion path against a captured baseline.' },
    { '@type': 'HowToStep', name: 'Install', text: 'Website, conversion paths, follow-up, attribution, reporting, and weekly operating rhythm installed in parallel.' },
    { '@type': 'HowToStep', name: 'Operate', text: 'Weekly connector audit, monthly creative refresh, quarterly system review. Receipts every Monday.' },
  ],
};

const phases = [
  {
    n: '01', name: 'Audit', when: 'Day 0 → Day 5',
    body: 'Before we build anything, we map what already exists. The current pipeline, every active channel, every integration, every conversion path. Each finding goes against a <a href="/playbook/captured-baseline">captured baseline</a> — the starting-point number we\'ll compute the delta against. The audit ships as a written document. You keep it whether you engage or not.',
    deliverables: ['Pipeline map (current state)', 'Channel + spend audit', 'Integration health report', 'Captured baseline document'],
  },
  {
    n: '02', name: 'Install', when: 'Day 5 → Day 30',
    body: 'Website, conversion paths, follow-up, attribution, reporting, and weekly operating rhythm are installed in parallel, not in sequence. The system is operational on Day 30.',
    deliverables: ['Multi-page website built for human + AI discovery', 'Conversion paths + tracking infrastructure', 'Lead attribution pipeline', 'Weekly operating dashboard'],
  },
  {
    n: '03', name: 'Operate', when: 'Day 30 → ongoing',
    body: 'Weekly connector audit, monthly creative refresh, quarterly system review. Every Monday morning a performance digest lands — what spent, what closed, what\'s next. The system runs whether you watch it or not. The relationship is month-to-month from the first day.',
    deliverables: ['Weekly performance report', 'Connector audit (Mon 4am ET)', 'Monthly creative drop', 'Quarterly system review'],
  },
];

// FAQ — voice-search phrased, mined from on-page copy. FAQPage schema emitted
// alongside the rendered <FAQ> section so answer engines see matching content.
const faqs = [
  {
    q: 'How long does it take to get the system live?',
    a: 'Thirty days. The work runs in three phases — Audit (Day 0 to 5), Install (Day 5 to 30), and Operate (Day 30 onward). The system is operational on Day 30.',
  },
  {
    q: 'What happens in the first 30 days?',
    a: 'First we audit: we map your current pipeline, channels, and conversion paths against a captured baseline, delivered as a written document you keep either way. Then we install the website, conversion paths, follow-up, attribution, and reporting in parallel, so the system is live by Day 30.',
  },
  {
    q: 'Is there a long discovery or strategy phase first?',
    a: 'No. There is no 30-day discovery phase that ends in a deck. Day 0 starts with the audit, strategy lives inside the running system, and every claim audits against the baseline.',
  },
  {
    q: 'What does the weekly rhythm look like after launch?',
    a: 'Every Monday a performance digest lands — what spent, what closed, what is next. Underneath, a weekly connector audit, monthly creative refresh, and quarterly system review keep it improving. It runs whether you watch it or not, month-to-month from the first day.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://buildwisemedia.com/how-it-works#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} jsonLd={[howTo, breadcrumb, faqSchema]}>

  <section class="how-hero">
    <div class="container">
      <p class="eyebrow">How It Works</p>
      <h1 class="h-hero">
        Three moves.<br/>
        <em>30</em> days.<br/>
        One operating system.
      </h1>
      <p class="hero-sub" style="max-width: 720px;">
        Most agencies sell a project. Ascend installs an operating rhythm: baseline first, system live in 30 days, weekly proof after that.
      </p>
    </div>
  </section>

  <section class="phases-section elev">
    <div class="container">
      <!-- @r020:F2 proof: Day 0→5→30 install timeline — encodes the 30-day operational claim the phase list makes in prose -->
      <figure class="scene-fig" style="max-width: 560px; margin: 0 0 56px;">
        <svg viewBox="0 0 520 112" role="img" aria-label="Timeline: Audit runs day 0 to 5, Install runs day 5 to 30, the system is operational and running from day 30 on.">
          <!-- track -->
          <line class="fx-hair" x1="24" y1="64" x2="496" y2="64" />
          <polyline class="fx-hair" points="490,60 496,64 490,68" fill="none" />
          <!-- ticks -->
          <line class="fx-hair" x1="24" y1="56" x2="24" y2="72" />
          <line class="fx-hair" x1="99" y1="56" x2="99" y2="72" />
          <line class="fx-hair" x1="446" y1="56" x2="446" y2="72" />
          <!-- phase labels -->
          <text class="fx-label" x="61" y="44" text-anchor="middle">01 AUDIT</text>
          <text class="fx-label" x="272" y="44" text-anchor="middle">02 INSTALL</text>
          <text class="fx-label" x="478" y="44" text-anchor="middle">03 RUN</text>
          <!-- operational vertex at day 30 -->
          <rect class="fx-vertex-filled" x="442" y="60" width="8" height="8" />
          <text class="fx-label-y2" x="446" y="24" text-anchor="middle">OPERATIONAL</text>
          <!-- day labels -->
          <text class="fx-label" x="24" y="92" text-anchor="start">DAY 0</text>
          <text class="fx-label" x="99" y="92" text-anchor="middle">DAY 5</text>
          <text class="fx-label" x="446" y="92" text-anchor="middle">DAY 30</text>
          <!-- caption -->
          <text class="fx-caption" x="24" y="110">THREE PHASES. THIRTY DAYS. THEN THE SYSTEM RUNS.</text>
        </svg>
      </figure>
      <ol class="phases-list" role="list">
        {phases.map((p) => (
          <li class="phase-row reveal">
            <header class="phase-head">
              <span class="phase-num mono">{p.n}</span>
              <span class="phase-when mono">{p.when}</span>
            </header>
            <h2 class="phase-name">{p.name}</h2>
            <p class="phase-body" set:html={p.body}></p>
            <p class="phase-deliv-label kpi-label mono">What ships</p>
            <ul class="phase-deliv-list">
              {p.deliverables.map((d) => (
                <li><span class="dot live"></span><span>{d}</span></li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="diff-section">
    <div class="container">
      <p class="section-tag">What makes this different</p>
      <h2 class="h-section">No <em>"strategy"</em> phase that produces a deck.</h2>
      <div class="diff-cols">
        <div class="diff-col">
          <p class="diff-label mono">Most agencies</p>
          <ul class="diff-list">
            <li>30 days of "discovery" before anything is built</li>
            <li>Strategy deck handed off; execution runs on hope</li>
            <li>Vendors don't talk; the founder is the integration layer</li>
            <li>Reports look plausible; nothing traces to a closed deal</li>
          </ul>
        </div>
        <div class="diff-col">
          <p class="diff-label mono diff-label--ours">Buildwise Media</p>
          <ul class="diff-list">
            <li>30 days from diagnostic to operational system</li>
            <li>Strategy lives inside the system, not in a deck</li>
            <li>One stack, one source of truth, one dashboard</li>
            <li>Every claim audits against a captured baseline</li>
          </ul>
        </div>
      </div>
      <p class="diff-footer mono"><a href="/playbook/poor-four">The four failure modes</a> · <a href="/playbook/fractional-cmo-alternative">Why fractional CMO doesn't close the gap</a></p>
    </div>
  </section>

  <!-- FAQ — answer-engine extractable Q&A, matches FAQPage schema -->
  <FAQ faqs={faqs} />

  <section class="how-cta elev">
    <div class="container ascend-cta-row">
      <div>
        <h2 class="h-closer">Ready to <em>start?</em></h2>
        <p class="lede" style="margin-top: 16px;">Day 0 starts with the audit. No commitment to keep going.</p>
      </div>
      <a href="/book" class="cta" data-cta-source="how-it-works-final">See If We're a Fit<span class="cta-arrow" aria-hidden="true">→</span></a>
    </div>
  </section>

</BaseLayout>

<style>
.how-hero { padding-top: clamp(140px, 14vw, 180px); padding-bottom: clamp(60px, 8vw, 100px); }

.phases-section { padding-block: var(--section-y); }
.phases-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
.phase-row { padding: 56px 0; border-top: 1px solid var(--rule); display: grid; grid-template-columns: minmax(0, 1fr); gap: 16px; }
.phase-row:last-child { border-bottom: 1px solid var(--rule); }
.phase-head { display: flex; gap: 24px; align-items: center; margin-bottom: 8px; }
.phase-num { font-size: 14px; letter-spacing: 0.25em; color: var(--y2); }
.phase-when { font-size: 11px; letter-spacing: 0.18em; color: var(--ink-faint); }
.phase-name { font-family: var(--sans); font-weight: 800; font-stretch: 75%; font-size: clamp(36px, 4vw, 56px); letter-spacing: -0.02em; line-height: 1; color: var(--ink); }
.phase-body { font-family: var(--sans); font-weight: 300; font-size: 18px; line-height: 1.65; color: var(--ink-dim); max-width: 760px; margin-bottom: 16px; }
.phase-deliv-label { color: var(--ink-faint); margin-top: 8px; }
.phase-deliv-list { list-style: none; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; max-width: 760px; }
.phase-deliv-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; line-height: 1.5; color: var(--ink-dim); }
.phase-deliv-list .dot { margin-top: 8px; }

.diff-section { padding-block: var(--section-y); }
.diff-cols { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 32px; margin-top: 48px; }
.diff-col { background: var(--bg-card); border: 1px solid var(--rule); padding: 32px; }
.diff-label { color: var(--ink-faint); margin-bottom: 24px; }
.diff-label--ours { color: var(--y2); }
.diff-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
.diff-list li { font-size: 15px; line-height: 1.55; color: var(--ink-dim); padding-left: 14px; border-left: 1px solid var(--rule); }
.diff-col:last-child .diff-list li { border-left-color: var(--y2); }

.diff-footer { margin-top: 40px; font-size: 11px; letter-spacing: 0.18em; color: var(--ink-faint); text-align: center; text-transform: uppercase; }
.diff-footer a { color: var(--ink-dim); transition: color 180ms ease; }
.diff-footer a:hover { color: var(--y2); }

.how-cta { padding-block: 80px; }
.ascend-cta-row { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }

@media (max-width: 720px) {
  .phase-deliv-list { grid-template-columns: 1fr; }
  .diff-cols { grid-template-columns: 1fr; }
}
</style>
