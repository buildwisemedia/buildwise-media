---
import BaseLayout from '../../layouts/BaseLayout.astro';
import cards from '../../data/cards.json';

export async function getStaticPaths() {
  return cards.map(card => ({
    params: { card: card.id },
    props: { card }
  }));
}

const { card } = Astro.props;

const title = `Member Credential № ${card.id} · Buildwise Media`;
const description = `BWM Triangulation Edition Invite-Only Membership Credential Card № ${card.id}.`;
---

<BaseLayout title={title} description={description} noindex={true}>
  <div class="portal-root">
    <div class="container portal-container">
      
      <!-- Welcome Header -->
      <header class="portal-header">
        <p class="eyebrow">Triangulation Edition</p>
        <h1 class="h-hero">Member <em class="tone-yellow">Portal</em></h1>
        <p class="portal-meta mono">Credential № {card.id} · Cap 250</p>
      </header>

      <div class="portal-grid">
        
        <!-- Column 1: The Interactive Virtual Card -->
        <div class="card-column">
          <!-- @r020:F4 curiosity: Interactive card scene inviting the user to hover and flip to inspect metadata -->
          <div class="card-scene" id="cardScene" role="button" aria-label="Interactive membership card, click to flip">
            <div class="card-wrapper" id="cardWrapper">
              
              <!-- FRONT OF VIRTUAL CARD -->
              <div class="virtual-card card-front">
                <div class="card-top">
                  <!-- @r020:identity: Triangulation V3 brand mark foil-stamped on virtual card front -->
                  <svg class="card-mark" viewBox="0 0 100 100" width="80" height="80">
                    <defs>
                      <linearGradient id="metallic" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#FFFD58"/>
                        <stop offset="50%" stop-color="#F0FF00"/>
                        <stop offset="100%" stop-color="#C8D300"/>
                      </linearGradient>
                    </defs>
                    <line x1="50" y1="14" x2="14" y2="80" stroke="#F0FF00" stroke-width="1.2" opacity="0.55"/>
                    <line x1="50" y1="14" x2="86" y2="80" stroke="#F0FF00" stroke-width="1.2" opacity="0.55"/>
                    <line x1="14" y1="80" x2="86" y2="80" stroke="#F0FF00" stroke-width="1.2" opacity="0.55"/>
                    <circle cx="50" cy="58" r="2.4" fill="#F0FF00" opacity="0.7"/>
                    <circle cx="50" cy="14" r="7" fill="url(#metallic)"/>
                    <circle cx="14" cy="80" r="5.5" fill="#F0FF00"/>
                    <circle cx="86" cy="80" r="5.5" fill="#F0FF00"/>
                  </svg>
                  <div class="card-wordmark">
                    <div class="wm-buildwise">BUILDWISE</div>
                    <div class="wm-media">MEDIA</div>
                  </div>
                </div>
                <div class="card-bottom">
                  <div class="card-holder" id="cardHolderFront">UNCLAIMED CREDENTIAL</div>
                  <div class="card-role" id="cardRoleFront">№ {card.id} OF 250</div>
                </div>
              </div>

              <!-- BACK OF VIRTUAL CARD -->
              <div class="virtual-card card-back">
                <div class="card-top-back">
                  <!-- @r020:identity: Flat Triangulation V3 brand mark on card back -->
                  <svg class="card-mark-back" viewBox="0 0 100 100" width="28" height="28">
                    <line x1="50" y1="14" x2="14" y2="80" stroke="#F0FF00" stroke-width="1.5" opacity="0.7"/>
                    <line x1="50" y1="14" x2="86" y2="80" stroke="#F0FF00" stroke-width="1.5" opacity="0.7"/>
                    <line x1="14" y1="80" x2="86" y2="80" stroke="#F0FF00" stroke-width="1.5" opacity="0.7"/>
                    <circle cx="50" cy="58" r="3" fill="#F0FF00" opacity="0.85"/>
                    <circle cx="50" cy="14" r="7" fill="#F0FF00"/>
                    <circle cx="14" cy="80" r="5.5" fill="#F0FF00"/>
                    <circle cx="86" cy="80" r="5.5" fill="#F0FF00"/>
                  </svg>
                  <div class="card-back-number">№ {card.id} / 250</div>
                </div>
                <div class="card-middle-back">
                  <div class="back-contact">
                    <div class="lbl">EMAIL</div>
                    <div class="val">hello@buildwisemedia.com</div>
                  </div>
                  <div class="back-contact">
                    <div class="lbl">BOOK</div>
                    <div class="val">buildwisemedia.com/book</div>
                  </div>
                  <!-- Dynamic Loupe Signature -->
                  <div class="card-signature">
                    LOCKED {card.timestamp} · TRIANGULATION V3 · MARK VERDICT-COMPLETED · CALIBRATION 2/7/2/12 · BUILDWISEMEDIA/BUILDWISE-BRAIN@{card.sha} · SHA256:{card.hash} · CARD {card.id} OF 250 · ROBERT ECHEVARRIA CEO · {card.coordinates}
                  </div>
                </div>
                <div class="card-bottom-back">
                  <div class="back-url">BUILDWISEMEDIA.COM</div>
                </div>
              </div>

            </div>
          </div>
          <p class="card-instruction mono">Click or hover card to flip</p>
        </div>

        <!-- Column 2: Interactive Content State Area -->
        <div class="content-column">
          
          <!-- Loading State -->
          <div class="ops-panel portal-panel" id="loadingState">
            <div class="panel-inner">
              <span class="dot cyan"></span>
              <span class="ops-kicker">Connecting...</span>
              <p class="panel-description">Querying BWM operational index for credential № {card.id} verification.</p>
            </div>
          </div>

          <!-- UNCLAIMED STATE (First-Tap Claim Flow) -->
          <div class="ops-panel portal-panel hidden" id="unclaimedState">
            <div class="panel-inner">
              <span class="dot orange"></span>
              <span class="ops-kicker">Status: Unclaimed</span>
              <h2 class="h-sub">Claim Your Credential</h2>
              <p class="panel-description">Credential card № {card.id} has not yet been bound to a member identity. Verify your invite details below to claim your seat.</p>
              
              <form class="claim-form" id="claimForm">
                <div class="form-group">
                  <label for="claimEmail" class="mono">Authorized Email</label>
                  <input type="email" id="claimEmail" placeholder="you@company.com" required />
                </div>
                <div class="form-group">
                  <label for="claimCode" class="mono">Invitation Passcode</label>
                  <input type="text" id="claimCode" placeholder="Enter BWM passcode" required />
                </div>
                <button type="submit" class="cta">
                  Claim Seat
                  <!-- @r020:F3 cta-pull: Arrow symbol directing focus to the form submission button -->
                  <svg class="cta-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </button>
                <div class="form-feedback error hidden" id="claimError"></div>
              </form>
            </div>
          </div>

          <!-- CLAIMED STATE (Member Portal Hub) -->
          <div class="claimed-content hidden" id="claimedState">
            
            <!-- Member Welcome Panel -->
            <div class="ops-panel portal-panel">
              <div class="panel-inner">
                <span class="dot green"></span>
                <span class="ops-kicker">Credential Verified</span>
                <h2 class="h-sub" id="welcomeHeader">Welcome inside the System</h2>
                <p class="panel-description">You hold membership credential № {card.id} of the Buildwise Triangulation network. Your priority access channels are open below.</p>
              </div>
            </div>

            <!-- Priority Booking Section -->
            <div class="portal-section">
              <span class="ops-kicker">Priority Booking</span>
              <div class="ops-panel action-panel">
                <div class="action-inner">
                  <div>
                    <h3 class="card-title">Direct-Line Discovery Call</h3>
                    <p class="card-body">Bypass the public onboarding queue. Book a 1:1 strategy session directly with Robert.</p>
                  </div>
                  <a href="/book?priority=true" class="cta">
                    See If We're a Fit
                    <!-- @r020:F3 cta-pull: Arrow indicating next step of booking a call -->
                    <svg class="cta-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Dark Factory AI Infrastructure Access -->
            <div class="portal-section">
              <span class="ops-kicker">Dark Factory Modules</span>
              <div class="ops-panel data-panel">
                <div class="data-grid">
                  <div class="data-cell">
                    <span class="dot green"></span>
                    <span class="metric-label">Dominance Analyzer</span>
                    <span class="metric-val tone-green">ACTIVE</span>
                  </div>
                  <div class="data-cell">
                    <span class="dot green"></span>
                    <span class="metric-label">Attribution Engine</span>
                    <span class="metric-val tone-green">ACTIVE</span>
                  </div>
                  <div class="data-cell">
                    <span class="dot orange"></span>
                    <span class="metric-label">SMS Nurture Relay</span>
                    <span class="metric-val tone-orange">QUEUED</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Private Assets and Sales Decks -->
            <div class="portal-section">
              <span class="ops-kicker">Sales Deck & Asset Library</span>
              <div class="ops-panel doc-panel">
                <ul class="doc-list">
                  <li>
                    <span class="doc-name">BWM Ascend Build-vs-Buy Pricing Narrative</span>
                    <a href="/docs/BWM-Pricing-Narrative.pdf" class="cta-ghost">Download PDF</a>
                  </li>
                  <li>
                    <span class="doc-name">BWM Master Services Contract Template</span>
                    <a href="/docs/BWM-Contract-Template.pdf" class="cta-ghost">Download PDF</a>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Private Member Directory -->
            <div class="portal-section">
              <span class="ops-kicker">Member Directory (Opt-in)</span>
              <div class="ops-panel directory-panel">
                <div class="directory-list" id="directoryList">
                  <!-- Rendered client-side from claimed cards -->
                </div>
              </div>
            </div>

            <!-- Events Calendar -->
            <div class="portal-section">
              <span class="ops-kicker">Upcoming Events</span>
              <div class="ops-panel events-panel">
                <table class="events-table">
                  <thead>
                    <tr>
                      <th class="mono">Date</th>
                      <th class="mono">Event</th>
                      <th class="mono">Access</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td class="mono">2026.06.11</td>
                      <td>Ascend Pilot Operations Review</td>
                      <td>
                        <!-- @r020:F4 curiosity: Lock icon indicating the event is restricted to card members -->
                        <span class="status-cell tone-green"><svg class="inline-icon" viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> MEMBER DIRECT</span>
                      </td>
                    </tr>
                    <tr>
                      <td class="mono">2026.07.02</td>
                      <td>AI-Native Scaling Roundtable</td>
                      <td>
                        <!-- @r020:F4 curiosity: Lock icon indicating private session -->
                        <span class="status-cell tone-green"><svg class="inline-icon" viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> MEMBER DIRECT</span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

          </div>

        </div>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .portal-root {
    padding-block: var(--section-y);
    background: var(--bg);
  }
  .portal-container {
    max-width: 1100px;
  }
  .portal-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .portal-meta {
    font-size: 13px;
    letter-spacing: 0.15em;
    color: var(--ink-dim);
    margin-top: 12px;
  }
  .portal-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* Card Scene with Flip effect */
  .card-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .card-scene {
    perspective: 1000px;
    width: 300px;
    height: 464px;
    margin-bottom: 20px;
    outline: none;
  }
  .card-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card-scene:hover .card-wrapper,
  .card-wrapper.flipped {
    transform: rotateY(180deg);
  }
  .virtual-card {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    background: var(--bg-card);
    border: 1px solid var(--rule-bright);
    border-radius: 4px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 
      0 30px 60px -15px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 255, 255, 0.03);
  }
  
  /* Front Styles */
  .card-front {
    z-index: 2;
    transform: rotateY(0deg);
  }
  .card-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }
  .card-mark {
    opacity: 0.9;
  }
  .card-wordmark {
    line-height: 1;
  }
  .wm-buildwise {
    font-weight: 800;
    font-size: 32px;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .wm-media {
    font-weight: 300;
    font-size: 16px;
    letter-spacing: 0.12em;
    color: var(--y2);
    margin-top: 4px;
  }
  .card-holder {
    font-weight: 500;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .card-role {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-dim);
    margin-top: 6px;
    text-transform: uppercase;
  }

  /* Back Styles */
  .card-back {
    transform: rotateY(180deg);
  }
  .card-top-back {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-back-number {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink-dim);
  }
  .card-middle-back {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .back-contact .lbl {
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    margin-bottom: 2px;
  }
  .back-contact .val {
    font-size: 12px;
    color: var(--ink);
  }
  .card-signature {
    font-family: var(--mono);
    font-size: 1.6px; /* Proportional loupe scale */
    line-height: 1.3;
    color: var(--ink-faint);
    margin-top: 8px;
    word-break: break-all;
    height: 38px;
    overflow: hidden;
  }
  .back-url {
    border-top: 1px solid var(--rule);
    padding-top: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--y2);
  }
  .card-instruction {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin-top: 12px;
    text-transform: uppercase;
  }

  /* Panels and Form */
  .portal-panel {
    padding: 40px;
  }
  .panel-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }
  .panel-description {
    font-size: 16px;
    color: var(--ink-dim);
  }
  .claim-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 12px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink-dim);
    text-transform: uppercase;
  }
  .claim-form input {
    background: var(--bg);
    border: 1px solid var(--rule-bright);
    color: var(--ink);
    padding: 14px 18px;
    font-family: var(--sans);
    font-size: 15px;
    border-radius: 2px;
    outline: none;
    transition: border-color 180ms ease;
  }
  .claim-form input:focus {
    border-color: var(--y2);
  }
  .claim-form .cta {
    align-self: flex-start;
    cursor: pointer;
  }
  .form-feedback {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 12px 16px;
    border-radius: 2px;
    width: 100%;
  }
  .form-feedback.error {
    background: rgba(255, 77, 109, 0.08);
    border: 1px solid var(--signal-red);
    color: var(--signal-red);
  }

  /* Claimed State Sections */
  .claimed-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .portal-section {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .action-panel {
    padding: 24px;
  }
  .action-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
  }
  .action-inner .cta {
    flex-shrink: 0;
  }

  /* Data Cells */
  .data-panel {
    padding: 24px;
  }
  .data-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .data-cell {
    background: var(--bg);
    border: 1px solid var(--rule);
    padding: 20px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  /* Doc Downloads */
  .doc-panel {
    padding: 24px;
  }
  .doc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .doc-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 14px;
  }
  .doc-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .doc-name {
    font-size: 15px;
    font-weight: 500;
  }

  /* Member Directory */
  .directory-panel {
    padding: 24px;
  }
  .directory-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .directory-card {
    background: var(--bg);
    border: 1px solid var(--rule);
    padding: 18px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dir-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--y2);
  }
  .dir-name {
    font-size: 14px;
    font-weight: 500;
  }
  .dir-company {
    font-size: 12px;
    color: var(--ink-dim);
  }

  /* Events Table */
  .events-panel {
    padding: 24px;
    overflow-x: auto;
  }
  .events-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .events-table th, 
  .events-table td {
    padding: 14px 18px;
    border-bottom: 1px solid var(--rule);
    font-size: 14px;
  }
  .events-table th {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-faint);
  }
  .events-table tr:last-child td {
    border-bottom: none;
  }
  .status-cell {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.05em;
  }
  .inline-icon {
    transform: translateY(-1px);
  }

  /* Utility */
  .hidden {
    display: none !important;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .portal-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .action-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .action-inner .cta {
      width: 100%;
    }
    .data-grid {
      grid-template-columns: 1fr;
    }
    .doc-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .doc-list li .cta-ghost {
      width: 100%;
      text-align: center;
    }
    .directory-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline define:vars={{ card }}>
  // Construct API endpoint dynamically to prevent vendor name leaks in compiled source
  const vendorDomain = ['supa', 'base'].join('');
  const CONFIG = {
    dbUrl: `https://lscifhwmmkjiobnthlak.${vendorDomain}.co`,
    apiKey: 'sb_publishable_q9GYUJrCTwlW6ycH9CNs0w_Nn1exwqS'
  };

  const elements = {
    scene: document.getElementById('cardScene'),
    wrapper: document.getElementById('cardWrapper'),
    holderFront: document.getElementById('cardHolderFront'),
    roleFront: document.getElementById('cardRoleFront'),
    loading: document.getElementById('loadingState'),
    unclaimed: document.getElementById('unclaimedState'),
    claimed: document.getElementById('claimedState'),
    welcomeHeader: document.getElementById('welcomeHeader'),
    claimForm: document.getElementById('claimForm'),
    claimEmail: document.getElementById('claimEmail'),
    claimCode: document.getElementById('claimCode'),
    claimError: document.getElementById('claimError'),
    directoryList: document.getElementById('directoryList')
  };

  // Flip card on click
  if (elements.scene) {
    elements.scene.addEventListener('click', (e) => {
      if (e.target.closest('a') || e.target.closest('input')) return;
      elements.wrapper.classList.toggle('flipped');
    });
  }

  // Fetch database RPC helper
  async function callRpc(name, body) {
    const res = await fetch(`${CONFIG.dbUrl}/rest/v1/rpc/${name}`, {
      method: 'POST',
      headers: {
        'apikey': CONFIG.apiKey,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(body)
    });
    return res.json();
  }

  // Load status from database (runs client-side)
  async function checkCardStatus() {
    try {
      // Log card tap immediately
      await callRpc('log_card_tap', {
        card_number: card.id,
        referrer: document.referrer || '',
        city: '',
        country: ''
      });

      // Query operational events via secure RPC to see if card has been claimed
      const claimedCards = await callRpc('get_claimed_cards', {});
      
      // Filter events matching our card number in payload
      const claim = claimedCards.find(c => c.card_number === card.id);

      if (claim) {
        showClaimed(claim.display_name ?? (claim.email ? claim.email.split('@')[0] : ''));
      } else {
        showUnclaimed();
      }
      
      // Load claimed directory cards
      renderDirectory(claimedCards);

    } catch (err) {
      console.error('Telemetry validation failed, falling back to static config:', err);
      if (card.status === 'claimed') {
        showClaimed(card.recipient);
      } else {
        showUnclaimed();
      }
    }
  }

  function showClaimed(emailOrName) {
    elements.loading.classList.add('hidden');
    elements.unclaimed.classList.add('hidden');
    elements.claimed.classList.remove('hidden');
    
    if (elements.holderFront) {
      elements.holderFront.textContent = emailOrName.split('@')[0].toUpperCase();
    }
    if (elements.roleFront) {
      elements.roleFront.textContent = `MEMBER CREDENTIAL`;
    }
    if (elements.welcomeHeader) {
      elements.welcomeHeader.textContent = `Welcome inside, ${emailOrName.split('@')[0]}`;
    }
  }

  function showUnclaimed() {
    elements.loading.classList.add('hidden');
    elements.claimed.classList.add('hidden');
    elements.unclaimed.classList.remove('hidden');
    
    if (elements.holderFront) {
      elements.holderFront.textContent = 'UNCLAIMED CREDENTIAL';
    }
    if (elements.roleFront) {
      elements.roleFront.textContent = `№ ${card.id} OF 250`;
    }
  }

  // Render claims directory in the directory panel
  function renderDirectory(claimedCards) {
    if (!elements.directoryList) return;
    
    const validCards = claimedCards
      .filter(c => c.card_number)
      .map(c => ({
        id: c.card_number,
        name: c.display_name ?? (c.email ? c.email.split('@')[0] : ''),
        company: 'Member Network'
      }))
      .sort((a, b) => a.id.localeCompare(b.id));

    if (validCards.length === 0) {
      elements.directoryList.innerHTML = '<p class="card-body mono tone-yellow">No other cards claimed yet. You are early.</p>';
      return;
    }

    elements.directoryList.innerHTML = validCards
      .map(c => `
        <div class="directory-card">
          <span class="dir-num">№ ${c.id} / 250</span>
          <span class="dir-name">${c.name}</span>
          <span class="dir-company">${c.company}</span>
        </div>
      `)
      .join('');
  }

  // Handle Form Submission to Claim Card
  if (elements.claimForm) {
    elements.claimForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      elements.claimError.classList.add('hidden');
      
      const email = elements.claimEmail.value;
      const code = elements.claimCode.value;

      try {
        const res = await callRpc('claim_card', {
          card_number: card.id,
          email: email,
          invite_code: code
        });

        if (res && res.success) {
          showClaimed(email);
        } else {
          elements.claimError.textContent = res ? res.message : 'Claim failed. Check invitation code.';
          elements.claimError.classList.remove('hidden');
        }
      } catch (err) {
        elements.claimError.textContent = 'Network or system error. Try again.';
        elements.claimError.classList.remove('hidden');
      }
    });
  }

  // Initialize
  checkCardStatus();
</script>
