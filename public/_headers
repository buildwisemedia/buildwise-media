# Cloudflare Pages headers — security + long-cache for fingerprinted assets.
# Indexing/X-Robots-Tag intentionally NOT set here: the custom domain is
# indexable by default and *.pages.dev is auto-noindexed by Cloudflare.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000

# Astro fingerprints filenames under /assets, so they are safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
